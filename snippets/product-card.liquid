{% doc %}
  Renders a botanical product card with image, difficulty, Latin name, and ZAR price.

  Pass `product_item` for live catalog data. Omit it (or pass blank) to render mock
  placeholder content for theme preview and empty grids.

  @param {product} [product_item] - The product to display
  @param {string} [sizes] - Optional sizes attribute for responsive images
  @param {number} [card_index] - Zero-based index for cycling mock preview data
  @param {boolean} [show_specimen_id] - Show the specimen tag line when true (default)

  @example
  {% render 'product-card', product_item: product %}
  {% render 'product-card', card_index: forloop.index0 %}
{% enddoc %}

{%- liquid
  assign use_live_product = false
  if product_item
    if product_item != blank
      assign use_live_product = true
    endif
  endif

  assign image_sizes = sizes | default: '(min-width: 990px) 22vw, (min-width: 750px) 24vw, 46vw'
  assign show_specimen_id_resolved = show_specimen_id
  if show_specimen_id_resolved == blank
    assign show_specimen_id_resolved = true
  endif

  if use_live_product
    assign card_url = product_item.url
    assign card_product = product_item
    assign product_image = card_product.featured_media.preview_image | default: card_product.featured_image
    assign use_shopify_image = false
    if product_image != blank and product_image.width > 0
      assign use_shopify_image = true
    endif

    assign genus_handle = card_product.metafields.custom.genus.value | default: card_product.metafields.custom.genus
    assign latin_name = card_product.metafields.custom.latin_name.value | default: card_product.metafields.custom.latin_name
    assign difficulty_raw = card_product.metafields.custom.difficulty.value | default: card_product.metafields.custom.difficulty
    assign difficulty = difficulty_raw | plus: 0

    case genus_handle
      when 'dionaea'
        assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Venus_flytrap_-_Dionaea_muscipula_-_panoramio_(3).jpg?width=1200'
      when 'sarracenia'
        assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Sarracenia_((leucophylla_x_flava)_x_(purpurea_montana_x_flava))_x_%27Judith_Hindle%27_(5065614694).jpg?width=1200'
      when 'nepenthes'
        assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Nepenthes_ventricosa0.jpg?width=1200'
      when 'pinguicula'
        assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Pinguicula_moranensis_0zz.jpg?width=1200'
      when 'cephalotus'
        assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Albany_Pitcher_Plant_Oxford_Botanic_Garden.jpg?width=1200'
      else
        assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Drosera_aliciae2_ies.jpg?width=1200'
    endcase

    assign card_title = card_product.title
  else
    assign use_shopify_image = false
    assign mock_slot = card_index | default: 0 | modulo: 11

    case mock_slot
      when 1
        assign card_title = "Nepenthes bicalcarata"
        assign latin_name = 'Nepenthes bicalcarata'
        assign difficulty = 4
        assign mock_price_cents = 85000
        assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Pitcher_Plant_(Nepenthes_ampullaria)_(8411421382).jpg?width=1200'
      when 2
        assign card_title = "Dionaea muscipula 'B52'"
        assign latin_name = 'Dionaea muscipula'
        assign difficulty = 3
        assign mock_price_cents = 20000
        assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Venus_Flytrap_showing_trigger_hairs.jpg?width=1200'
      when 3
        assign card_title = 'Sarracenia flava'
        assign latin_name = 'Sarracenia flava'
        assign difficulty = 2
        assign mock_price_cents = 35000
        assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Sarracenia_((leucophylla_x_flava)_x_(purpurea_montana_x_flava))_x_%27Judith_Hindle%27_(5065614694).jpg?width=1200'
      when 4
        assign card_title = 'Pinguicula moranensis'
        assign latin_name = 'Pinguicula moranensis'
        assign difficulty = 2
        assign mock_price_cents = 25000
        assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Pinguicula_moranensis_(and_prey).jpg?width=1200'
      when 5
        assign card_title = 'Cephalotus follicularis'
        assign latin_name = 'Cephalotus follicularis'
        assign difficulty = 5
        assign mock_price_cents = 95000
        assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Cephalotus_follicularis_Hennern_3.jpg?width=1200'
      when 6
        assign card_title = 'Heliamphora minor'
        assign latin_name = 'Heliamphora minor'
        assign difficulty = 5
        assign mock_price_cents = 120000
        assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Heliamphora_nutans.jpg?width=1200'
      when 7
        assign card_title = 'Utricularia sandersonii'
        assign latin_name = 'Utricularia sandersonii'
        assign difficulty = 3
        assign mock_price_cents = 12000
        assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Common_Bladderwort_(3630283910).jpg?width=1200'
      when 8
        assign card_title = 'Darlingtonia californica'
        assign latin_name = 'Darlingtonia californica'
        assign difficulty = 4
        assign mock_price_cents = 65000
        assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Darlingtonia_californica_ne5.JPG?width=1200'
      when 9
        assign card_title = 'Byblis liniflora'
        assign latin_name = 'Byblis liniflora'
        assign difficulty = 2
        assign mock_price_cents = 18000
        assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Drosera_capensis_bend.JPG?width=1200'
      when 10
        assign card_title = 'Drosophyllum lusitanicum'
        assign latin_name = 'Drosophyllum lusitanicum'
        assign difficulty = 4
        assign mock_price_cents = 45000
        assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Pinguicula_moranensis_(and_prey).jpg?width=1200'
      else
        assign card_title = "Drosera capensis 'Alba'"
        assign latin_name = 'Drosera capensis'
        assign difficulty = 2
        assign mock_price_cents = 15000
        assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Drosera_capensis_bend.JPG?width=1200'
    endcase

    assign card_url = '#'
    assign preview_id_string = mock_slot | plus: 2401 | append: ''
    assign preview_id_size = preview_id_string | size
    assign preview_id_start = preview_id_size | minus: 4
    if preview_id_start < 0
      assign preview_id_start = 0
    endif
    assign specimen_id_suffix = preview_id_string | slice: preview_id_start, 4
  endif

  assign specimen_id = '#BT-LOG-' | append: specimen_id_suffix
  if use_live_product
    assign id_string = card_product.id | append: ''
    assign id_size = id_string | size
    assign id_start = id_size | minus: 4
    if id_start < 0
      assign id_start = 0
    endif
    assign specimen_id_suffix = id_string | slice: id_start, 4
    assign specimen_id = '#BT-LOG-' | append: specimen_id_suffix
  endif

  assign specimen_id_for_media = specimen_id
  if show_specimen_id_resolved == false
    assign specimen_id_for_media = blank
  endif
-%}

<article
  class="product-card{% unless use_live_product %} product-card--mock{% endunless %}"
  {% if use_live_product %}
    data-product-id="{{ card_product.id }}"
  {% endif %}
>
  {%- if show_specimen_id_resolved -%}
    <p class="product-card__specimen-id">
      <span class="visually-hidden">{{ 'products.card.specimen_id' | t }}</span>
      {{- specimen_id | escape -}}
    </p>
  {%- endif -%}
  {%- if use_live_product -%}
    {%- render 'product-card-badges', product_item: product_item -%}
  {%- else -%}
    {%- render 'product-card-badges',
      mock_slot: card_index | default: 0,
      mock_difficulty: difficulty
    -%}
  {%- endif -%}
  <a class="product-card__link" href="{{ card_url }}">
    <span class="product-card__media">
      {%- comment -%} TODO: replace placeholder image before launch — see placeholder-images.md {%- endcomment -%}
      {% render 'botanical-product-image',
        use_shopify_image: use_shopify_image,
        product_image: product_image,
        fallback_url: placeholder_url,
        product_title: card_title,
        specimen_id: specimen_id_for_media,
        sizes: image_sizes,
        css_class: 'product-card__image'
      %}
    </span>

    <span class="product-card__body">
      {%- if difficulty > 0 -%}
        <span
          class="product-card__difficulty difficulty-pips"
          role="img"
          aria-label="{{ 'products.card.difficulty_label' | t: level: difficulty, max: 5 }}"
        >
          {%- for pip in (1..5) -%}
            <span
              class="difficulty-pip{% if pip <= difficulty %} difficulty-pip--filled{% endif %}"
              aria-hidden="true"
            ></span>
          {%- endfor -%}
        </span>
      {%- endif -%}

      <h3 class="product-card__title">{{ card_title }}</h3>

      {%- if latin_name != blank -%}
        <span class="product-card__latin">
          <em>{{ latin_name }}</em>
        </span>
      {%- endif -%}

      <span class="product-card__price">
        {%- if use_live_product -%}
          {%- if card_product.compare_at_price > card_product.price -%}
            <span class="visually-hidden">{{ 'products.card.price_sale' | t }}</span>
            <span class="product-card__price-sale">{% render 'zar-price', amount_cents: card_product.price %}</span>
            <span class="visually-hidden">{{ 'products.card.price_regular' | t }}</span>
            <s class="product-card__price-compare">{% render 'zar-price', amount_cents: card_product.compare_at_price %}</s>
          {%- else -%}
            <span class="product-card__price-regular">{% render 'zar-price', amount_cents: card_product.price %}</span>
          {%- endif -%}
        {%- else -%}
          <span class="product-card__price-regular">{% render 'zar-price', amount_cents: mock_price_cents %}</span>
        {%- endif -%}
      </span>
    </span>
  </a>
</article>

{% stylesheet %}
  .product-card__specimen-id {
    margin: 0;
    padding: var(--space-xs) var(--space-md);
    font-family: 'Courier New', Courier, 'Liberation Mono', monospace;
    font-size: 0.5625rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #061410;
    border-block-end: 0.5px solid rgb(10 24 18 / 0.1);
  }
{% endstylesheet %}
