{% doc %}
  Outputs a Wikimedia Commons placeholder URL for a genus collection handle.
  Used when no collection image or block-level placeholder is set.

  @param {string} genus_handle - Collection handle (e.g. drosera, nepenthes)

  @example
  {% capture url %}{% render 'genus-placeholder-url', genus_handle: 'drosera' %}{% endcapture %}
{% enddoc %}

{%- liquid
  assign handle = genus_handle | handleize
-%}

{%- case handle -%}
  {%- when 'dionaea' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Venus_flytrap_-_Dionaea_muscipula_-_panoramio_(3).jpg?width=800
  {%- when 'sarracenia' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Sarracenia_Judith_Hindle_(5964475729).jpg?width=800
  {%- when 'nepenthes' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Nepenthes_rajah.png?width=800
  {%- when 'drosera' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Drosera_Capensis.jpg?width=800
  {%- when 'pinguicula' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Pinguicula_moranensis.jpg?width=800
  {%- when 'cephalotus' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Cephalotus_follicularis_0001.JPG?width=800
  {%- when 'heliamphora' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Heliamphora_nutans_(a_pitcher_plant_from_Venezuela)_at_Kew_Gardens_(5253200783).jpg?width=800
  {%- when 'utricularia' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Greater_Bladderwort_Utricularia_vulgaris_(6171429381).jpg?width=800
  {%- when 'darlingtonia' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Darlingtonias.JPG?width=800
  {%- when 'byblis' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/ByblisLinifloraHabitus.JPG?width=800
  {%- when 'drossophyllum' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Drosophyllum_lusitanicum_RBGK.JPG?width=800
  {%- when 'other' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Aldrovanda_vesiculosa.jpg?width=800
  {%- when 'growing-supplies' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Sphagnum_centrale.jpeg?width=800
{%- endcase -%}
