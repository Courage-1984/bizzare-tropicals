{% doc %}
  Decorative SVG icon for care overview pillar cards.

  @param {string} icon - One of: water, light, substrate, dormancy, humidity, feeding, default

  @example
  {% render 'care-overview-pillar-icon', icon: 'water' %}
{% enddoc %}

{%- liquid
  assign icon_key = icon | default: 'default' | strip | downcase
-%}

<span class="care-overview__pillar-icon" aria-hidden="true">
  {%- case icon_key -%}
    {%- when 'water' -%}
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" focusable="false">
        <path d="M12 3.5c2.5 3.8 5 7.2 5 10.2a5 5 0 1 1-10 0c0-3 2.5-6.4 5-10.2Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
      </svg>
    {%- when 'light' -%}
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" focusable="false">
        <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.2"/>
        <path d="M12 3v2M12 19v2M3 12h2M19 12h2M5.6 5.6l1.4 1.4M17 17l1.4 1.4M5.6 18.4l1.4-1.4M17 7l1.4-1.4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
    {%- when 'substrate' -%}
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" focusable="false">
        <path d="M5 16c1.5-4 4-7 7-9 3 2 5.5 5 7 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M4 18h16" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
    {%- when 'dormancy' -%}
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" focusable="false">
        <path d="M8 14c0-3.3 1.8-6 4-6s4 2.7 4 6" stroke="currentColor" stroke-width="1.2"/>
        <path d="M6 18h12M12 6V4M9 8l-2-1M15 8l2-1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
    {%- when 'humidity' -%}
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" focusable="false">
        <path d="M8 14c0-2.2 1.8-4 4-4s4 1.8 4 4-1.8 4-4 4" stroke="currentColor" stroke-width="1.2"/>
        <path d="M6 18h12M10 10l-3-2M14 10l3-2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
    {%- when 'feeding' -%}
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" focusable="false">
        <circle cx="12" cy="12" r="7" stroke="currentColor" stroke-width="1.2"/>
        <path d="M8.5 12h7M12 8.5v7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
    {%- else -%}
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" focusable="false">
        <path d="M12 4c-3 4-5 7.2-5 10a5 5 0 1 0 10 0c0-2.8-2-6-5-10Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
        <path d="M9 19h6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
  {%- endcase -%}
</span>
