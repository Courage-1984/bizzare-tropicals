{% doc %}
  Renders the terracotta wax seal on product media (PDP and cards).

  @param {product} [product_item] - Live product for tag checks
  @param {string} [mock_tags] - Comma-separated tag fallback (e.g. `Rare`)

  @example
  {% render 'wax-seal-badge', product_item: product, mock_tags: 'Rare' %}
  {% render 'wax-seal-badge', mock_tags: 'Rare' %}
{% enddoc %}

{%- liquid
  assign show_rare = false

  if product_item != blank
    if product_item.tags contains 'Rare'
      assign show_rare = true
    elsif mock_tags != blank
      if mock_tags contains 'Rare'
        assign show_rare = true
      endif
    endif
  elsif mock_tags != blank
    if mock_tags contains 'Rare'
      assign show_rare = true
    endif
  endif
-%}

{%- if show_rare -%}
  <div class="wax-seal-badge" aria-hidden="true">
    <span class="wax-seal-badge__seal product-card__badge product-card__badge--wax product-card__badge--wax-rare">
      <span class="product-card__badge-text">{{ 'products.card.badge_rare' | t }}</span>
    </span>
  </div>
{%- endif -%}

{% stylesheet %}
  .product__media-item {
    position: relative;
  }

  .product__media-item .wax-seal-badge {
    position: absolute;
    top: var(--space-md);
    inset-inline-end: var(--space-md);
    z-index: 4;
    pointer-events: none;
  }

  .product__media-item .wax-seal-badge__seal {
    position: static;
    display: inline-flex;
  }
{% endstylesheet %}
