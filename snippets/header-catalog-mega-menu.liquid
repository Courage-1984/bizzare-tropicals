{% doc %}
  Catalog mega menu — live genus collections with products, thumbnails from collection, product, blocks, or placeholders.

  @param {string} [variant] - `desktop` or `mobile` (default: desktop)
  @param {array} [mega_menu_blocks] - Header blocks for per-genus images (type `mega_menu_item`)
{% enddoc %}

{%- liquid
  assign menu_variant = variant | default: 'desktop'
  assign excluded_handles = 'all,frontpage,growing-supplies,growing_supplies,supplies,accessories,nepenthes' | split: ','
  capture catalog_genus_handles
    render 'catalog-genus-handles'
  endcapture
  assign genus_order = catalog_genus_handles | strip | split: ','
  assign rendered_handles = ''
-%}

{%- capture genus_menu_html -%}
  {%- comment -%} Preferred genus order (client catalogue) {%- endcomment -%}
  {%- for genus_handle in genus_order -%}
    {%- assign collection = collections[genus_handle] -%}
    {%- if collection == blank -%}
      {%- continue -%}
    {%- endif -%}
    {%- if collection.products_count == 0 -%}
      {%- continue -%}
    {%- endif -%}
    {%- assign rendered_handles = rendered_handles | append: genus_handle | append: ',' -%}
    {%- render 'header-catalog-mega-menu-item',
      collection: collection,
      variant: menu_variant,
      mega_menu_blocks: mega_menu_blocks
    -%}
  {%- endfor -%}

  {%- comment -%} Any other in-stock genus collections not in the ordered list {%- endcomment -%}
  {%- for collection in collections -%}
    {%- liquid
      assign skip_collection = false

      assign rendered_needle = ',' | append: collection.handle | append: ','
      assign rendered_haystack = ',' | append: rendered_handles
      if rendered_haystack contains rendered_needle
        assign skip_collection = true
      endif

      for excluded_handle in excluded_handles
        if collection.handle == excluded_handle
          assign skip_collection = true
          break
        endif
      endfor

      if skip_collection == false
        if collection.handle contains '-'
          assign skip_collection = true
        endif
      endif

      if skip_collection
        continue
      endif

      if collection.products_count == 0
        continue
      endif
    -%}
    {%- render 'header-catalog-mega-menu-item',
      collection: collection,
      variant: menu_variant,
      mega_menu_blocks: mega_menu_blocks
    -%}
  {%- endfor -%}
{%- endcapture -%}

{%- assign genus_menu_stripped = genus_menu_html | strip -%}

{%- if genus_menu_stripped != blank -%}
  {%- if menu_variant == 'desktop' -%}
    <div
      class="site-nav__mega-menu"
      id="catalog-mega-menu"
      role="region"
      aria-label="{{ 'header.catalog_mega_menu' | t }}"
    >
      <div class="site-nav__mega-menu-grid" role="list">
        {{ genus_menu_html }}
      </div>
    </div>
  {%- else -%}
    <ul class="site-nav__mega-menu-list site-nav__mega-menu-list--mobile" role="list">
      {{ genus_menu_html }}
    </ul>
  {%- endif -%}
{%- endif -%}
