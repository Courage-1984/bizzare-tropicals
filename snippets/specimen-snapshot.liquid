{% doc %}
  Minimal specimen snapshot row for the PDP dossier column.

  @param {string} [latin_name] - Binomial or cultivar line
  @param {string} [origin_value] - Origin location (metafield)
  @param {number} [difficulty] - Difficulty level 1–5
  @param {string} [light_value] - Lux / light requirements (custom.lux_requirements)
  @param {string} [water_value] - Watering / media note (custom.potting_media)
  @param {string} [temp_value] - Temperature range (custom.temp_range)
  @param {boolean} [show_latin] - Show latin chip when true
  @param {boolean} [show_origin] - Show origin chip when true
  @param {boolean} [show_difficulty] - Show difficulty chip when true
  @param {boolean} [show_light] - Show light chip when true
  @param {boolean} [show_water] - Show water chip when true
  @param {boolean} [show_temp] - Show temp chip when true

  @example
  {% render 'specimen-snapshot',
    latin_name: latin_name,
    origin_value: spec_origin_raw,
    difficulty: difficulty,
    light_value: snapshot_light,
    show_latin: true,
    show_origin: true,
    show_difficulty: true,
    show_light: true
  %}
{% enddoc %}

{%- liquid
  assign has_snapshot = false
  if show_latin or show_origin or show_difficulty or show_light or show_water or show_temp
    assign has_snapshot = true
  endif
-%}

{%- if has_snapshot -%}
  <div
    class="specimen-snapshot"
    aria-label="{{ 'products.main.specimen_snapshot_label' | t }}"
  >
    <ul class="specimen-snapshot__list" role="list">
      {%- if show_latin and latin_name != blank -%}
        <li class="specimen-snapshot__item">
          <span class="specimen-snapshot__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3c-1.5 2-4 4.5-4 8a4 4 0 0 0 8 0c0-3.5-2.5-6-4-8z"/>
              <path d="M12 11v10"/>
            </svg>
          </span>
          <span class="specimen-snapshot__body">
            <span class="specimen-snapshot__label">{{ 'products.main.snapshot_latin' | t }}</span>
            <span class="specimen-snapshot__value"><em>{{ latin_name | escape }}</em></span>
          </span>
        </li>
      {%- endif -%}

      {%- if show_origin and origin_value != blank -%}
        <li class="specimen-snapshot__item">
          <span class="specimen-snapshot__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M2 12h20"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
          </span>
          <span class="specimen-snapshot__body">
            <span class="specimen-snapshot__label">{{ 'products.main.snapshot_origin' | t }}</span>
            <span class="specimen-snapshot__value">{{ origin_value | escape }}</span>
          </span>
        </li>
      {%- endif -%}

      {%- if show_difficulty and difficulty > 0 -%}
        <li class="specimen-snapshot__item">
          <span class="specimen-snapshot__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2v4"/>
              <path d="m4.93 4.93 2.83 2.83"/>
              <path d="M2 12h4"/>
              <path d="m4.93 19.07 2.83-2.83"/>
              <path d="M12 18v4"/>
              <path d="m19.07 19.07-2.83-2.83"/>
              <path d="M18 12h4"/>
              <path d="m19.07 4.93-2.83 2.83"/>
            </svg>
          </span>
          <span class="specimen-snapshot__body">
            <span class="specimen-snapshot__label">{{ 'products.main.snapshot_difficulty' | t }}</span>
            <span class="specimen-snapshot__value specimen-snapshot__value--difficulty">
              <span class="visually-hidden">{{ 'products.card.difficulty_label' | t: level: difficulty, max: 5 }}</span>
              <span
                class="main-product__difficulty difficulty-pips"
                aria-hidden="true"
              >
                {%- for pip in (1..5) -%}
                  <span
                    class="difficulty-pip{% if pip <= difficulty %} difficulty-pip--filled{% endif %}"
                  ></span>
                {%- endfor -%}
              </span>
            </span>
          </span>
        </li>
      {%- endif -%}

      {%- if show_light and light_value != blank -%}
        <li class="specimen-snapshot__item">
          <span class="specimen-snapshot__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="4"/>
              <path d="M12 2v2"/>
              <path d="M12 20v2"/>
              <path d="m4.93 4.93 1.41 1.41"/>
              <path d="m17.66 17.66 1.41 1.41"/>
              <path d="M2 12h2"/>
              <path d="M20 12h2"/>
              <path d="m6.34 17.66-1.41 1.41"/>
              <path d="m19.07 4.93-1.41 1.41"/>
            </svg>
          </span>
          <span class="specimen-snapshot__body">
            <span class="specimen-snapshot__label">{{ 'products.main.snapshot_light' | t }}</span>
            <span class="specimen-snapshot__value">{{ light_value | escape }}</span>
          </span>
        </li>
      {%- endif -%}

      {%- if show_water and water_value != blank -%}
        <li class="specimen-snapshot__item">
          <span class="specimen-snapshot__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
            </svg>
          </span>
          <span class="specimen-snapshot__body">
            <span class="specimen-snapshot__label">{{ 'products.main.snapshot_water' | t }}</span>
            <span class="specimen-snapshot__value">{{ water_value | escape }}</span>
          </span>
        </li>
      {%- endif -%}

      {%- if show_temp and temp_value != blank -%}
        <li class="specimen-snapshot__item">
          <span class="specimen-snapshot__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/>
            </svg>
          </span>
          <span class="specimen-snapshot__body">
            <span class="specimen-snapshot__label">{{ 'products.main.snapshot_temp' | t }}</span>
            <span class="specimen-snapshot__value">{{ temp_value | escape }}</span>
          </span>
        </li>
      {%- endif -%}
    </ul>
  </div>
{%- endif -%}
