{% doc %}
  Shown when a native policy has no Admin body yet. Full HTML is in content/policies/ for paste into Admin.

  @param {string} policy_handle - Shopify policy handle (e.g. refund-policy)
{% enddoc %}

{%- liquid
  assign policy_handle = policy_handle | default: policy.handle | strip
-%}

<p class="policy-page__empty">
  {{ 'sections.main_policy_page.admin_fallback_hint' | t }}
  {%- if policy_handle != blank -%}
    <span class="visually-hidden"> ({{ policy_handle | escape }})</span>
  {%- endif -%}
</p>
