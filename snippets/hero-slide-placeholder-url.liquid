{% doc %}
  Outputs a Wikimedia Commons hero banner URL for a genus collection handle.
  URLs use Special:FilePath per .cursor/context/placeholder-images.md.

  @param {string} genus_handle - Collection handle from slide button link (e.g. drosera)

  @example
  {% capture url %}{% render 'hero-slide-placeholder-url', genus_handle: 'nepenthes' %}{% endcapture %}
{% enddoc %}

{%- liquid
  assign handle = genus_handle | handleize
  assign width = '2400'
-%}

{%- case handle -%}
  {%- when 'drosera' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Drosera_Capensis.jpg?width={{ width }}
  {%- when 'nepenthes' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Nepenthes_rajah.png?width={{ width }}
  {%- when 'nepenthes-highland' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Nepenthes_villosa.jpg?width={{ width }}
  {%- when 'nepenthes-intermediate' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Nepenthes_ventricosa4.jpg?width={{ width }}
  {%- when 'nepenthes-lowland' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Nepenthes_ampullaria.jpg?width={{ width }}
  {%- when 'pinguicula' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Pinguicula_moranensis.jpg?width={{ width }}
  {%- when 'cephalotus' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Cephalotus_follicularis_0001.JPG?width={{ width }}
  {%- when 'heliamphora' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Heliamphora_nutans_(a_pitcher_plant_from_Venezuela)_at_Kew_Gardens_(5253200783).jpg?width={{ width }}
  {%- when 'dionaea' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Venus_Fly_Trap_(Dionaea_muscipula).jpg?width={{ width }}
  {%- when 'sarracenia' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Sarracenia_Judith_Hindle_(5964475729).jpg?width={{ width }}
  {%- when 'utricularia' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Greater_Bladderwort_Utricularia_vulgaris_(6171429381).jpg?width={{ width }}
  {%- when 'darlingtonia' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Darlingtonias.JPG?width={{ width }}
  {%- when 'byblis' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/ByblisLinifloraHabitus.JPG?width={{ width }}
  {%- when 'drossophyllum' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Drosophyllum_lusitanicum_RBGK.JPG?width={{ width }}
  {%- when 'other' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Aldrovanda_vesiculosa.jpg?width={{ width }}
  {%- when 'growing-supplies' -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Sphagnum_centrale.jpeg?width={{ width }}
  {%- else -%}
    https://commons.wikimedia.org/wiki/Special:FilePath/Sarracenia_Judith_Hindle_(5964475729).jpg?width={{ width }}
{%- endcase -%}
