<!doctype html>
<html lang="{{ locale }}" dir="{{ direction }}" class="{{ checkout_html_classes }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, height=device-height, minimum-scale=1.0">
    <title>{{ page_title }}</title>
    {{ content_for_header }}
    {{ checkout_stylesheets }}
    {{ checkout_scripts }}
    {% style %}
      .specimen-log-frame--checkout {
        max-width: 40rem;
        margin: 0 auto var(--space-xl);
        padding: var(--space-xl);
        background: #f7f4ed;
        border: 1px solid #121614;
        outline: 1px solid #121614;
        outline-offset: 5px;
      }

      .checkout-specimen-log__title {
        margin: 0 0 var(--space-sm);
        font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, 'Book Antiqua', Georgia, serif;
        font-size: 1.25rem;
        font-weight: 400;
        letter-spacing: 0.1em;
        text-align: center;
        text-transform: uppercase;
        color: #121614;
      }

      .checkout-specimen-log__overline {
        margin: 0 0 var(--space-xs);
        font-family: 'Courier New', Courier, monospace;
        font-size: 0.65rem;
        letter-spacing: 0.14em;
        text-align: center;
        text-transform: uppercase;
        color: rgb(18 22 20 / 0.6);
      }

      .checkout-thank-you__signature {
        max-width: 40rem;
        margin: 3rem auto 0;
        padding-block-start: 1rem;
        border-block-start: 1px solid #121614;
        width: 12.5rem;
      }

      .checkout-thank-you__signature-name {
        margin: 0;
        font-family: 'Brush Script MT', 'Segoe Script', cursive;
        font-size: 1.2rem;
        color: #121614;
      }

      .checkout-thank-you__signature-title {
        margin: 0.25rem 0 0;
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: rgb(18 22 20 / 0.65);
      }
    {% endstyle %}
  </head>
  <body>
    {{ skip_to_content_link }}

    {%- if checkout.page == 'thank_you' -%}
      <div class="specimen-log-frame specimen-log-frame--checkout checkout-specimen-log" role="presentation">
        <p class="checkout-specimen-log__overline">{{ 'sections.order_status.overline' | t }}</p>
        <h2 class="checkout-specimen-log__title">{{ 'sections.order_status.title' | t }}</h2>
      </div>
    {%- endif -%}

    {{ content_for_layout }}

    {%- if checkout.page == 'thank_you' -%}
      <div class="checkout-thank-you__signature">
        <p class="checkout-thank-you__signature-name">{{ 'sections.order_status.signature_name' | t }}</p>
        <p class="checkout-thank-you__signature-title">{{ 'sections.order_status.signature_title' | t }}</p>
      </div>
    {%- endif -%}

    {{ tracking_code }}
  </body>
</html>
