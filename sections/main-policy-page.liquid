{%- liquid
  assign fallback_title = section.settings.fallback_title | strip
  if fallback_title == blank
    assign fallback_title = 'sections.main_policy_page.fallback_title_default' | t
  endif

  assign policy_title = policy.title | strip
  assign page_title_raw = page.title | strip
  if policy_title != blank
    assign page_title = policy_title
  elsif page_title_raw != blank
    assign page_title = page_title_raw
  else
    assign page_title = fallback_title
  endif

  assign intro_text = section.settings.intro | strip
  if intro_text == blank
    assign intro_text = 'sections.main_policy_page.intro_default' | t
  endif

  assign default_body_content = section.settings.default_body
  if default_body_content == blank
    assign default_body_content = 'sections.main_policy_page.default_body_default' | t
  endif

  assign policy_body = policy.body
  assign page_body = page.content
  assign policy_handle = policy.handle | strip

  capture body_html
    if policy_body != blank
      echo policy_body
    elsif page_body != blank
      echo page_body
    elsif default_body_content != blank
      echo default_body_content
    elsif policy_handle != blank
      render 'policy-fallback-body', policy_handle: policy_handle
    else
      echo '<p class="policy-page__empty">'
      echo 'sections.main_policy_page.empty' | t
      echo '</p>'
    endif
  endcapture
-%}

<div class="policy-page-section" {{ section.shopify_attributes }}>
  {% render 'policy-page-shell', page_title: page_title, intro_text: intro_text, body_html: body_html %}
</div>

{% schema %}
{
  "name": "t:sections.main_policy_page.name",
  "tag": "section",
  "class": "policy-page-section",
  "settings": [
    {
      "type": "text",
      "id": "fallback_title",
      "label": "t:sections.main_policy_page.settings.fallback_title",
      "default": "Policy"
    },
    {
      "type": "text",
      "id": "intro",
      "label": "t:sections.main_policy_page.settings.intro"
    },
    {
      "type": "html",
      "id": "default_body",
      "label": "t:sections.main_policy_page.settings.default_body",
      "info": "t:sections.main_policy_page.settings.default_body_info"
    }
  ]
}
{% endschema %}
