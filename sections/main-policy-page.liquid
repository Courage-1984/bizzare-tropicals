{%- liquid
  assign fallback_title = section.settings.fallback_title | strip
  if fallback_title == blank
    assign fallback_title = 'sections.main_policy_page.fallback_title_default' | t
  endif

  assign policy_title = policy.title | strip
  assign page_title_raw = page.title | strip
  if policy_title != blank
    assign page_title = policy_title
  elsif page_title_raw != blank
    assign page_title = page_title_raw
  else
    assign page_title = fallback_title
  endif

  assign intro_text = section.settings.intro | strip
  if intro_text == blank
    assign intro_text = 'sections.main_policy_page.intro_default' | t
  endif

  assign default_body_content = section.settings.default_body
  if default_body_content == blank
    assign default_body_content = 'sections.main_policy_page.default_body_default' | t
  endif

  assign policy_body = policy.body
  assign page_body = page.content
  assign policy_handle = policy.handle | strip

  assign has_primary_content = false
  if policy_body != blank
    assign has_primary_content = true
  elsif page_body != blank
    assign has_primary_content = true
  endif

  assign has_default_body = false
  if default_body_content != blank
    assign has_default_body = true
  endif

  assign has_policy_fallback = false
  if has_primary_content == false and has_default_body == false and policy_handle != blank
    assign has_policy_fallback = true
  endif
-%}

<article class="policy-page full-width" {{ section.shopify_attributes }}>
  <div class="policy-page__inner">
    <header class="policy-page__header">
      <h1 class="policy-page__title">{{ page_title | escape }}</h1>
      <p class="policy-page__intro">{{ intro_text | escape }}</p>
    </header>

    <div class="policy-page__content rte">
      {%- if policy_body != blank -%}
        {{ policy_body }}
      {%- elsif page_body != blank -%}
        {{ page_body }}
      {%- elsif has_default_body -%}
        {{ default_body_content }}
      {%- elsif has_policy_fallback -%}
        {% render 'policy-fallback-body', policy_handle: policy_handle %}
      {%- else -%}
        <p class="policy-page__empty">{{ 'sections.main_policy_page.empty' | t }}</p>
      {%- endif -%}
    </div>
  </div>
</article>

{% stylesheet %}
  .policy-page {
    padding-block: var(--space-3xl) var(--space-4xl);
    background-color: var(--color-parchment);
  }

  .policy-page__inner {
    width: min(var(--page-width), calc(100% - var(--page-margin) * 2));
    max-width: 42rem;
    margin-inline: auto;
  }

  .policy-page__title {
    margin: 0 0 var(--space-md);
    font-family: var(--font-family-serif);
    font-size: clamp(1.75rem, 3vw + 0.5rem, 2.75rem);
    font-weight: 400;
    color: var(--color-forest-green-dark);
  }

  .policy-page__intro {
    margin: 0 0 var(--space-xl);
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-muted);
  }

  .policy-page__content :is(p, ul, ol) {
    margin: 0 0 var(--space-md);
    line-height: var(--line-height-relaxed);
    color: var(--color-forest-green-dark);
  }

  .policy-page__content h2 {
    margin: var(--space-xl) 0 var(--space-md);
    font-family: var(--font-family-serif);
    font-size: var(--font-size-lg);
    font-weight: 400;
    color: var(--color-forest-green-dark);
  }

  .policy-page__content h2:first-child {
    margin-block-start: 0;
  }

  .policy-page__content li + li {
    margin-block-start: var(--space-xs);
  }

  .policy-page__empty {
    margin: 0;
    padding: var(--space-lg);
    text-align: center;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background-color: rgb(255 255 255 / 0.45);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.main_policy_page.name",
  "tag": "section",
  "class": "policy-page-section",
  "settings": [
    {
      "type": "text",
      "id": "fallback_title",
      "label": "t:sections.main_policy_page.settings.fallback_title",
      "default": "Policy"
    },
    {
      "type": "text",
      "id": "intro",
      "label": "t:sections.main_policy_page.settings.intro"
    },
    {
      "type": "html",
      "id": "default_body",
      "label": "t:sections.main_policy_page.settings.default_body",
      "info": "t:sections.main_policy_page.settings.default_body_info"
    }
  ]
}
{% endschema %}
