{%- liquid
  assign overlay_opacity = section.settings.overlay_opacity | default: 50 | times: 1.0 | divided_by: 100.0
  assign default_placeholder = section.settings.default_placeholder_image
  assign autoplay_seconds = section.settings.autoplay_seconds | default: 7
  assign autoplay_ms = autoplay_seconds | times: 1000
  assign enable_autoplay = section.settings.enable_autoplay
  assign visible_slide_count = 0

  for block in section.blocks
    if block.type != 'slide'
      continue
    endif

    assign block_visible = false
    if block.settings.image != blank
      assign block_visible = true
    endif
    if block_visible == false
      if block.settings.placeholder_image != blank
        assign block_visible = true
      endif
    endif
    if block_visible == false
      if block.settings.collection != blank
        assign block_visible = true
      endif
    endif
    if block_visible == false
      if block.settings.heading != blank
        assign block_visible = true
      endif
    endif
    if block_visible == false
      if block.settings.subheading != blank
        assign block_visible = true
      endif
    endif
    if block_visible == false
      if block.settings.button_label != blank
        if block.settings.button_link != blank
          assign block_visible = true
        elsif block.settings.collection != blank
          assign block_visible = true
        endif
      endif
    endif

    if block_visible
      assign visible_slide_count = visible_slide_count | plus: 1
    endif
  endfor

  assign slide_count = visible_slide_count
  assign visible_slide_index = 0
  assign first_visible_slide_set = false
-%}

<section
  class="home-slider full-width"
  data-home-slider
  data-section-id="{{ section.id }}"
  data-autoplay-enabled="{% if enable_autoplay %}true{% else %}false{% endif %}"
  data-autoplay-ms="{{ autoplay_ms }}"
  style="--home-slider-overlay-opacity: {{ overlay_opacity }};"
  {% if slide_count > 0 %}
    aria-roledescription="carousel"
    aria-label="{{ 'sections.home_slider.carousel_label' | t }}"
  {% endif %}
  {{ section.shopify_attributes }}
>
  {%- if slide_count > 0 -%}
    <div class="home-slider__viewport">
      <div class="home-slider__slides" data-home-slides>
        {%- for block in section.blocks -%}
          {%- liquid
            assign slide_collection = block.settings.collection
            assign slide_image = block.settings.image
            assign use_shopify_image = false
            assign placeholder_url = block.settings.placeholder_image | strip
            assign slide_handle = ''
            assign slide_heading = block.settings.heading | strip
            assign slide_subheading = block.settings.subheading | strip
            assign slide_button_label = block.settings.button_label | strip
            assign slide_button_link = block.settings.button_link

            if slide_collection != blank
              if slide_button_link == blank
                assign slide_button_link = slide_collection.url
              endif
              assign slide_handle = slide_collection.handle
            endif

            if slide_button_link != blank
              if slide_button_link contains '/collections/'
                assign link_handle = slide_button_link | split: '/collections/' | last | split: '?' | first | split: '/' | first
                if slide_handle == blank
                  assign slide_handle = link_handle
                endif
              endif
            endif

            if slide_heading == blank
              if slide_collection != blank
                capture collection_display_title
                  render 'collection-display-title', collection: slide_collection
                endcapture
                assign slide_heading = collection_display_title | strip
              endif
            endif

            if slide_image != blank and slide_image.width > 0
              assign use_shopify_image = true
            endif

            if use_shopify_image == false and slide_collection != blank
              if slide_collection.image != blank and slide_collection.image.width > 0
                assign slide_image = slide_collection.image
                assign use_shopify_image = true
              else
                assign fallback_product = slide_collection.products.first
                if fallback_product != blank
                  assign fallback_media = fallback_product.featured_media.preview_image | default: fallback_product.featured_image
                  if fallback_media != blank and fallback_media.width > 0
                    assign slide_image = fallback_media
                    assign use_shopify_image = true
                  endif
                endif
              endif
            endif

            if use_shopify_image == false
              if placeholder_url == blank and slide_handle != blank
                capture hero_placeholder
                  render 'hero-slide-placeholder-url', genus_handle: slide_handle
                endcapture
                assign placeholder_url = hero_placeholder | strip
              endif
              if placeholder_url == blank
                assign placeholder_url = default_placeholder | strip
              endif
            endif

            assign slide_has_media = false
            if use_shopify_image
              assign slide_has_media = true
            endif
            if slide_has_media == false
              if placeholder_url != blank
                assign slide_has_media = true
              endif
            endif

            assign slide_has_text = false
            if slide_heading != blank
              assign slide_has_text = true
            endif
            if slide_has_text == false
              if slide_subheading != blank
                assign slide_has_text = true
              endif
            endif

            assign slide_has_cta = false
            if slide_button_label != blank
              if slide_button_link != blank
                assign slide_has_cta = true
              endif
            endif

            if slide_has_media == false
              if slide_has_text == false
                if slide_has_cta == false
                  continue
                endif
              endif
            endif

            assign is_first_slide = false
            unless first_visible_slide_set
              assign is_first_slide = true
              assign first_visible_slide_set = true
            endunless

            assign slide_alt = slide_heading
            if slide_alt == blank
              assign slide_alt = shop.name
            endif
          -%}

          <article
            id="home-slide-{{ block.id }}"
            class="home-slider__slide{% if is_first_slide %} is-active{% endif %}"
            data-home-slide
            data-block-id="{{ block.id }}"
            data-slide-index="{{ visible_slide_index }}"
            aria-hidden="{% if is_first_slide %}false{% else %}true{% endif %}"
            {{ block.shopify_attributes }}
          >
            <div
              class="home-slider__media{% if use_shopify_image == false and placeholder_url != blank %} home-slider__media--fallback{% endif %}{% unless slide_has_media %} home-slider__media--empty{% endunless %}"
              aria-hidden="true"
              {% if use_shopify_image == false and placeholder_url != blank %}
                style="background-image: url('{{ placeholder_url | escape }}');"
              {% endif %}
            >
              {%- if use_shopify_image -%}
                {%- liquid
                  assign slide_img_width = slide_image.width | default: 2400
                  assign slide_img_height = slide_image.height | default: 1600
                -%}
                {%- if is_first_slide -%}
                  {{
                    slide_image
                    | image_url: width: 2400
                    | image_tag:
                      class: 'home-slider__image',
                      widths: '750, 1100, 1500, 1800, 2400',
                      sizes: '100vw',
                      alt: slide_alt,
                      loading: 'eager',
                      fetchpriority: 'high',
                      width: slide_img_width,
                      height: slide_img_height
                  }}
                {%- else -%}
                  {{
                    slide_image
                    | image_url: width: 2400
                    | image_tag:
                      class: 'home-slider__image',
                      widths: '750, 1100, 1500, 1800, 2400',
                      sizes: '100vw',
                      alt: slide_alt,
                      loading: 'lazy',
                      width: slide_img_width,
                      height: slide_img_height
                  }}
                {%- endif -%}
              {%- elsif placeholder_url != blank -%}
                {%- comment -%} TODO: replace placeholder before launch — .cursor/context/placeholder-images.md {%- endcomment -%}
                <img
                  class="home-slider__image home-slider__image--fallback"
                  src="{{ placeholder_url | escape }}"
                  alt="{% if slide_heading != blank %}{{ slide_heading | escape }}{% else %}{{ shop.name | escape }}{% endif %}"
                  width="2400"
                  height="1600"
                  {% if is_first_slide %}
                    loading="eager"
                    fetchpriority="high"
                  {% else %}
                    loading="lazy"
                  {% endif %}
                  decoding="async"
                >
              {%- else -%}
                <span class="home-slider__image home-slider__image--placeholder" aria-hidden="true"></span>
              {%- endif -%}
              <div class="home-slider__overlay"></div>
            </div>

            <div class="home-slider__content">
              {%- if slide_heading != blank -%}
                {%- if is_first_slide -%}
                  <h1 class="home-slider__heading font-serif">{{ slide_heading | escape }}</h1>
                {%- else -%}
                  <h2 class="home-slider__heading font-serif">{{ slide_heading | escape }}</h2>
                {%- endif -%}
              {%- endif -%}

              {%- if slide_subheading != blank -%}
                <p class="home-slider__subheading">{{ slide_subheading | escape }}</p>
              {%- endif -%}

              {%- if slide_button_label != blank and slide_button_link != blank -%}
                <a class="home-slider__button" href="{{ slide_button_link }}">
                  {{- slide_button_label | escape -}}
                </a>
              {%- endif -%}
            </div>
          </article>
          {%- assign visible_slide_index = visible_slide_index | plus: 1 -%}
        {%- endfor -%}
      </div>
    </div>

    {%- if slide_count > 1 -%}
      <div class="home-slider__controls" data-home-controls>
        <button
          type="button"
          class="home-slider__arrow home-slider__arrow--prev"
          data-home-prev
          aria-label="{{ 'sections.home_slider.prev_slide' | t }}"
        >
          <span aria-hidden="true">&larr;</span>
        </button>

        <div class="home-slider__dots" data-home-dots role="tablist" aria-label="{{ 'sections.home_slider.slide_dots' | t }}">
          {%- assign dot_index = 0 -%}
          {%- assign dot_first_set = false -%}
          {%- for block in section.blocks -%}
            {%- if block.type != 'slide' -%}
              {%- continue -%}
            {%- endif -%}
            {%- liquid
              assign dot_visible = false
              if block.settings.image != blank
                assign dot_visible = true
              endif
              if dot_visible == false
                if block.settings.placeholder_image != blank
                  assign dot_visible = true
                endif
              endif
              if dot_visible == false
                if block.settings.collection != blank
                  assign dot_visible = true
                endif
              endif
              if dot_visible == false
                if block.settings.heading != blank
                  assign dot_visible = true
                endif
              endif
              if dot_visible == false
                if block.settings.subheading != blank
                  assign dot_visible = true
                endif
              endif
              if dot_visible == false
                if block.settings.button_label != blank
                  if block.settings.button_link != blank
                    assign dot_visible = true
                  elsif block.settings.collection != blank
                    assign dot_visible = true
                  endif
                endif
              endif
            -%}
            {%- unless dot_visible -%}
              {%- continue -%}
            {%- endunless -%}
            {%- assign dot_is_active = false -%}
            {%- unless dot_first_set -%}
              {%- assign dot_is_active = true -%}
              {%- assign dot_first_set = true -%}
            {%- endunless -%}
            <button
              type="button"
              class="home-slider__dot{% if dot_is_active %} is-active{% endif %}"
              data-home-dot
              data-slide-index="{{ dot_index }}"
              data-block-id="{{ block.id }}"
              role="tab"
              aria-selected="{% if dot_is_active %}true{% else %}false{% endif %}"
              aria-controls="home-slide-{{ block.id }}"
              aria-label="{{ 'sections.home_slider.go_to_slide' | t: index: dot_index | plus: 1 }}"
            ></button>
            {%- assign dot_index = dot_index | plus: 1 -%}
          {%- endfor -%}
        </div>

        <button
          type="button"
          class="home-slider__arrow home-slider__arrow--next"
          data-home-next
          aria-label="{{ 'sections.home_slider.next_slide' | t }}"
        >
          <span aria-hidden="true">&rarr;</span>
        </button>
      </div>
    {%- endif -%}
  {%- else -%}
    <div class="home-slider__empty">
      <p>{{ 'sections.home_slider.empty' | t }}</p>
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .home-slider {
    --home-slider-crossfade: 1.5s;
    --home-slider-ken-burns: 8s;
    --home-slider-text-delay: 0.4s;
    position: relative;
    width: 100%;
    min-height: clamp(22rem, 72svh, 42rem);
    overflow: hidden;
    color: var(--color-text-inverse);
  }

  .home-slider__viewport {
    position: absolute;
    inset: 0;
  }

  .home-slider__slides {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: inherit;
  }

  .home-slider__slide {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    filter: blur(8px);
    transition:
      opacity var(--home-slider-crossfade) var(--ease-out),
      filter var(--home-slider-crossfade) var(--ease-out),
      visibility 0s linear var(--home-slider-crossfade);
  }

  .home-slider__slide.is-active {
    z-index: 1;
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    filter: blur(0);
    transition:
      opacity var(--home-slider-crossfade) var(--ease-out),
      filter var(--home-slider-crossfade) var(--ease-out),
      visibility 0s linear 0s;
  }

  .home-slider__media {
    position: absolute;
    inset: 0;
    overflow: hidden;
    isolation: isolate;
    transform: translateZ(0);
    background-color: var(--color-primary-hover);
    background-position: center center;
    background-size: cover;
    background-repeat: no-repeat;
  }

  .home-slider__image {
    width: 100%;
    height: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    object-position: center center;
    transform: scale3d(1, 1, 1);
    transform-origin: center center;
    backface-visibility: hidden;
  }

  .home-slider__image--placeholder {
    display: block;
    background:
      linear-gradient(145deg, var(--color-forest-green) 0%, var(--color-forest-green-dark) 100%);
  }

  .home-slider__media--empty .home-slider__overlay {
    opacity: 0.85;
  }

  .home-slider__slide.is-active .home-slider__image {
    animation: homeSliderKenBurns var(--home-slider-ken-burns) ease-out forwards;
  }

  .home-slider__slide:not(.is-active) .home-slider__image {
    animation: none;
    transform: scale3d(1, 1, 1);
  }

  @keyframes homeSliderKenBurns {
    from {
      transform: scale3d(1, 1, 1);
    }

    to {
      transform: scale3d(1.1, 1.1, 1);
    }
  }

  .home-slider__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(
        ellipse 85% 70% at 50% 45%,
        rgb(12 18 14 / calc(var(--home-slider-overlay-opacity) * 0.15)) 0%,
        rgb(12 18 14 / calc(var(--home-slider-overlay-opacity) * 0.65)) 100%
      ),
      linear-gradient(
        180deg,
        rgb(12 18 14 / calc(var(--home-slider-overlay-opacity) * 0.45)) 0%,
        rgb(12 18 14 / calc(var(--home-slider-overlay-opacity) * 0.35)) 40%,
        rgb(12 18 14 / var(--home-slider-overlay-opacity)) 100%
      );
  }

  .home-slider__content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
    width: 100%;
    max-width: 42rem;
    margin-inline: auto;
    padding: var(--space-3xl) var(--page-margin);
    text-align: center;
    pointer-events: none;
    transform: translateZ(0);
    backface-visibility: hidden;
  }

  .home-slider__slide.is-active .home-slider__content {
    pointer-events: auto;
  }

  .home-slider__heading,
  .home-slider__subheading,
  .home-slider__button {
    opacity: 0;
    transform: translate3d(0, 1.25rem, 0);
    transition:
      opacity 0.65s var(--ease-out),
      transform 0.65s var(--ease-out);
    transition-delay: 0s;
  }

  .home-slider__slide.is-active .home-slider__heading {
    opacity: 1;
    transform: translate3d(0, 0, 0);
    transition-delay: var(--home-slider-text-delay);
  }

  .home-slider__slide.is-active .home-slider__subheading {
    opacity: 1;
    transform: translate3d(0, 0, 0);
    transition-delay: calc(var(--home-slider-text-delay) + 0.15s);
  }

  .home-slider__slide.is-active .home-slider__button {
    opacity: 1;
    transform: translate3d(0, 0, 0);
    transition-delay: calc(var(--home-slider-text-delay) + 0.3s);
  }

  .home-slider__content .home-slider__button {
    pointer-events: auto;
  }

  .home-slider__heading {
    margin: 0;
    font-size: clamp(1.875rem, 4.5vw + 0.75rem, 3.25rem);
    font-weight: 400;
    line-height: var(--line-height-tight);
    letter-spacing: 0.01em;
    text-wrap: balance;
    text-shadow: 0 2px 28px rgb(0 0 0 / 0.45);
  }

  .home-slider__heading.font-serif {
    font-style: normal;
  }

  .home-slider__subheading {
    margin: 0;
    max-width: 36ch;
    font-family: var(--font-family-base);
    font-size: clamp(1rem, 1.25vw + 0.75rem, 1.1875rem);
    font-weight: 400;
    line-height: var(--line-height-relaxed);
    color: rgb(255 255 255 / 0.9);
    text-wrap: pretty;
    text-shadow: 0 1px 18px rgb(0 0 0 / 0.35);
  }

  .home-slider__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.875rem;
    padding: var(--space-sm) var(--space-2xl);
    font-family: var(--font-family-base);
    font-size: var(--font-size-sm);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-primary-hover);
    background-color: var(--color-background);
    border: 1px solid rgb(255 255 255 / 0.2);
    border-radius: var(--radius-sm);
    transition:
      background-color var(--transition-fast),
      color var(--transition-fast),
      transform var(--transition-fast);
  }

  .home-slider__button:hover {
    color: var(--color-text-inverse);
    background-color: var(--color-accent);
    transform: translate3d(0, -1px, 0);
  }

  .home-slider__controls {
    position: absolute;
    inset-inline: 0;
    bottom: var(--space-lg);
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    padding-inline: var(--page-margin);
    pointer-events: none;
  }

  .home-slider__arrow,
  .home-slider__dot {
    pointer-events: auto;
  }

  .home-slider__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    cursor: pointer;
    color: var(--color-text-inverse);
    background: rgb(12 18 14 / 0.35);
    border: 1px solid rgb(255 255 255 / 0.25);
    border-radius: var(--radius-full);
    backdrop-filter: blur(6px);
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast),
      transform var(--transition-fast);
  }

  .home-slider__arrow:hover {
    background: rgb(12 18 14 / 0.55);
    border-color: rgb(255 255 255 / 0.45);
    transform: translate3d(0, -1px, 0);
  }

  .home-slider__dots {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
  }

  .home-slider__dot {
    width: 0.625rem;
    height: 0.625rem;
    padding: 0;
    cursor: pointer;
    background: rgb(255 255 255 / 0.35);
    border: 1px solid rgb(255 255 255 / 0.5);
    border-radius: var(--radius-full);
    transition:
      transform var(--transition-fast),
      background-color var(--transition-fast);
  }

  .home-slider__dot.is-active {
    background: var(--color-background);
    transform: scale(1.2);
  }

  .home-slider__empty {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: inherit;
    padding: var(--space-2xl);
    text-align: center;
    color: var(--color-text-muted);
  }

  @media (max-width: 749px) {
    .home-slider {
      min-height: clamp(20rem, 65svh, 34rem);
    }

    .home-slider__content {
      gap: var(--space-md);
      padding-block: var(--space-2xl);
    }

    .home-slider__subheading {
      max-width: none;
    }

    .home-slider__controls {
      bottom: var(--space-md);
    }

    .home-slider__arrow {
      width: 2.5rem;
      height: 2.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-slider__slide {
      filter: none;
      transition: none;
    }

    .home-slider__slide.is-active .home-slider__image {
      animation: none;
      transform: scale3d(1, 1, 1);
    }

    .home-slider__heading,
    .home-slider__subheading,
    .home-slider__button,
    .home-slider__slide.is-active .home-slider__heading,
    .home-slider__slide.is-active .home-slider__subheading,
    .home-slider__slide.is-active .home-slider__button {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .home-slider__button:hover,
    .home-slider__arrow:hover {
      transform: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    'use strict';

    var SECTION_SELECTOR = '[data-home-slider]';
    var RESUME_DELAY_MS = 8000;

    function prefersReducedMotion() {
      try {
        return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      } catch (error) {
        return false;
      }
    }

    function destroyHomeSlider(root) {
      if (!root || !root._homeSliderState) {
        return;
      }

      try {
        var state = root._homeSliderState;

        if (state.autoplayTimer) {
          clearInterval(state.autoplayTimer);
        }

        if (state.resumeTimer) {
          clearTimeout(state.resumeTimer);
        }

        state.listeners.forEach(function (entry) {
          entry.target.removeEventListener(entry.type, entry.handler);
        });
      } catch (error) {
        console.error('Home slider: teardown failed.', error);
      }

      delete root._homeSliderState;
      root.dataset.homeSliderInitialized = 'false';
    }

    function initHomeSlider(root) {
      if (!root) {
        return;
      }

      destroyHomeSlider(root);

      var slides = Array.prototype.slice.call(root.querySelectorAll('[data-home-slide]'));
      if (slides.length === 0) {
        return;
      }

      var autoplayEnabled = root.getAttribute('data-autoplay-enabled') !== 'false';
      var autoplayMs = parseInt(root.getAttribute('data-autoplay-ms'), 10);
      if (isNaN(autoplayMs) || autoplayMs < 3000) {
        autoplayMs = 7000;
      }

      var prevButton = root.querySelector('[data-home-prev]');
      var nextButton = root.querySelector('[data-home-next]');
      var controls = root.querySelector('[data-home-controls]');
      var dots = Array.prototype.slice.call(root.querySelectorAll('[data-home-dot]'));
      var currentIndex = 0;
      var slidesLength = slides.length;
      var autoplayPaused = false;
      var state = {
        autoplayTimer: null,
        resumeTimer: null,
        listeners: []
      };

      function trackListener(target, type, handler) {
        target.addEventListener(type, handler);
        state.listeners.push({ target: target, type: type, handler: handler });
      }

      slides.forEach(function (slide, index) {
        if (slide.classList.contains('is-active')) {
          currentIndex = index;
        }
      });

      function stopAutoplay() {
        if (state.autoplayTimer) {
          clearInterval(state.autoplayTimer);
          state.autoplayTimer = null;
        }
      }

      function startAutoplay() {
        stopAutoplay();

        if (!autoplayEnabled || slidesLength <= 1 || autoplayPaused || prefersReducedMotion() || document.hidden) {
          return;
        }

        state.autoplayTimer = setInterval(function () {
          if (document.hidden) {
            return;
          }
          try {
            setActiveSlide(currentIndex + 1, { fromAutoplay: true });
          } catch (error) {
            console.error('Home slider: autoplay tick failed.', error);
          }
        }, autoplayMs);
      }

      function pauseAutoplay() {
        autoplayPaused = true;
        stopAutoplay();

        if (state.resumeTimer) {
          clearTimeout(state.resumeTimer);
          state.resumeTimer = null;
        }
      }

      function scheduleAutoplayResume() {
        if (state.resumeTimer) {
          clearTimeout(state.resumeTimer);
        }

        state.resumeTimer = setTimeout(function () {
          try {
            autoplayPaused = false;
            startAutoplay();
          } catch (error) {
            console.error('Home slider: autoplay resume failed.', error);
          }
        }, RESUME_DELAY_MS);
      }

      function setActiveSlide(index, options) {
        var opts = options || {};
        var nextIndex = index;

        if (nextIndex < 0) {
          nextIndex = slidesLength - 1;
        }

        if (nextIndex >= slidesLength) {
          nextIndex = 0;
        }

        if (nextIndex === currentIndex && !opts.force) {
          return;
        }

        if (!opts.fromAutoplay) {
          pauseAutoplay();
          scheduleAutoplayResume();
        }

        try {
          slides.forEach(function (slide, slideIndex) {
            var isActive = slideIndex === nextIndex;
            slide.classList.toggle('is-active', isActive);
            slide.setAttribute('aria-hidden', isActive ? 'false' : 'true');
          });

          dots.forEach(function (dot, dotIndex) {
            var isActive = dotIndex === nextIndex;
            dot.classList.toggle('is-active', isActive);
            dot.setAttribute('aria-selected', isActive ? 'true' : 'false');
          });

          currentIndex = nextIndex;
        } catch (error) {
          console.error('Home slider: failed to change slide.', error);
        }
      }

      function goToNext() {
        setActiveSlide(currentIndex + 1, { force: true });
      }

      function goToPrev() {
        setActiveSlide(currentIndex - 1, { force: true });
      }

      function bindControl(element, handler) {
        if (!element) {
          return;
        }

        trackListener(element, 'click', function (event) {
          try {
            event.preventDefault();
            handler();
          } catch (error) {
            console.error('Home slider: control handler failed.', error);
          }
        });
      }

      bindControl(prevButton, goToPrev);
      bindControl(nextButton, goToNext);

      dots.forEach(function (dot) {
        trackListener(dot, 'click', function (event) {
          try {
            event.preventDefault();
            var index = parseInt(dot.getAttribute('data-slide-index'), 10);
            if (!isNaN(index)) {
              setActiveSlide(index, { force: true });
            }
          } catch (error) {
            console.error('Home slider: dot navigation failed.', error);
          }
        });
      });

      if (controls) {
        trackListener(controls, 'pointerdown', pauseAutoplay);
        trackListener(controls, 'pointerenter', pauseAutoplay);
        trackListener(controls, 'focusin', pauseAutoplay);
        trackListener(controls, 'pointerup', scheduleAutoplayResume);
        trackListener(controls, 'pointerleave', scheduleAutoplayResume);
        trackListener(controls, 'focusout', scheduleAutoplayResume);
      }

      root.goToHomeSlide = function (index) {
        setActiveSlide(index, { force: true });
      };

      root.goToHomeSlideByBlockId = function (blockId) {
        pauseAutoplay();

        var targetIndex = slides.findIndex(function (slide) {
          return slide.getAttribute('data-block-id') === blockId;
        });

        if (targetIndex >= 0) {
          setActiveSlide(targetIndex, { force: true });
        }
      };

      root._homeSliderState = state;
      root.dataset.homeSliderInitialized = 'true';
      startAutoplay();
    }

    function initAllHomeSliders(scope) {
      var context = scope || document;
      var sliders = context.querySelectorAll(SECTION_SELECTOR);

      sliders.forEach(function (slider) {
        initHomeSlider(slider);
      });
    }

    try {
      initAllHomeSliders(document);

      document.addEventListener('shopify:section:load', function (event) {
        try {
          if (!event.target) {
            return;
          }

          initAllHomeSliders(event.target);
        } catch (error) {
          console.error('Home slider: section load handler failed.', error);
        }
      });

      document.addEventListener('shopify:section:unload', function (event) {
        try {
          if (!event.target) {
            return;
          }

          var slider = event.target.querySelector(SECTION_SELECTOR);
          if (slider) {
            destroyHomeSlider(slider);
          }
        } catch (error) {
          console.error('Home slider: section unload handler failed.', error);
        }
      });

      document.addEventListener('shopify:block:select', function (event) {
        try {
          if (!event.target || !event.detail || !event.detail.blockId) {
            return;
          }

          var slider = event.target.querySelector(SECTION_SELECTOR);
          if (!slider) {
            return;
          }

          if (typeof slider.goToHomeSlideByBlockId === 'function') {
            slider.goToHomeSlideByBlockId(event.detail.blockId);
          } else {
            initHomeSlider(slider);
            if (typeof slider.goToHomeSlideByBlockId === 'function') {
              slider.goToHomeSlideByBlockId(event.detail.blockId);
            }
          }
        } catch (error) {
          console.error('Home slider: block select handler failed.', error);
        }
      });
    } catch (error) {
      console.error('Home slider: slider failed to initialize.', error);
    }
  })();
{% endjavascript %}

