<section
  class="customer-account full-width"
  aria-labelledby="customer-account-title-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="customer-account__inner">
    <header class="customer-account__header">
      <h1 id="customer-account-title-{{ section.id }}" class="customer-account__title">
        {{ 'customers.account.title' | t }}
      </h1>
      {%- if customer.first_name != blank -%}
        <p class="customer-account__greeting">
          {{ 'customers.account.welcome' | t: name: customer.first_name }}
        </p>
      {%- endif -%}
    </header>

    <div class="customer-account__actions">
      <a class="customer-account__card link-underline-grow" href="{{ routes.account_addresses_url }}">
        <span class="customer-account__card-label">{{ 'customers.account.addresses' | t }}</span>
      </a>
    </div>

    {%- paginate customer.orders by 10 -%}
      <section class="customer-account__orders" aria-labelledby="customer-orders-title-{{ section.id }}">
        <h2 id="customer-orders-title-{{ section.id }}" class="customer-account__subtitle">
          {{ 'customers.account.orders_heading' | t }}
        </h2>

        {%- if customer.orders.size > 0 -%}
          <ul class="customer-account__order-list" role="list">
            {%- for order in customer.orders -%}
              <li class="customer-account__order-item">
                <a class="customer-account__order-link" href="{{ order.customer_url }}">
                  <span class="customer-account__order-name">{{ order.name }}</span>
                  <span class="customer-account__order-meta">
                    {{ order.created_at | date: '%d %b %Y' }} · {{ order.financial_status_label }} · {{ order.total_net_amount | money }}
                  </span>
                </a>
              </li>
            {%- endfor -%}
          </ul>
          {%- if paginate.pages > 1 -%}
            <div class="customer-account__pagination">
              {{ paginate | default_pagination }}
            </div>
          {%- endif -%}
        {%- else -%}
          <p class="customer-account__empty">{{ 'customers.account.no_orders' | t }}</p>
        {%- endif -%}
      </section>
    {%- endpaginate -%}

    <p class="customer-account__logout">
      <a class="customer-account__link link-underline-grow" href="{{ routes.account_logout_url }}">
        {{ 'customers.account.logout' | t }}
      </a>
    </p>
  </div>
</section>

{% stylesheet %}
  .customer-account {
    padding-block: var(--space-3xl) var(--space-4xl);
    background-color: var(--color-parchment);
  }

  .customer-account__inner {
    width: min(var(--page-width), calc(100% - var(--page-margin) * 2));
    max-width: 40rem;
    margin-inline: auto;
  }

  .customer-account__title {
    margin: 0 0 var(--space-sm);
    font-family: var(--font-family-serif);
    font-size: clamp(1.75rem, 3vw + 0.5rem, 2.5rem);
    font-weight: 400;
    color: var(--color-forest-green-dark);
  }

  .customer-account__greeting {
    margin: 0 0 var(--space-xl);
    color: var(--color-text-muted);
  }

  .customer-account__actions {
    margin-block-end: var(--space-xl);
  }

  .customer-account__card {
    display: inline-flex;
    padding: var(--space-md) var(--space-lg);
    text-decoration: none;
    color: var(--color-forest-green-dark);
    background-color: var(--color-surface-elevated);
    border: 1px solid var(--color-forest-green-dark);
    border-radius: var(--radius-sm);
  }

  .customer-account__card-label {
    font-size: var(--font-size-sm);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .customer-account__subtitle {
    margin: 0 0 var(--space-md);
    font-family: var(--font-family-serif);
    font-size: var(--font-size-lg);
    font-weight: 400;
    color: var(--color-forest-green-dark);
  }

  .customer-account__order-list {
    margin: 0;
    padding: 0;
    list-style: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .customer-account__order-item + .customer-account__order-item {
    border-block-start: 1px solid var(--color-border);
  }

  .customer-account__order-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    padding: var(--space-md) var(--space-lg);
    text-decoration: none;
    color: inherit;
    transition: background-color var(--transition-fast);
  }

  .customer-account__order-link:hover {
    background-color: rgb(10 24 18 / 0.04);
  }

  .customer-account__order-name {
    font-weight: 600;
    color: var(--color-forest-green-dark);
  }

  .customer-account__order-meta {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .customer-account__empty {
    margin: 0;
    color: var(--color-text-muted);
  }

  .customer-account__logout {
    margin-block-start: var(--space-2xl);
    text-align: center;
  }

  .customer-account__link {
    color: var(--color-forest-green-dark);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.main_account.name",
  "tag": "section",
  "class": "customer-account-section",
  "settings": []
}
{% endschema %}
