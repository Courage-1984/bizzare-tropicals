    will-change: transform;
  }

  .main-product__submit:hover:not(:disabled) {
    background-color: var(--color-primary);
    transform: scale(1.02);
  }

  .main-product__submit:disabled {
    cursor: not-allowed;
    opacity: 0.55;
  }

  .main-product__preview-note {
    margin: 0 0 var(--space-md);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .main-product__cultivation {
    margin-block: var(--space-xl);
    padding-block-start: var(--space-lg);
    border-block-start: 1px solid var(--color-border);
  }

  .main-product__cultivation-dossier .main-product__description ul {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .main-product__cultivation-dossier .main-product__description ul > li {
    margin: 0;
    padding-block-start: 0.5rem;
    border-block-start: 1px solid rgb(0 0 0 / 0.1);
  }

  .main-product__cultivation-dossier .main-product__description ul li > :is(strong, b):first-child {
    display: block;
    margin: 0 0 var(--space-xs);
    font-family: var(--font-family-base);
    font-size: 0.75rem;
    font-style: normal;
    font-weight: 700;
    line-height: var(--line-height-tight);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-forest-green-dark);
  }

  .main-product__cultivation-dossier .main-product__description ul > li {
    font-family: var(--font-family-serif);
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--color-forest-green-dark);
  }

  .main-product__field-data {
    padding-block-start: var(--space-lg);
    border-block-start: 1px solid var(--color-border);
  }

  .main-product__field-data-title {
    margin: 0 0 var(--space-md);
    font-family: var(--font-family-base);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .main-product__field-grid {
    margin: 0;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-md);
    overflow: hidden;
    background-color: var(--color-surface-elevated);
  }

  .main-product__field-row {
    display: grid;
    grid-template-columns: minmax(7rem, 38%) 1fr;
    gap: var(--space-md);
    margin: 0;
    padding: var(--space-sm) var(--space-md);
    border-block-end: 1px solid var(--color-border);
  }

  .main-product__field-row:last-child {
    border-block-end: none;
  }

  .main-product__field-row dt {
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .main-product__field-row dd {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    margin: 0;
    font-size: var(--font-size-sm);
    line-height: var(--line-height-base);
  }

  .main-product__field-value {
    font-weight: 600;
    color: var(--color-text);
  }

  .main-product__difficulty {
    margin-inline-start: auto;
  }

  .main-product__description {
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-muted);
  }

  .main-product__description :is(p, ul, ol) {
    margin: 0 0 var(--space-md);
  }

  @media (min-width: 750px) {
    .main-product__cultivation-dossier .main-product__description ul {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 990px) {
    .main-product__layout {
      flex-direction: row;
      align-items: flex-start;
      gap: var(--space-3xl);
    }

    .main-product__gallery.product__media {
      flex: 3 1 0;
      position: sticky;
      top: 20px;
      align-self: flex-start;
      height: auto;
      overflow: visible;
    }

    .main-product__dossier {
      flex: 2 1 0;
      min-width: 0;
    }
  }

  .main-product__origin {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
    margin-block-end: var(--space-xl);
    padding: var(--space-md) var(--space-lg);
    background-color: rgb(30 51 32 / 0.04);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .main-product__origin-icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    color: var(--color-primary);
  }

  .main-product__origin-text {
    margin: 0;
    font-family: var(--font-family-serif);
    font-size: var(--font-size-md);
    font-style: italic;
    line-height: var(--line-height-relaxed);
    color: var(--color-forest-green-dark);
  }

  .main-product__accordions {
    display: flex;
    flex-direction: column;
    margin-block-end: var(--space-xl);
  }

  .main-product__accordion {
    border-block-end: 1px solid var(--color-border-strong);
  }

  .main-product__accordion:first-child {
    border-block-start: 1px solid var(--color-border-strong);
  }

  .main-product__accordion-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-md) 0;
    font-family: var(--font-family-base);
    font-size: var(--font-size-sm);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-forest-green-dark);
    cursor: pointer;
    list-style: none;
  }

  .main-product__accordion-summary::-webkit-details-marker {
    display: none;
  }

  .main-product__accordion-summary::after {
    content: '+';
    flex-shrink: 0;
    font-size: 1.125rem;
    font-weight: 400;
    line-height: 1;
    color: var(--color-primary);
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .main-product__accordion[open] .main-product__accordion-summary::after {
    transform: rotate(45deg);
  }

  .main-product__accordion-body {
    padding-block: 0 var(--space-md);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-muted);
  }

  .main-product__accordion-body p {
    margin: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .main-product__submit {
      transition: background-color var(--transition-fast);
    }

    .main-product__submit:hover:not(:disabled) {
      transform: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    'use strict';

    function formatZar(cents) {
      var value = parseInt(cents, 10) || 0;
      var rands = Math.floor(value / 100);
      var fractional = value % 100;
      var fractionalDisplay = fractional < 10 ? '0' + fractional : String(fractional);
      var randsDisplay = String(rands);

      if (rands >= 1000) {
        var thousands = Math.floor(rands / 1000);
        var remainder = rands % 1000;
        var remainderPadded = String(remainder);
        while (remainderPadded.length < 3) {
          remainderPadded = '0' + remainderPadded;
        }
        randsDisplay = thousands + ' ' + remainderPadded;
      }

      return 'R ' + randsDisplay + ',' + fractionalDisplay;
    }

    function readVariants(root) {
      var script = root.querySelector('[data-main-product-variants]');
      if (!script) {
        return [];
      }
      try {
        return JSON.parse(script.textContent);
      } catch (error) {
        console.error('Main product: invalid variant JSON.', error);
        return [];
      }
    }

    function findVariant(variants, id) {
      var targetId = parseInt(id, 10);
      for (var i = 0; i < variants.length; i += 1) {
        if (variants[i].id === targetId) {
          return variants[i];
        }
      }
      return null;
    }

    function getStatusMode(variant) {
      if (!variant || !variant.available) {
        return 'sold_out';
      }
      if (variant.inventory_management === 'shopify') {
        var qty = parseInt(variant.inventory_quantity, 10) || 0;
        if (qty > 5) {
          return 'cultivating';
        }
        if (qty > 0) {
          return 'limited';
        }
        return 'sold_out';
      }
      return 'cultivating';
    }

    function updateStatus(root, variant) {
      var statusEl = root.querySelector('[data-product-status]');
      var statusText = root.querySelector('[data-product-status-text]');
      if (!statusEl || !statusText) {
        return;
      }

      var mode = getStatusMode(variant);
      var limitedTemplate = root.dataset.statusLimitedTemplate || '';
      var cultivatingText = root.dataset.statusCultivating || '';

      statusEl.classList.remove(
        'main-product__status--limited',
        'main-product__status--cultivating',
        'main-product__status--sold_out'
      );
      statusEl.classList.add('main-product__status--' + mode);
      statusEl.dataset.statusMode = mode;

      if (mode === 'sold_out') {
        statusEl.hidden = true;
        return;
      }

      statusEl.hidden = false;

      if (mode === 'limited') {
        var qty = parseInt(variant.inventory_quantity, 10) || 0;
        statusEl.dataset.statusCount = String(qty);
        statusText.textContent = limitedTemplate.replace('__COUNT__', String(qty));
      } else {
        statusText.textContent = cultivatingText;
      }
    }

    function updatePrice(root, variant) {
      var priceRoot = root.querySelector('[data-product-price]');
      if (!priceRoot || !variant) {
        return;
      }

      var price = parseInt(variant.price, 10) || 0;
      var compareAt = parseInt(variant.compare_at_price, 10) || 0;
      var saleEl = priceRoot.querySelector('[data-product-price-sale]');
      var compareEl = priceRoot.querySelector('[data-product-price-compare]');
      var regularEl = priceRoot.querySelector('[data-product-price-regular]');

      if (compareAt > price) {
        if (!saleEl) {
          priceRoot.innerHTML =
            '<span class="visually-hidden">Sale</span>' +
            '<span class="main-product__price-sale" data-product-price-sale></span>' +
            '<span class="visually-hidden">Regular</span>' +
            '<s class="main-product__price-compare" data-product-price-compare></s>';
          saleEl = priceRoot.querySelector('[data-product-price-sale]');
          compareEl = priceRoot.querySelector('[data-product-price-compare]');
        }
        if (regularEl) {
          regularEl.remove();
        }
        saleEl.textContent = formatZar(price);
        compareEl.textContent = formatZar(compareAt);
      } else {
        if (!regularEl) {
          priceRoot.innerHTML =
            '<span class="main-product__price-regular" data-product-price-regular></span>';
          regularEl = priceRoot.querySelector('[data-product-price-regular]');
        }
        if (saleEl) {
          saleEl.remove();
        }
        if (compareEl) {
          compareEl.remove();
        }
        regularEl.textContent = formatZar(price);
      }
    }

    function updateVariantUrl(variantId) {
      try {
        var url = new URL(window.location.href);
        url.searchParams.set('variant', String(variantId));
        window.history.replaceState({}, '', url.toString());
      } catch (error) {
        /* Non-blocking */
      }
    }

    function applyVariant(root, variantId) {
      var variants = readVariants(root);
      var variant = findVariant(variants, variantId);
      if (!variant) {
        return;
      }

      var addButton = root.querySelector('[data-add-to-cart]');
      var addLabel = root.dataset.labelAdd || 'ADD TO CONSERVATORY';
      var soldOutLabel = root.dataset.labelSoldOut || 'Sold out';

      updatePrice(root, variant);
      updateStatus(root, variant);
      updateVariantUrl(variant.id);

      if (addButton) {
        addButton.disabled = !variant.available;
        addButton.textContent = variant.available ? addLabel : soldOutLabel;
      }
    }

    function initMainProduct(root) {
      if (!root || root.dataset.mainProductInitialized === 'true') {
        return;
      }

      var qtyInput = root.querySelector('[data-qty-input]');
      var qtyMinus = root.querySelector('[data-qty-minus]');
      var qtyPlus = root.querySelector('[data-qty-plus]');
      var variantSelect = root.querySelector('[data-variant-select]');
      var addButton = root.querySelector('[data-add-to-cart]');

      if (qtyInput && qtyMinus && qtyPlus) {
        qtyMinus.addEventListener('click', function () {
          var current = parseInt(qtyInput.value, 10) || 1;
          qtyInput.value = Math.max(1, current - 1);
        });
        qtyPlus.addEventListener('click', function () {
          var current = parseInt(qtyInput.value, 10) || 1;
          qtyInput.value = current + 1;
        });
      }

      if (variantSelect) {
        variantSelect.addEventListener('change', function () {
          applyVariant(root, variantSelect.value);
        });
        applyVariant(root, variantSelect.value);
      } else if (addButton) {
        var hiddenId = root.querySelector('[data-variant-id]');
        if (hiddenId && hiddenId.value) {
          applyVariant(root, hiddenId.value);
        }
      }

      root.dataset.mainProductInitialized = 'true';
    }

    function initAll(scope) {
      var context = scope || document;
      context.querySelectorAll('[data-main-product]').forEach(initMainProduct);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        initAll();
      });
    } else {
      initAll();
    }

    document.addEventListener('shopify:section:load', function (event) {
      initAll(event.target);
    });
  })();
{% endjavascript %}

