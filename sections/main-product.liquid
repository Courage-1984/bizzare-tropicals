{%- liquid
  comment
    Theme Editor / zero-product onboarding fallbacks (see placeholder-images.md).
  endcomment
  assign force_mock = false
  if request.design_mode
    if product == blank or product.id == blank
      assign force_mock = true
    endif
  endif

  assign mock_title = section.settings.mock_title | strip
  if mock_title == blank
    assign mock_title = 'products.main.mock_title' | t
  endif
  assign mock_price = 450000
  assign mock_latin_name = section.settings.mock_latin_name | strip
  if mock_latin_name == blank
    assign mock_latin_name = 'products.main.mock_latin' | t
  endif
  assign mock_inventory = 3
  assign mock_tags = 'Rare'
  assign mock_description = section.settings.mock_description
  if mock_description == blank
    assign mock_description = 'products.main.accordion_care_fallback' | t
  endif
  assign mock_difficulty = 4
  assign mock_temperature_group = 'highland'
  assign mock_trap_type = 'pitfall'
  assign mock_dormancy_required = false

  comment
    Mock gallery — Unsplash fallbacks when product.media is empty (Field Guide preview).
  endcomment
  assign mock_img_1 = section.settings.mock_image_1 | strip
  if mock_img_1 == blank
    assign mock_img_1 = 'https://images.unsplash.com/photo-1593691509543-c55fb37b3ce0?w=800&q=80&auto=format&fit=crop'
  endif
  assign mock_img_2 = section.settings.mock_image_2 | strip
  if mock_img_2 == blank
    assign mock_img_2 = 'https://images.unsplash.com/photo-1466781783364-869c525ede59?w=800&q=80&auto=format&fit=crop'
  endif
  assign mock_img_3 = section.settings.mock_image_3 | strip
  if mock_img_3 == blank
    assign mock_img_3 = 'https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=800&q=80&auto=format&fit=crop'
  endif
  assign mock_gallery_urls = mock_img_1 | append: '|' | append: mock_img_2 | append: '|' | append: mock_img_3 | split: '|'

  unless force_mock
    if product != blank
      if product.handle contains 'preview'
        assign force_mock = true
      endif
    endif
  endunless

  assign use_live_product = false
  if product
    if product.id != blank
      unless force_mock
        assign use_live_product = true
      endunless
    endif
  endif

  assign has_gallery = false
  assign show_mock_gallery = true
  assign verified_gallery_urls = '' | split: '|'
  assign gallery_supplement_count = 0
  assign gallery_media = '' | split: '|'

  if force_mock
    assign use_live_product = false
    assign show_mock_gallery = true
    assign display_title = mock_title
    assign latin_name = mock_latin_name
    assign difficulty = mock_difficulty
    assign temperature_group = mock_temperature_group
    assign trap_type = mock_trap_type
    assign dormancy_required = mock_dormancy_required
    assign price_cents = mock_price
    assign compare_at_cents = 0
    assign product_description = mock_description
    assign has_gallery = false
    assign status_inventory = mock_inventory
    assign status_mode = 'limited'
  elsif use_live_product
    assign display_title = product.title | default: mock_title
    assign latin_name = product.metafields.custom.latin_name.value | default: product.metafields.custom.latin_name | default: mock_latin_name
    assign difficulty_raw = product.metafields.custom.difficulty.value | default: product.metafields.custom.difficulty
    assign difficulty = difficulty_raw | default: mock_difficulty | plus: 0
    if difficulty == 0
      assign difficulty = mock_difficulty
    endif
    if difficulty < 1
      assign difficulty = 1
    endif
    if difficulty > 5
      assign difficulty = 5
    endif
    assign temperature_group = product.metafields.custom.temperature_group.value | default: product.metafields.custom.temperature_group | default: mock_temperature_group
    assign trap_type = product.metafields.custom.trap_type.value | default: product.metafields.custom.trap_type | default: mock_trap_type
    assign dormancy_required = product.metafields.custom.dormancy_required.value | default: product.metafields.custom.dormancy_required | default: mock_dormancy_required
    assign price_cents = product.selected_or_first_available_variant.price | default: mock_price
    assign compare_at_cents = product.selected_or_first_available_variant.compare_at_price | default: 0
    assign product_description = product.description | default: mock_description
    assign current_variant = product.selected_or_first_available_variant

    comment
      Use the fullest image set — CSV/import sometimes leaves product.media smaller than product.images.
    endcomment
    assign gallery_media = product.media
    if product.images.size > gallery_media.size
      assign gallery_media = product.images
    endif
    if gallery_media.size == 0 and product.images.size > 0
      assign gallery_media = product.images
    endif
    assign verified_gallery_urls = '' | split: '|'
    capture verified_gallery_raw
      render 'verified-gallery-urls', product_handle: product.handle
    endcapture
    assign verified_gallery_raw = verified_gallery_raw | strip
    if verified_gallery_raw != blank
      assign verified_gallery_urls = verified_gallery_raw | split: '###BT###'
    endif

    assign gallery_supplement_count = 0
    if verified_gallery_urls.size > gallery_media.size
      assign gallery_supplement_count = verified_gallery_urls.size | minus: gallery_media.size
    endif

    if gallery_media.size > 0
      assign has_gallery = true
      assign show_mock_gallery = false
    elsif verified_gallery_urls.size > 0
      assign has_gallery = true
      assign show_mock_gallery = false
    else
      assign show_mock_gallery = true
    endif
  else
    assign display_title = mock_title
    assign latin_name = mock_latin_name
    assign difficulty = mock_difficulty
    assign temperature_group = mock_temperature_group
    assign trap_type = mock_trap_type
    assign dormancy_required = mock_dormancy_required
    assign price_cents = mock_price
    assign compare_at_cents = 0
    assign product_description = mock_description
    assign has_gallery = false
    assign show_mock_gallery = true
  endif

  assign temp_group_key = temperature_group | handleize
  assign trap_type_key = trap_type | handleize

  case temp_group_key
    when 'highland'
      assign temp_group_label = 'products.main.temperature_groups.highland' | t
    when 'intermediate'
      assign temp_group_label = 'products.main.temperature_groups.intermediate' | t
    when 'lowland'
      assign temp_group_label = 'products.main.temperature_groups.lowland' | t
    when 'temperate'
      assign temp_group_label = 'products.main.temperature_groups.temperate' | t
    when 'tropical'
      assign temp_group_label = 'products.main.temperature_groups.tropical' | t
    when 'mediterranean'
      assign temp_group_label = 'products.main.temperature_groups.mediterranean' | t
    else
      assign temp_group_label = temperature_group | replace: '-', ' ' | capitalize
  endcase

  case trap_type_key
    when 'snap'
      assign trap_type_label = 'products.main.trap_types.snap' | t
    when 'pitfall'
      assign trap_type_label = 'products.main.trap_types.pitfall' | t
    when 'flypaper'
      assign trap_type_label = 'products.main.trap_types.flypaper' | t
    when 'suction'
      assign trap_type_label = 'products.main.trap_types.suction' | t
    when 'lobster-pot'
      assign trap_type_label = 'products.main.trap_types.lobster_pot' | t
    else
      assign trap_type_label = trap_type | replace: '-', ' ' | capitalize
  endcase

  assign form_id = 'main-product-form-' | append: section.id

  if dormancy_required == true or dormancy_required == 'true'
    assign dormancy_label = 'products.main.dormancy_yes' | t
  else
    assign dormancy_label = 'products.main.dormancy_no' | t
  endif

  assign status_mode = 'cultivating'
  assign status_inventory = 0
  assign tracks_inventory = false

  if use_live_product
    assign status_inventory = current_variant.inventory_quantity | default: 0 | plus: 0
    if current_variant.inventory_management == 'shopify'
      assign tracks_inventory = true
    endif

    if current_variant.available == false
      assign status_mode = 'sold_out'
    elsif tracks_inventory
      if status_inventory > 5
        assign status_mode = 'cultivating'
      elsif status_inventory > 0
        assign status_mode = 'limited'
      else
        assign status_mode = 'sold_out'
      endif
    else
      assign status_mode = 'cultivating'
    endif
  else
    assign status_inventory = mock_inventory
    assign status_mode = 'limited'
  endif

  assign has_care_guide = false
  if use_live_product
    assign care_guide_metafield = product.metafields.custom.care_guide
    if care_guide_metafield != blank
      assign care_guide_value = care_guide_metafield.value | default: care_guide_metafield
      if care_guide_value != blank
        assign has_care_guide = true
      endif
    endif
  endif

  comment
    Specimen technical schema — live storefront uses metafields only; theme editor may show demo placeholders.
  endcomment
  assign editor_demo_origin = 'Mount Kinabalu, Borneo'
  assign editor_demo_altitude = '1,500m - 2,500m'
  assign editor_demo_humidity = '75%'
  assign editor_demo_temp_range = '12°C - 26°C'
  assign editor_demo_substrate = 'Live Sphagnum/Perlite 50/50'
  assign editor_demo_clone_id = 'BE-3672'
  assign editor_demo_growth_rate = 'Slow/Moderate'
  assign editor_demo_light_intensity = '10,000 - 15,000 Lux'

  assign spec_origin_raw = ''
  assign spec_altitude_raw = ''
  assign spec_humidity_raw = ''
  assign spec_temp_range_raw = ''
  assign spec_substrate_raw = ''
  assign spec_clone_raw = ''
  assign spec_growth_raw = ''
  assign spec_light_raw = ''
  assign snapshot_light = ''
  assign snapshot_water = ''
  assign snapshot_temp = ''

  if use_live_product
    assign spec_origin_raw = product.metafields.custom.origin_location.value | default: product.metafields.custom.origin_location | default: '' | strip
    assign spec_altitude_raw = product.metafields.custom.origin_altitude.value | default: product.metafields.custom.origin_altitude | default: '' | strip
    assign spec_humidity_raw = product.metafields.custom.humidity_min.value | default: product.metafields.custom.humidity_min | default: '' | strip
    assign spec_temp_range_raw = product.metafields.custom.temp_range.value | default: product.metafields.custom.temp_range | default: '' | strip
    assign spec_substrate_raw = product.metafields.custom.potting_media.value | default: product.metafields.custom.potting_media | default: '' | strip
    assign spec_clone_raw = product.metafields.custom.clonotype_code.value | default: product.metafields.custom.clonotype_code | default: '' | strip
    assign spec_growth_raw = product.metafields.custom.growth_speed.value | default: product.metafields.custom.growth_speed | default: '' | strip
    assign spec_light_raw = product.metafields.custom.lux_requirements.value | default: product.metafields.custom.lux_requirements | default: '' | strip
    assign snapshot_light = spec_light_raw
    assign care_water_raw = product.metafields.custom.water_requirements.value | default: product.metafields.custom.water_requirements | default: '' | strip
    if care_water_raw == blank
      assign care_water_raw = product.metafields.custom.water.value | default: product.metafields.custom.water | default: '' | strip
    endif
    assign snapshot_water = care_water_raw
    if snapshot_water == blank
      assign snapshot_water = spec_substrate_raw
    endif
    assign snapshot_temp = spec_temp_range_raw
    assign genus_handle = product.metafields.custom.genus.value | default: product.metafields.custom.genus | default: '' | strip
  endif

  assign genus_handle = genus_handle | default: '' | strip
  assign care_water_raw = care_water_raw | default: '' | strip

  assign spec_origin_display = spec_origin_raw
  assign spec_altitude_display = spec_altitude_raw
  assign spec_humidity_display = spec_humidity_raw
  assign spec_temp_range_display = spec_temp_range_raw
  assign spec_substrate_display = spec_substrate_raw
  assign spec_clone_display = spec_clone_raw
  assign spec_growth_display = spec_growth_raw
  assign spec_light_display = spec_light_raw

  if request.design_mode
    if spec_origin_display == blank
      assign spec_origin_display = editor_demo_origin
    endif
    if spec_altitude_display == blank
      assign spec_altitude_display = editor_demo_altitude
    endif
    if spec_humidity_display == blank
      assign spec_humidity_display = editor_demo_humidity
    endif
    if spec_temp_range_display == blank
      assign spec_temp_range_display = editor_demo_temp_range
    endif
    if spec_substrate_display == blank
      assign spec_substrate_display = editor_demo_substrate
    endif
    if spec_clone_display == blank
      assign spec_clone_display = editor_demo_clone_id
    endif
    if spec_growth_display == blank
      assign spec_growth_display = editor_demo_growth_rate
    endif
    if spec_light_display == blank
      assign spec_light_display = editor_demo_light_intensity
    endif
  endif

  assign show_snapshot_latin = false
  assign show_snapshot_origin = false
  assign show_snapshot_difficulty = false
  assign show_snapshot_light = false
  assign show_snapshot_water = false
  assign show_snapshot_temp = false

  if latin_name != blank
    assign show_snapshot_latin = true
  endif
  if difficulty > 0
    assign show_snapshot_difficulty = true
  endif

  if use_live_product
    if spec_origin_raw != blank
      assign show_snapshot_origin = true
    endif
    if snapshot_light != blank
      assign show_snapshot_light = true
    endif
    if snapshot_water != blank
      assign show_snapshot_water = true
    endif
    if snapshot_temp != blank
      assign show_snapshot_temp = true
    endif
  elsif force_mock or request.design_mode
    assign show_snapshot_origin = true
    assign show_snapshot_light = true
    assign show_snapshot_water = true
    assign show_snapshot_temp = true
    if snapshot_light == blank
      assign snapshot_light = editor_demo_light_intensity
    endif
    if snapshot_water == blank
      assign snapshot_water = editor_demo_substrate
    endif
    if snapshot_temp == blank
      assign snapshot_temp = editor_demo_temp_range
    endif
    if spec_origin_raw == blank
      assign spec_origin_raw = editor_demo_origin
    endif
  endif

  assign show_technical_deep_dive = false
  if spec_origin_raw != blank
    assign show_technical_deep_dive = true
  endif
  if spec_altitude_raw != blank
    assign show_technical_deep_dive = true
  endif
  if spec_humidity_raw != blank
    assign show_technical_deep_dive = true
  endif
  if spec_temp_range_raw != blank
    assign show_technical_deep_dive = true
  endif
  if spec_substrate_raw != blank
    assign show_technical_deep_dive = true
  endif
  if spec_clone_raw != blank
    assign show_technical_deep_dive = true
  endif
  if spec_growth_raw != blank
    assign show_technical_deep_dive = true
  endif
  if spec_light_raw != blank
    assign show_technical_deep_dive = true
  endif
  if temperature_group != blank
    assign show_technical_deep_dive = true
  endif
  assign spec_temp_group_display = temp_group_label
  if request.design_mode
    assign show_technical_deep_dive = true
    if spec_temp_group_display == blank
      assign spec_temp_group_display = 'products.main.temperature_groups.highland' | t
    endif
  endif

  assign show_care_dossier = false
  if has_care_guide
    assign show_care_dossier = true
  endif
  if product_description contains '<ul' or product_description contains '<li'
    assign show_care_dossier = true
  endif
  if spec_light_raw != blank or care_water_raw != blank or spec_substrate_raw != blank or spec_humidity_raw != blank or spec_temp_range_raw != blank
    assign show_care_dossier = true
  endif
  if section.settings.care_fallback != blank
    assign show_care_dossier = true
  endif
  if request.design_mode
    assign show_care_dossier = true
  endif

  assign care_fallback_rendered = section.settings.care_fallback | strip
  if care_fallback_rendered == blank
    assign care_fallback_rendered = 'products.main.accordion_care_fallback' | t
  endif
-%}

<article
  class="main-product reveal-up{% if force_mock or use_live_product == false %} main-product--preview{% endif %}"
  data-force-mock="{% if force_mock %}true{% else %}false{% endif %}"
  data-main-product
  data-status-limited-display="{{ 'products.main.status_limited_emphasis' | t | escape }}"
  data-status-cultivating-display="{{ 'products.main.status_cultivating_emphasis' | t | escape }}"
  data-label-add="{{ 'products.main.add_to_conservatory' | t | escape }}"
  data-label-sold-out="{{ 'products.main.sold_out' | t | escape }}"
  {{ section.shopify_attributes }}
>
  <div class="main-product__layout">
    {% render 'product-gallery-cinema',
      use_live_product: use_live_product,
      has_gallery: has_gallery,
      show_mock_gallery: show_mock_gallery,
      gallery_media: gallery_media,
      verified_gallery_urls: verified_gallery_urls,
      gallery_supplement_count: gallery_supplement_count,
      mock_gallery_urls: mock_gallery_urls,
      display_title: display_title,
      latin_name: latin_name,
      product: product,
      mock_img_1: mock_img_1,
      section_id: section.id
    %}

    <div class="main-product__dossier" data-product-dossier>
      <header class="main-product__header">
        {%- unless show_snapshot_latin -%}
          {%- if latin_name != blank -%}
            <p class="main-product__latin">
              <em>{{ latin_name | escape }}</em>
            </p>
          {%- endif -%}
        {%- endunless -%}
        <h1 class="main-product__title">{{ display_title | escape }}</h1>
      </header>

      <p class="main-product__price" data-product-price>
        {%- if compare_at_cents > price_cents -%}
          <span class="visually-hidden">{{ 'products.card.price_sale' | t }}</span>
          <span class="main-product__price-sale" data-product-price-sale>{% render 'zar-price', amount_cents: price_cents %}</span>
          <span class="visually-hidden">{{ 'products.card.price_regular' | t }}</span>
          <s class="main-product__price-compare" data-product-price-compare>{% render 'zar-price', amount_cents: compare_at_cents %}</s>
        {%- else -%}
          <span class="main-product__price-regular" data-product-price-regular>{% render 'zar-price', amount_cents: price_cents %}</span>
        {%- endif -%}
      </p>

      <p
        class="main-product__inventory-status main-product__inventory-status--{{ status_mode }}"
        data-product-status
        data-status-mode="{{ status_mode }}"
        {% if status_mode == 'sold_out' %}
          hidden
        {% endif %}
      >
        <span class="main-product__inventory-status-bracket" aria-hidden="true">[</span>
        {{ 'products.main.inventory_status_label' | t }}
        <span class="main-product__inventory-status-value" data-product-status-text>
          {%- if status_mode == 'limited' -%}
            {{ 'products.main.status_limited_emphasis' | t }}
          {%- else -%}
            {{ 'products.main.status_cultivating_emphasis' | t }}
          {%- endif -%}
        </span>
        <span class="main-product__inventory-status-bracket" aria-hidden="true">]</span>
      </p>

      {% render 'specimen-snapshot',
        latin_name: latin_name,
        origin_value: spec_origin_raw,
        difficulty: difficulty,
        light_value: snapshot_light,
        water_value: snapshot_water,
        temp_value: snapshot_temp,
        show_latin: show_snapshot_latin,
        show_origin: show_snapshot_origin,
        show_difficulty: show_snapshot_difficulty,
        show_light: show_snapshot_light,
        show_water: show_snapshot_water,
        show_temp: show_snapshot_temp
      %}

      {%- if show_care_dossier -%}
        {% render 'product-care-dossier',
          product: product,
          use_live_product: use_live_product,
          has_care_guide: has_care_guide,
          product_description: product_description,
          care_fallback: care_fallback_rendered,
          light_value: spec_light_raw,
          water_value: care_water_raw,
          substrate_value: spec_substrate_raw,
          humidity_value: spec_humidity_raw,
          temp_value: spec_temp_range_raw,
          dormancy_required: dormancy_required,
          genus_handle: genus_handle,
          section_id: section.id
        %}
      {%- endif -%}

      {%- if use_live_product -%}
        {%- form 'product', product, class: 'main-product__form', id: form_id -%}
          {%- if product.variants.size > 1 -%}
            <div class="main-product__variants">
              <label class="main-product__label" for="main-product-variant-{{ section.id }}">
                {{ 'products.main.variant_label' | t }}
              </label>
              <select
                id="main-product-variant-{{ section.id }}"
                class="main-product__variant-select"
                name="id"
                data-variant-select
              >
                {%- for variant in product.variants -%}
                  <option
                    value="{{ variant.id }}"
                    {% if variant == current_variant %}
                      selected
                    {% endif %}
                    {% unless variant.available %}
                      disabled
                    {% endunless %}
                  >
                    {{ variant.title }}
                    {%- unless variant.available %} — {{ 'products.main.sold_out' | t }}{% endunless -%}
                  </option>
                {%- endfor -%}
              </select>
            </div>
          {%- else -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>
          {%- endif -%}

          {%- if section.settings.show_cites_notice -%}
            {% render 'product-cites-notice', product: product %}
          {%- endif -%}

          <div class="main-product__purchase">
            <div class="main-product__quantity" data-quantity>
              <span class="main-product__label" id="main-product-qty-label-{{ section.id }}">
                {{ 'products.main.quantity' | t }}
              </span>
              <div class="main-product__quantity-control" role="group" aria-labelledby="main-product-qty-label-{{ section.id }}">
                <button
                  type="button"
                  class="main-product__qty-btn"
                  data-qty-minus
                  aria-label="{{ 'products.main.quantity_decrease' | t }}"
                >
                  <span aria-hidden="true">−</span>
                </button>
                <input
                  class="main-product__qty-input"
                  type="number"
                  name="quantity"
                  value="1"
                  min="1"
                  inputmode="numeric"
                  data-qty-input
                  aria-label="{{ 'products.main.quantity' | t }}"
                >
                <button
                  type="button"
                  class="main-product__qty-btn"
                  data-qty-plus
                  aria-label="{{ 'products.main.quantity_increase' | t }}"
                >
                  <span aria-hidden="true">+</span>
                </button>
              </div>
            </div>

            <button
              type="submit"
              class="main-product__submit"
              name="add"
              {% unless current_variant.available %}
                disabled
              {% endunless %}
              data-add-to-cart
            >
              {%- if current_variant.available -%}
                {{ 'products.main.add_to_conservatory' | t }}
              {%- else -%}
                {{ 'products.main.sold_out' | t }}
              {%- endif -%}
            </button>
          </div>
        {%- endform -%}
      {%- else -%}
        <p class="main-product__preview-note">{{ 'products.main.preview_note' | t }}</p>
        <div class="main-product__purchase main-product__purchase--preview">
          <div class="main-product__quantity" data-quantity>
            <span class="main-product__label" id="main-product-qty-label-preview-{{ section.id }}">
              {{ 'products.main.quantity' | t }}
            </span>
            <div
              class="main-product__quantity-control"
              role="group"
              aria-labelledby="main-product-qty-label-preview-{{ section.id }}"
            >
              <button type="button" class="main-product__qty-btn" disabled aria-hidden="true">
                <span aria-hidden="true">−</span>
              </button>
              <input
                class="main-product__qty-input"
                type="number"
                value="1"
                min="1"
                readonly
                tabindex="-1"
                aria-hidden="true"
              >
              <button type="button" class="main-product__qty-btn" disabled aria-hidden="true">
                <span aria-hidden="true">+</span>
              </button>
            </div>
          </div>
          <button type="button" class="main-product__submit" disabled>
            {{ 'products.main.add_to_conservatory' | t }}
          </button>
        </div>
      {%- endif -%}

      <div class="main-product__accordions" aria-label="{{ 'products.main.accordions_label' | t }}">
        <details data-pdp-accordion>
          <summary class="pdp-accordion-title" aria-expanded="false">
            {{ 'products.main.accordion_lineage_title' | t }}
            <span class="icon-plus" aria-hidden="true">+</span>
          </summary>
          <div class="pdp-accordion-content">
            {%- liquid
              assign accordion_lineage_body = section.settings.accordion_lineage_body | strip
              if accordion_lineage_body == blank
                assign accordion_lineage_body = 'products.main.accordion_lineage_body' | t
              endif
            -%}
            <p>{{ accordion_lineage_body | escape }}</p>
          </div>
        </details>
        <details data-pdp-accordion>
          <summary class="pdp-accordion-title" aria-expanded="false">
            {{ 'products.main.accordion_arrival_title' | t }}
            <span class="icon-plus" aria-hidden="true">+</span>
          </summary>
          <div class="pdp-accordion-content">
            {%- liquid
              assign accordion_arrival_body = section.settings.accordion_arrival_body | strip
              if accordion_arrival_body == blank
                assign accordion_arrival_body = 'products.main.accordion_arrival_body' | t
              endif
            -%}
            <p>{{ accordion_arrival_body | escape }}</p>
          </div>
        </details>
      </div>

      {%- if section.settings.show_pair_with_supplies and use_live_product -%}
        {% render 'product-pair-with-supplies', product: product, limit: section.settings.pair_with_limit %}
      {%- endif -%}

      {%- liquid
        assign origin_narrative = section.settings.origin_text | strip
        if origin_narrative == blank
          assign origin_narrative = 'products.main.origin_text' | t
        endif
        assign origin_display = spec_origin_display
        if spec_origin_raw == blank and origin_narrative != blank
          assign origin_display = origin_narrative
        elsif spec_origin_raw != blank and origin_narrative != blank
          assign origin_display = spec_origin_display | append: '. ' | append: origin_narrative
        endif
      -%}
      {%- if origin_display != blank -%}
        <div class="main-product__origin" aria-labelledby="main-product-origin-{{ section.id }}">
          <span class="main-product__origin-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M2 12h20"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
          </span>
          <p id="main-product-origin-{{ section.id }}" class="main-product__origin-text">
            <span class="visually-hidden">{{ 'products.main.origin_heading' | t }}:</span>
            {{ origin_display | escape }}
          </p>
        </div>
      {%- endif -%}

      {%- if use_live_product -%}
        <script type="application/json" data-main-product-variants>
          [
            {%- for variant in product.variants -%}
              {
                "id": {{ variant.id | json }},
                "available": {{ variant.available | json }},
                "price": {{ variant.price }},
                "compare_at_price": {{ variant.compare_at_price | default: 0 }},
                "inventory_quantity": {{ variant.inventory_quantity | default: 0 }},
                "inventory_management": {{ variant.inventory_management | json }}
              }{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
          ]
        </script>
      {%- endif -%}

    </div>
  </div>

  {%- if show_technical_deep_dive -%}
    <section
      class="main-product__deep-dive"
      aria-labelledby="main-product-technical-{{ section.id }}"
    >
      <header class="main-product__deep-dive-header">
        <p class="main-product__deep-dive-eyebrow">{{ 'products.main.technical_data_heading' | t }}</p>
        <h2 id="main-product-technical-{{ section.id }}" class="main-product__deep-dive-title">
          {{ display_title | escape }}
        </h2>
        <p class="main-product__deep-dive-subtitle">{{ 'products.main.technical_data_subheading' | t }}</p>
      </header>

      <dl class="main-product__tech-grid">
        {%- if spec_origin_raw != blank or request.design_mode -%}
          <div class="main-product__tech-cell">
            <dt class="main-product__tech-label">{{ 'products.main.spec_origin' | t }}</dt>
            <dd class="main-product__tech-value">{{ spec_origin_display | escape }}</dd>
          </div>
        {%- endif -%}
        {%- if spec_altitude_raw != blank or request.design_mode -%}
          <div class="main-product__tech-cell">
            <dt class="main-product__tech-label">{{ 'products.main.spec_altitude' | t }}</dt>
            <dd class="main-product__tech-value">{{ spec_altitude_display | escape }}</dd>
          </div>
        {%- endif -%}
        {%- if spec_humidity_raw != blank or request.design_mode -%}
          <div class="main-product__tech-cell">
            <dt class="main-product__tech-label">{{ 'products.main.spec_humidity' | t }}</dt>
            <dd class="main-product__tech-value">{{ spec_humidity_display | escape }}</dd>
          </div>
        {%- endif -%}
        {%- if spec_temp_range_raw != blank or request.design_mode -%}
          <div class="main-product__tech-cell">
            <dt class="main-product__tech-label">{{ 'products.main.spec_temperature_range' | t }}</dt>
            <dd class="main-product__tech-value">{{ spec_temp_range_display | escape }}</dd>
          </div>
        {%- endif -%}
        {%- if spec_substrate_raw != blank or request.design_mode -%}
          <div class="main-product__tech-cell">
            <dt class="main-product__tech-label">{{ 'products.main.spec_substrate' | t }}</dt>
            <dd class="main-product__tech-value">{{ spec_substrate_display | escape }}</dd>
          </div>
        {%- endif -%}
        {%- if spec_clone_raw != blank or request.design_mode -%}
          <div class="main-product__tech-cell">
            <dt class="main-product__tech-label">{{ 'products.main.spec_clone_id' | t }}</dt>
            <dd class="main-product__tech-value">{{ spec_clone_display | escape }}</dd>
          </div>
        {%- endif -%}
        {%- if spec_growth_raw != blank or request.design_mode -%}
          <div class="main-product__tech-cell">
            <dt class="main-product__tech-label">{{ 'products.main.spec_growth_rate' | t }}</dt>
            <dd class="main-product__tech-value">{{ spec_growth_display | escape }}</dd>
          </div>
        {%- endif -%}
        {%- if spec_light_raw != blank or request.design_mode -%}
          <div class="main-product__tech-cell">
            <dt class="main-product__tech-label">{{ 'products.main.spec_light_intensity' | t }}</dt>
            <dd class="main-product__tech-value">{{ spec_light_display | escape }}</dd>
          </div>
        {%- endif -%}
        {%- if temperature_group != blank or request.design_mode -%}
          <div class="main-product__tech-cell">
            <dt class="main-product__tech-label">{{ 'products.main.spec_temperature' | t }}</dt>
            <dd class="main-product__tech-value">{{ spec_temp_group_display | escape }}</dd>
          </div>
        {%- endif -%}
      </dl>
    </section>
  {%- endif -%}

  {%- if use_live_product -%}
    {% render 'product-structured-data',
      product: product,
      difficulty: difficulty,
      origin_value: spec_origin_display,
      clonotype_value: spec_clone_display
    %}
  {%- endif -%}
</article>

{% stylesheet %}
  .main-product {
    padding-block: var(--space-2xl) var(--space-3xl);
  }

  .main-product__layout {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-2xl);
    width: min(var(--page-width), calc(100% - var(--page-margin) * 2));
    margin-inline: auto;
  }

  .main-product {
    overflow: visible;
  }

  /* Cinematic PDP gallery — viewport-fit stage + vertical thumb rail */
  .main-product__gallery.product__media {
    width: 100%;
    min-width: 0;
  }

  .main-product__gallery-cinema {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75rem;
    align-items: stretch;
    width: 100%;
  }

  .main-product__gallery-cinema:not(:has(.main-product__gallery-rail)) {
    grid-template-columns: 1fr;
  }

  .main-product__gallery-rail {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 5.25rem;
    flex-shrink: 0;
    max-height: min(82vh, calc(100svh - var(--header-height, 4rem) - 6rem));
    overflow-y: auto;
    overflow-x: hidden;
    padding: 2px;
    scrollbar-width: thin;
    scrollbar-color: rgb(10 24 18 / 0.28) transparent;
  }

  .main-product__gallery-thumb {
    position: relative;
    flex-shrink: 0;
    width: 100%;
    aspect-ratio: 4 / 5;
    margin: 0;
    padding: 0;
    overflow: hidden;
    cursor: pointer;
    background: var(--color-parchment);
    border: 1px solid rgb(10 24 18 / 0.22);
    border-radius: 3px;
    box-shadow: 0 1px 4px rgb(10 24 18 / 0.06);
    transition:
      border-color 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.45s ease;
    opacity: 0.72;
  }

  .main-product__gallery-thumb:hover,
  .main-product__gallery-thumb:focus-visible {
    opacity: 1;
    border-color: var(--color-forest-green-dark);
    transform: translateY(-1px);
  }

  .main-product__gallery-thumb.is-active {
    opacity: 1;
    border-color: var(--color-forest-green-dark);
    box-shadow: 0 4px 14px rgb(10 24 18 / 0.14);
  }

  .main-product__gallery-thumb-frame {
    position: absolute;
    inset: 0;
    pointer-events: none;
    border: 2px solid transparent;
    border-radius: 2px;
    transition: border-color 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .main-product__gallery-thumb.is-active .main-product__gallery-thumb-frame {
    border-color: rgb(247 244 237 / 0.35);
  }

  .main-product__gallery-thumb-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .main-product__gallery-stage {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    --gallery-stage-pad: clamp(1rem, 2vw, 1.5rem);
    min-height: min(62vh, 26rem);
    max-height: min(84vh, calc(100svh - var(--header-height, 4rem) - 3.5rem));
    padding: var(--gallery-stage-pad);
    overflow: hidden;
    background: linear-gradient(165deg, rgb(247 244 237 / 0.98) 0%, rgb(235 228 214 / 0.92) 100%);
    border: 1px solid var(--color-forest-green-dark);
    border-radius: 4px;
    box-shadow: var(--shadow-md);
  }

  .main-product__gallery-stage .wax-seal-badge {
    position: absolute;
    top: -0.25rem;
    inset-inline-end: -0.25rem;
    z-index: 4;
    pointer-events: none;
  }

  .main-product__gallery-slides {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: min(58vh, 24rem);
    max-height: inherit;
  }

  .main-product__gallery-slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: clamp(0.75rem, 1.5vw, 1.25rem);
    box-sizing: border-box;
    opacity: 0;
    visibility: hidden;
    transform: scale(1.035);
    transition:
      opacity 1.15s cubic-bezier(0.22, 1, 0.36, 1),
      transform 1.35s cubic-bezier(0.22, 1, 0.36, 1),
      visibility 0s linear 1.15s;
    pointer-events: none;
  }

  .main-product__gallery-slide.is-active {
    opacity: 1;
    visibility: visible;
    transform: scale(1);
    transition:
      opacity 1.15s cubic-bezier(0.22, 1, 0.36, 1),
      transform 1.35s cubic-bezier(0.22, 1, 0.36, 1),
      visibility 0s;
    pointer-events: auto;
    z-index: 1;
  }

  .main-product__gallery-slide.is-active .main-product__gallery-stage-image {
    animation: main-product-gallery-ken-burns 7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .main-product__gallery.is-gallery-paused .main-product__gallery-slide.is-active .main-product__gallery-stage-image {
    animation-play-state: paused;
  }

  .main-product__gallery-stage.is-zoom-active .main-product__gallery-slide.is-active .main-product__gallery-stage-image,
  .main-product__gallery-stage.is-magnified .main-product__gallery-slide.is-active .main-product__gallery-stage-image {
    animation: none;
  }

  @keyframes main-product-gallery-ken-burns {
    from {
      transform: scale(1);
    }

    to {
      transform: scale(1.045);
    }
  }

  .main-product__gallery-stage-image,
  .main-product__gallery-stage-media {
    display: block;
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    margin: auto;
    object-fit: contain;
    object-position: center;
  }

  .main-product__gallery-nav {
    position: absolute;
    inset: 0;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-inline: clamp(0.35rem, 1.2vw, 0.85rem);
    pointer-events: none;
  }

  .main-product__gallery-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.625rem;
    height: 2.625rem;
    padding: 0;
    pointer-events: auto;
    cursor: pointer;
    color: var(--color-forest-green-dark);
    background: rgb(247 244 237 / 0.9);
    border: 1px solid rgb(10 24 18 / 0.18);
    border-radius: 50%;
    box-shadow: 0 2px 12px rgb(10 24 18 / 0.1);
    backdrop-filter: blur(10px);
    opacity: 0.82;
    transform: translate3d(0, 0, 0);
    transition:
      opacity 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      background-color 0.35s ease,
      border-color 0.35s ease,
      box-shadow 0.35s ease;
  }

  .main-product__gallery-arrow--prev {
    margin-inline-start: 0.15rem;
  }

  .main-product__gallery-arrow--next {
    margin-inline-end: 0.15rem;
  }

  .main-product__gallery-arrow-icon {
    display: block;
    flex-shrink: 0;
  }

  .main-product__gallery-stage:hover .main-product__gallery-arrow,
  .main-product__gallery-arrow:focus-visible {
    opacity: 1;
    border-color: rgb(10 24 18 / 0.32);
    box-shadow: 0 4px 18px rgb(10 24 18 / 0.14);
  }

  .main-product__gallery-arrow--prev:hover,
  .main-product__gallery-arrow--prev:focus-visible {
    transform: translate3d(-2px, 0, 0);
  }

  .main-product__gallery-arrow--next:hover,
  .main-product__gallery-arrow--next:focus-visible {
    transform: translate3d(2px, 0, 0);
  }

  .main-product__gallery-stage-media--video,
  .main-product__gallery-stage-media--model {
    width: 100%;
    max-height: inherit;
  }

  .main-product__gallery-stage-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(ellipse 85% 70% at 50% 45%, transparent 55%, rgb(10 24 18 / 0.12) 100%);
    opacity: 0.85;
    z-index: 2;
  }

  .main-product__gallery-progress {
    position: absolute;
    inset-inline: var(--gallery-stage-pad, var(--space-md));
    bottom: var(--gallery-stage-pad, var(--space-sm));
    z-index: 3;
    height: 2px;
    overflow: hidden;
    background: rgb(10 24 18 / 0.12);
    border-radius: 1px;
  }

  .main-product__gallery-progress-bar {
    display: block;
    width: 0%;
    height: 100%;
    background: var(--color-forest-green-dark);
    border-radius: inherit;
  }

  .main-product__gallery-zoom {
    position: absolute;
    inset-block-end: var(--gallery-stage-pad, var(--space-md));
    inset-inline-end: var(--gallery-stage-pad, var(--space-md));
    z-index: 6;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    cursor: zoom-in;
    color: var(--color-forest-green-dark);
    background: rgb(247 244 237 / 0.92);
    border: 1px solid rgb(10 24 18 / 0.2);
    border-radius: 50%;
    box-shadow: 0 2px 10px rgb(10 24 18 / 0.1);
    backdrop-filter: blur(8px);
    opacity: 0;
    transition:
      opacity 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      background-color 0.35s ease,
      border-color 0.35s ease;
  }

  .main-product__gallery-stage:hover .main-product__gallery-zoom,
  .main-product__gallery-zoom:focus-visible,
  .main-product__gallery-stage.is-magnified .main-product__gallery-zoom {
    opacity: 1;
  }

  .main-product__gallery-stage.is-magnified .main-product__gallery-zoom {
    cursor: zoom-out;
  }

  .main-product__gallery-slide.is-active .main-product__gallery-stage-image {
    transform: scale(var(--zoom-scale, 1));
    transform-origin: var(--zoom-x, 50%) var(--zoom-y, 50%);
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  .main-product__gallery-stage.is-magnified {
    cursor: zoom-out;
  }

  .main-product__gallery-stage.is-zoom-active:not(.is-magnified) {
    cursor: zoom-in;
  }

  .specimen-snapshot {
    margin-block-end: var(--space-lg);
    padding-block-end: var(--space-md);
    border-block-end: 1px solid rgb(10 24 18 / 0.12);
  }

  .specimen-snapshot__list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-sm) var(--space-md);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .specimen-snapshot__item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    min-width: 0;
  }

  .specimen-snapshot__icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    color: var(--color-primary);
    opacity: 0.85;
  }

  .specimen-snapshot__body {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .specimen-snapshot__label {
    font-family: 'Courier New', Courier, 'Liberation Mono', monospace;
    font-size: 0.5625rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .specimen-snapshot__value {
    font-size: 0.8125rem;
    line-height: 1.35;
    color: var(--color-forest-green-dark);
  }

  .specimen-snapshot__value em {
    font-family: var(--font-family-serif);
    font-style: italic;
    font-size: 0.875rem;
  }

  .specimen-snapshot__value--difficulty .difficulty-pip {
    width: 0.45rem;
    height: 0.45rem;
  }

  .main-product__dossier {
    min-width: 0;
    padding: var(--space-xl);
    background-color: var(--color-parchment);
    border: 1px solid var(--color-forest-green-dark);
    border-radius: var(--radius-lg);
    box-shadow: 2px 2px 10px rgb(0 0 0 / 0.05);
  }

  .main-product__header {
    margin-block-end: var(--space-md);
  }

  .main-product__latin {
    margin: 0 0 var(--space-sm);
    font-family: var(--font-family-serif);
    font-size: clamp(1.25rem, 1.75vw + 0.5rem, 1.625rem);
    font-style: italic;
    font-weight: 400;
    line-height: var(--line-height-tight);
    letter-spacing: 0.02em;
    color: var(--color-forest-green-dark);
    opacity: 0.92;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .main-product__latin em {
    font-style: italic;
  }

  .main-product__title {
    margin: 0;
    font-family: var(--font-family-serif);
    font-size: clamp(2rem, 3.5vw + 0.5rem, 3.25rem);
    font-weight: 400;
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tight);
    color: var(--color-forest-green-dark);
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .main-product__price {
    margin: var(--space-lg) 0 var(--space-md);
    font-size: clamp(1.25rem, 2vw + 0.25rem, 1.75rem);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .main-product__price-sale {
    color: var(--color-accent);
    margin-inline-end: var(--space-sm);
  }

  .main-product__price-compare {
    font-size: var(--font-size-md);
    font-weight: 400;
    color: var(--color-text-muted);
  }

  /* Scarcity / inventory ledger line */
  .main-product__inventory-status {
    margin: 0 0 var(--space-lg);
    font-family: 'Courier New', Courier, 'Liberation Mono', monospace;
    font-size: 0.6875rem;
    font-weight: 600;
    line-height: 1.45;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-forest-green-dark);
  }

  .main-product__inventory-status-bracket {
    opacity: 0.65;
  }

  .main-product__inventory-status-value {
    color: #3d6b4a;
  }

  .main-product__inventory-status--limited .main-product__inventory-status-value {
    color: #cd6d3d;
  }

  .main-product__label {
    display: block;
    margin-block-end: var(--space-xs);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .main-product__variants {
    margin-block-end: var(--space-lg);
  }

  .main-product__variant-select {
    width: 100%;
    min-height: 2.75rem;
    padding: var(--space-sm) var(--space-md);
    background-color: var(--color-surface-elevated);
    border: 1px solid var(--color-border);
    text-overflow: ellipsis;
  }

  .main-product__cites-notice {
    margin-block: var(--space-md);
    padding: var(--space-md);
    border: 1px solid rgb(180 120 40 / 0.45);
    border-radius: var(--radius-sm);
    background: rgb(180 120 40 / 0.08);
  }

  .main-product__cites-notice-title {
    margin: 0 0 var(--space-xs);
    font-size: var(--font-size-sm);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .main-product__cites-notice-text {
    margin: 0;
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: rgb(var(--color-foreground-rgb) / 0.85);
  }

  .main-product__pair-with {
    margin-block: var(--space-xl) var(--space-md);
    padding-block-start: var(--space-lg);
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
