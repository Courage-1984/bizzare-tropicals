{% javascript %}
  (function () {
    'use strict';

    function formatZar(cents) {
      var value = parseInt(cents, 10) || 0;
      var rands = Math.floor(value / 100);
      var fractional = value % 100;
      var fractionalDisplay = fractional < 10 ? '0' + fractional : String(fractional);
      var randsDisplay = String(rands);

      if (rands >= 1000) {
        var thousands = Math.floor(rands / 1000);
        var remainder = rands % 1000;
        var remainderPadded = String(remainder);
        while (remainderPadded.length < 3) {
          remainderPadded = '0' + remainderPadded;
        }
        randsDisplay = thousands + ' ' + remainderPadded;
      }

      return 'R ' + randsDisplay + ',' + fractionalDisplay;
    }

    function readVariants(root) {
      var script = root.querySelector('[data-main-product-variants]');
      if (!script) {
        return [];
      }
      try {
        return JSON.parse(script.textContent);
      } catch (error) {
        console.error('Main product: invalid variant JSON.', error);
        return [];
      }
    }

    function findVariant(variants, id) {
      var targetId = parseInt(id, 10);
      for (var i = 0; i < variants.length; i += 1) {
        if (variants[i].id === targetId) {
          return variants[i];
        }
      }
      return null;
    }

    function getStatusMode(variant) {
      if (!variant || !variant.available) {
        return 'sold_out';
      }
      if (variant.inventory_management === 'shopify') {
        var qty = parseInt(variant.inventory_quantity, 10) || 0;
        if (qty > 5) {
          return 'cultivating';
        }
        if (qty > 0) {
          return 'limited';
        }
        return 'sold_out';
      }
      return 'cultivating';
    }

    function updateStatus(root, variant) {
      var statusEl = root.querySelector('[data-product-status]');
      var statusText = root.querySelector('[data-product-status-text]');
      if (!statusEl || !statusText) {
        return;
      }

      var mode = getStatusMode(variant);
      var limitedTemplate = root.dataset.statusLimitedDisplay || '';
      var cultivatingText = root.dataset.statusCultivatingDisplay || '';

      statusEl.classList.remove(
        'main-product__inventory-status--limited',
        'main-product__inventory-status--cultivating',
        'main-product__inventory-status--sold_out'
      );
      statusEl.classList.add('main-product__inventory-status--' + mode);
      statusEl.dataset.statusMode = mode;

      if (mode === 'sold_out') {
        statusEl.hidden = true;
        return;
      }

      statusEl.hidden = false;

      if (mode === 'limited') {
        statusText.textContent = root.dataset.statusLimitedDisplay || limitedTemplate;
      } else {
        statusText.textContent = root.dataset.statusCultivatingDisplay || cultivatingText;
      }
    }

    function updatePrice(root, variant) {
      var priceRoot = root.querySelector('[data-product-price]');
      if (!priceRoot || !variant) {
        return;
      }

      var price = parseInt(variant.price, 10) || 0;
      var compareAt = parseInt(variant.compare_at_price, 10) || 0;
      var saleEl = priceRoot.querySelector('[data-product-price-sale]');
      var compareEl = priceRoot.querySelector('[data-product-price-compare]');
      var regularEl = priceRoot.querySelector('[data-product-price-regular]');

      if (compareAt > price) {
        if (!saleEl) {
          priceRoot.innerHTML =
            '<span class="visually-hidden">Sale</span>' +
            '<span class="main-product__price-sale" data-product-price-sale></span>' +
            '<span class="visually-hidden">Regular</span>' +
            '<s class="main-product__price-compare" data-product-price-compare></s>';
          saleEl = priceRoot.querySelector('[data-product-price-sale]');
          compareEl = priceRoot.querySelector('[data-product-price-compare]');
        }
        if (regularEl) {
          regularEl.remove();
        }
        saleEl.textContent = formatZar(price);
        compareEl.textContent = formatZar(compareAt);
      } else {
        if (!regularEl) {
          priceRoot.innerHTML =
            '<span class="main-product__price-regular" data-product-price-regular></span>';
          regularEl = priceRoot.querySelector('[data-product-price-regular]');
        }
        if (saleEl) {
          saleEl.remove();
        }
        if (compareEl) {
          compareEl.remove();
        }
        regularEl.textContent = formatZar(price);
      }
    }

    function updateVariantUrl(variantId) {
      try {
        var url = new URL(window.location.href);
        url.searchParams.set('variant', String(variantId));
        window.history.replaceState({}, '', url.toString());
      } catch (error) {
        /* Non-blocking */
      }
    }

    function applyVariant(root, variantId) {
      var variants = readVariants(root);
      var variant = findVariant(variants, variantId);
      if (!variant) {
        return;
      }

      var addButton = root.querySelector('[data-add-to-cart]');
      var addLabel = root.dataset.labelAdd || 'ADD TO CONSERVATORY';
      var soldOutLabel = root.dataset.labelSoldOut || 'Sold out';

      updatePrice(root, variant);
      updateStatus(root, variant);
      updateVariantUrl(variant.id);

      if (addButton) {
        addButton.disabled = !variant.available;
        addButton.textContent = variant.available ? addLabel : soldOutLabel;
      }
    }


    var GALLERY_INTERVAL_MS = 6000;

    function prefersReducedMotion() {
      return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    }

    function initGalleryZoom(gallery) {
      var stage = gallery.querySelector('[data-gallery-stage]');
      var zoomBtn = gallery.querySelector('[data-gallery-zoom-toggle]');
      if (!stage) {
        return;
      }

      var hoverZoom = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
      var zoomInLabel = gallery.dataset.labelZoomIn || 'Zoom image';
      var zoomOutLabel = gallery.dataset.labelZoomOut || 'Exit zoom';
      var hoverScale = 1.58;
      var magnifiedScale = 3.15;
      var targetScale = 1;
      var currentScale = 1;
      var targetX = 50;
      var targetY = 50;
      var currentX = 50;
      var currentY = 50;
      var isMagnified = false;
      var isHovering = false;
      var motionFrame = null;

      function lerp(start, end, amount) {
        return start + (end - start) * amount;
      }

      function applyZoomVars() {
        stage.style.setProperty('--zoom-scale', String(currentScale));
        stage.style.setProperty('--zoom-x', currentX + '%');
        stage.style.setProperty('--zoom-y', currentY + '%');
      }

      function resolveTargetScale() {
        if (isMagnified) {
          return magnifiedScale;
        }
        if (isHovering && hoverZoom) {
          return hoverScale;
        }
        return 1;
      }

      function tickZoomMotion() {
        targetScale = resolveTargetScale();
        currentScale = lerp(currentScale, targetScale, 0.1);
        currentX = lerp(currentX, targetX, 0.14);
        currentY = lerp(currentY, targetY, 0.14);
        applyZoomVars();

        var scaleSettled = Math.abs(currentScale - targetScale) < 0.002;
        var xSettled = Math.abs(currentX - targetX) < 0.05;
        var ySettled = Math.abs(currentY - targetY) < 0.05;

        if (scaleSettled && xSettled && ySettled) {
          currentScale = targetScale;
          currentX = targetX;
          currentY = targetY;
          applyZoomVars();
          motionFrame = null;
          return;
        }

        motionFrame = window.requestAnimationFrame(tickZoomMotion);
      }

      function startZoomMotion() {
        if (motionFrame) {
          return;
        }
        motionFrame = window.requestAnimationFrame(tickZoomMotion);
      }

      function setPointerTarget(event) {
        var rect = stage.getBoundingClientRect();
        if (!rect.width || !rect.height) {
          return;
        }

        targetX = Math.max(8, Math.min(92, ((event.clientX - rect.left) / rect.width) * 100));
        targetY = Math.max(8, Math.min(92, ((event.clientY - rect.top) / rect.height) * 100));
        startZoomMotion();
      }

      function toggleMagnify() {
        isMagnified = !isMagnified;
        stage.classList.toggle('is-magnified', isMagnified);
        if (zoomBtn) {
          zoomBtn.setAttribute('aria-pressed', isMagnified ? 'true' : 'false');
          zoomBtn.setAttribute('aria-label', isMagnified ? zoomOutLabel : zoomInLabel);
        }
        startZoomMotion();
      }

      function activeSlideHasZoomableImage() {
        var activeSlide = stage.querySelector('[data-gallery-slide].is-active');
        return Boolean(
          activeSlide && activeSlide.querySelector('.main-product__gallery-stage-image')
        );
      }

      if (zoomBtn) {
        zoomBtn.addEventListener('click', function (event) {
          event.stopPropagation();
          toggleMagnify();
        });
      }

      stage.addEventListener('click', function (event) {
        if (event.target.closest('button')) {
          return;
        }
        if (!activeSlideHasZoomableImage()) {
          return;
        }
        toggleMagnify();
      });

      stage.addEventListener('mousemove', setPointerTarget);

      if (hoverZoom) {
        stage.addEventListener('mouseenter', function () {
          isHovering = true;
          stage.classList.add('is-zoom-active');
          startZoomMotion();
        });
        stage.addEventListener('mouseleave', function () {
          isHovering = false;
          stage.classList.remove('is-zoom-active');
          startZoomMotion();
        });
      }

      applyZoomVars();
    }

    function initProductGalleryCinema(gallery) {
      if (!gallery || gallery.dataset.galleryCinemaInit === 'true') {
        return;
      }

      initGalleryZoom(gallery);

      var count = parseInt(gallery.dataset.galleryCount, 10) || 0;
      if (count < 2) {
        gallery.dataset.galleryCinemaInit = 'true';
        return;
      }

      var autoplayEnabled = gallery.dataset.galleryAutoplay === 'true';
      var slides = gallery.querySelectorAll('[data-gallery-slide]');
      var thumbs = gallery.querySelectorAll('[data-gallery-thumb]');
      var prevBtn = gallery.querySelector('[data-gallery-prev]');
      var nextBtn = gallery.querySelector('[data-gallery-next]');
      var progressBar = gallery.querySelector('[data-gallery-progress-bar]');
      var progressEl = gallery.querySelector('[data-gallery-progress]');
      var current = 0;
      var isPaused = false;
      var progressElapsed = 0;
      var progressFrame = null;
      var lastProgressTick = 0;

      function renderProgress() {
        if (!progressBar) {
          return;
        }

        var pct = Math.min(100, (progressElapsed / GALLERY_INTERVAL_MS) * 100);
        progressBar.style.transition = 'none';
        progressBar.style.width = pct + '%';

        if (progressEl) {
          progressEl.setAttribute('aria-valuenow', String(Math.round(pct)));
        }
      }

      function clearProgressLoop() {
        if (progressFrame) {
          cancelAnimationFrame(progressFrame);
          progressFrame = null;
        }
      }

      function progressLoop(now) {
        if (isPaused || !autoplayEnabled) {
          return;
        }

        if (!lastProgressTick) {
          lastProgressTick = now;
        }

        var delta = now - lastProgressTick;
        lastProgressTick = now;
        progressElapsed += delta;
        renderProgress();

        if (progressElapsed >= GALLERY_INTERVAL_MS) {
          progressElapsed = 0;
          lastProgressTick = 0;
          goTo(current + 1);
          return;
        }

        progressFrame = requestAnimationFrame(progressLoop);
      }

      function startProgressLoop() {
        clearProgressLoop();
        if (isPaused || !autoplayEnabled || prefersReducedMotion() || document.hidden) {
          return;
        }

        lastProgressTick = 0;
        progressFrame = requestAnimationFrame(progressLoop);
      }

      function pauseAutoplay() {
        if (isPaused) {
          return;
        }

        isPaused = true;
        gallery.classList.add('is-gallery-paused');
        clearProgressLoop();
      }

      function resumeAutoplay() {
        if (!isPaused) {
          return;
        }

        isPaused = false;
        gallery.classList.remove('is-gallery-paused');

        if (!autoplayEnabled || prefersReducedMotion() || document.hidden) {
          return;
        }

        startProgressLoop();
      }

      function goTo(index) {
        index = ((index % count) + count) % count;
        current = index;

        slides.forEach(function (slide, slideIndex) {
          var active = slideIndex === index;
          slide.classList.toggle('is-active', active);
          slide.hidden = !active;
        });

        thumbs.forEach(function (thumb, thumbIndex) {
          var thumbActive = thumbIndex === index;
          thumb.classList.toggle('is-active', thumbActive);
          thumb.setAttribute('aria-selected', thumbActive ? 'true' : 'false');
        });

        progressElapsed = 0;
        lastProgressTick = 0;
        renderProgress();

        if (!isPaused && autoplayEnabled) {
          startProgressLoop();
        }
      }

      thumbs.forEach(function (thumb) {
        thumb.addEventListener('click', function () {
          var index = parseInt(thumb.dataset.galleryIndex, 10) || 0;
          goTo(index);
        });
      });

      if (prevBtn) {
        prevBtn.addEventListener('click', function () {
          goTo(current - 1);
        });
      }

      if (nextBtn) {
        nextBtn.addEventListener('click', function () {
          goTo(current + 1);
        });
      }

      gallery.addEventListener('mouseenter', pauseAutoplay);
      gallery.addEventListener('mouseleave', resumeAutoplay);
      gallery.addEventListener('focusin', pauseAutoplay);
      gallery.addEventListener('focusout', function (event) {
        if (!gallery.contains(event.relatedTarget)) {
          resumeAutoplay();
        }
      });

      document.addEventListener('visibilitychange', function () {
        if (document.hidden) {
          pauseAutoplay();
        } else if (gallery.isConnected) {
          resumeAutoplay();
        }
      });

      goTo(0);
      isPaused = false;
      startProgressLoop();
      gallery.dataset.galleryCinemaInit = 'true';
    }

    function initMainProduct(root) {
      if (!root || root.dataset.mainProductInitialized === 'true') {
        return;
      }

      var qtyInput = root.querySelector('[data-qty-input]');
      var qtyMinus = root.querySelector('[data-qty-minus]');
      var qtyPlus = root.querySelector('[data-qty-plus]');
      var variantSelect = root.querySelector('[data-variant-select]');
      var addButton = root.querySelector('[data-add-to-cart]');

      if (qtyInput && qtyMinus && qtyPlus) {
        qtyMinus.addEventListener('click', function () {
          var current = parseInt(qtyInput.value, 10) || 1;
          qtyInput.value = Math.max(1, current - 1);
        });
        qtyPlus.addEventListener('click', function () {
          var current = parseInt(qtyInput.value, 10) || 1;
          qtyInput.value = current + 1;
        });
      }

      if (variantSelect) {
        variantSelect.addEventListener('change', function () {
          applyVariant(root, variantSelect.value);
        });
        applyVariant(root, variantSelect.value);
      } else if (addButton) {
        var hiddenId = root.querySelector('[data-variant-id]');
        if (hiddenId && hiddenId.value) {
          applyVariant(root, hiddenId.value);
        }
      }

      var accordions = root.querySelectorAll('[data-pdp-accordion]');
      accordions.forEach(function (details) {
        var summary = details.querySelector('summary');
        if (!summary) {
          return;
        }

        function syncExpanded() {
          summary.setAttribute('aria-expanded', details.open ? 'true' : 'false');
        }

        syncExpanded();
        details.addEventListener('toggle', syncExpanded);
      });

      root.querySelectorAll('[data-product-gallery-cinema]').forEach(initProductGalleryCinema);

      root.dataset.mainProductInitialized = 'true';
    }

    function initAll(scope) {
      var context = scope || document;
      context.querySelectorAll('[data-main-product]').forEach(initMainProduct);
      context.querySelectorAll('[data-product-gallery-cinema]').forEach(initProductGalleryCinema);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        initAll();
      });
    } else {
      initAll();
    }

    document.addEventListener('shopify:section:load', function (event) {
      initAll(event.target);
    });
  })();
{% endjavascript %}

