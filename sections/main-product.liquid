{%- liquid
  comment
    Theme Editor / zero-product onboarding fallbacks (see placeholder-images.md).
  endcomment
  assign force_mock = false
  if request.design_mode
    assign force_mock = true
  endif

  assign mock_title = section.settings.mock_title | default: 'Nepenthes edwardsiana'
  assign mock_price = 450000
  assign mock_latin_name = section.settings.mock_latin_name | default: 'N. edwardsiana (Highland)'
  assign mock_inventory = 3
  assign mock_tags = 'Rare'
  assign mock_description = section.settings.mock_description | default: '<ul><li><strong>LIGHT:</strong> Bright, indirect light.</li><li><strong>WATER:</strong> Reverse osmosis only. Keep sphagnum moist.</li><li><strong>HUMIDITY:</strong> 70-90% ambient required.</li><li><strong>TEMPERATURE:</strong> Highland (Day: 25°C, Night: 12°C).</li></ul>'
  assign mock_difficulty = 4
  assign mock_temperature_group = 'highland'
  assign mock_trap_type = 'pitfall'
  assign mock_dormancy_required = false

  comment
    Mock gallery — Unsplash fallbacks when product.media is empty (Field Guide preview).
  endcomment
  assign mock_img_1 = section.settings.mock_image_1 | default: 'https://images.unsplash.com/photo-1593691509543-c55fb37b3ce0?w=800&q=80&auto=format&fit=crop'
  assign mock_img_2 = section.settings.mock_image_2 | default: 'https://images.unsplash.com/photo-1466781783364-869c525ede59?w=800&q=80&auto=format&fit=crop'
  assign mock_img_3 = section.settings.mock_image_3 | default: 'https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=800&q=80&auto=format&fit=crop'
  assign mock_gallery_urls = mock_img_1 | append: '|' | append: mock_img_2 | append: '|' | append: mock_img_3 | split: '|'

  unless force_mock
    if product != blank
      if product.handle contains 'preview'
        assign force_mock = true
      endif
    endif
  endunless

  assign use_live_product = false
  if product
    if product.id != blank
      unless force_mock
        assign use_live_product = true
      endunless
    endif
  endif

  assign has_gallery = false
  assign show_mock_gallery = true

  if force_mock
    assign use_live_product = false
    assign show_mock_gallery = true
    assign display_title = mock_title
    assign latin_name = mock_latin_name
    assign difficulty = mock_difficulty
    assign temperature_group = mock_temperature_group
    assign trap_type = mock_trap_type
    assign dormancy_required = mock_dormancy_required
    assign price_cents = mock_price
    assign compare_at_cents = 0
    assign product_description = mock_description
    assign has_gallery = false
    assign status_inventory = mock_inventory
    assign status_mode = 'limited'
  elsif use_live_product
    assign display_title = product.title | default: mock_title
    assign latin_name = product.metafields.custom.latin_name.value | default: product.metafields.custom.latin_name | default: mock_latin_name
    assign difficulty_raw = product.metafields.custom.difficulty.value | default: product.metafields.custom.difficulty
    assign difficulty = difficulty_raw | default: mock_difficulty | plus: 0
    if difficulty == 0
      assign difficulty = mock_difficulty
    endif
    assign temperature_group = product.metafields.custom.temperature_group.value | default: product.metafields.custom.temperature_group | default: mock_temperature_group
    assign trap_type = product.metafields.custom.trap_type.value | default: product.metafields.custom.trap_type | default: mock_trap_type
    assign dormancy_required = product.metafields.custom.dormancy_required.value | default: product.metafields.custom.dormancy_required | default: mock_dormancy_required
    assign price_cents = product.selected_or_first_available_variant.price | default: mock_price
    assign compare_at_cents = product.selected_or_first_available_variant.compare_at_price | default: 0
    assign product_description = product.description | default: mock_description
    assign current_variant = product.selected_or_first_available_variant

    assign gallery_media = product.media
    if gallery_media.size == 0 and product.images.size > 0
      assign gallery_media = product.images
    endif
    if gallery_media.size > 0
      assign has_gallery = true
      assign show_mock_gallery = false
    else
      assign show_mock_gallery = true
    endif
  else
    assign display_title = mock_title
    assign latin_name = mock_latin_name
    assign difficulty = mock_difficulty
    assign temperature_group = mock_temperature_group
    assign trap_type = mock_trap_type
    assign dormancy_required = mock_dormancy_required
    assign price_cents = mock_price
    assign compare_at_cents = 0
    assign product_description = mock_description
    assign has_gallery = false
    assign show_mock_gallery = true
  endif

  assign temp_group_key = temperature_group | handleize
  assign trap_type_key = trap_type | handleize

  case temp_group_key
    when 'highland'
      assign temp_group_label = 'products.main.temperature_groups.highland' | t
    when 'intermediate'
      assign temp_group_label = 'products.main.temperature_groups.intermediate' | t
    when 'lowland'
      assign temp_group_label = 'products.main.temperature_groups.lowland' | t
    when 'temperate'
      assign temp_group_label = 'products.main.temperature_groups.temperate' | t
    when 'tropical'
      assign temp_group_label = 'products.main.temperature_groups.tropical' | t
    when 'mediterranean'
      assign temp_group_label = 'products.main.temperature_groups.mediterranean' | t
    else
      assign temp_group_label = temperature_group | replace: '-', ' ' | capitalize
  endcase

  case trap_type_key
    when 'snap'
      assign trap_type_label = 'products.main.trap_types.snap' | t
    when 'pitfall'
      assign trap_type_label = 'products.main.trap_types.pitfall' | t
    when 'flypaper'
      assign trap_type_label = 'products.main.trap_types.flypaper' | t
    when 'suction'
      assign trap_type_label = 'products.main.trap_types.suction' | t
    when 'lobster-pot'
      assign trap_type_label = 'products.main.trap_types.lobster_pot' | t
    else
      assign trap_type_label = trap_type | replace: '-', ' ' | capitalize
  endcase

  assign form_id = 'main-product-form-' | append: section.id

  if dormancy_required == true or dormancy_required == 'true'
    assign dormancy_label = 'products.main.dormancy_yes' | t
  else
    assign dormancy_label = 'products.main.dormancy_no' | t
  endif

  assign status_mode = 'cultivating'
  assign status_inventory = 0
  assign tracks_inventory = false

  if use_live_product
    assign status_inventory = current_variant.inventory_quantity | default: 0 | plus: 0
    if current_variant.inventory_management == 'shopify'
      assign tracks_inventory = true
    endif

    if current_variant.available == false
      assign status_mode = 'sold_out'
    elsif tracks_inventory
      if status_inventory > 5
        assign status_mode = 'cultivating'
      elsif status_inventory > 0
        assign status_mode = 'limited'
      else
        assign status_mode = 'sold_out'
      endif
    else
      assign status_mode = 'cultivating'
    endif
  else
    assign status_inventory = mock_inventory
    assign status_mode = 'limited'
  endif

  assign has_care_guide = false
  if use_live_product
    assign care_guide_metafield = product.metafields.custom.care_guide
    if care_guide_metafield != blank
      assign care_guide_value = care_guide_metafield.value | default: care_guide_metafield
      if care_guide_value != blank
        assign has_care_guide = true
      endif
    endif
  endif

  comment
    Specimen technical schema — metafields with demo fallbacks (placeholder-images.md).
  endcomment
  assign fallback_origin = 'Mount Kinabalu, Borneo'
  assign fallback_altitude = '1,500m - 2,500m'
  assign fallback_humidity = '75%'
  assign fallback_temp_range = '12°C - 26°C'
  assign fallback_substrate = 'Live Sphagnum/Perlite 50/50'
  assign fallback_clone_id = 'BE-3672'
  assign fallback_growth_rate = 'Slow/Moderate'
  assign fallback_light_intensity = '10,000 - 15,000 Lux'

  assign spec_origin_raw = ''
  assign spec_altitude_raw = ''
  assign spec_humidity_raw = ''
  assign spec_temp_range_raw = ''
  assign spec_substrate_raw = ''
  assign spec_clone_raw = ''
  assign spec_growth_raw = ''
  assign spec_light_raw = ''

  if use_live_product
    assign spec_origin_raw = product.metafields.custom.origin_location.value | default: product.metafields.custom.origin_location | default: '' | strip
    assign spec_altitude_raw = product.metafields.custom.origin_altitude.value | default: product.metafields.custom.origin_altitude | default: '' | strip
    assign spec_humidity_raw = product.metafields.custom.humidity_min.value | default: product.metafields.custom.humidity_min | default: '' | strip
    assign spec_temp_range_raw = product.metafields.custom.temp_range.value | default: product.metafields.custom.temp_range | default: '' | strip
    assign spec_substrate_raw = product.metafields.custom.potting_media.value | default: product.metafields.custom.potting_media | default: '' | strip
    assign spec_clone_raw = product.metafields.custom.clonotype_code.value | default: product.metafields.custom.clonotype_code | default: '' | strip
    assign spec_growth_raw = product.metafields.custom.growth_speed.value | default: product.metafields.custom.growth_speed | default: '' | strip
    assign spec_light_raw = product.metafields.custom.lux_requirements.value | default: product.metafields.custom.lux_requirements | default: '' | strip
  endif

  assign spec_origin_display = spec_origin_raw | default: fallback_origin
  assign spec_altitude_display = spec_altitude_raw | default: fallback_altitude
  assign spec_humidity_display = spec_humidity_raw | default: fallback_humidity
  assign spec_temp_range_display = spec_temp_range_raw | default: fallback_temp_range
  assign spec_substrate_display = spec_substrate_raw | default: fallback_substrate
  assign spec_clone_display = spec_clone_raw | default: fallback_clone_id
  assign spec_growth_display = spec_growth_raw | default: fallback_growth_rate
  assign spec_light_display = spec_light_raw | default: fallback_light_intensity

  assign show_technical_deep_dive = true
-%}

<article
  class="main-product reveal-up{% if force_mock or use_live_product == false %} main-product--preview{% endif %}"
  data-force-mock="{% if force_mock %}true{% else %}false{% endif %}"
  data-main-product
  data-status-limited-display="{{ 'products.main.status_limited_emphasis' | t | escape }}"
  data-status-cultivating-display="{{ 'products.main.status_cultivating_emphasis' | t | escape }}"
  data-label-add="{{ 'products.main.add_to_conservatory' | t | escape }}"
  data-label-sold-out="{{ 'products.main.sold_out' | t | escape }}"
  {{ section.shopify_attributes }}
>
  <div class="main-product__layout">
    <div class="main-product__gallery product__media" data-product-gallery>
      {%- if use_live_product and has_gallery -%}
        {%- for media in gallery_media -%}
          <div class="product__media-item main-product__gallery-frame">
            {%- if forloop.first -%}
              {% render 'wax-seal-badge', product_item: product, mock_tags: mock_tags %}
            {%- endif -%}
              {%- liquid
                assign gallery_loading = 'lazy'
                assign gallery_fetch_high = false
                if forloop.first
                  assign gallery_loading = 'eager'
                  assign gallery_fetch_high = true
                endif
                assign gallery_image = media.preview_image | default: media
                assign gallery_img_width = gallery_image.width | default: 1600
                assign gallery_img_height = gallery_image.height | default: 2000
                assign id_string = product.id | append: ''
                assign id_size = id_string | size
                assign id_start = id_size | minus: 4
                if id_start < 0
                  assign id_start = 0
                endif
                assign gallery_specimen_suffix = id_string | slice: id_start, 4
                assign gallery_specimen_id = '#BT-LOG-' | append: gallery_specimen_suffix
                assign gallery_alt = display_title | append: ' — ' | append: gallery_specimen_id
                if media.alt != blank
                  assign gallery_alt = media.alt
                endif
              -%}
              {%- if gallery_image != blank -%}
                {%- if gallery_fetch_high -%}
                  {{
                    gallery_image
                    | image_url: width: 1600, height: 2000, crop: 'center'
                    | image_tag:
                      class: 'main-product__gallery-image',
                      widths: '600, 900, 1200, 1600',
                      sizes: '(min-width: 990px) 48vw, 100vw',
                      loading: gallery_loading,
                      fetchpriority: 'high',
                      width: gallery_img_width,
                      height: gallery_img_height,
                      alt: gallery_alt
                  }}
                {%- else -%}
                  {{
                    gallery_image
                    | image_url: width: 1600, height: 2000, crop: 'center'
                    | image_tag:
                      class: 'main-product__gallery-image',
                      widths: '600, 900, 1200, 1600',
                      sizes: '(min-width: 990px) 48vw, 100vw',
                      loading: gallery_loading,
                      width: gallery_img_width,
                      height: gallery_img_height,
                      alt: gallery_alt
                  }}
                {%- endif -%}
              {%- else -%}
                {% render 'botanical-product-image',
                  fallback_url: mock_img_1,
                  product_title: display_title,
                  specimen_id: gallery_specimen_id,
                  css_class: 'main-product__gallery-image',
                  sizes: '(min-width: 990px) 48vw, 100vw',
                  loading: gallery_loading,
                  fetchpriority: gallery_fetch_high | default: false
                %}
              {%- endif -%}
          </div>
        {%- endfor -%}
      {%- elsif show_mock_gallery -%}
        {%- comment -%} Mock image engine — 3-slide gallery when live media is empty or in preview mode {%- endcomment -%}
        {%- for mock_src in mock_gallery_urls -%}
          <div class="product__media-item main-product__gallery-frame">
            {%- if forloop.first -%}
              {% render 'wax-seal-badge', product_item: product, mock_tags: mock_tags %}
            {%- endif -%}
            {%- if mock_src != blank -%}
              <img
                class="main-product__gallery-image main-product__gallery-image--fallback"
                src="{{ mock_src }}"
                alt="{% if forloop.index == 2 %}{{ latin_name | escape }}{% else %}{{ display_title | escape }}{% endif %}"
                width="800"
                height="1000"
                {% if forloop.first %}
                  loading="eager"
                  fetchpriority="high"
                {% else %}
                  loading="lazy"
                {% endif %}
                decoding="async"
              >
            {%- else -%}
              {%- liquid
                assign mock_slide_loading = 'lazy'
                if forloop.first
                  assign mock_slide_loading = 'eager'
                endif
              -%}
              {% render 'botanical-product-image',
                fallback_url: mock_img_1,
                product_title: display_title,
                specimen_id: '#BT-LOG-PREVIEW',
                css_class: 'main-product__gallery-image',
                sizes: '(min-width: 990px) 48vw, 100vw',
                loading: mock_slide_loading,
                fetchpriority: forloop.first
              %}
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="product__media-item main-product__gallery-frame">
          {% render 'wax-seal-badge', product_item: product, mock_tags: mock_tags %}
          {% render 'botanical-product-image',
            fallback_url: mock_img_1,
            product_title: display_title,
            specimen_id: '#BT-LOG-PREVIEW',
            css_class: 'main-product__gallery-image',
            sizes: '(min-width: 990px) 48vw, 100vw',
            loading: 'eager',
            fetchpriority: 'high'
          %}
        </div>
      {%- endif -%}
    </div>

    <div class="main-product__dossier" data-product-dossier>
      <header class="main-product__header">
        {%- if latin_name != blank -%}
          <p class="main-product__latin">
            <em>{{ latin_name | escape }}</em>
          </p>
        {%- endif -%}
        <h1 class="main-product__title">{{ display_title | escape }}</h1>
      </header>

      <p class="main-product__price" data-product-price>
        {%- if compare_at_cents > price_cents -%}
          <span class="visually-hidden">{{ 'products.card.price_sale' | t }}</span>
          <span class="main-product__price-sale" data-product-price-sale>{% render 'zar-price', amount_cents: price_cents %}</span>
          <span class="visually-hidden">{{ 'products.card.price_regular' | t }}</span>
          <s class="main-product__price-compare" data-product-price-compare>{% render 'zar-price', amount_cents: compare_at_cents %}</s>
        {%- else -%}
          <span class="main-product__price-regular" data-product-price-regular>{% render 'zar-price', amount_cents: price_cents %}</span>
        {%- endif -%}
      </p>

      <p
        class="main-product__inventory-status main-product__inventory-status--{{ status_mode }}"
        data-product-status
        data-status-mode="{{ status_mode }}"
        {% if status_mode == 'sold_out' %}
          hidden
        {% endif %}
      >
        <span class="main-product__inventory-status-bracket" aria-hidden="true">[</span>
        {{ 'products.main.inventory_status_label' | t }}
        <span class="main-product__inventory-status-value" data-product-status-text>
          {%- if status_mode == 'limited' -%}
            {{ 'products.main.status_limited_emphasis' | t }}
          {%- else -%}
            {{ 'products.main.status_cultivating_emphasis' | t }}
          {%- endif -%}
        </span>
        <span class="main-product__inventory-status-bracket" aria-hidden="true">]</span>
      </p>

      {%- if use_live_product -%}
        {%- form 'product', product, class: 'main-product__form', id: form_id -%}
          {%- if product.variants.size > 1 -%}
            <div class="main-product__variants">
              <label class="main-product__label" for="main-product-variant-{{ section.id }}">
                {{ 'products.main.variant_label' | t }}
              </label>
              <select
                id="main-product-variant-{{ section.id }}"
                class="main-product__variant-select"
                name="id"
                data-variant-select
              >
                {%- for variant in product.variants -%}
                  <option
                    value="{{ variant.id }}"
                    {% if variant == current_variant %}
                      selected
                    {% endif %}
                    {% unless variant.available %}
                      disabled
                    {% endunless %}
                  >
                    {{ variant.title }}
                    {%- unless variant.available %} — {{ 'products.main.sold_out' | t }}{% endunless -%}
                  </option>
                {%- endfor -%}
              </select>
            </div>
          {%- else -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>
          {%- endif -%}

          <div class="main-product__purchase">
            <div class="main-product__quantity" data-quantity>
              <span class="main-product__label" id="main-product-qty-label-{{ section.id }}">
                {{ 'products.main.quantity' | t }}
              </span>
              <div class="main-product__quantity-control" role="group" aria-labelledby="main-product-qty-label-{{ section.id }}">
                <button
                  type="button"
                  class="main-product__qty-btn"
                  data-qty-minus
                  aria-label="{{ 'products.main.quantity_decrease' | t }}"
                >
                  <span aria-hidden="true">−</span>
                </button>
                <input
                  class="main-product__qty-input"
                  type="number"
                  name="quantity"
                  value="1"
                  min="1"
                  inputmode="numeric"
                  data-qty-input
                  aria-label="{{ 'products.main.quantity' | t }}"
                >
                <button
                  type="button"
                  class="main-product__qty-btn"
                  data-qty-plus
                  aria-label="{{ 'products.main.quantity_increase' | t }}"
                >
                  <span aria-hidden="true">+</span>
                </button>
              </div>
            </div>

            <button
              type="submit"
              class="main-product__submit"
              name="add"
              {% unless current_variant.available %}
                disabled
              {% endunless %}
              data-add-to-cart
            >
              {%- if current_variant.available -%}
                {{ 'products.main.add_to_conservatory' | t }}
              {%- else -%}
                {{ 'products.main.sold_out' | t }}
              {%- endif -%}
            </button>
          </div>
        {%- endform -%}
      {%- else -%}
        <p class="main-product__preview-note">{{ 'products.main.preview_note' | t }}</p>
        <div class="main-product__purchase main-product__purchase--preview">
          <div class="main-product__quantity" data-quantity>
            <span class="main-product__label" id="main-product-qty-label-preview-{{ section.id }}">
              {{ 'products.main.quantity' | t }}
            </span>
            <div
              class="main-product__quantity-control"
              role="group"
              aria-labelledby="main-product-qty-label-preview-{{ section.id }}"
            >
              <button type="button" class="main-product__qty-btn" disabled aria-hidden="true">
                <span aria-hidden="true">−</span>
              </button>
              <input
                class="main-product__qty-input"
                type="number"
                value="1"
                min="1"
                readonly
                tabindex="-1"
                aria-hidden="true"
              >
              <button type="button" class="main-product__qty-btn" disabled aria-hidden="true">
                <span aria-hidden="true">+</span>
              </button>
            </div>
          </div>
          <button type="button" class="main-product__submit" disabled>
            {{ 'products.main.add_to_conservatory' | t }}
          </button>
        </div>
      {%- endif -%}

      <div class="main-product__accordions" aria-label="{{ 'products.main.accordions_label' | t }}">
        <details data-pdp-accordion>
          <summary class="pdp-accordion-title" aria-expanded="false">
            {{ 'products.main.accordion_care_title' | t }}
            <span class="icon-plus" aria-hidden="true">+</span>
          </summary>
          <div class="pdp-accordion-content">
            {%- if has_care_guide -%}
              {{ product.metafields.custom.care_guide | metafield_tag }}
            {%- else -%}
              {%- assign care_fallback_text = section.settings.care_fallback | default: 'High humidity and RO water required. Maintain bright, diffused light and use reverse-osmosis or rainwater only. Do not fertilize the substrate directly.' -%}
              <p>{{ care_fallback_text }}</p>
            {%- endif -%}
          </div>
        </details>
        <details data-pdp-accordion>
          <summary class="pdp-accordion-title" aria-expanded="false">
            {{ 'products.main.accordion_lineage_title' | t }}
            <span class="icon-plus" aria-hidden="true">+</span>
          </summary>
          <div class="pdp-accordion-content">
            <p>{{ section.settings.accordion_lineage_body | default: 'Cultivated via tissue culture from ethically sourced mother stock. Zero wild poaching. Acclimated to ambient humidity prior to dispatch.' }}</p>
          </div>
        </details>
        <details data-pdp-accordion>
          <summary class="pdp-accordion-title" aria-expanded="false">
            {{ 'products.main.accordion_arrival_title' | t }}
            <span class="icon-plus" aria-hidden="true">+</span>
          </summary>
          <div class="pdp-accordion-content">
            <p>{{ section.settings.accordion_arrival_body | default: 'Shipped via specialized botanical courier. Specimen is hand-packed in long-fiber sphagnum moss and insulated against temperature fluctuations.' }}</p>
          </div>
        </details>
      </div>

      {%- liquid
        assign origin_narrative = section.settings.origin_text | default: 'Cultivated in Gauteng from ethically propagated stock.'
        assign origin_display = spec_origin_display
        if spec_origin_raw == blank and origin_narrative != blank
          assign origin_display = origin_narrative
        elsif spec_origin_raw != blank and origin_narrative != blank
          assign origin_display = spec_origin_display | append: '. ' | append: origin_narrative
        endif
      -%}
      {%- if spec_origin_raw != blank or request.design_mode or spec_origin_display != blank -%}
        <div class="main-product__origin" aria-labelledby="main-product-origin-{{ section.id }}">
          <span class="main-product__origin-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M2 12h20"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
          </span>
          <p id="main-product-origin-{{ section.id }}" class="main-product__origin-text">
            <span class="visually-hidden">{{ 'products.main.origin_heading' | t }}:</span>
            {{ origin_display | escape }}
          </p>
        </div>
      {%- endif -%}

      {%- if use_live_product -%}
        <script type="application/json" data-main-product-variants>
          [
            {%- for variant in product.variants -%}
              {
                "id": {{ variant.id | json }},
                "available": {{ variant.available | json }},
                "price": {{ variant.price }},
                "compare_at_price": {{ variant.compare_at_price | default: 0 }},
                "inventory_quantity": {{ variant.inventory_quantity | default: 0 }},
                "inventory_management": {{ variant.inventory_management | json }}
              }{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
          ]
        </script>
      {%- endif -%}

      <section
        class="main-product__cultivation main-product__cultivation-dossier"
        aria-labelledby="main-product-cultivation-{{ section.id }}"
      >
        <h2 id="main-product-cultivation-{{ section.id }}" class="visually-hidden">
          {{ 'products.main.cultivation_heading' | t }}
        </h2>
        <div class="main-product__description rte" data-product-description>
          {{ product_description }}
        </div>
      </section>

      <section class="main-product__field-data" aria-labelledby="main-product-field-data-{{ section.id }}">
        <h2 id="main-product-field-data-{{ section.id }}" class="main-product__field-data-title">
          {{ 'products.main.field_data_heading' | t }}
        </h2>
        <dl class="main-product__field-grid">
          <div class="main-product__field-row">
            <dt>{{ 'products.main.spec_difficulty' | t }}</dt>
            <dd>
              <span class="main-product__field-value">{{ difficulty }}/5</span>
              <span
                class="main-product__difficulty difficulty-pips"
                role="img"
                aria-label="{{ 'products.card.difficulty_label' | t: level: difficulty, max: 5 }}"
              >
                {%- for pip in (1..5) -%}
                  <span
                    class="difficulty-pip{% if pip <= difficulty %} difficulty-pip--filled{% endif %}"
                    aria-hidden="true"
                  ></span>
                {%- endfor -%}
              </span>
            </dd>
          </div>
          <div class="main-product__field-row">
            <dt>{{ 'products.main.spec_temperature' | t }}</dt>
            <dd class="main-product__field-value">{{ temp_group_label | escape }}</dd>
          </div>
          <div class="main-product__field-row">
            <dt>{{ 'products.main.spec_trap' | t }}</dt>
            <dd class="main-product__field-value">{{ trap_type_label | escape }}</dd>
          </div>
          <div class="main-product__field-row">
            <dt>{{ 'products.main.spec_dormancy' | t }}</dt>
            <dd class="main-product__field-value">{{ dormancy_label | escape }}</dd>
          </div>
        </dl>
      </section>
    </div>
  </div>

  {%- if show_technical_deep_dive -%}
    <section
      class="main-product__deep-dive"
      aria-labelledby="main-product-technical-{{ section.id }}"
    >
      <header class="main-product__deep-dive-header">
        <p class="main-product__deep-dive-eyebrow">{{ 'products.main.technical_data_heading' | t }}</p>
        <h2 id="main-product-technical-{{ section.id }}" class="main-product__deep-dive-title">
          {{ display_title | escape }}
        </h2>
        <p class="main-product__deep-dive-subtitle">{{ 'products.main.technical_data_subheading' | t }}</p>
      </header>

      <dl class="main-product__tech-grid">
        {%- if spec_origin_raw != blank or request.design_mode or spec_origin_display != blank -%}
          <div class="main-product__tech-cell">
            <dt class="main-product__tech-label">{{ 'products.main.spec_origin' | t }}</dt>
            <dd class="main-product__tech-value">{{ spec_origin_display | escape }}</dd>
          </div>
        {%- endif -%}
        {%- if spec_altitude_raw != blank or request.design_mode or spec_altitude_display != blank -%}
          <div class="main-product__tech-cell">
            <dt class="main-product__tech-label">{{ 'products.main.spec_altitude' | t }}</dt>
            <dd class="main-product__tech-value">{{ spec_altitude_display | escape }}</dd>
          </div>
        {%- endif -%}
        {%- if spec_humidity_raw != blank or request.design_mode or spec_humidity_display != blank -%}
          <div class="main-product__tech-cell">
            <dt class="main-product__tech-label">{{ 'products.main.spec_humidity' | t }}</dt>
            <dd class="main-product__tech-value">{{ spec_humidity_display | escape }}</dd>
          </div>
        {%- endif -%}
        {%- if spec_temp_range_raw != blank or request.design_mode or spec_temp_range_display != blank -%}
          <div class="main-product__tech-cell">
            <dt class="main-product__tech-label">{{ 'products.main.spec_temperature_range' | t }}</dt>
            <dd class="main-product__tech-value">{{ spec_temp_range_display | escape }}</dd>
          </div>
        {%- endif -%}
        {%- if spec_substrate_raw != blank or request.design_mode or spec_substrate_display != blank -%}
          <div class="main-product__tech-cell">
            <dt class="main-product__tech-label">{{ 'products.main.spec_substrate' | t }}</dt>
            <dd class="main-product__tech-value">{{ spec_substrate_display | escape }}</dd>
          </div>
        {%- endif -%}
        {%- if spec_clone_raw != blank or request.design_mode or spec_clone_display != blank -%}
          <div class="main-product__tech-cell">
            <dt class="main-product__tech-label">{{ 'products.main.spec_clone_id' | t }}</dt>
            <dd class="main-product__tech-value">{{ spec_clone_display | escape }}</dd>
          </div>
        {%- endif -%}
        {%- if spec_growth_raw != blank or request.design_mode or spec_growth_display != blank -%}
          <div class="main-product__tech-cell">
            <dt class="main-product__tech-label">{{ 'products.main.spec_growth_rate' | t }}</dt>
            <dd class="main-product__tech-value">{{ spec_growth_display | escape }}</dd>
          </div>
        {%- endif -%}
        {%- if spec_light_raw != blank or request.design_mode or spec_light_display != blank -%}
          <div class="main-product__tech-cell">
            <dt class="main-product__tech-label">{{ 'products.main.spec_light_intensity' | t }}</dt>
            <dd class="main-product__tech-value">{{ spec_light_display | escape }}</dd>
          </div>
        {%- endif -%}
      </dl>
    </section>
  {%- endif -%}

  {%- if use_live_product -%}
    {% render 'product-structured-data',
      product: product,
      difficulty: difficulty,
      origin_value: spec_origin_display,
      clonotype_value: spec_clone_display
    %}
  {%- endif -%}
</article>

{% stylesheet %}
  .main-product {
    padding-block: var(--space-2xl) var(--space-3xl);
  }

  .main-product__layout {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-2xl);
    width: min(var(--page-width), calc(100% - var(--page-margin) * 2));
    margin-inline: auto;
  }

  .main-product {
    overflow: visible;
  }

  /* Gallery — shared frame + image (Field Guide specimen plates) */
  .product__media-item.main-product__gallery-frame {
    position: relative;
    margin: 0;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: var(--color-parchment);
    border: 1px solid var(--color-forest-green-dark);
    border-radius: 4px;
    box-shadow: var(--shadow-md);
  }

  .main-product__gallery-image {
    display: block;
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center center;
    transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .main-product__gallery-frame:hover .main-product__gallery-image {
    transform: scale(1.04);
  }

  .main-product__gallery.product__media {
    width: 100%;
    min-width: 0;
  }

  .main-product__dossier {
    min-width: 0;
    padding: var(--space-xl);
    background-color: var(--color-parchment);
    border: 1px solid var(--color-forest-green-dark);
    border-radius: var(--radius-lg);
    box-shadow: 2px 2px 10px rgb(0 0 0 / 0.05);
  }

  .main-product__header {
    margin-block-end: var(--space-md);
  }

  .main-product__latin {
    margin: 0 0 var(--space-sm);
    font-family: var(--font-family-serif);
    font-size: clamp(1.25rem, 1.75vw + 0.5rem, 1.625rem);
    font-style: italic;
    font-weight: 400;
    line-height: var(--line-height-tight);
    letter-spacing: 0.02em;
    color: var(--color-forest-green-dark);
    opacity: 0.92;
  }

  .main-product__latin em {
    font-style: italic;
  }

  .main-product__title {
    margin: 0;
    font-family: var(--font-family-serif);
    font-size: clamp(2rem, 3.5vw + 0.5rem, 3.25rem);
    font-weight: 400;
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tight);
    color: var(--color-forest-green-dark);
  }

  .main-product__price {
    margin: var(--space-lg) 0 var(--space-md);
    font-size: clamp(1.25rem, 2vw + 0.25rem, 1.75rem);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .main-product__price-sale {
    color: var(--color-accent);
    margin-inline-end: var(--space-sm);
  }

  .main-product__price-compare {
    font-size: var(--font-size-md);
    font-weight: 400;
    color: var(--color-text-muted);
  }

  /* Scarcity / inventory ledger line */
  .main-product__inventory-status {
    margin: 0 0 var(--space-lg);
    font-family: 'Courier New', Courier, 'Liberation Mono', monospace;
    font-size: 0.6875rem;
    font-weight: 600;
    line-height: 1.45;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-forest-green-dark);
  }

  .main-product__inventory-status-bracket {
    opacity: 0.65;
  }

  .main-product__inventory-status-value {
    color: #3d6b4a;
  }

  .main-product__inventory-status--limited .main-product__inventory-status-value {
    color: #cd6d3d;
  }

  .main-product__label {
    display: block;
    margin-block-end: var(--space-xs);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .main-product__variants {
    margin-block-end: var(--space-lg);
  }

  .main-product__variant-select {
    width: 100%;
    min-height: 2.75rem;
    padding: var(--space-sm) var(--space-md);
    background-color: var(--color-surface-elevated);
    border: 1px solid var(--color-border);
  }

  .main-product__purchase {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    align-items: stretch;
    margin-block-end: var(--space-xl);
  }

  .main-product__quantity-control {
    display: inline-flex;
    align-items: stretch;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    overflow: hidden;
    background-color: var(--color-surface-elevated);
  }

  .main-product__qty-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    min-height: 2.75rem;
    padding: 0;
    cursor: pointer;
    color: var(--color-text);
    background-color: var(--color-surface);
    border: none;
    transition: background-color var(--transition-fast);
  }

  .main-product__qty-btn:hover {
    background-color: var(--color-border);
  }

  .main-product__qty-input {
    width: 3.5rem;
    min-height: 2.75rem;
    padding: var(--space-xs);
    text-align: center;
    border: none;
    border-inline: 1px solid var(--color-border);
    -moz-appearance: textfield;
    appearance: textfield;
  }

  .main-product__qty-input::-webkit-outer-spin-button,
  .main-product__qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .main-product__submit {
    width: 100%;
    min-height: 3rem;
    padding: var(--space-sm) var(--space-xl);
    font-family: var(--font-family-serif);
    font-size: var(--font-size-sm);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    color: var(--color-parchment);
    background-color: var(--color-forest-green-dark);
    border: 1px solid var(--color-forest-green-dark);
    border-radius: var(--radius-sm);
    transition:
      background-color 0.4s cubic-bezier(0.25, 1, 0.5, 1),
      transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    will-change: transform;
  }

  .main-product__submit:hover:not(:disabled) {
    background-color: var(--color-primary);
    transform: translateY(-2px);
  }

  .main-product__submit:disabled {
    cursor: not-allowed;
    opacity: 0.55;
  }

  .main-product__preview-note {
    margin: 0 0 var(--space-md);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .main-product__cultivation {
    margin-block: var(--space-xl);
    padding-block-start: var(--space-lg);
    border-block-start: 1px solid var(--color-border);
  }

  .main-product__cultivation-dossier .main-product__description ul {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .main-product__cultivation-dossier .main-product__description ul > li {
    margin: 0;
    padding-block-start: 0.5rem;
    border-block-start: 1px solid rgb(0 0 0 / 0.1);
  }

  .main-product__cultivation-dossier .main-product__description ul li > :is(strong, b):first-child {
    display: block;
    margin: 0 0 var(--space-xs);
    font-family: var(--font-family-base);
    font-size: 0.75rem;
    font-style: normal;
    font-weight: 700;
    line-height: var(--line-height-tight);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-forest-green-dark);
  }

  .main-product__cultivation-dossier .main-product__description ul > li {
    font-family: var(--font-family-serif);
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--color-forest-green-dark);
  }

  .main-product__field-data {
    padding-block-start: var(--space-lg);
    border-block-start: 1px solid var(--color-border);
  }

  .main-product__field-data-title {
    margin: 0 0 var(--space-md);
    font-family: var(--font-family-base);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  /* Field data — printed ledger grid */
  .main-product__field-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin: 0;
    overflow: hidden;
    background-color: var(--color-surface-elevated);
    border: 0.5px solid var(--color-forest-green-dark);
    border-radius: 4px;
  }

  .main-product__field-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    margin: 0;
    padding: var(--space-sm) var(--space-md);
    border: 0.5px solid rgb(10 24 18 / 0.2);
  }

  .main-product__field-row dt {
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .main-product__field-row dd {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    margin: 0;
    font-size: var(--font-size-sm);
    line-height: var(--line-height-base);
  }

  .main-product__field-value {
    font-weight: 600;
    color: var(--color-text);
  }

  .main-product__difficulty {
    margin-inline-start: auto;
  }

  .main-product__description {
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-muted);
  }

  .main-product__description :is(p, ul, ol) {
    margin: 0 0 var(--space-md);
  }

  @media (min-width: 750px) {
    .main-product__cultivation-dossier .main-product__description ul {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Technical data sheet — below-the-fold deep dive */
  .main-product__deep-dive {
    width: min(var(--page-width), calc(100% - var(--page-margin) * 2));
    margin: var(--space-3xl) auto 0;
    padding: var(--space-xl) var(--space-lg);
    background-color: var(--color-parchment);
    border: 0.5px solid var(--color-forest-green-dark);
    border-radius: 4px;
    box-shadow: 1px 2px 0 rgb(10 24 18 / 0.06);
  }

  .main-product__deep-dive-header {
    margin-block-end: var(--space-lg);
    padding-block-end: var(--space-md);
    border-block-end: 0.5px solid rgb(10 24 18 / 0.2);
  }

  .main-product__deep-dive-eyebrow {
    margin: 0 0 var(--space-xs);
    font-family: 'Courier New', Courier, 'Liberation Mono', monospace;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .main-product__deep-dive-title {
    margin: 0 0 var(--space-sm);
    font-family: var(--font-family-serif);
    font-size: clamp(1.35rem, 2vw + 0.35rem, 1.75rem);
    font-weight: 400;
    line-height: var(--line-height-tight);
    color: var(--color-forest-green-dark);
  }

  .main-product__deep-dive-subtitle {
    margin: 0;
    max-width: 52ch;
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-muted);
  }

  .main-product__tech-grid {
    display: grid;
    grid-template-columns: 1fr;
    margin: 0;
    overflow: hidden;
    border: 0.5px solid var(--color-forest-green-dark);
    border-radius: 2px;
  }

  .main-product__tech-cell {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    margin: 0;
    padding: var(--space-md) var(--space-lg);
    border: 0.5px solid rgb(10 24 18 / 0.2);
    background-color: rgb(247 244 237 / 0.65);
  }

  .main-product__tech-label {
    margin: 0;
    font-family: 'Courier New', Courier, 'Liberation Mono', monospace;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .main-product__tech-value {
    margin: 0;
    font-family: var(--font-family-serif);
    font-size: var(--font-size-md);
    font-weight: 400;
    line-height: var(--line-height-relaxed);
    color: var(--color-forest-green-dark);
    font-variant-numeric: tabular-nums;
  }

  @media (min-width: 750px) {
    .main-product__tech-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  /* Mobile — horizontal snap-scroll gallery */
  @media (max-width: 989px) {
    .main-product__gallery.product__media {
      display: flex;
      flex-direction: row;
      gap: 1rem;
      width: 100%;
      min-width: 0;
      padding-inline: 2rem;
      padding-bottom: 1rem;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    .main-product__gallery.product__media::-webkit-scrollbar {
      display: none;
    }

    .product__media-item.main-product__gallery-frame {
      flex: 0 0 85vw;
      width: auto;
      scroll-snap-align: center;
    }

    .main-product__gallery-frame:hover .main-product__gallery-image {
      transform: none;
    }
  }

  /* Desktop — split sticky dossier (Field Guide spread) */
  @media (min-width: 990px) {
    .main-product__layout {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 4rem;
      align-items: start;
    }

    .main-product__gallery.product__media {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      position: sticky;
      top: 2rem;
      height: max-content;
      width: 100%;
      min-width: 0;
      padding-inline: 0;
      padding-bottom: 0;
      overflow: visible;
      scroll-snap-type: none;
    }

    .product__media-item.main-product__gallery-frame {
      flex: unset;
      width: 100%;
      scroll-snap-align: none;
    }

    .main-product__dossier {
      min-width: 0;
    }

    .main-product__field-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .main-product__origin {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
    margin-block-end: var(--space-xl);
    padding: var(--space-md) var(--space-lg);
    background-color: rgb(30 51 32 / 0.04);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .main-product__origin-icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    color: var(--color-primary);
  }

  .main-product__origin-text {
    margin: 0;
    font-family: var(--font-family-serif);
    font-size: var(--font-size-md);
    font-style: italic;
    line-height: var(--line-height-relaxed);
    color: var(--color-forest-green-dark);
  }

  .main-product__accordions {
    display: flex;
    flex-direction: column;
    margin-block-start: 2rem;
    margin-block-end: var(--space-xl);
  }

  .main-product__accordions details {
    border-bottom: 1px solid var(--color-forest-green-dark);
    padding-block: 1rem;
  }

  .main-product__accordions summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--color-forest-green-dark);
  }

  .main-product__accordions summary:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 3px;
  }

  .main-product__accordions summary::-webkit-details-marker {
    display: none;
  }

  .main-product__accordions .icon-plus {
    flex-shrink: 0;
    font-size: 1.125rem;
    font-weight: 400;
    line-height: 1;
    color: var(--color-primary);
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .main-product__accordions details[open] .icon-plus {
    transform: rotate(45deg);
  }

  .pdp-accordion-content {
    padding-top: 1rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-forest-green-dark);
    opacity: 0.9;
  }

  .pdp-accordion-content p {
    margin: 0;
  }

  .pdp-accordion-content :is(p, ul, ol) + :is(p, ul, ol) {
    margin-block-start: var(--space-sm);
  }

  @media (prefers-reduced-motion: reduce) {
    .main-product__submit {
      transition: background-color var(--transition-fast);
    }

    .main-product__submit:hover:not(:disabled) {
      transform: none;
    }

    .main-product__gallery-frame:hover .main-product__gallery-image {
      transform: none;
    }

    .main-product__accordions details[open] .icon-plus {
      transform: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    'use strict';

    function formatZar(cents) {
      var value = parseInt(cents, 10) || 0;
      var rands = Math.floor(value / 100);
      var fractional = value % 100;
      var fractionalDisplay = fractional < 10 ? '0' + fractional : String(fractional);
      var randsDisplay = String(rands);

      if (rands >= 1000) {
        var thousands = Math.floor(rands / 1000);
        var remainder = rands % 1000;
        var remainderPadded = String(remainder);
        while (remainderPadded.length < 3) {
          remainderPadded = '0' + remainderPadded;
        }
        randsDisplay = thousands + ' ' + remainderPadded;
      }

      return 'R ' + randsDisplay + ',' + fractionalDisplay;
    }

    function readVariants(root) {
      var script = root.querySelector('[data-main-product-variants]');
      if (!script) {
        return [];
      }
      try {
        return JSON.parse(script.textContent);
      } catch (error) {
        console.error('Main product: invalid variant JSON.', error);
        return [];
      }
    }

    function findVariant(variants, id) {
      var targetId = parseInt(id, 10);
      for (var i = 0; i < variants.length; i += 1) {
        if (variants[i].id === targetId) {
          return variants[i];
        }
      }
      return null;
    }

    function getStatusMode(variant) {
      if (!variant || !variant.available) {
        return 'sold_out';
      }
      if (variant.inventory_management === 'shopify') {
        var qty = parseInt(variant.inventory_quantity, 10) || 0;
        if (qty > 5) {
          return 'cultivating';
        }
        if (qty > 0) {
          return 'limited';
        }
        return 'sold_out';
      }
      return 'cultivating';
    }

    function updateStatus(root, variant) {
      var statusEl = root.querySelector('[data-product-status]');
      var statusText = root.querySelector('[data-product-status-text]');
      if (!statusEl || !statusText) {
        return;
      }

      var mode = getStatusMode(variant);
      var limitedTemplate = root.dataset.statusLimitedDisplay || '';
      var cultivatingText = root.dataset.statusCultivatingDisplay || '';

      statusEl.classList.remove(
        'main-product__inventory-status--limited',
        'main-product__inventory-status--cultivating',
        'main-product__inventory-status--sold_out'
      );
      statusEl.classList.add('main-product__inventory-status--' + mode);
      statusEl.dataset.statusMode = mode;

      if (mode === 'sold_out') {
        statusEl.hidden = true;
        return;
      }

      statusEl.hidden = false;

      if (mode === 'limited') {
        statusText.textContent = root.dataset.statusLimitedDisplay || limitedTemplate;
      } else {
        statusText.textContent = root.dataset.statusCultivatingDisplay || cultivatingText;
      }
    }

    function updatePrice(root, variant) {
      var priceRoot = root.querySelector('[data-product-price]');
      if (!priceRoot || !variant) {
        return;
      }

      var price = parseInt(variant.price, 10) || 0;
      var compareAt = parseInt(variant.compare_at_price, 10) || 0;
      var saleEl = priceRoot.querySelector('[data-product-price-sale]');
      var compareEl = priceRoot.querySelector('[data-product-price-compare]');
      var regularEl = priceRoot.querySelector('[data-product-price-regular]');

      if (compareAt > price) {
        if (!saleEl) {
          priceRoot.innerHTML =
            '<span class="visually-hidden">Sale</span>' +
            '<span class="main-product__price-sale" data-product-price-sale></span>' +
            '<span class="visually-hidden">Regular</span>' +
            '<s class="main-product__price-compare" data-product-price-compare></s>';
          saleEl = priceRoot.querySelector('[data-product-price-sale]');
          compareEl = priceRoot.querySelector('[data-product-price-compare]');
        }
        if (regularEl) {
          regularEl.remove();
        }
        saleEl.textContent = formatZar(price);
        compareEl.textContent = formatZar(compareAt);
      } else {
        if (!regularEl) {
          priceRoot.innerHTML =
            '<span class="main-product__price-regular" data-product-price-regular></span>';
          regularEl = priceRoot.querySelector('[data-product-price-regular]');
        }
        if (saleEl) {
          saleEl.remove();
        }
        if (compareEl) {
          compareEl.remove();
        }
        regularEl.textContent = formatZar(price);
      }
    }

    function updateVariantUrl(variantId) {
      try {
        var url = new URL(window.location.href);
        url.searchParams.set('variant', String(variantId));
        window.history.replaceState({}, '', url.toString());
      } catch (error) {
        /* Non-blocking */
      }
    }

    function applyVariant(root, variantId) {
      var variants = readVariants(root);
      var variant = findVariant(variants, variantId);
      if (!variant) {
        return;
      }

      var addButton = root.querySelector('[data-add-to-cart]');
      var addLabel = root.dataset.labelAdd || 'ADD TO CONSERVATORY';
      var soldOutLabel = root.dataset.labelSoldOut || 'Sold out';

      updatePrice(root, variant);
      updateStatus(root, variant);
      updateVariantUrl(variant.id);

      if (addButton) {
        addButton.disabled = !variant.available;
        addButton.textContent = variant.available ? addLabel : soldOutLabel;
      }
    }

    function initMainProduct(root) {
      if (!root || root.dataset.mainProductInitialized === 'true') {
        return;
      }

      var qtyInput = root.querySelector('[data-qty-input]');
      var qtyMinus = root.querySelector('[data-qty-minus]');
      var qtyPlus = root.querySelector('[data-qty-plus]');
      var variantSelect = root.querySelector('[data-variant-select]');
      var addButton = root.querySelector('[data-add-to-cart]');

      if (qtyInput && qtyMinus && qtyPlus) {
        qtyMinus.addEventListener('click', function () {
          var current = parseInt(qtyInput.value, 10) || 1;
          qtyInput.value = Math.max(1, current - 1);
        });
        qtyPlus.addEventListener('click', function () {
          var current = parseInt(qtyInput.value, 10) || 1;
          qtyInput.value = current + 1;
        });
      }

      if (variantSelect) {
        variantSelect.addEventListener('change', function () {
          applyVariant(root, variantSelect.value);
        });
        applyVariant(root, variantSelect.value);
      } else if (addButton) {
        var hiddenId = root.querySelector('[data-variant-id]');
        if (hiddenId && hiddenId.value) {
          applyVariant(root, hiddenId.value);
        }
      }

      var accordions = root.querySelectorAll('[data-pdp-accordion]');
      accordions.forEach(function (details) {
        var summary = details.querySelector('summary');
        if (!summary) {
          return;
        }

        function syncExpanded() {
          summary.setAttribute('aria-expanded', details.open ? 'true' : 'false');
        }

        syncExpanded();
        details.addEventListener('toggle', syncExpanded);
      });

      root.dataset.mainProductInitialized = 'true';
    }

    function initAll(scope) {
      var context = scope || document;
      context.querySelectorAll('[data-main-product]').forEach(initMainProduct);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        initAll();
      });
    } else {
      initAll();
    }

    document.addEventListener('shopify:section:load', function (event) {
      initAll(event.target);
    });
  })();
{% endjavascript %}

