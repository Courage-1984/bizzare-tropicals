{%- liquid
  comment
    Theme Editor / zero-product onboarding fallbacks (see placeholder-images.md).
  endcomment
  assign force_mock = false
  if request.design_mode
    assign force_mock = true
  endif

  assign mock_title = 'Nepenthes edwardsiana'
  assign mock_price = 450000
  assign mock_latin_name = 'N. edwardsiana (Highland)'
  assign mock_inventory = 3
  assign mock_tags = 'Rare'
  assign mock_description = '<ul><li><strong>LIGHT:</strong> Bright, indirect light.</li><li><strong>WATER:</strong> Reverse osmosis only. Keep sphagnum moist.</li><li><strong>HUMIDITY:</strong> 70-90% ambient required.</li><li><strong>TEMPERATURE:</strong> Highland (Day: 25°C, Night: 12°C).</li></ul>'
  assign mock_difficulty = 4
  assign mock_temperature_group = 'highland'
  assign mock_trap_type = 'pitfall'
  assign mock_dormancy_required = false

  assign mock_gallery_url_1 = 'https://commons.wikimedia.org/wiki/Special:FilePath/Nepenthes_villosa_(14238410874).jpg?width=1600'
  assign mock_gallery_url_2 = 'https://commons.wikimedia.org/wiki/Special:FilePath/Large_lower_pitcher_of_wild_Nepenthes_rajah_plant.jpg?width=1600'
  assign mock_gallery_url_3 = 'https://commons.wikimedia.org/wiki/Special:FilePath/Nepenthes_villosa_036.jpg?width=1600'

  unless force_mock
    if product != blank
      if product.handle contains 'preview'
        assign force_mock = true
      endif
    endif
  endunless

  assign use_live_product = false
  if product
    if product.id != blank
      unless force_mock
        assign use_live_product = true
      endunless
    endif
  endif

  assign has_gallery = false
  assign show_mock_gallery = true

  if force_mock
    assign use_live_product = false
    assign show_mock_gallery = true
    assign display_title = mock_title
    assign latin_name = mock_latin_name
    assign difficulty = mock_difficulty
    assign temperature_group = mock_temperature_group
    assign trap_type = mock_trap_type
    assign dormancy_required = mock_dormancy_required
    assign price_cents = mock_price
    assign compare_at_cents = 0
    assign product_description = mock_description
    assign has_gallery = false
    assign status_inventory = mock_inventory
    assign status_mode = 'limited'
  elsif use_live_product
    assign display_title = product.title | default: mock_title
    assign latin_name = product.metafields.custom.latin_name.value | default: product.metafields.custom.latin_name | default: mock_latin_name
    assign difficulty_raw = product.metafields.custom.difficulty.value | default: product.metafields.custom.difficulty
    assign difficulty = difficulty_raw | default: mock_difficulty | plus: 0
    if difficulty == 0
      assign difficulty = mock_difficulty
    endif
    assign temperature_group = product.metafields.custom.temperature_group.value | default: product.metafields.custom.temperature_group | default: mock_temperature_group
    assign trap_type = product.metafields.custom.trap_type.value | default: product.metafields.custom.trap_type | default: mock_trap_type
    assign dormancy_required = product.metafields.custom.dormancy_required.value | default: product.metafields.custom.dormancy_required | default: mock_dormancy_required
    assign price_cents = product.selected_or_first_available_variant.price | default: mock_price
    assign compare_at_cents = product.selected_or_first_available_variant.compare_at_price | default: 0
    assign product_description = product.description | default: mock_description
    assign current_variant = product.selected_or_first_available_variant

    assign gallery_media = product.media
    if gallery_media.size == 0 and product.images.size > 0
      assign gallery_media = product.images
    endif
    if gallery_media.size > 0
      assign has_gallery = true
      assign show_mock_gallery = false
    endif
  else
    assign display_title = mock_title
    assign latin_name = mock_latin_name
    assign difficulty = mock_difficulty
    assign temperature_group = mock_temperature_group
    assign trap_type = mock_trap_type
    assign dormancy_required = mock_dormancy_required
    assign price_cents = mock_price
    assign compare_at_cents = 0
    assign product_description = mock_description
    assign has_gallery = false
    assign show_mock_gallery = true
  endif

  assign temp_group_key = temperature_group | handleize
  assign trap_type_key = trap_type | handleize

  case temp_group_key
    when 'highland'
      assign temp_group_label = 'products.main.temperature_groups.highland' | t
    when 'intermediate'
      assign temp_group_label = 'products.main.temperature_groups.intermediate' | t
    when 'lowland'
      assign temp_group_label = 'products.main.temperature_groups.lowland' | t
    when 'temperate'
      assign temp_group_label = 'products.main.temperature_groups.temperate' | t
    when 'tropical'
      assign temp_group_label = 'products.main.temperature_groups.tropical' | t
    when 'mediterranean'
      assign temp_group_label = 'products.main.temperature_groups.mediterranean' | t
    else
      assign temp_group_label = temperature_group | replace: '-', ' ' | capitalize
  endcase

  case trap_type_key
    when 'snap'
      assign trap_type_label = 'products.main.trap_types.snap' | t
    when 'pitfall'
      assign trap_type_label = 'products.main.trap_types.pitfall' | t
    when 'flypaper'
      assign trap_type_label = 'products.main.trap_types.flypaper' | t
    when 'suction'
      assign trap_type_label = 'products.main.trap_types.suction' | t
    when 'lobster-pot'
      assign trap_type_label = 'products.main.trap_types.lobster_pot' | t
    else
      assign trap_type_label = trap_type | replace: '-', ' ' | capitalize
  endcase

  assign form_id = 'main-product-form-' | append: section.id

  if dormancy_required == true or dormancy_required == 'true'
    assign dormancy_label = 'products.main.dormancy_yes' | t
  else
    assign dormancy_label = 'products.main.dormancy_no' | t
  endif

  assign status_mode = 'cultivating'
  assign status_inventory = 0
  assign tracks_inventory = false

  if use_live_product
    assign status_inventory = current_variant.inventory_quantity | default: 0 | plus: 0
    if current_variant.inventory_management == 'shopify'
      assign tracks_inventory = true
    endif

    if current_variant.available == false
      assign status_mode = 'sold_out'
    elsif tracks_inventory
      if status_inventory > 5
        assign status_mode = 'cultivating'
      elsif status_inventory > 0
        assign status_mode = 'limited'
      else
        assign status_mode = 'sold_out'
      endif
    else
      assign status_mode = 'cultivating'
    endif
  else
    assign status_inventory = mock_inventory
    assign status_mode = 'limited'
  endif
-%}

<article
  class="main-product reveal-up{% if force_mock or use_live_product == false %} main-product--preview{% endif %}"
  data-force-mock="{% if force_mock %}true{% else %}false{% endif %}"
  data-main-product
  data-status-limited-template="{{ 'products.main.status_limited' | t: count: '__COUNT__' | escape }}"
  data-status-cultivating="{{ 'products.main.status_cultivating' | t | escape }}"
  data-label-add="{{ 'products.main.add_to_conservatory' | t | escape }}"
  data-label-sold-out="{{ 'products.main.sold_out' | t | escape }}"
  {{ section.shopify_attributes }}
>
  <div class="main-product__layout">
    <div class="main-product__gallery product__media" data-product-gallery>
      {%- if use_live_product and has_gallery -%}
        {%- for media in gallery_media -%}
          <div class="product__media-item main-product__gallery-frame">
            {%- if forloop.first -%}
              {% render 'wax-seal-badge', product_item: product, mock_tags: mock_tags %}
            {%- endif -%}
              {%- liquid
                assign gallery_loading = 'lazy'
                assign gallery_priority = 'auto'
                if forloop.first
                  assign gallery_loading = 'eager'
                  assign gallery_priority = 'high'
                endif
              -%}
              {{
                media
                | image_url: width: 1600, height: 2000, crop: 'center'
                | image_tag:
                  class: 'main-product__gallery-image',
                  widths: '600, 900, 1200, 1600',
                  sizes: '(min-width: 990px) 48vw, 100vw',
                  loading: gallery_loading,
                  fetchpriority: gallery_priority,
                  alt: media.alt | default: display_title
              }}
          </div>
        {%- endfor -%}
      {%- elsif show_mock_gallery -%}
        {%- comment -%} TODO: replace placeholders — nepenthes-highland-product-01 (placeholder-images.md) {%- endcomment -%}
        <div class="product__media-item main-product__gallery-frame">
          {% render 'wax-seal-badge', product_item: product, mock_tags: mock_tags %}
          <img
            class="main-product__gallery-image main-product__gallery-image--fallback"
            src="{{ mock_gallery_url_1 }}"
            alt="{{ display_title | escape }}"
            width="1600"
            height="2000"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          >
        </div>
        <div class="product__media-item main-product__gallery-frame">
          <img
            class="main-product__gallery-image main-product__gallery-image--fallback"
            src="{{ mock_gallery_url_2 }}"
            alt="{{ latin_name | escape }}"
            width="1600"
            height="2000"
            loading="lazy"
            decoding="async"
          >
        </div>
        <div class="product__media-item main-product__gallery-frame">
          <img
            class="main-product__gallery-image main-product__gallery-image--fallback"
            src="{{ mock_gallery_url_3 }}"
            alt="{{ display_title | escape }}"
            width="1600"
            height="2000"
            loading="lazy"
            decoding="async"
          >
        </div>
      {%- endif -%}
    </div>

    <div class="main-product__dossier" data-product-dossier>
      <header class="main-product__header">
        {%- if latin_name != blank -%}
          <p class="main-product__latin">
            <em>{{ latin_name | escape }}</em>
          </p>
        {%- endif -%}
        <h1 class="main-product__title">{{ display_title | escape }}</h1>
      </header>

      <p class="main-product__price" data-product-price>
        {%- if compare_at_cents > price_cents -%}
          <span class="visually-hidden">{{ 'products.card.price_sale' | t }}</span>
          <span class="main-product__price-sale" data-product-price-sale>{% render 'zar-price', amount_cents: price_cents %}</span>
          <span class="visually-hidden">{{ 'products.card.price_regular' | t }}</span>
          <s class="main-product__price-compare" data-product-price-compare>{% render 'zar-price', amount_cents: compare_at_cents %}</s>
        {%- else -%}
          <span class="main-product__price-regular" data-product-price-regular>{% render 'zar-price', amount_cents: price_cents %}</span>
        {%- endif -%}
      </p>

      <p
        class="main-product__status main-product__status--{{ status_mode }}"
        data-product-status
        data-status-mode="{{ status_mode }}"
        {% if status_mode == 'limited' %}
          data-status-count="{{ status_inventory }}"
        {% endif %}
        {% if status_mode == 'sold_out' %}
          hidden
        {% endif %}
      >
        <span class="main-product__status-dot" aria-hidden="true"></span>
        <span class="main-product__status-text" data-product-status-text>
          {%- if status_mode == 'limited' -%}
            {{ 'products.main.status_limited' | t: count: status_inventory }}
          {%- else -%}
            {{ 'products.main.status_cultivating' | t }}
          {%- endif -%}
        </span>
      </p>

      {%- if use_live_product -%}
        {%- form 'product', product, class: 'main-product__form', id: form_id -%}
          {%- if product.variants.size > 1 -%}
            <div class="main-product__variants">
              <label class="main-product__label" for="main-product-variant-{{ section.id }}">
                {{ 'products.main.variant_label' | t }}
              </label>
              <select
                id="main-product-variant-{{ section.id }}"
                class="main-product__variant-select"
                name="id"
                data-variant-select
              >
                {%- for variant in product.variants -%}
                  <option
                    value="{{ variant.id }}"
                    {% if variant == current_variant %}
                      selected
                    {% endif %}
                    {% unless variant.available %}
                      disabled
                    {% endunless %}
                  >
                    {{ variant.title }}
                    {%- unless variant.available %} — {{ 'products.main.sold_out' | t }}{% endunless -%}
                  </option>
                {%- endfor -%}
              </select>
            </div>
          {%- else -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>
          {%- endif -%}

          <div class="main-product__purchase">
            <div class="main-product__quantity" data-quantity>
              <span class="main-product__label" id="main-product-qty-label-{{ section.id }}">
                {{ 'products.main.quantity' | t }}
              </span>
              <div class="main-product__quantity-control" role="group" aria-labelledby="main-product-qty-label-{{ section.id }}">
                <button
                  type="button"
                  class="main-product__qty-btn"
                  data-qty-minus
                  aria-label="{{ 'products.main.quantity_decrease' | t }}"
                >
                  <span aria-hidden="true">−</span>
                </button>
                <input
                  class="main-product__qty-input"
                  type="number"
                  name="quantity"
                  value="1"
                  min="1"
                  inputmode="numeric"
                  data-qty-input
                  aria-label="{{ 'products.main.quantity' | t }}"
                >
                <button
                  type="button"
                  class="main-product__qty-btn"
                  data-qty-plus
                  aria-label="{{ 'products.main.quantity_increase' | t }}"
                >
                  <span aria-hidden="true">+</span>
                </button>
              </div>
            </div>

            <button
              type="submit"
              class="main-product__submit"
              name="add"
              {% unless current_variant.available %}
                disabled
              {% endunless %}
              data-add-to-cart
            >
              {%- if current_variant.available -%}
                {{ 'products.main.add_to_conservatory' | t }}
              {%- else -%}
                {{ 'products.main.sold_out' | t }}
              {%- endif -%}
            </button>
          </div>
        {%- endform -%}
      {%- else -%}
        <p class="main-product__preview-note">{{ 'products.main.preview_note' | t }}</p>
        <div class="main-product__purchase main-product__purchase--preview">
          <div class="main-product__quantity" data-quantity>
            <span class="main-product__label" id="main-product-qty-label-preview-{{ section.id }}">
              {{ 'products.main.quantity' | t }}
            </span>
            <div
              class="main-product__quantity-control"
              role="group"
              aria-labelledby="main-product-qty-label-preview-{{ section.id }}"
            >
              <button type="button" class="main-product__qty-btn" disabled aria-hidden="true">
                <span aria-hidden="true">−</span>
              </button>
              <input
                class="main-product__qty-input"
                type="number"
                value="1"
                min="1"
                readonly
                tabindex="-1"
                aria-hidden="true"
              >
              <button type="button" class="main-product__qty-btn" disabled aria-hidden="true">
                <span aria-hidden="true">+</span>
              </button>
            </div>
          </div>
          <button type="button" class="main-product__submit" disabled>
            {{ 'products.main.add_to_conservatory' | t }}
          </button>
        </div>
      {%- endif -%}

      <div class="main-product__origin" aria-labelledby="main-product-origin-{{ section.id }}">
        <span class="main-product__origin-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M2 12h20"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
        </span>
        <p id="main-product-origin-{{ section.id }}" class="main-product__origin-text">
          <span class="visually-hidden">{{ 'products.main.origin_heading' | t }}:</span>
          {{ 'products.main.origin_text' | t }}
        </p>
      </div>

      <div class="main-product__accordions" aria-label="{{ 'products.main.accordions_label' | t }}">
        <details class="main-product__accordion">
          <summary class="main-product__accordion-summary">
            {{ 'products.main.accordion_arrival_title' | t }}
          </summary>
          <div class="main-product__accordion-body rte">
            <p>{{ 'products.main.accordion_arrival_body' | t }}</p>
          </div>
        </details>
        <details class="main-product__accordion">
          <summary class="main-product__accordion-summary">
            {{ 'products.main.accordion_lineage_title' | t }}
          </summary>
          <div class="main-product__accordion-body rte">
            <p>{{ 'products.main.accordion_lineage_body' | t }}</p>
          </div>
        </details>
      </div>

      {%- if use_live_product -%}
        <script type="application/json" data-main-product-variants>
          [
            {%- for variant in product.variants -%}
              {
                "id": {{ variant.id | json }},
                "available": {{ variant.available | json }},
                "price": {{ variant.price }},
                "compare_at_price": {{ variant.compare_at_price | default: 0 }},
                "inventory_quantity": {{ variant.inventory_quantity | default: 0 }},
                "inventory_management": {{ variant.inventory_management | json }}
              }{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
          ]
        </script>
      {%- endif -%}

      <section
        class="main-product__cultivation main-product__cultivation-dossier"
        aria-labelledby="main-product-cultivation-{{ section.id }}"
      >
        <h2 id="main-product-cultivation-{{ section.id }}" class="visually-hidden">
          {{ 'products.main.cultivation_heading' | t }}
        </h2>
        <div class="main-product__description rte" data-product-description>
          {{ product_description }}
        </div>
      </section>

      <section class="main-product__field-data" aria-labelledby="main-product-field-data-{{ section.id }}">
        <h2 id="main-product-field-data-{{ section.id }}" class="main-product__field-data-title">
          {{ 'products.main.field_data_heading' | t }}
        </h2>
        <dl class="main-product__field-grid">
          <div class="main-product__field-row">
            <dt>{{ 'products.main.spec_difficulty' | t }}</dt>
            <dd>
              <span class="main-product__field-value">{{ difficulty }}/5</span>
              <span
                class="main-product__difficulty difficulty-pips"
                role="img"
                aria-label="{{ 'products.card.difficulty_label' | t: level: difficulty, max: 5 }}"
              >
                {%- for pip in (1..5) -%}
                  <span
                    class="difficulty-pip{% if pip <= difficulty %} difficulty-pip--filled{% endif %}"
                    aria-hidden="true"
                  ></span>
                {%- endfor -%}
              </span>
            </dd>
          </div>
          <div class="main-product__field-row">
            <dt>{{ 'products.main.spec_temperature' | t }}</dt>
            <dd class="main-product__field-value">{{ temp_group_label | escape }}</dd>
          </div>
          <div class="main-product__field-row">
            <dt>{{ 'products.main.spec_trap' | t }}</dt>
            <dd class="main-product__field-value">{{ trap_type_label | escape }}</dd>
          </div>
          <div class="main-product__field-row">
            <dt>{{ 'products.main.spec_dormancy' | t }}</dt>
            <dd class="main-product__field-value">{{ dormancy_label | escape }}</dd>
          </div>
        </dl>
      </section>
    </div>
  </div>
</article>

{% stylesheet %}
  .main-product {
    padding-block: var(--space-2xl) var(--space-3xl);
  }

  .main-product__layout {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2xl);
    width: min(var(--page-width), calc(100% - var(--page-margin) * 2));
    margin-inline: auto;
  }

  .main-product {
    overflow: visible;
  }

  .main-product__gallery.product__media {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    width: 100%;
    min-width: 0;
    height: auto;
    overflow: visible;
  }

  .product__media-item.main-product__gallery-frame {
    position: relative;
    margin: 0;
    width: 100%;
    overflow: hidden;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .main-product__gallery-image {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center center;
  }

  .main-product__dossier {
    min-width: 0;
    padding: var(--space-xl);
    background-color: var(--color-parchment);
    border: 1px solid var(--color-forest-green-dark);
    border-radius: var(--radius-lg);
    box-shadow: 2px 2px 10px rgb(0 0 0 / 0.05);
  }

  .main-product__header {
    margin-block-end: var(--space-md);
  }

  .main-product__latin {
    margin: 0 0 var(--space-sm);
    font-family: var(--font-family-serif);
    font-size: clamp(1.125rem, 1.5vw + 0.5rem, 1.5rem);
    font-style: italic;
    font-weight: 400;
    line-height: var(--line-height-tight);
    color: var(--color-primary);
  }

  .main-product__latin em {
    font-style: italic;
  }

  .main-product__title {
    margin: 0;
    font-family: var(--font-family-serif);
    font-size: clamp(2rem, 3.5vw + 0.5rem, 3.25rem);
    font-weight: 400;
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tight);
    color: var(--color-forest-green-dark);
  }

  .main-product__price {
    margin: var(--space-lg) 0 var(--space-md);
    font-size: clamp(1.25rem, 2vw + 0.25rem, 1.75rem);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .main-product__price-sale {
    color: var(--color-accent);
    margin-inline-end: var(--space-sm);
  }

  .main-product__price-compare {
    font-size: var(--font-size-md);
    font-weight: 400;
    color: var(--color-text-muted);
  }

  .main-product__status {
    display: flex;
    gap: var(--space-sm);
    align-items: flex-start;
    margin: 0 0 var(--space-lg);
    font-family: 'Courier New', Courier, 'Liberation Mono', monospace;
    font-size: 0.6875rem;
    font-weight: 600;
    line-height: 1.45;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-forest-green-dark);
  }

  .main-product__status-dot {
    flex-shrink: 0;
    width: 8px;
    height: 8px;
    margin-block-start: 0.2rem;
    border-radius: var(--radius-full);
    background-color: var(--color-primary);
  }

  .main-product__status--limited .main-product__status-dot {
    background-color: #c45c2a;
  }

  .main-product__status--cultivating .main-product__status-dot {
    background-color: #3d6b4a;
  }

  .main-product__status-text {
    flex: 1;
    min-width: 0;
  }

  .main-product__label {
    display: block;
    margin-block-end: var(--space-xs);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .main-product__variants {
    margin-block-end: var(--space-lg);
  }

  .main-product__variant-select {
    width: 100%;
    min-height: 2.75rem;
    padding: var(--space-sm) var(--space-md);
    background-color: var(--color-surface-elevated);
    border: 1px solid var(--color-border);
  }

  .main-product__purchase {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    align-items: flex-end;
    margin-block-end: var(--space-xl);
  }

  .main-product__quantity-control {
    display: inline-flex;
    align-items: stretch;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    overflow: hidden;
    background-color: var(--color-surface-elevated);
  }

  .main-product__qty-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    min-height: 2.75rem;
    padding: 0;
    cursor: pointer;
    color: var(--color-text);
    background-color: var(--color-surface);
    border: none;
    transition: background-color var(--transition-fast);
  }

  .main-product__qty-btn:hover {
    background-color: var(--color-border);
