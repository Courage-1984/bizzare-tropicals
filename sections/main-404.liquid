<section
  class="main-404 full-width"
  aria-labelledby="main-404-heading-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="main-404__inner">
    <h1 id="main-404-heading-{{ section.id }}" class="main-404__heading">
      {{- section.settings.heading | escape -}}
    </h1>
    <p class="main-404__subtext">
      {{- section.settings.subtext | escape -}}
    </p>
    {%- if section.settings.message != blank -%}
      <p class="main-404__message">{{ section.settings.message }}</p>
    {%- endif -%}
    <a class="main-404__cta" href="{{ section.settings.cta_link | default: '/collections/all' }}">
      {{- section.settings.cta_label | escape -}}
    </a>
  </div>
</section>

{% stylesheet %}
  .main-404 {
    display: grid;
    place-items: center;
    min-height: clamp(24rem, 70svh, 40rem);
    padding: var(--space-3xl) var(--page-margin);
    color: var(--color-parchment);
    background:
      radial-gradient(ellipse 90% 80% at 50% 20%, rgb(45 74 52 / 0.35) 0%, transparent 55%),
      linear-gradient(165deg, #0a1410 0%, #121f18 45%, #0d1612 100%);
  }

  .main-404__inner {
    width: min(36rem, 100%);
    text-align: center;
  }

  .main-404__heading {
    margin: 0 0 var(--space-md);
    font-family: var(--font-family-serif);
    font-size: clamp(2rem, 5vw + 0.5rem, 3.5rem);
    font-weight: 700;
    line-height: var(--line-height-tight);
    letter-spacing: 0.06em;
    color: #6fa882;
    text-wrap: balance;
  }

  .main-404__subtext {
    margin: 0 0 var(--space-lg);
    font-family: var(--font-family-serif);
    font-size: clamp(1.25rem, 2vw + 0.5rem, 1.5rem);
    font-style: italic;
    line-height: var(--line-height-relaxed);
    color: rgb(244 238 224 / 0.9);
    text-wrap: pretty;
  }

  .main-404__message {
    margin: 0 0 var(--space-2xl);
    font-family: var(--font-family-base);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: rgb(244 238 224 / 0.65);
    text-wrap: pretty;
  }

  .main-404__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: var(--space-sm) var(--space-2xl);
    font-family: var(--font-family-base);
    font-size: var(--font-size-sm);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-primary-hover);
    background-color: var(--color-parchment);
    border: 1px solid rgb(244 238 224 / 0.2);
    border-radius: var(--radius-sm);
    transition:
      background-color var(--transition-fast),
      color var(--transition-fast),
      transform var(--transition-fast);
  }

  .main-404__cta:hover {
    color: var(--color-text-inverse);
    background-color: var(--color-accent);
    transform: translate3d(0, -2px, 0);
  }

  @media (prefers-reduced-motion: reduce) {
    .main-404__cta:hover {
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.main_404.name",
  "tag": "section",
  "class": "main-404-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.main_404.settings.heading",
      "default": "404 - PAGE NOT FOUND"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "t:sections.main_404.settings.subtext",
      "default": "Abandoned Greenhouse"
    },
    {
      "type": "textarea",
      "id": "message",
      "label": "t:sections.main_404.settings.message",
      "info": "t:sections.main_404.settings.message_info"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "t:sections.main_404.settings.cta_label",
      "default": "Return to conservatory"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "t:sections.main_404.settings.cta_link",
      "default": "/collections/all"
    }
  ]
}
{% endschema %}
