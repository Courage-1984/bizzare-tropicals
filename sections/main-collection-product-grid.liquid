{%- liquid
  capture collection_display_title
    render 'collection-display-title', collection: collection
  endcapture
  assign collection_heading = collection_display_title | strip
  if collection_heading == blank
    assign collection_heading = collection.title | strip
  endif
  if collection_heading == blank
    assign collection_heading = 'general.collection' | t
  endif

  assign grid_heading = section.settings.heading | strip
  if grid_heading == blank
    assign grid_heading = collection_heading
  endif

  assign active_filter_count = 0
  for filter in collection.filters
    if filter.type == 'price_range'
      if filter.min_value.value != blank or filter.max_value.value != blank
        assign active_filter_count = active_filter_count | plus: 1
      endif
    else
      assign active_filter_count = active_filter_count | plus: filter.active_values.size
    endif
  endfor
-%}

<section
  class="collection-grid-section"
  data-collection-grid-section
  data-section-id="{{ section.id }}"
  aria-labelledby="collection-grid-heading-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <header class="collection-grid-section__header">
    <div class="collection-grid-section__heading-group">
      <h2 id="collection-grid-heading-{{ section.id }}" class="collection-grid-section__title">
        {{ grid_heading | escape }}
      </h2>
      {%- if collection.products_count > 0 -%}
        <p class="collection-grid-section__count" data-collection-product-count>
          {{ 'sections.main_collection_product_grid.product_count' | t: count: collection.products_count }}
        </p>
      {%- endif -%}
    </div>

    <div class="collection-grid-section__actions">
      {%- unless collection.handle == 'all' -%}
        <a
          class="collection-grid-section__reset-link link-underline-grow"
          href="{{ routes.all_products_collection_url }}"
          data-collection-reset-view
        >
          {{ 'sections.main_collection_product_grid.view_all_products' | t }}
        </a>
      {%- endunless -%}
      <button
        type="button"
        class="collection-grid-section__filter-trigger"
        data-cultivation-filter-open
        aria-expanded="false"
        aria-controls="cultivation-filter-drawer-{{ section.id }}"
      >
        <span class="collection-grid-section__filter-trigger-label">
          {{ 'sections.main_collection_product_grid.filter_trigger' | t }}
        </span>
        {%- if active_filter_count > 0 -%}
          <span class="collection-grid-section__filter-badge" data-cultivation-filter-badge aria-hidden="true">
            {{- active_filter_count -}}
          </span>
        {%- else -%}
          <span class="collection-grid-section__filter-badge" data-cultivation-filter-badge hidden aria-hidden="true">0</span>
        {%- endif -%}
      </button>
    </div>
  </header>

  {% render 'cultivation-filter-drawer', collection: collection, section_id: section.id %}

  <div id="CollectionProductGrid-{{ section.id }}" data-collection-product-grid>
    {%- paginate collection.products by 24 -%}
      {%- if collection.products.size > 0 -%}
        <ul class="collection-grid collection-grid--bento" role="list" data-collection-grid-list data-reveal-stagger>
          {%- assign page_offset = paginate.current_page | minus: 1 | times: paginate.page_size -%}
          {%- assign rendered_product_ids = '' -%}
          {%- for product in collection.products -%}
            {%- assign product_id_marker = product.id | append: '|' -%}
            {%- unless rendered_product_ids contains product_id_marker -%}
              {%- assign rendered_product_ids = rendered_product_ids | append: product_id_marker -%}
              {%- liquid
                assign absolute_index = page_offset | plus: forloop.index0
                assign variant_seed = product.id | plus: absolute_index | modulo: 17
                assign items_remaining = paginate.page_size | minus: forloop.index
                assign bento_variant = 'collection-grid__item--base'

                if items_remaining > 4
                  if variant_seed == 0 or variant_seed == 8 or variant_seed == 13
                    assign bento_variant = 'collection-grid__item--wide'
                  elsif variant_seed == 2 or variant_seed == 10
                    assign bento_variant = 'collection-grid__item--tall'
                  elsif variant_seed == 6
                    assign bento_variant = 'collection-grid__item--compact'
                  elsif variant_seed == 5
                    assign hero_gate = absolute_index | modulo: 24
                    if hero_gate == 0
                      assign bento_variant = 'collection-grid__item--hero'
                    else
                      assign bento_variant = 'collection-grid__item--wide'
                    endif
                  endif
                endif
              -%}
              <li
                class="collection-grid__item {{ bento_variant }} reveal-up"
                role="listitem"
                data-product-id="{{ product.id }}"
              >
                {% render 'product-card',
                  product_item: product,
                  card_index: absolute_index,
                  show_specimen_id: false,
                  sizes: '(min-width: 990px) 22vw, (min-width: 750px) 24vw, 46vw'
                %}
              </li>
            {%- endunless -%}
          {%- endfor -%}
        </ul>

        {%- if paginate.next -%}
          <div class="collection-load-more" data-collection-load-more-wrap>
            <button
              type="button"
              class="collection-load-more__button collection-load-more__button--field-guide"
              data-collection-load-more
              data-next-url="{{ paginate.next.url }}"
            >
              {{ 'sections.main_collection_product_grid.load_more' | t }}
            </button>
          </div>
        {%- else -%}
          <div class="collection-load-more" data-collection-load-more-wrap hidden></div>
        {%- endif -%}
      {%- else -%}
        <p class="collection-grid-section__empty">
          {{ 'sections.main_collection_product_grid.empty' | t }}
        </p>
        <ul
          class="collection-grid collection-grid--bento collection-grid--preview"
          role="list"
          aria-label="{{ 'sections.main_collection_product_grid.preview_label' | t }}"
          {% unless request.design_mode %}
            hidden
          {% endunless %}
        >
          {%- for i in (1..12) -%}
            <li class="collection-grid__item collection-grid__item--base reveal-up" role="listitem">
              {% render 'product-card',
                card_index: forloop.index0,
                show_specimen_id: false,
                sizes: '(min-width: 990px) 22vw, (min-width: 750px) 24vw, 46vw'
              %}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% stylesheet %}
  .collection-grid-section {
    padding-block: var(--space-xl) var(--space-4xl);
  }

  .collection-grid-section__header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm) var(--space-lg);
    margin-block-end: var(--space-xl);
  }

  .collection-grid-section__heading-group {
    flex: 1 1 auto;
    min-width: min(100%, 12rem);
  }

  .collection-grid-section__title {
    margin: 0;
    font-size: clamp(1.25rem, 2vw + 0.5rem, 1.75rem);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-tight);
  }

  .collection-grid-section__count {
    margin: var(--space-2xs) 0 0;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .collection-grid-section__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-sm) var(--space-md);
  }

  .collection-grid-section__reset-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.75rem;
    padding: var(--space-sm) var(--space-md);
    font-family: 'Courier New', Courier, 'Liberation Mono', monospace;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-forest-green-dark);
    background-color: rgb(10 24 18 / 0.04);
    border: 1px solid rgb(10 24 18 / 0.22);
    border-radius: var(--radius-sm);
    transition:
      background-color 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .collection-grid-section__reset-link:hover {
    background-color: rgb(10 24 18 / 0.08);
    border-color: var(--color-forest-green-dark);
  }

  .collection-grid-section__filter-trigger {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    min-height: 2.75rem;
    padding: var(--space-sm) var(--space-lg);
    font-family: var(--font-family-base);
    font-size: var(--font-size-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    color: var(--color-forest-green-dark);
    background-color: var(--color-parchment);
    border: 1px solid var(--color-forest-green-dark);
    border-radius: var(--radius-sm);
    transition:
      background-color 0.8s cubic-bezier(0.25, 1, 0.5, 1),
      color 0.8s cubic-bezier(0.25, 1, 0.5, 1),
      transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .collection-grid-section__filter-trigger:hover {
    color: var(--color-text-inverse);
    background-color: var(--color-forest-green-dark);
    transform: translate3d(0, -1px, 0);
  }

  .collection-grid-section__filter-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.25rem;
    height: 1.25rem;
    padding-inline: 0.3rem;
    font-size: 0.625rem;
    font-weight: 700;
    line-height: 1;
    color: var(--color-parchment);
    background-color: var(--color-forest-green-dark);
    border-radius: var(--radius-full);
    transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .collection-grid-section__filter-trigger:hover .collection-grid-section__filter-badge {
    color: var(--color-forest-green-dark);
    background-color: var(--color-parchment);
  }

  .collection-grid-section__empty {
    margin: 0 0 var(--space-xl);
    font-size: var(--font-size-md);
    color: var(--color-text-muted);
  }

  .collection-grid-section--busy [data-collection-product-grid] {
    opacity: 0.55;
    pointer-events: none;
    transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  /* Cultivation filter drawer — styles live in snippets/cultivation-filter-drawer.liquid */

  @media (max-width: 989px) {
    .collection-grid-section--filters-open [data-collection-product-grid] {
      pointer-events: none;
    }

    .collection-grid-section--filters-open .collection-grid-section__header {
      position: relative;
      z-index: calc(var(--z-drawer) + 6);
    }
  }

  .collection-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-md);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .collection-grid__item {
    min-width: 0;
    overflow: visible;
    align-self: start;
  }

  .collection-grid--bento .collection-grid__item--base .product-card__media {
    aspect-ratio: 1 / 1;
  }

  .collection-grid--bento .collection-grid__item--wide .product-card__media {
    aspect-ratio: 16 / 10;
  }

  .collection-grid--bento .collection-grid__item--tall .product-card__media,
  .collection-grid--bento .collection-grid__item--hero .product-card__media {
    aspect-ratio: 4 / 5;
  }

  .collection-grid--bento .collection-grid__item--compact .product-card__media {
    aspect-ratio: 1 / 1;
  }

  .collection-load-more {
    display: flex;
    justify-content: center;
    margin-block-start: var(--space-2xl);
  }

  .collection-load-more__button {
    min-height: 3rem;
    padding: var(--space-sm) var(--space-2xl);
    font-family: var(--font-family-base);
    font-size: var(--font-size-xs);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition:
      background-color 0.8s cubic-bezier(0.25, 1, 0.5, 1),
      color 0.8s cubic-bezier(0.25, 1, 0.5, 1),
      border-color 0.8s cubic-bezier(0.25, 1, 0.5, 1),
      transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .collection-load-more__button--field-guide {
    color: var(--color-forest-green-dark);
    background-color: transparent;
    border: 1px solid var(--color-forest-green-dark);
  }

  .collection-load-more__button--field-guide:hover:not(:disabled) {
    color: var(--color-parchment);
    background-color: var(--color-forest-green-dark);
    transform: translate3d(0, -2px, 0);
  }

  .collection-load-more__button:disabled {
    cursor: wait;
    opacity: 0.65;
  }

  @media (min-width: 990px) {
    .collection-grid-section__filter-trigger {
      display: none;
    }
  }

  @media (min-width: 750px) {
    .collection-grid {
      gap: var(--space-lg);
    }
  }

  @media (min-width: 990px) {
    .collection-grid--bento {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: minmax(12rem, auto);
      grid-auto-flow: dense;
      align-items: start;
      gap: var(--space-lg);
    }

    .collection-grid--bento .collection-grid__item--hero {
      grid-column: span 2;
      grid-row: span 2;
    }

    .collection-grid--bento .collection-grid__item--wide {
      grid-column: span 2;
      grid-row: span 1;
    }

    .collection-grid--bento .collection-grid__item--tall {
      grid-column: span 1;
      grid-row: span 2;
    }

    .collection-grid--bento .collection-grid__item--compact {
      grid-column: span 1;
      grid-row: span 1;
    }

    .collection-grid--bento .collection-grid__item--base {
      grid-column: span 1;
      grid-row: span 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .collection-grid-section__filter-trigger,
    .collection-grid-section__filter-badge,
    .collection-load-more__button,
    .collection-grid-section--busy [data-collection-product-grid] {
      transition: none;
    }

    .collection-load-more__button:hover:not(:disabled) {
      transform: none;
    }

    .collection-grid-section__filter-trigger:hover {
      transform: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    'use strict';

    function initCollectionReveal(scope) {
      if (window.ThemeReveal) {
        if (scope) {
          window.ThemeReveal.reset(scope);
        }
        window.ThemeReveal.init(scope || document);
      }
    }

    function getCollectionSection(root) {
      return root.closest('[data-collection-grid-section]');
    }

    function mergeFacetSearchParams(form) {
      var merged = new URLSearchParams();
      var formParams = new URLSearchParams(new FormData(form));
      var current = new URLSearchParams(window.location.search);
      var preserveKeys = ['sort_by', 'view', 'q'];

      preserveKeys.forEach(function (key) {
        if (current.has(key) && !formParams.has(key)) {
          merged.set(key, current.get(key));
        }
      });

      formParams.forEach(function (value, key) {
        merged.append(key, value);
      });

      return merged;
    }

    function buildFacetUrl(form, sectionId) {
      var url = new URL(form.action, window.location.origin);
      var params = mergeFacetSearchParams(form);

      params.forEach(function (value, key) {
        url.searchParams.append(key, value);
      });

      url.searchParams.set('section_id', sectionId);
      return url;
    }

    function setFiltersDrawerOpen(section, open) {
      if (!section) {
        return;
      }

      section.classList.toggle('collection-grid-section--filters-open', open);
    }

    function updateFilterBadge(section, count) {
      var badge = section.querySelector('[data-cultivation-filter-badge]');
      if (!badge) {
        return;
      }

      if (count > 0) {
        badge.textContent = String(count);
        badge.hidden = false;
      } else {
        badge.hidden = true;
      }
    }

    function renderCollectionSection(section, html) {
      var parser = new DOMParser();
      var doc = parser.parseFromString(html, 'text/html');
      var sectionId = section.dataset.sectionId;
      var incomingWrapper = doc.getElementById('shopify-section-' + sectionId);
      var incomingSection = incomingWrapper
        ? incomingWrapper.querySelector('[data-collection-grid-section]')
        : doc.querySelector('[data-collection-grid-section]');

      if (!incomingSection) {
        return;
      }

      section.innerHTML = incomingSection.innerHTML;
      bindCultivationFilter(section);
      initCollectionReveal(section);
    }

    function setFilterBusy(section, busy) {
      section.classList.toggle('collection-grid-section--busy', busy);
      var drawer = section.querySelector('[data-cultivation-filter]');
      if (drawer) {
        drawer.classList.toggle('cultivation-filter--busy', busy);
      }
    }

    function submitFacetForm(form, section) {
      var sectionId = section.dataset.sectionId;
      if (!sectionId) {
        return Promise.resolve();
      }

      setFilterBusy(section, true);
      var url = buildFacetUrl(form, sectionId);

      return fetch(url.toString(), {
        credentials: 'same-origin',
        headers: { Accept: 'text/html' },
      })
        .then(function (response) {
          if (!response.ok) {
            throw new Error('Collection filter: section render failed.');
          }
          return response.text();
        })
        .then(function (html) {
          renderCollectionSection(section, html);
          var nextUrl = new URL(form.action, window.location.origin);
          var params = mergeFacetSearchParams(form);

          params.forEach(function (value, key) {
            nextUrl.searchParams.append(key, value);
          });
          window.history.replaceState({}, '', nextUrl.pathname + nextUrl.search);
        })
        .catch(function (error) {
          console.error(error);
        })
        .finally(function () {
          setFilterBusy(section, false);
        });
    }

    function openFilterDrawer(drawer, trigger, section) {
      drawer.classList.add('is-open');
      drawer.setAttribute('aria-hidden', 'false');
      var panel = drawer.querySelector('[data-cultivation-filter-panel]');
      var overlay = drawer.querySelector('[data-cultivation-filter-overlay]');

      if (panel) {
        panel.setAttribute('aria-hidden', 'false');
      }

      if (overlay) {
        overlay.hidden = false;
      }

      if (trigger) {
        trigger.setAttribute('aria-expanded', 'true');
      }

      setFiltersDrawerOpen(section || getCollectionSection(drawer), true);
      document.documentElement.classList.add('is-scroll-locked');
    }

    function closeFilterDrawer(drawer, trigger, section) {
      drawer.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
      var panel = drawer.querySelector('[data-cultivation-filter-panel]');
      var overlay = drawer.querySelector('[data-cultivation-filter-overlay]');

      if (panel) {
        panel.setAttribute('aria-hidden', 'true');
      }

      if (overlay) {
        overlay.hidden = true;
      }

      if (trigger) {
        trigger.setAttribute('aria-expanded', 'false');
        trigger.focus();
      }

      setFiltersDrawerOpen(section || getCollectionSection(drawer), false);
      document.documentElement.classList.remove('is-scroll-locked');
    }

    function bindCultivationFilter(scope) {
      var section = getCollectionSection(scope) || scope;
      if (!section || !section.matches('[data-collection-grid-section]')) {
        return;
      }

      var drawer = section.querySelector('[data-cultivation-filter]');
      var trigger = section.querySelector('[data-cultivation-filter-open]');
      var form = section.querySelector('[data-cultivation-facet-form]');

      if (!drawer || !form) {
        return;
      }

      if (drawer.dataset.cultivationFilterBound === 'true') {
        return;
      }

      drawer.dataset.cultivationFilterBound = 'true';

      function syncFilterPresentation() {
        var isDesktop = false;
        try {
          isDesktop = window.matchMedia('(min-width: 990px)').matches;
        } catch (error) {
          isDesktop = false;
        }

        if (isDesktop) {
          drawer.setAttribute('aria-hidden', 'false');
          drawer.classList.remove('is-open');
        } else if (!drawer.classList.contains('is-open')) {
          drawer.setAttribute('aria-hidden', 'true');
        }
      }

      syncFilterPresentation();

      var overlay = drawer.querySelector('[data-cultivation-filter-overlay]');
      var closeButtons = drawer.querySelectorAll('[data-cultivation-filter-close]');
      var clearButtons = drawer.querySelectorAll('[data-cultivation-filter-clear]');
      var inputs = drawer.querySelectorAll('[data-cultivation-facet-input]');

      if (trigger) {
        trigger.addEventListener('click', function () {
          if (drawer.classList.contains('is-open')) {
            closeFilterDrawer(drawer, trigger, section);
          } else {
            openFilterDrawer(drawer, trigger, section);
          }
        });
      }

      closeButtons.forEach(function (button) {
        button.addEventListener('click', function () {
          closeFilterDrawer(drawer, trigger, section);
        });
      });

      if (overlay) {
        overlay.addEventListener('click', function () {
          closeFilterDrawer(drawer, trigger, section);
        });
      }

      inputs.forEach(function (input) {
        input.addEventListener('change', function () {
          submitFacetForm(form, section);
        });
      });

      var priceInputs = drawer.querySelectorAll('[data-cultivation-price-input]');
      var priceDebounceTimer = null;

      priceInputs.forEach(function (input) {
        input.addEventListener('change', function () {
          submitFacetForm(form, section);
        });

        input.addEventListener('input', function () {
          if (priceDebounceTimer) {
            clearTimeout(priceDebounceTimer);
          }

          priceDebounceTimer = setTimeout(function () {
            submitFacetForm(form, section);
          }, 500);
        });
      });

      clearButtons.forEach(function (clearButton) {
        clearButton.addEventListener('click', function () {
          inputs.forEach(function (input) {
            if (input.type === 'checkbox') {
              input.checked = false;
            } else if (input.type === 'number') {
              input.value = '';
            }
          });
          submitFacetForm(form, section);
        });
      });

      bindLoadMore(section);
    }

    function bindLoadMore(section) {
      var button = section.querySelector('[data-collection-load-more]');
      if (!button || button.dataset.loadMoreBound === 'true') {
        return;
      }

      button.dataset.loadMoreBound = 'true';

      button.addEventListener('click', function () {
        loadMoreProducts(section, button);
      });
    }

    function loadMoreProducts(section, button) {
      var nextUrl = button.getAttribute('data-next-url');
      var sectionId = section.dataset.sectionId;

      if (!nextUrl || !sectionId || button.disabled) {
        return;
      }

      button.disabled = true;

      var url = new URL(nextUrl, window.location.origin);
      url.searchParams.set('section_id', sectionId);

      fetch(url.toString(), {
        credentials: 'same-origin',
        headers: { Accept: 'text/html' },
      })
        .then(function (response) {
          if (!response.ok) {
            throw new Error('Collection grid: load more failed.');
          }
          return response.text();
        })
        .then(function (html) {
          var parser = new DOMParser();
          var doc = parser.parseFromString(html, 'text/html');
          var incomingList = doc.querySelector('[data-collection-grid-list]');
          var list = section.querySelector('[data-collection-grid-list]');

          if (!incomingList || !list) {
            return;
          }

          var existingIds = new Set();
          list.querySelectorAll('[data-product-id]').forEach(function (item) {
            var id = item.getAttribute('data-product-id');
            if (id) {
              existingIds.add(id);
            }
          });

          var newItems = incomingList.querySelectorAll('.collection-grid__item');
          newItems.forEach(function (item) {
            var productId = item.getAttribute('data-product-id');
            if (productId && existingIds.has(productId)) {
              return;
            }
            if (productId) {
              existingIds.add(productId);
            }
            list.appendChild(item);
          });

          initCollectionReveal(list);

          var incomingButton = doc.querySelector('[data-collection-load-more]');
          var wrap = section.querySelector('[data-collection-load-more-wrap]');

          if (incomingButton && incomingButton.getAttribute('data-next-url')) {
            button.setAttribute('data-next-url', incomingButton.getAttribute('data-next-url'));
            button.disabled = false;
          } else if (wrap) {
            wrap.hidden = true;
          }
        })
        .catch(function (error) {
          console.error(error);
          button.disabled = false;
        });
    }

    function initAll(scope) {
      var root = scope || document;
      initCollectionReveal(root);
      root.querySelectorAll('[data-collection-grid-section]').forEach(function (section) {
        bindCultivationFilter(section);
      });
    }

    document.addEventListener('keydown', function (event) {
      if (event.key !== 'Escape') {
        return;
      }

      var openDrawer = document.querySelector('.cultivation-filter.is-open');
      if (!openDrawer) {
        return;
      }

      var section = getCollectionSection(openDrawer);
      var trigger = section ? section.querySelector('[data-cultivation-filter-open]') : null;
      closeFilterDrawer(openDrawer, trigger, section);
    });

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        initAll();
      });
    } else {
      initAll();
    }

    document.addEventListener('shopify:section:load', function (event) {
      initAll(event.target);
    });
  })();
{% endjavascript %}

