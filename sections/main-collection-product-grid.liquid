{%- liquid
  assign grid_heading = section.settings.heading
  if grid_heading == blank
    assign grid_heading = collection.title
  endif
-%}

<section
  class="collection-grid-section"
  data-bento-reveal
  aria-labelledby="collection-grid-heading-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <header class="collection-grid-section__header">
    <h2 id="collection-grid-heading-{{ section.id }}" class="collection-grid-section__title">
      {{ grid_heading | escape }}
    </h2>
    {%- if collection.products_count > 0 -%}
      <p class="collection-grid-section__count">
        {{ 'sections.main_collection_product_grid.product_count' | t: count: collection.products_count }}
      </p>
    {%- endif -%}
  </header>

  {%- paginate collection.products by 24 -%}
    {%- if collection.products.size > 0 -%}
      <ul class="collection-grid collection-grid--bento" role="list">
        {%- for product in collection.products -%}
          <li class="collection-grid__item" role="listitem" data-bento-item>
            {% render 'product-card',
              product_item: product,
              card_index: forloop.index0,
              sizes: '(min-width: 990px) 22vw, (min-width: 750px) 24vw, 46vw'
            %}
          </li>
        {%- endfor -%}
      </ul>

      {%- if paginate.pages > 1 -%}
        <nav class="collection-pagination" aria-label="{{ 'sections.main_collection_product_grid.pagination' | t }}">
          {{ paginate | default_pagination }}
        </nav>
      {%- endif -%}
    {%- else -%}
      <ul
        class="collection-grid collection-grid--bento collection-grid--preview"
        role="list"
        aria-label="{{ 'sections.main_collection_product_grid.preview_label' | t }}"
      >
        {%- for i in (1..12) -%}
          <li class="collection-grid__item" role="listitem" data-bento-item>
            {% render 'product-card',
              card_index: forloop.index0,
              sizes: '(min-width: 990px) 22vw, (min-width: 750px) 24vw, 46vw'
            %}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  {%- endpaginate -%}
</section>

{% stylesheet %}
  .collection-grid-section {
    padding-block: var(--space-xl) var(--space-4xl);
  }

  .collection-grid-section__header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-sm) var(--space-lg);
    margin-block-end: var(--space-xl);
  }

  .collection-grid-section__title {
    margin: 0;
    font-size: clamp(1.25rem, 2vw + 0.5rem, 1.75rem);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-tight);
  }

  .collection-grid-section__count {
    margin: 0;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .collection-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-md);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .collection-grid__item {
    min-width: 0;
    overflow: visible;
  }

  .collection-grid--bento .collection-grid__item {
    opacity: 0;
    transform: translate3d(0, 30px, 0);
    transition:
      opacity 0.65s cubic-bezier(0.25, 1, 0.5, 1),
      transform 0.65s cubic-bezier(0.25, 1, 0.5, 1);
    will-change: transform, opacity;
  }

  .collection-grid--bento .collection-grid__item.is-revealed {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .collection-grid--bento .product-card__media {
    aspect-ratio: 1 / 1;
  }

  .collection-grid--bento .collection-grid__item:nth-child(1) .product-card__media,
  .collection-grid--bento .collection-grid__item:nth-child(10) .product-card__media {
    aspect-ratio: 4 / 5;
  }

  .collection-grid--bento .collection-grid__item:nth-child(4) .product-card__media,
  .collection-grid--bento .collection-grid__item:nth-child(12) .product-card__media {
    aspect-ratio: 16 / 9;
  }

  .collection-pagination {
    margin-block-start: var(--space-2xl);
  }

  .collection-pagination :is(.pagination, nav) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
  }

  .collection-pagination a,
  .collection-pagination span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    min-height: 2.5rem;
    padding: var(--space-xs) var(--space-sm);
    font-size: var(--font-size-sm);
    text-decoration: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  .collection-pagination a:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .collection-pagination .current,
  .collection-pagination [aria-current='page'] {
    font-weight: 600;
    color: var(--color-text-inverse);
    background-color: var(--color-primary);
    border-color: var(--color-primary);
  }

  @media (min-width: 750px) {
    .collection-grid {
      gap: var(--space-lg);
    }
  }

  @media (min-width: 990px) {
    .collection-grid--bento {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: minmax(12rem, auto);
      gap: var(--space-lg);
    }

    .collection-grid--bento .collection-grid__item:nth-child(1),
    .collection-grid--bento .collection-grid__item:nth-child(10) {
      grid-column: span 2;
      grid-row: span 2;
    }

    .collection-grid--bento .collection-grid__item:nth-child(4),
    .collection-grid--bento .collection-grid__item:nth-child(12) {
      grid-column: span 2;
      grid-row: span 1;
    }

    .collection-grid--bento .collection-grid__item:not(:nth-child(1)):not(:nth-child(4)):not(:nth-child(10)):not(:nth-child(12)) {
      grid-column: span 1;
      grid-row: span 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .collection-grid--bento .collection-grid__item {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    'use strict';

    function initBentoReveal(scope) {
      var root = scope || document;
      var sections = root.querySelectorAll('[data-bento-reveal]');

      sections.forEach(function (section) {
        if (section.dataset.bentoRevealInitialized === 'true') {
          return;
        }

        var items = section.querySelectorAll('[data-bento-item]');
        if (!items.length) {
          return;
        }

        var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (prefersReducedMotion) {
          items.forEach(function (item) {
            item.classList.add('is-revealed');
          });
          section.dataset.bentoRevealInitialized = 'true';
          return;
        }

        var staggerIndex = 0;
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (!entry.isIntersecting) {
                return;
              }

              var item = entry.target;
              var delay = staggerIndex * 0.08;
              staggerIndex += 1;
              item.style.transitionDelay = delay + 's';
              item.classList.add('is-revealed');
              observer.unobserve(item);
            });
          },
          {
            root: null,
            rootMargin: '0px 0px -8% 0px',
            threshold: 0.12,
          }
        );

        items.forEach(function (item) {
          observer.observe(item);
        });

        section.dataset.bentoRevealInitialized = 'true';
      });
    }

    function initAll(scope) {
      initBentoReveal(scope);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        initAll();
      });
    } else {
      initAll();
    }

    document.addEventListener('shopify:section:load', function (event) {
      initAll(event.target);
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.main_collection_product_grid.name",
  "tag": "section",
  "class": "main-collection-product-grid-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.main_collection_product_grid.settings.heading",
      "info": "t:sections.main_collection_product_grid.settings.heading_info"
    }
  ]
}
{% endschema %}
