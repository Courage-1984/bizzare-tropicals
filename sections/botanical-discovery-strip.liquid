{%- liquid
  assign anchor_heading = section.settings.anchor_heading | strip
  if anchor_heading == blank
    assign anchor_heading = 'Shop plants and accessories below!'
  endif
  assign anchor_color = section.settings.anchor_color | default: '#c41e3a'
  assign transition_ease = 'cubic-bezier(0.25, 0.46, 0.45, 0.94)'
  assign card_min_height = section.settings.card_min_height | default: 320
  assign has_valid_cards = false
-%}

<section
  class="botanical-discovery-strip full-width reveal-up"
  data-discovery-strip
  aria-labelledby="discovery-strip-anchor-{{ section.id }}"
  style="
    --discovery-anchor-color: {{ anchor_color }};
    --discovery-card-min-height: {{ card_min_height }}px;
    --discovery-transition-ease: {{ transition_ease }};
  "
  {{ section.shopify_attributes }}
>
  {%- if anchor_heading != blank -%}
    <h2 id="discovery-strip-anchor-{{ section.id }}" class="botanical-discovery-strip__anchor">
      {{ anchor_heading | escape }}
    </h2>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div
      class="botanical-discovery-strip__grid"
      data-discovery-grid
      data-reveal-stagger
      role="list"
    >
      {%- assign discovery_card_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'discovery_card' -%}
          {%- assign discovery_card_index = discovery_card_index | plus: 1 -%}
          {%- liquid
            assign card_collection = block.settings.collection
            assign card_title = block.settings.title | strip
            assign card_description = block.settings.description | strip
            assign card_link = block.settings.link | strip
            assign card_image = block.settings.image
            assign card_placeholder = block.settings.placeholder_image | strip
            assign use_shopify_image = false

            if card_collection != blank
              if card_title == blank
                capture collection_display_title
                  render 'collection-display-title', collection: card_collection
                endcapture
                assign card_title = collection_display_title | strip
              endif
              if card_link == blank
                assign card_link = card_collection.url
              endif
            endif

            if card_image != blank and card_image.width > 0
              assign use_shopify_image = true
            elsif card_placeholder != blank
              assign use_shopify_image = false
            else
              if card_collection != blank
                if card_collection.image != blank and card_collection.image.width > 0
                  assign card_image = card_collection.image
                  assign use_shopify_image = true
                endif
                if use_shopify_image == false
                  assign fallback_product = card_collection.products.first
                  if fallback_product != blank
                    assign fallback_media = fallback_product.featured_media.preview_image | default: fallback_product.featured_image
                    if fallback_media != blank and fallback_media.width > 0
                      assign card_image = fallback_media
                      assign use_shopify_image = true
                    endif
                  endif
                endif
              endif

              if use_shopify_image == false and card_collection != blank
                assign genus_handle = card_collection.handle
                capture card_placeholder
                  render 'genus-placeholder-url', genus_handle: genus_handle
                endcapture
                assign card_placeholder = card_placeholder | strip
              endif

              if use_shopify_image == false and card_placeholder == blank
                assign discovery_card_key = blank
                if card_link contains '/pages/about-us'
                  assign discovery_card_key = 'tissue_culture'
                elsif card_link contains '/collections/growing-supplies'
                  assign discovery_card_key = 'supplies'
                elsif card_link contains 'sort_by=created-descending'
                  assign discovery_card_key = 'new_arrivals'
                elsif discovery_card_index == 1
                  assign discovery_card_key = 'beginner'
                elsif discovery_card_index == 2
                  assign discovery_card_key = 'tissue_culture'
                elsif discovery_card_index == 3
                  assign discovery_card_key = 'supplies'
                elsif discovery_card_index == 4
                  assign discovery_card_key = 'new_arrivals'
                endif
                capture card_placeholder
                  render 'discovery-card-placeholder-url', card_key: discovery_card_key
                endcapture
                assign card_placeholder = card_placeholder | strip
              endif
            endif
          -%}

          {%- if card_title != blank and card_link != blank -%}
            {%- assign has_valid_cards = true -%}
            <div class="botanical-discovery-strip__cell reveal-up" role="listitem" {{ block.shopify_attributes }}>
              <a
                class="discovery-card"
                href="{{ card_link }}"
                data-discovery-card
              >
                <span class="discovery-card__media" aria-hidden="true">
                  {%- if use_shopify_image -%}
                    {{
                      card_image
                      | image_url: width: 1200, height: 1500, crop: 'center'
                      | image_tag:
                        class: 'discovery-card__image',
                        widths: '400, 600, 800, 1000, 1200',
                        sizes: '(min-width: 990px) 25vw, (min-width: 480px) 50vw, 85vw',
                        loading: 'lazy',
                        alt: ''
                    }}
                  {%- elsif card_placeholder != blank -%}
                    <img
                      class="discovery-card__image"
                      src="{{ card_placeholder | escape }}"
                      alt=""
                      width="1200"
                      height="1500"
                      loading="lazy"
                      decoding="async"
                    >
                  {%- else -%}
                    <span class="discovery-card__image discovery-card__image--placeholder"></span>
                  {%- endif -%}
                </span>

                <span class="discovery-card__overlay" aria-hidden="true"></span>

                <span class="discovery-card__content">
                  <span class="discovery-card__title">{{ card_title | escape }}</span>
                  {%- if card_description != blank -%}
                    <span class="discovery-card__description">{{ card_description | escape }}</span>
                  {%- endif -%}
                </span>

                <span class="visually-hidden">
                  {{- 'sections.botanical_discovery_strip.card_label' | t: title: card_title -}}
                </span>
              </a>
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- if has_valid_cards == false -%}
    <p class="botanical-discovery-strip__empty">{{ 'sections.botanical_discovery_strip.empty' | t }}</p>
  {%- endif -%}
</section>

{% stylesheet %}
  .botanical-discovery-strip-section.shopify-section {
    display: block;
    grid-template-columns: none;
  }

  .botanical-discovery-strip-section.shopify-section > * {
    grid-column: auto;
  }

  .botanical-discovery-strip {
    --discovery-overlay-idle: 0.2;
    --discovery-overlay-hover: 0.6;
    --discovery-overlay-touch: 0.45;
    padding-block: var(--space-2xl) var(--space-3xl);
    padding-inline: var(--page-margin);
    background-color: var(--color-forest-green-dark);
  }

  .botanical-discovery-strip__anchor {
    margin: 0 0 var(--space-xl);
    font-family: var(--font-family-base);
    font-size: clamp(1.125rem, 2.5vw + 0.5rem, 1.75rem);
    font-weight: 700;
    line-height: var(--line-height-tight);
    letter-spacing: 0.14em;
    text-align: center;
    text-transform: uppercase;
    color: var(--discovery-anchor-color);
  }

  .botanical-discovery-strip__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .botanical-discovery-strip__cell {
    min-width: 0;
  }

  .discovery-card {
    position: relative;
    display: block;
    min-height: var(--discovery-card-min-height);
    overflow: hidden;
    text-decoration: none;
    border-radius: var(--radius-md);
    background-color: var(--color-forest-green);
    isolation: isolate;
  }

  .discovery-card__media {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .discovery-card__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1) translate3d(0, 0, 0);
    transition: transform 500ms var(--discovery-transition-ease);
    will-change: transform;
  }

  .discovery-card__image--placeholder {
    background:
      linear-gradient(145deg, var(--color-forest-green) 0%, var(--color-forest-green-dark) 100%);
  }

  .discovery-card__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgb(10 20 14 / 0.15) 0%,
      rgb(10 20 14 / 0.72) 100%
    );
    opacity: var(--discovery-overlay-idle);
    mix-blend-mode: multiply;
    transition: opacity 500ms var(--discovery-transition-ease);
  }

  .discovery-card__content {
    position: absolute;
    inset: auto 0 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-lg);
    pointer-events: none;
  }

  .discovery-card__title {
    margin: 0;
    font-family: var(--font-family-base);
    font-size: clamp(0.875rem, 1.2vw + 0.5rem, 1.125rem);
    font-weight: 700;
    line-height: var(--line-height-tight);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-inverse);
    text-shadow:
      0 1px 2px rgb(0 0 0 / 0.65),
      0 0 1px rgb(0 0 0 / 0.85);
    -webkit-text-stroke: 0.35px rgb(0 0 0 / 0.35);
    transform: translate3d(0, 0, 0);
    transition: transform 500ms var(--discovery-transition-ease);
  }

  .discovery-card__description {
    margin: 0;
    font-family: var(--font-family-base);
    font-size: var(--font-size-sm);
    font-weight: 400;
    line-height: var(--line-height-relaxed);
    color: rgb(255 255 255 / 0.92);
    text-shadow: 0 1px 3px rgb(0 0 0 / 0.55);
    opacity: 0.9;
    transition: opacity 500ms var(--discovery-transition-ease);
  }

  @media (hover: hover) and (pointer: fine) {
    .discovery-card:hover .discovery-card__image,
    .discovery-card:focus-visible .discovery-card__image {
      transform: scale(1.15) translate3d(20px, 0, 0);
    }

    .discovery-card:hover .discovery-card__overlay,
    .discovery-card:focus-visible .discovery-card__overlay {
      opacity: var(--discovery-overlay-hover);
      mix-blend-mode: color-burn;
    }

    .discovery-card:hover .discovery-card__title,
    .discovery-card:focus-visible .discovery-card__title {
      transform: translate3d(0, -15px, 0);
    }

    .discovery-card:hover .discovery-card__description,
    .discovery-card:focus-visible .discovery-card__description {
      opacity: 1;
    }
  }

  .discovery-card.is-revealed .discovery-card__image {
    transform: scale(1.15) translate3d(20px, 0, 0);
  }

  .discovery-card.is-revealed .discovery-card__overlay {
    opacity: var(--discovery-overlay-hover);
    mix-blend-mode: color-burn;
  }

  .discovery-card.is-revealed .discovery-card__title {
    transform: translate3d(0, -15px, 0);
  }

  .discovery-card.is-revealed .discovery-card__description {
    opacity: 1;
  }

  @media (hover: none), (pointer: coarse) {
    .botanical-discovery-strip {
      --discovery-overlay-idle: var(--discovery-overlay-touch);
    }

    .discovery-card__description {
      opacity: 0.88;
    }

    .discovery-card__title {
      transform: translate3d(0, -8px, 0);
    }
  }

  .botanical-discovery-strip__empty {
    margin: 0;
    text-align: center;
    color: var(--color-footer-text);
    font-size: var(--font-size-sm);
  }

  @media (max-width: 989px) {
    .botanical-discovery-strip__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-sm);
    }
  }

  @media (max-width: 479px) {
    .botanical-discovery-strip__grid {
      gap: var(--space-xs);
    }

    .discovery-card {
      min-height: max(16rem, var(--discovery-card-min-height));
    }

    .discovery-card__content {
      padding: var(--space-md);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .discovery-card__image,
    .discovery-card__overlay,
    .discovery-card__title,
    .discovery-card__description {
      transition: none;
    }

    .discovery-card:hover .discovery-card__image,
    .discovery-card:focus-visible .discovery-card__image,
    .discovery-card.is-revealed .discovery-card__image {
      transform: none;
    }

    .discovery-card:hover .discovery-card__title,
    .discovery-card:focus-visible .discovery-card__title,
    .discovery-card.is-revealed .discovery-card__title {
      transform: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    'use strict';

    var STRIP_SELECTOR = '[data-discovery-strip]';

    function isTouchPrimary() {
      try {
        return window.matchMedia('(hover: none), (pointer: coarse)').matches;
      } catch (error) {
        return false;
      }
    }

    function clearRevealedCards(cards, except) {
      cards.forEach(function (card) {
        if (card !== except) {
          card.classList.remove('is-revealed');
        }
      });
    }

    function bindDiscoveryStrip(root) {
      if (!root || root.dataset.discoveryStripBound === 'true') {
        return;
      }

      root.dataset.discoveryStripBound = 'true';

      var cards = root.querySelectorAll('[data-discovery-card]');
      if (cards.length === 0) {
        return;
      }

      if (!isTouchPrimary()) {
        return;
      }

      cards.forEach(function (card) {
        card.addEventListener('click', function (event) {
          if (!card.classList.contains('is-revealed')) {
            event.preventDefault();
            clearRevealedCards(cards, card);
            card.classList.add('is-revealed');
          }
        });
      });

      document.addEventListener('click', function (event) {
        if (!root.contains(event.target)) {
          clearRevealedCards(cards);
        }
      });
    }

    function initAll(scope) {
      var context = scope || document;
      context.querySelectorAll(STRIP_SELECTOR).forEach(bindDiscoveryStrip);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        initAll();
      });
    } else {
      initAll();
    }

    document.addEventListener('shopify:section:load', function (event) {
      initAll(event.target);
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.botanical_discovery_strip.name",
  "tag": "section",
  "class": "botanical-discovery-strip-section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "anchor_heading",
      "label": "t:sections.botanical_discovery_strip.settings.anchor_heading",
      "default": "SHOP PLANTS AND ACCESSORIES BELOW!"
    },
    {
      "type": "color",
      "id": "anchor_color",
      "label": "t:sections.botanical_discovery_strip.settings.anchor_color",
      "default": "#c41e3a"
    },
    {
      "type": "range",
      "id": "card_min_height",
      "label": "t:sections.botanical_discovery_strip.settings.card_min_height",
      "min": 240,
      "max": 480,
      "step": 10,
      "unit": "px",
      "default": 320
    }
  ],
  "blocks": [
    {
      "type": "discovery_card",
      "name": "t:sections.botanical_discovery_strip.blocks.discovery_card.name",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:general.collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.botanical_discovery_strip.blocks.discovery_card.settings.title",
          "info": "t:sections.botanical_discovery_strip.blocks.discovery_card.settings.title_info"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:sections.botanical_discovery_strip.blocks.discovery_card.settings.description"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.botanical_discovery_strip.blocks.discovery_card.settings.link",
          "info": "t:sections.botanical_discovery_strip.blocks.discovery_card.settings.link_info"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.botanical_discovery_strip.blocks.discovery_card.settings.image",
          "info": "t:sections.botanical_discovery_strip.blocks.discovery_card.settings.image_info"
        },
        {
          "type": "text",
          "id": "placeholder_image",
          "label": "t:sections.botanical_discovery_strip.blocks.discovery_card.settings.placeholder_image",
          "info": "t:sections.botanical_discovery_strip.blocks.discovery_card.settings.placeholder_image_info"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.botanical_discovery_strip.name",
      "blocks": [
        {
          "type": "discovery_card",
          "settings": {
            "title": "Beginner plants",
            "description": "Hardy carnivores for your first bench or windowsill.",
            "link": "/collections/all",
            "placeholder_image": "https://commons.wikimedia.org/wiki/Special:FilePath/Drosera_Capensis.jpg?width=1200"
          }
        },
        {
          "type": "discovery_card",
          "settings": {
            "title": "Produced in our tissue culture (TC) lab",
            "description": "In-house propagation from sterile flask to bench-ready plants.",
            "link": "/pages/about-us",
            "placeholder_image": "https://commons.wikimedia.org/wiki/Special:FilePath/Perlite_as_a_medium_for_rooting_of_cuttings.jpg?width=1200"
          }
        },
        {
          "type": "discovery_card",
          "settings": {
            "title": "Accessories and supplies",
            "description": "Substrate, pots, water, and grow-room essentials.",
            "link": "/collections/growing-supplies",
            "placeholder_image": "https://commons.wikimedia.org/wiki/Special:FilePath/Schultz_Sphagnum_Peat_Moss.jpg?width=1200"
          }
        },
        {
          "type": "discovery_card",
          "settings": {
            "title": "New arrivals",
            "description": "Freshly cataloged specimens from the propagation lab.",
            "link": "/collections/all?sort_by=created-descending",
            "placeholder_image": "https://commons.wikimedia.org/wiki/Special:FilePath/Nepenthes_ventricosa0.jpg?width=1200"
          }
        }
      ]
    }
  ]
}
{% endschema %}
