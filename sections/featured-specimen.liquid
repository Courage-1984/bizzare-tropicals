{%- liquid
  assign featured_product = section.settings.product
  assign specimen_image = section.settings.image
  assign placeholder_fallback = section.settings.placeholder_image | default: 'https://commons.wikimedia.org/wiki/Special:FilePath/Pitcher_Plant_(Nepenthes_ampullaria)_(8411421382).jpg?width=1600'
  assign use_shopify_image = false
  assign display_heading = section.settings.heading
  assign display_subheading = section.settings.subheading
  assign button_label = section.settings.button_label
  assign button_link = section.settings.button_link

  if featured_product != blank
    if specimen_image == blank
      assign specimen_image = featured_product.featured_media.preview_image | default: featured_product.featured_image
    endif
    if display_heading == blank
      assign display_heading = featured_product.metafields.custom.latin_name.value | default: featured_product.metafields.custom.latin_name | default: featured_product.title
    endif
    if button_link == blank
      assign button_link = featured_product.url
    endif
  endif

  if specimen_image != blank and specimen_image.width > 0
    assign use_shopify_image = true
  endif

  assign image_alt = display_heading | default: 'Nepenthes bicalcarata'
-%}

<section
  class="featured-specimen full-width reveal-up"
  style="--featured-specimen-bg: {{ section.settings.background_color | default: '#121614' }};"
  aria-labelledby="featured-specimen-heading-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="featured-specimen__grid">
    <div class="featured-specimen__content">
      <p class="featured-specimen__subheading">
        {{ display_subheading | default: 'A rare pitcher plant with distinctive fang-like appendages.' | escape }}
      </p>

      <h2 id="featured-specimen-heading-{{ section.id }}" class="featured-specimen__heading">
        <em>{{ display_heading | default: 'Nepenthes bicalcarata' | escape }}</em>
      </h2>

      {%- assign button_label = button_label | default: 'View specimen' -%}
      {%- assign button_link = button_link | default: '/collections/nepenthes' -%}
      {%- if button_label != blank and button_link != blank -%}
        <a class="featured-specimen__button" href="{{ button_link }}">
          {{- button_label | escape -}}
        </a>
      {%- endif -%}
    </div>

    <div class="featured-specimen__media">
      <div class="featured-specimen__image-wrap">
        {%- comment -%} TODO: replace placeholder image before launch — see placeholder-images.md {%- endcomment -%}
        {%- if use_shopify_image -%}
          {{
            specimen_image
            | image_url: width: 2000
            | image_tag:
              class: 'featured-specimen__image',
              widths: '750, 1100, 1500, 2000',
              sizes: '(min-width: 990px) 50vw, 100vw',
              loading: 'lazy',
              alt: image_alt
          }}
        {%- else -%}
          <img
            class="featured-specimen__image featured-specimen__image--fallback"
            src="{{ placeholder_fallback }}"
            alt="{{ image_alt | escape }}"
            width="1600"
            height="1200"
            loading="lazy"
            decoding="async"
          >
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .featured-specimen {
    --featured-specimen-ink: var(--color-parchment);
    --featured-specimen-ink-muted: rgb(247 244 237 / 0.78);
    color: var(--featured-specimen-ink);
    background-color: var(--featured-specimen-bg, #121614);
  }

  .featured-specimen__grid {
    display: grid;
    grid-template-columns: 1fr;
    min-height: min(100%, 32rem);
  }

  .featured-specimen__content {
    order: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: var(--space-lg);
    padding: 4rem 10%;
    background-color: var(--featured-specimen-bg, #121614);
  }

  .featured-specimen__subheading {
    margin: 0;
    max-width: 36ch;
    font-family: var(--font-family-base);
    font-size: 0.75rem;
    font-weight: 600;
    line-height: var(--line-height-relaxed);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--featured-specimen-ink-muted);
  }

  .featured-specimen__heading {
    margin: 0;
    max-width: 14ch;
    font-family: var(--font-family-serif);
    font-size: clamp(3rem, 5vw, 6rem);
    font-weight: 400;
    font-style: normal;
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tight);
    color: var(--featured-specimen-ink);
  }

  .featured-specimen__heading em {
    font-style: italic;
  }

  .featured-specimen__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.875rem;
    margin-block-start: var(--space-sm);
    padding: var(--space-sm) var(--space-2xl);
    font-family: var(--font-family-base);
    font-size: var(--font-size-sm);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    text-decoration: none;
    color: var(--featured-specimen-ink);
    background-color: transparent;
    border: 1px solid var(--featured-specimen-ink);
    border-radius: var(--radius-sm);
    transition:
      color 0.5s cubic-bezier(0.25, 1, 0.5, 1),
      background-color 0.5s cubic-bezier(0.25, 1, 0.5, 1),
      transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .featured-specimen__button:hover,
  .featured-specimen__button:focus-visible {
    color: var(--color-forest-green-dark);
    background-color: var(--featured-specimen-ink);
    transform: translate3d(0, -1px, 0);
  }

  .featured-specimen__button:focus-visible {
    outline: 2px solid var(--featured-specimen-ink);
    outline-offset: 3px;
  }

  .featured-specimen__media {
    order: 1;
    min-height: 0;
  }

  .featured-specimen__image-wrap {
    width: 100%;
    height: 100%;
    min-height: 500px;
    overflow: hidden;
  }

  .featured-specimen__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  @media (min-width: 750px) {
    .featured-specimen__grid {
      grid-template-columns: 1fr 1fr;
    }

    .featured-specimen__content {
      order: 1;
    }

    .featured-specimen__media {
      order: 2;
    }

    .featured-specimen__image-wrap {
      min-height: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .featured-specimen__button {
      transition: none;
    }

    .featured-specimen__button:hover,
    .featured-specimen__button:focus-visible {
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.featured_specimen.name",
  "tag": "section",
  "class": "featured-specimen-section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.featured_specimen.settings.background_color",
      "default": "#121614"
    },
    {
      "type": "product",
      "id": "product",
      "label": "t:sections.featured_specimen.settings.product",
      "info": "t:sections.featured_specimen.settings.product_info"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.featured_specimen.settings.image",
      "info": "t:sections.featured_specimen.settings.image_info"
    },
    {
      "type": "text",
      "id": "placeholder_image",
      "label": "t:sections.featured_specimen.settings.placeholder_image",
      "info": "t:sections.featured_specimen.settings.placeholder_image_info",
      "default": "https://commons.wikimedia.org/wiki/Special:FilePath/Pitcher_Plant_(Nepenthes_ampullaria)_(8411421382).jpg?width=1600"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.featured_specimen.settings.subheading",
      "default": "A rare pitcher plant with distinctive fang-like appendages."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.featured_specimen.settings.heading",
      "default": "Nepenthes bicalcarata"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.featured_specimen.settings.button_label",
      "default": "View specimen"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.featured_specimen.settings.button_link"
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_specimen.name",
      "settings": {
        "background_color": "#121614",
        "subheading": "A rare pitcher plant with distinctive fang-like appendages.",
        "heading": "Nepenthes bicalcarata",
        "button_label": "View specimen",
        "button_link": "/collections/nepenthes",
        "placeholder_image": "https://commons.wikimedia.org/wiki/Special:FilePath/Pitcher_Plant_(Nepenthes_ampullaria)_(8411421382).jpg?width=1600"
      }
    }
  ]
}
{% endschema %}
