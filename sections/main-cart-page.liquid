{% doc %}
  Cart page — opens the AJAX cart drawer instead of a legacy table cart UI.

  @example
  Used by templates/cart.json when customers visit /cart directly.
{% enddoc %}

<div class="cart-page full-width" {{ section.shopify_attributes }}>
  <div class="cart-page__inner">
    <h1 class="cart-page__title">{{ 'sections.main_cart_page.title' | t }}</h1>
    <p class="cart-page__text">{{ 'sections.main_cart_page.description' | t }}</p>
    <p class="cart-page__actions">
      <button type="button" class="cart-page__open" data-cart-page-open>
        {{ 'sections.main_cart_page.open_drawer' | t }}
      </button>
      <a class="cart-page__continue link-underline-grow" href="{{ routes.all_products_collection_url }}">
        {{ 'sections.main_cart_page.continue_shopping' | t }}
      </a>
    </p>
  </div>
</div>

{% stylesheet %}
  .cart-page {
    padding-block: var(--space-3xl) var(--space-4xl);
    background-color: var(--color-parchment);
  }

  .cart-page__inner {
    width: min(var(--page-width), calc(100% - var(--page-margin) * 2));
    max-width: 36rem;
    margin-inline: auto;
    text-align: center;
  }

  .cart-page__title {
    margin: 0 0 var(--space-md);
    font-family: var(--font-family-serif);
    font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2.25rem);
    font-weight: 400;
    color: var(--color-forest-green-dark);
  }

  .cart-page__text {
    margin: 0 0 var(--space-xl);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-muted);
  }

  .cart-page__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    justify-content: center;
    align-items: center;
    margin: 0;
  }

  .cart-page__open {
    padding: 0.75rem 1.5rem;
    font-family: inherit;
    font-size: var(--font-size-sm);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-parchment);
    background-color: var(--color-forest-green-dark);
    border: 1px solid var(--color-forest-green-dark);
    border-radius: var(--radius-sm);
    cursor: pointer;
  }

  .cart-page__open:hover {
    background-color: var(--color-forest-green);
  }

  .cart-page__continue {
    font-size: var(--font-size-sm);
    color: var(--color-forest-green-dark);
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    'use strict';

    function openCartDrawer() {
      if (window.CartDrawer && typeof window.CartDrawer.open === 'function') {
        window.CartDrawer.open();
        return;
      }
      var trigger = document.querySelector('[data-cart-drawer-open]');
      if (trigger) {
        trigger.click();
      }
    }

    document.querySelectorAll('[data-cart-page-open]').forEach(function (button) {
      button.addEventListener('click', openCartDrawer);
    });

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', openCartDrawer);
    } else {
      openCartDrawer();
    }
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.main_cart_page.name",
  "tag": "section",
  "class": "cart-page-section",
  "settings": []
}
{% endschema %}
