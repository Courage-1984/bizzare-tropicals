{%- liquid
  assign collection_image = collection.image
  assign use_collection_image = false

  if collection_image != blank
    if collection_image.width > 0
      assign use_collection_image = true
    endif
  endif
-%}

<section
  class="collection-banner full-width reveal-up"
  aria-labelledby="collection-banner-title-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  {%- if use_collection_image -%}
    <div class="collection-banner__media" aria-hidden="true">
      {{
        collection_image
        | image_url: width: 2400, height: 1400, crop: 'center'
        | image_tag:
          class: 'collection-banner__image',
          widths: '800, 1200, 1600, 2000, 2400',
          sizes: '100vw',
          loading: 'eager',
          fetchpriority: 'high',
          alt: ''
      }}
    </div>
  {%- endif -%}

  <div class="collection-banner__scrim" aria-hidden="true"></div>

  <div class="collection-banner__content">
    <h1 id="collection-banner-title-{{ section.id }}" class="collection-banner__title">
      {{ collection.title | escape }}
    </h1>

    {%- if collection.description != blank -%}
      <div class="collection-banner__description rte">
        {{ collection.description }}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .collection-banner-section.shopify-section {
    display: block;
    grid-template-columns: none;
  }

  .collection-banner-section.shopify-section > * {
    grid-column: auto;
  }

  .collection-banner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 40vh;
    padding: var(--space-3xl) var(--page-margin);
    overflow: hidden;
    color: var(--color-parchment);
    background-color: var(--color-forest-green-dark);
    text-align: center;
  }

  .collection-banner__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    margin: 0;
    pointer-events: none;
  }

  .collection-banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.3;
  }

  .collection-banner__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgb(10 20 11 / 0.55) 0%,
      rgb(10 20 11 / 0.72) 55%,
      rgb(10 20 11 / 0.85) 100%
    );
    pointer-events: none;
  }

  .collection-banner__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    width: min(100%, 44rem);
    margin-inline: auto;
  }

  .collection-banner__title {
    margin: 0;
    font-family: var(--font-family-serif);
    font-size: clamp(2.75rem, 6vw + 0.5rem, 4.5rem);
    font-weight: 400;
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tight);
    text-wrap: balance;
    color: var(--color-parchment);
  }

  .collection-banner__description {
    max-width: 600px;
    margin: 0;
    font-family: var(--font-family-base);
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: rgb(247 244 237 / 0.92);
  }

  .collection-banner__description :is(p, ul, ol) {
    margin: 0 0 var(--space-md);
  }

  .collection-banner__description > :last-child {
    margin-block-end: 0;
  }

  .collection-banner__description ul,
  .collection-banner__description ol {
    padding-inline-start: 1.25rem;
    text-align: start;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.collection_banner.name",
  "tag": "section",
  "class": "collection-banner-section",
  "settings": []
}
{% endschema %}
