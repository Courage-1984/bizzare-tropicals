{%- liquid
  assign hero_title = collection.title | default: 'Products'
  assign illustration_image = section.settings.illustration_image
  assign placeholder_src = 'https://commons.wikimedia.org/wiki/Special:FilePath/Nepenthes_rajah.png?width=1200'
  assign hero_image_src = placeholder_src
  assign hero_image_alt = hero_title | escape

  if illustration_image != blank
    assign hero_image_src = illustration_image | image_url: width: 1200
    assign hero_image_alt = illustration_image.alt | default: hero_title | escape
  endif
-%}

<section
  class="catalog-hero full-width"
  aria-labelledby="catalog-hero-title-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="catalog-hero__stage">
    <h1 id="catalog-hero-title-{{ section.id }}" class="catalog-hero__title">
      {{ hero_title | escape }}
    </h1>

    <div class="catalog-hero__art">
      <img
        class="catalog-hero__img"
        src="{{ hero_image_src }}"
        alt="{{ hero_image_alt }}"
        width="1200"
        height="1600"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      >

      <p class="catalog-hero__callout catalog-hero__callout--rim">
        <span class="catalog-hero__callout-text">{{ 'sections.collection_banner.callout_rim_short' | t }}</span>
      </p>
      <p class="catalog-hero__callout catalog-hero__callout--wax">
        <span class="catalog-hero__callout-text">{{ 'sections.collection_banner.callout_wax_short' | t }}</span>
      </p>
      <p class="catalog-hero__callout catalog-hero__callout--pool">
        <span class="catalog-hero__callout-text">{{ 'sections.collection_banner.callout_pool_short' | t }}</span>
      </p>
    </div>
  </div>
</section>

{% stylesheet %}
  .collection-anatomy-section.shopify-section,
  .catalog-hero-section.shopify-section {
    display: block;
    grid-template-columns: none;
  }

  .collection-anatomy-section.shopify-section > *,
  .catalog-hero-section.shopify-section > * {
    grid-column: auto;
  }

  .catalog-hero {
    min-height: 100vh;
    color: var(--color-parchment);
    background-color: #121614;
  }

  .catalog-hero__stage {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 1200px;
    min-height: 100vh;
    margin: 0 auto;
    padding: var(--space-3xl) var(--page-margin);
    text-align: center;
  }

  .catalog-hero__title {
    position: relative;
    z-index: 2;
    margin: 0 0 2rem;
    font-family: var(--font-family-serif);
    font-size: clamp(2.25rem, 5vw + 0.5rem, 4rem);
    font-weight: 400;
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tight);
    color: var(--color-parchment);
    text-wrap: balance;
  }

  .catalog-hero__art {
    position: relative;
    width: min(100%, 420px);
    margin: 0 auto;
  }

  .catalog-hero__img {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: auto;
    max-height: min(62vh, 560px);
    margin: 0 auto;
    object-fit: contain;
    object-position: center center;
  }

  .catalog-hero__callout {
    position: absolute;
    z-index: 3;
    margin: 0;
    padding: 0;
    text-align: start;
  }

  .catalog-hero__callout-text {
    display: block;
    font-family: var(--font-family-base);
    font-size: 0.65rem;
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-parchment);
  }

  .catalog-hero__callout::after {
    content: '';
    position: absolute;
    width: 100px;
    height: 1px;
    background-color: var(--color-parchment);
    transform-origin: left center;
  }

  .catalog-hero__callout--rim {
    top: 40%;
    left: 20%;
  }

  .catalog-hero__callout--rim::after {
    top: 50%;
    left: 100%;
    margin-inline-start: 0.35rem;
    transform: rotate(-24deg);
  }

  .catalog-hero__callout--wax {
    top: 52%;
    left: 18%;
  }

  .catalog-hero__callout--wax::after {
    top: 50%;
    left: 100%;
    margin-inline-start: 0.35rem;
    transform: rotate(-8deg);
  }

  .catalog-hero__callout--pool {
    top: 68%;
    left: 22%;
  }

  .catalog-hero__callout--pool::after {
    top: 50%;
    left: 100%;
    margin-inline-start: 0.35rem;
    transform: rotate(12deg);
  }

  @media (max-width: 749px) {
    .catalog-hero__callout {
      display: none;
    }

    .catalog-hero__stage {
      min-height: 100vh;
      padding-block: var(--space-2xl);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.collection_banner.name",
  "tag": "section",
  "class": "catalog-hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "illustration_image",
      "label": "t:sections.collection_banner.settings.illustration_image",
      "info": "t:sections.collection_banner.settings.illustration_image_info"
    }
  ]
}
{% endschema %}
