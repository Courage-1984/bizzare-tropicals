{%- liquid
  assign illustration_image = section.settings.illustration_image
  assign illustration_alt = illustration_image.alt | default: collection.title | escape
-%}

<section
  class="collection-anatomy full-width reveal-up"
  aria-labelledby="collection-anatomy-title-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="collection-anatomy__inner">
    <h1 id="collection-anatomy-title-{{ section.id }}" class="collection-anatomy__title">
      {{ collection.title | escape }}
    </h1>

    <div class="collection-anatomy__figure anatomy-hero-container">
      {%- if illustration_image != blank -%}
        {{
          illustration_image
          | image_url: width: 800
          | image_tag:
            class: 'anatomy-hero-img',
            widths: '400, 600, 800',
            sizes: '300px',
            loading: 'eager',
            fetchpriority: 'high',
            alt: illustration_alt
        }}
      {%- else -%}
        <div class="anatomy-placeholder">
          <p class="anatomy-placeholder__text">{{ 'sections.collection_banner.placeholder_upload' | t }}</p>
        </div>
      {%- endif -%}

      <p class="collection-anatomy__callout anatomy-callout collection-anatomy__callout--rim">
        {{ 'sections.collection_banner.callout_rim' | t }}
      </p>
      <p class="collection-anatomy__callout anatomy-callout collection-anatomy__callout--wax">
        {{ 'sections.collection_banner.callout_wax' | t }}
      </p>
      <p class="collection-anatomy__callout anatomy-callout collection-anatomy__callout--pool">
        {{ 'sections.collection_banner.callout_pool' | t }}
      </p>
    </div>

    {%- if collection.description != blank -%}
      <div class="collection-anatomy__description rte">
        {{ collection.description }}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .collection-anatomy-section.shopify-section {
    display: block;
    grid-template-columns: none;
  }

  .collection-anatomy-section.shopify-section > * {
    grid-column: auto;
  }

  .collection-anatomy {
    padding: var(--space-3xl) var(--page-margin);
    color: var(--color-parchment);
    background-color: #121614;
  }

  .collection-anatomy__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 1200px;
    min-height: 60vh;
    margin: 0 auto;
    text-align: center;
  }

  .collection-anatomy__title {
    margin: 0 0 2rem;
    font-family: var(--font-family-serif);
    font-size: clamp(2rem, 4vw + 0.5rem, 3.5rem);
    font-weight: 400;
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tight);
    color: var(--color-parchment);
    text-wrap: balance;
  }

  .anatomy-hero-container {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: min(100%, 32rem);
    height: 60vh;
    max-height: 600px;
    margin: 2rem auto;
    overflow: visible;
  }

  .anatomy-hero-img {
    position: relative;
    z-index: 2;
    display: block;
    width: auto;
    max-width: 100%;
    height: auto;
    max-height: 100%;
    object-fit: contain;
    object-position: center center;
    border-radius: 10px;
  }

  .anatomy-placeholder {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    border: 1px dashed rgb(244 238 224 / 0.3);
    border-radius: 10px;
    color: var(--color-parchment);
  }

  .anatomy-placeholder__text {
    margin: 0;
    padding: var(--space-md);
    font-family: var(--font-family-serif);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    text-align: center;
    text-wrap: balance;
  }

  .collection-anatomy__callout {
    position: absolute;
    z-index: 3;
    width: max-content;
    max-width: 12rem;
    margin: 0;
    font-family: var(--font-family-base);
    font-size: 0.65rem;
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-parchment);
    text-align: start;
  }

  .collection-anatomy__callout::before {
    content: '';
    display: inline-block;
    width: 40px;
    height: 1px;
    margin-inline-end: 0.5rem;
    vertical-align: middle;
    background-color: var(--color-parchment);
  }

  .anatomy-callout.collection-anatomy__callout--rim {
    top: 10%;
    left: 105%;
  }

  .anatomy-callout.collection-anatomy__callout--wax {
    top: 50%;
    right: 105%;
    display: flex;
    flex-direction: row-reverse;
    align-items: center;
    text-align: end;
    transform: translateY(-50%);
  }

  .collection-anatomy__callout--wax::before {
    flex-shrink: 0;
    margin-inline-end: 0;
    margin-inline-start: 0.5rem;
  }

  .anatomy-callout.collection-anatomy__callout--pool {
    bottom: 10%;
    left: 105%;
  }

  .collection-anatomy__description {
    max-width: 36rem;
    margin: 0;
    font-family: var(--font-family-base);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: rgb(247 244 237 / 0.78);
  }

  .collection-anatomy__description :is(p, ul, ol) {
    margin: 0 0 var(--space-sm);
  }

  .collection-anatomy__description > :last-child {
    margin-block-end: 0;
  }

  @media (max-width: 749px) {
    .collection-anatomy__inner {
      min-height: auto;
    }

    .anatomy-hero-container {
      height: 50vh;
      max-height: 420px;
      margin-block: var(--space-2xl);
    }

    .anatomy-callout,
    .collection-anatomy__callout {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.collection_banner.name",
  "tag": "section",
  "class": "collection-anatomy-section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.collection_banner.settings.anatomy_header"
    },
    {
      "type": "image_picker",
      "id": "illustration_image",
      "label": "t:sections.collection_banner.settings.illustration_image",
      "info": "t:sections.collection_banner.settings.illustration_image_info"
    }
  ]
}
{% endschema %}
