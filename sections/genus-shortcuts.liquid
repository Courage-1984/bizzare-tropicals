{%- liquid
  assign section_heading = section.settings.heading
-%}

<section
  class="genus-shortcuts"
  aria-labelledby="genus-shortcuts-heading-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  {%- if section_heading != blank -%}
    <header class="genus-shortcuts__header">
      <h2 id="genus-shortcuts-heading-{{ section.id }}" class="genus-shortcuts__section-title">
        {{ section_heading | escape }}
      </h2>
    </header>
  {%- endif -%}

  <ul class="genus-shortcuts__grid" role="list">
    {%- for block in section.blocks -%}
      {%- liquid
        assign genus_key = block.settings.genus_key
        assign card_title = block.settings.title
        assign card_link = block.settings.collection_link
        assign card_image = block.settings.image
        assign use_shopify_image = false

        if card_image != blank and card_image.width > 0
          assign use_shopify_image = true
        endif

        if card_title == blank
          case genus_key
            when 'dionaea'
              assign card_title = 'Dionaea'
            when 'sarracenia'
              assign card_title = 'Sarracenia'
            when 'nepenthes'
              assign card_title = 'Nepenthes'
            when 'drosera'
              assign card_title = 'Drosera'
            else
              assign card_title = 'Genus'
          endcase
        endif

        if card_link == blank
          assign card_link = '/collections/' | append: genus_key
        endif

        case genus_key
          when 'dionaea'
            assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Venus_Fly_Trap_(Dionaea_muscipula).jpg?width=1200'
          when 'sarracenia'
            assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Sarracenia_Judith_Hindle_(5964475729).jpg?width=1200'
          when 'nepenthes'
            assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Nepenthes_rajah.png?width=1200'
          when 'drosera'
            assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Drosera_Capensis.jpg?width=1200'
          else
            assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Drosera_Capensis.jpg?width=1200'
        endcase

      -%}

      <li class="genus-shortcuts__item" role="listitem" {{ block.shopify_attributes }}>
        <a class="genus-shortcuts__card" href="{{ card_link }}">
          <span class="genus-shortcuts__media" aria-hidden="true">
            {%- comment -%} TODO: replace placeholder image before launch — see placeholder-images.md {%- endcomment -%}
            {%- if use_shopify_image -%}
              {{
                card_image
                | image_url: width: 800, height: 800, crop: 'center'
                | image_tag:
                  class: 'genus-shortcuts__image',
                  widths: '400, 600, 800',
                  sizes: '(min-width: 990px) 22vw, (min-width: 750px) 23vw, 46vw',
                  loading: 'lazy',
                  alt: ''
              }}
            {%- else -%}
              <img
                class="genus-shortcuts__image genus-shortcuts__image--fallback"
                src="{{ placeholder_url }}"
                alt=""
                width="800"
                height="800"
                loading="lazy"
                decoding="async"
              >
            {%- endif -%}
            <span class="genus-shortcuts__scrim"></span>
          </span>

          <span class="genus-shortcuts__content">
            <span class="genus-shortcuts__title">{{ card_title | escape }}</span>
            <span class="genus-shortcuts__cta">{{ 'sections.genus_shortcuts.shop_collection' | t }}</span>
          </span>
          <span class="visually-hidden">
            {{- 'sections.genus_shortcuts.card_label' | t: genus: card_title -}}
          </span>
        </a>
      </li>
    {%- endfor -%}
  </ul>
</section>

{% stylesheet %}
  .genus-shortcuts {
    padding-block: var(--space-3xl);
  }

  .genus-shortcuts__header {
    margin-block-end: var(--space-xl);
    text-align: center;
  }

  .genus-shortcuts__section-title {
    margin: 0;
    font-family: var(--font-family-base);
    font-size: clamp(1.25rem, 2vw + 0.5rem, 1.75rem);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .genus-shortcuts__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-md);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .genus-shortcuts__item {
    min-width: 0;
  }

  .genus-shortcuts__card {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: clamp(11rem, 34vw, 16rem);
    overflow: hidden;
    text-decoration: none;
    color: var(--color-text-inverse);
    background-color: var(--color-primary-hover);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    transition:
      transform var(--transition-transform),
      box-shadow var(--transition-base);
  }

  .genus-shortcuts__card::after {
    content: '';
    position: absolute;
    inset: var(--space-sm);
    z-index: 2;
    border: 1px solid rgb(255 255 255 / 0.18);
    border-radius: var(--radius-md);
    pointer-events: none;
    transition: border-color var(--transition-base);
  }

  .genus-shortcuts__card:hover::after {
    border-color: rgb(255 255 255 / 0.32);
  }

  .genus-shortcuts__card:hover {
    transform: translate3d(0, -4px, 0);
    box-shadow: var(--shadow-md);
  }

  .genus-shortcuts__card:focus-visible {
    outline-offset: 4px;
  }

  .genus-shortcuts__media {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-radius: inherit;
  }

  .genus-shortcuts__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    transform: scale3d(1, 1, 1);
    transition:
      transform var(--transition-transform),
      filter var(--transition-base);
  }

  .genus-shortcuts__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgb(12 18 14 / 0.15) 0%,
      rgb(12 18 14 / 0.55) 55%,
      rgb(12 18 14 / 0.78) 100%
    );
    transition: background-color var(--transition-base);
  }

  .genus-shortcuts__card:hover .genus-shortcuts__image {
    transform: scale3d(1.04, 1.04, 1);
    filter: brightness(0.82);
  }

  .genus-shortcuts__card:hover .genus-shortcuts__scrim {
    background: linear-gradient(
      180deg,
      rgb(12 18 14 / 0.25) 0%,
      rgb(12 18 14 / 0.62) 55%,
      rgb(12 18 14 / 0.88) 100%
    );
  }

  .genus-shortcuts__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex: 1;
    flex-direction: column;
    justify-content: flex-end;
    gap: var(--space-xs);
    margin-top: auto;
    padding: var(--space-lg);
    min-height: 100%;
  }

  .genus-shortcuts__title {
    margin: 0;
    font-family: var(--font-family-serif);
    font-size: clamp(1.375rem, 2.5vw + 0.5rem, 2rem);
    font-style: normal;
    font-weight: 400;
    line-height: var(--line-height-tight);
    letter-spacing: 0.01em;
    text-wrap: balance;
  }

  .genus-shortcuts__cta {
    font-size: var(--font-size-sm);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 0.2em;
    text-decoration-thickness: 1px;
  }

  @media (min-width: 750px) {
    .genus-shortcuts__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: var(--space-lg);
    }

    .genus-shortcuts__card {
      min-height: clamp(14rem, 22vw, 18rem);
    }

    .genus-shortcuts__content {
      padding: var(--space-xl);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .genus-shortcuts__card,
    .genus-shortcuts__image {
      transition: none;
    }

    .genus-shortcuts__card:hover {
      transform: none;
    }

    .genus-shortcuts__card:hover .genus-shortcuts__image {
      transform: none;
      filter: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.genus_shortcuts.name",
  "tag": "section",
  "class": "genus-shortcuts-section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.genus_shortcuts.settings.heading",
      "default": "Shop by genus"
    }
  ],
  "blocks": [
    {
      "type": "genus",
      "name": "t:sections.genus_shortcuts.blocks.genus.name",
      "settings": [
        {
          "type": "select",
          "id": "genus_key",
          "label": "t:sections.genus_shortcuts.blocks.genus.settings.genus_key",
          "options": [
            { "value": "dionaea", "label": "Dionaea" },
            { "value": "sarracenia", "label": "Sarracenia" },
            { "value": "nepenthes", "label": "Nepenthes" },
            { "value": "drosera", "label": "Drosera" }
          ],
          "default": "dionaea"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.text"
        },
        {
          "type": "url",
          "id": "collection_link",
          "label": "t:sections.genus_shortcuts.blocks.genus.settings.collection_link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.background"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.genus_shortcuts.name",
      "blocks": [
        {
          "type": "genus",
          "settings": {
            "genus_key": "dionaea",
            "title": "Dionaea",
            "collection_link": "/collections/dionaea"
          }
        },
        {
          "type": "genus",
          "settings": {
            "genus_key": "sarracenia",
            "title": "Sarracenia",
            "collection_link": "/collections/sarracenia"
          }
        },
        {
          "type": "genus",
          "settings": {
            "genus_key": "nepenthes",
            "title": "Nepenthes",
            "collection_link": "/collections/nepenthes"
          }
        },
        {
          "type": "genus",
          "settings": {
            "genus_key": "drosera",
            "title": "Drosera",
            "collection_link": "/collections/drosera"
          }
        }
      ]
    }
  ]
}
{% endschema %}
