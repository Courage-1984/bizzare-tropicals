{%- liquid
  assign section_heading = section.settings.heading | strip
  if section_heading == blank
    assign section_heading = 'sections.genus_shortcuts.strip_label' | t
  endif
  assign default_placeholder = section.settings.default_placeholder_image
  assign use_dynamic_genera = section.settings.use_dynamic_genera
  capture genus_cards_markup
    if use_dynamic_genera
      render 'genus-shortcuts-dynamic-strip', default_placeholder: default_placeholder
    else
      for block in section.blocks
        if block.type == 'genus'
          liquid
            assign card_collection = block.settings.collection
            assign card_title = block.settings.title
            assign card_link = block.settings.link
            assign card_image = block.settings.image
            assign placeholder_url = block.settings.placeholder_image
            if placeholder_url contains 'Venus_Flytrap_(Dionaea_muscipula)'
              assign placeholder_url = blank
            endif
            assign genus_handle = card_title | handleize
            assign use_shopify_image = false

            if card_collection != blank
              assign genus_handle = card_collection.handle
              if card_title == blank
                capture collection_display_title
                  render 'collection-display-title', collection: card_collection
                endcapture
                assign card_title = collection_display_title | strip
              endif
              if card_link == blank
                assign card_link = card_collection.url
              endif
              if card_image == blank
                if card_collection.image != blank
                  if card_collection.image.width > 0
                    assign card_image = card_collection.image
                  endif
                endif
                if card_image == blank
                  assign fallback_product = card_collection.products.first
                  if fallback_product != blank
                    assign card_image = fallback_product.featured_media.preview_image | default: fallback_product.featured_image
                  endif
                endif
              endif
            endif

            if section.settings.hide_empty_collections
              if card_collection != blank
                if card_collection.products_count == 0
                  assign card_title = blank
                endif
              endif
            endif

            if card_link == blank
              if card_title != blank
                assign card_link = card_title | handleize | prepend: '/collections/'
              endif
            endif

            if card_image != blank
              if card_image.width > 0
                assign use_shopify_image = true
              endif
            endif

            unless use_shopify_image
              if placeholder_url == blank
                capture genus_placeholder
                  render 'genus-placeholder-url', genus_handle: genus_handle
                endcapture
                assign placeholder_url = genus_placeholder | strip
              endif
              if placeholder_url == blank
                assign placeholder_url = default_placeholder
              endif
            endunless

          if card_title != blank and card_link != blank
            echo '<li class="genus-shortcuts__item reveal-up" data-carousel-item role="listitem" '
            echo block.shopify_attributes
            echo '>'
            render 'genus-arch-card', card_title: card_title, card_link: card_link, placeholder_url: placeholder_url, card_image: card_image, use_shopify_image: use_shopify_image
            echo '</li>'
          endif
        endif
      endfor
    endif
  endcapture
  assign genus_cards_markup = genus_cards_markup | strip
  assign has_genus_cards = false
  if genus_cards_markup != blank
    assign has_genus_cards = true
  endif
-%}

<section
  class="genus-shortcuts reveal-up"
  data-genus-carousel
  aria-labelledby="genus-shortcuts-heading-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  {%- if section_heading != blank or has_genus_cards -%}
    <header class="genus-shortcuts__header">
      {%- if section_heading != blank -%}
        <h2 id="genus-shortcuts-heading-{{ section.id }}" class="genus-shortcuts__section-title">
          {{ section_heading | escape }}
        </h2>
      {%- endif -%}

      {%- if has_genus_cards -%}
        <div class="genus-shortcuts__nav" data-carousel-nav hidden>
          <button
            type="button"
            class="genus-shortcuts__arrow"
            data-carousel-prev
            aria-controls="genus-carousel-track-{{ section.id }}"
            aria-label="{{ 'sections.genus_shortcuts.prev' | t }}"
          >
            <span aria-hidden="true">&larr;</span>
          </button>
          <button
            type="button"
            class="genus-shortcuts__arrow"
            data-carousel-next
            aria-controls="genus-carousel-track-{{ section.id }}"
            aria-label="{{ 'sections.genus_shortcuts.next' | t }}"
          >
            <span aria-hidden="true">&rarr;</span>
          </button>
        </div>
      {%- endif -%}
    </header>
  {%- endif -%}

  {%- if has_genus_cards -%}
    <div
      class="genus-shortcuts__viewport"
      id="genus-carousel-track-{{ section.id }}"
      data-carousel-viewport
      data-carousel-track
      aria-label="{{ 'sections.genus_shortcuts.strip_label' | t }}"
    >
      <ul
        class="genus-shortcuts__strip"
        data-reveal-stagger
        role="list"
      >
        {{- genus_cards_markup -}}
      </ul>
    </div>
  {%- else -%}
    <p class="genus-shortcuts__empty">{{ 'sections.genus_shortcuts.empty' | t }}</p>
  {%- endif -%}
</section>

{% stylesheet %}
  .genus-shortcuts {
    padding-block: var(--space-3xl);
  }

  .genus-shortcuts__header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    margin-block-end: var(--space-xl);
    text-align: center;
  }

  .genus-shortcuts__section-title {
    margin: 0;
    font-family: var(--font-family-base);
    font-size: clamp(1.25rem, 2vw + 0.5rem, 1.75rem);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .genus-shortcuts__nav {
    display: none;
    gap: var(--space-xs);
  }

  .genus-shortcuts__nav.is-visible {
    display: inline-flex;
  }

  .genus-shortcuts__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    cursor: pointer;
    color: var(--color-parchment);
    background-color: var(--color-forest-green-dark);
    border: 1px solid rgb(255 255 255 / 0.12);
    border-radius: var(--radius-full);
    transition:
      background-color var(--transition-fast),
      transform var(--transition-fast),
      opacity var(--transition-fast);
  }

  .genus-shortcuts__arrow:hover:not(:disabled) {
    background-color: var(--color-forest-green);
    transform: translate3d(0, -1px, 0);
  }

  .genus-shortcuts__arrow:disabled {
    cursor: not-allowed;
    opacity: 0.4;
  }

  .genus-shortcuts__arrow:focus-visible {
    outline-color: var(--color-focus);
  }

  .genus-shortcuts__empty {
    margin: 0;
    padding: var(--space-xl);
    text-align: center;
    color: var(--color-text-muted);
  }

  .genus-shortcuts__viewport {
    margin-inline: calc(50% - 50vw);
    width: 100vw;
    max-width: 100vw;
    padding-inline: max(var(--page-margin), env(safe-area-inset-left, 0px));
    padding-inline-end: max(var(--page-margin), env(safe-area-inset-right, 0px));
    overflow-x: auto;
    overflow-y: visible;
    overscroll-behavior-x: contain;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scroll-padding-inline: max(var(--page-margin), env(safe-area-inset-left, 0px));
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .genus-shortcuts__viewport:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 4px;
  }

  .genus-shortcuts__viewport::-webkit-scrollbar {
    display: none;
  }

  .genus-shortcuts__strip {
    display: flex;
    gap: 2rem;
    margin: 0;
    padding: var(--space-sm) 0 var(--space-lg);
    list-style: none;
  }

  .genus-shortcuts__item {
    flex: 0 0 auto;
    width: clamp(14rem, 72vw, 22rem);
    scroll-snap-align: start;
    min-width: 0;
  }

  @media (min-width: 990px) {
    .genus-shortcuts__header {
      justify-content: space-between;
      text-align: start;
    }

    .genus-shortcuts__item {
      width: clamp(14rem, 18vw, 19rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .genus-shortcuts__viewport {
      scroll-behavior: auto;
    }

    .genus-shortcuts__arrow:hover:not(:disabled) {
      transition: none;
      transform: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    'use strict';

    var SECTION_SELECTOR = '[data-genus-carousel]';

    function initCarousel(root) {
      if (!root || !window.BT || !window.BT.initScrollCarousel) {
        return;
      }

      window.BT.initScrollCarousel(root, {
        track: '[data-carousel-track]',
        navMinWidth: 990,
        autoplayDisableMinWidth: 990
      });
    }

    function initAll(scope) {
      (scope || document).querySelectorAll(SECTION_SELECTOR).forEach(initCarousel);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        initAll();
      });
    } else {
      initAll();
    }

    document.addEventListener('shopify:section:load', function (event) {
      initAll(event.target);
    });

    document.addEventListener('shopify:section:unload', function (event) {
      var section = event.target.querySelector(SECTION_SELECTOR);
      if (section && window.BT && window.BT.destroyScrollCarousel) {
        window.BT.destroyScrollCarousel(section);
      }
    });
  })();
{% endjavascript %}

{% schema %}
