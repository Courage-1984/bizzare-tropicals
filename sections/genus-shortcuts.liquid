{%- liquid
  assign section_heading = section.settings.heading
  assign default_placeholder = section.settings.default_placeholder_image
  assign use_dynamic_genera = section.settings.use_dynamic_genera
  assign has_genus_cards = false

  if use_dynamic_genera
    assign has_genus_cards = true
  elsif section.blocks.size > 0
    assign has_genus_cards = true
  endif
-%}

<section
  class="genus-shortcuts reveal-up"
  data-genus-carousel
  aria-labelledby="genus-shortcuts-heading-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  {%- if section_heading != blank or has_genus_cards -%}
    <header class="genus-shortcuts__header">
      {%- if section_heading != blank -%}
        <h2 id="genus-shortcuts-heading-{{ section.id }}" class="genus-shortcuts__section-title">
          {{ section_heading | escape }}
        </h2>
      {%- endif -%}

      {%- if has_genus_cards -%}
        <div class="genus-shortcuts__nav" data-carousel-nav hidden>
          <button
            type="button"
            class="genus-shortcuts__arrow"
            data-carousel-prev
            aria-controls="genus-carousel-track-{{ section.id }}"
            aria-label="{{ 'sections.genus_shortcuts.prev' | t }}"
          >
            <span aria-hidden="true">&larr;</span>
          </button>
          <button
            type="button"
            class="genus-shortcuts__arrow"
            data-carousel-next
            aria-controls="genus-carousel-track-{{ section.id }}"
            aria-label="{{ 'sections.genus_shortcuts.next' | t }}"
          >
            <span aria-hidden="true">&rarr;</span>
          </button>
        </div>
      {%- endif -%}
    </header>
  {%- endif -%}

  {%- if has_genus_cards -%}
    <div class="genus-shortcuts__viewport" data-carousel-viewport>
      <ul
        id="genus-carousel-track-{{ section.id }}"
        class="genus-shortcuts__strip"
        data-carousel-track
        data-reveal-stagger
        role="list"
        tabindex="0"
        aria-label="{{ 'sections.genus_shortcuts.strip_label' | t }}"
      >
        {%- if use_dynamic_genera -%}
          {% render 'genus-shortcuts-dynamic-strip', default_placeholder: default_placeholder %}
        {%- else -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'genus' -%}
            {%- liquid
              assign card_collection = block.settings.collection
              assign card_title = block.settings.title
              assign card_link = block.settings.link
              assign card_image = block.settings.image
              assign placeholder_url = block.settings.placeholder_image
              if placeholder_url contains 'Venus_Flytrap_(Dionaea_muscipula)'
                assign placeholder_url = blank
              endif
              assign genus_handle = card_title | handleize
              assign use_shopify_image = false

              if card_collection != blank
                assign genus_handle = card_collection.handle
                if card_title == blank
                  assign card_title = card_collection.title
                endif
                if card_link == blank
                  assign card_link = card_collection.url
                endif
                if card_image == blank
                  if card_collection.image != blank
                    if card_collection.image.width > 0
                      assign card_image = card_collection.image
                    endif
                  endif
                  if card_image == blank
                    assign fallback_product = card_collection.products.first
                    if fallback_product != blank
                      assign card_image = fallback_product.featured_media.preview_image | default: fallback_product.featured_image
                    endif
                  endif
                endif
              endif

              if section.settings.hide_empty_collections
                if card_collection != blank
                  if card_collection.products_count == 0
                    assign card_title = blank
                  endif
                endif
              endif

              if card_link == blank
                if card_title != blank
                  assign card_link = card_title | handleize | prepend: '/collections/'
                endif
              endif

              if card_image != blank
                if card_image.width > 0
                  assign use_shopify_image = true
                endif
              endif

              unless use_shopify_image
                if placeholder_url == blank
                  capture genus_placeholder
                    render 'genus-placeholder-url', genus_handle: genus_handle
                  endcapture
                  assign placeholder_url = genus_placeholder | strip
                endif
                if placeholder_url == blank
                  assign placeholder_url = default_placeholder
                endif
              endunless
            -%}

            {%- if card_title != blank -%}
              {%- if card_link != blank -%}
                <li class="genus-shortcuts__item reveal-up" data-carousel-item {{ block.shopify_attributes }} role="listitem">
                  {% render 'genus-arch-card',
                    card_title: card_title,
                    card_link: card_link,
                    placeholder_url: placeholder_url,
                    card_image: card_image,
                    use_shopify_image: use_shopify_image
                  %}
                </li>
              {%- endif -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
        {%- endif -%}
      </ul>
    </div>
  {%- else -%}
    <p class="genus-shortcuts__empty">{{ 'sections.genus_shortcuts.empty' | t }}</p>
  {%- endif -%}
</section>

{% stylesheet %}
  .genus-shortcuts {
    padding-block: var(--space-3xl);
  }

  .genus-shortcuts__header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    margin-block-end: var(--space-xl);
    text-align: center;
  }

  .genus-shortcuts__section-title {
    margin: 0;
    font-family: var(--font-family-base);
    font-size: clamp(1.25rem, 2vw + 0.5rem, 1.75rem);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .genus-shortcuts__nav {
    display: none;
    gap: var(--space-xs);
  }

  .genus-shortcuts__nav.is-visible {
    display: inline-flex;
  }

  .genus-shortcuts__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    cursor: pointer;
    color: var(--color-parchment);
    background-color: var(--color-forest-green-dark);
    border: 1px solid rgb(255 255 255 / 0.12);
    border-radius: var(--radius-full);
    transition:
      background-color var(--transition-fast),
      transform var(--transition-fast),
      opacity var(--transition-fast);
  }

  .genus-shortcuts__arrow:hover:not(:disabled) {
    background-color: var(--color-forest-green);
    transform: translate3d(0, -1px, 0);
  }

  .genus-shortcuts__arrow:disabled {
    cursor: not-allowed;
    opacity: 0.4;
  }

  .genus-shortcuts__arrow:focus-visible {
    outline-color: var(--color-focus);
  }

  .genus-shortcuts__empty {
    margin: 0;
    padding: var(--space-xl);
    text-align: center;
    color: var(--color-text-muted);
  }

  .genus-shortcuts__viewport {
    margin-inline: calc(var(--page-margin) * -1);
    padding-inline: var(--page-margin);
    overflow: hidden;
  }

  .genus-shortcuts__strip:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 4px;
  }

  .genus-shortcuts__strip {
    display: flex;
    gap: 2rem;
    margin: 0;
    padding: var(--space-xs) var(--page-margin) var(--space-md);
    list-style: none;
    overflow-x: auto;
    overscroll-behavior-x: contain;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .genus-shortcuts__strip::-webkit-scrollbar {
    display: none;
  }

  .genus-shortcuts__item {
    flex: 0 0 auto;
    width: 60vw;
    scroll-snap-align: start;
    min-width: 0;
  }

  @media (min-width: 990px) {
    .genus-shortcuts__header {
      justify-content: space-between;
      text-align: start;
    }

    .genus-shortcuts__viewport {
      margin-inline: 0;
      padding-inline: 0;
    }

    .genus-shortcuts__strip {
      padding-inline: 0;
    }

    .genus-shortcuts__item {
      width: 20vw;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .genus-shortcuts__strip {
      scroll-behavior: auto;
    }

    .genus-shortcuts__arrow:hover:not(:disabled) {
      transition: none;
      transform: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    'use strict';

    var SECTION_SELECTOR = '[data-genus-carousel]';
    var AUTOPLAY_MS = 6000;
    var RESUME_DELAY_MS = 8000;

    function prefersReducedMotion() {
      try {
        return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      } catch (error) {
        return false;
      }
    }

    function destroyCarousel(root) {
      if (!root || !root._genusCarouselState) {
        return;
      }

      try {
        var state = root._genusCarouselState;

        if (state.autoplayTimer) {
          clearInterval(state.autoplayTimer);
        }

        if (state.resumeTimer) {
          clearTimeout(state.resumeTimer);
        }

        state.listeners.forEach(function (entry) {
          entry.target.removeEventListener(entry.type, entry.handler);
        });
      } catch (error) {
        console.error('Genus shortcuts: teardown failed.', error);
      }

      delete root._genusCarouselState;
      root.dataset.genusCarouselInitialized = 'false';
    }

    function updateNavState(track, prevButton, nextButton) {
      if (!track || !prevButton || !nextButton) {
        return;
      }

      var overflow = track.scrollWidth > track.clientWidth + 2;
      prevButton.disabled = !overflow;
      nextButton.disabled = !overflow;
    }

    function getScrollStep(track) {
      var firstItem = track.querySelector('[data-carousel-item]');
      if (!firstItem) {
        return track.clientWidth * 0.85;
      }

      var trackStyles = window.getComputedStyle(track);
      var gap = parseFloat(trackStyles.columnGap || trackStyles.gap || '0') || 0;
      return firstItem.offsetWidth + gap;
    }

    function initCarousel(root) {
      if (!root) {
        return;
      }

      destroyCarousel(root);

      var track = root.querySelector('[data-carousel-track]');
      var nav = root.querySelector('[data-carousel-nav]');
      var prevButton = root.querySelector('[data-carousel-prev]');
      var nextButton = root.querySelector('[data-carousel-next]');

      if (!track || !prevButton || !nextButton || !nav) {
        return;
      }

      var desktopQuery = window.matchMedia('(min-width: 990px)');
      var autoplayPaused = false;
      var state = {
        listeners: [],
        autoplayTimer: null,
        resumeTimer: null
      };

      function trackListener(target, type, handler, options) {
        target.addEventListener(type, handler, options);
        state.listeners.push({ target: target, type: type, handler: handler });
      }

      function scrollByStep(direction) {
        var step = getScrollStep(track) * direction;
        var behavior = prefersReducedMotion() ? 'auto' : 'smooth';
        track.scrollBy({ left: step, behavior: behavior });
      }

      function scrollNextWithLoop() {
        var maxScroll = track.scrollWidth - track.clientWidth;
        var atEnd = track.scrollLeft >= maxScroll - 2;
        var behavior = prefersReducedMotion() ? 'auto' : 'smooth';

        if (atEnd) {
          track.scrollTo({ left: 0, behavior: behavior });
          return;
        }

        scrollByStep(1);
      }

      function scrollPrevWithLoop() {
        var atStart = track.scrollLeft <= 2;
        var maxScroll = track.scrollWidth - track.clientWidth;
        var behavior = prefersReducedMotion() ? 'auto' : 'smooth';

        if (atStart) {
          track.scrollTo({ left: maxScroll, behavior: behavior });
          return;
        }

        scrollByStep(-1);
      }

      function stopAutoplay() {
        if (state.autoplayTimer) {
          clearInterval(state.autoplayTimer);
          state.autoplayTimer = null;
        }
      }

      function startAutoplay() {
        stopAutoplay();

        var overflow = track.scrollWidth > track.clientWidth + 2;
        if (!overflow || autoplayPaused || prefersReducedMotion() || document.hidden) {
          return;
        }

        state.autoplayTimer = setInterval(function () {
          if (document.hidden) {
            return;
          }
          try {
            scrollNextWithLoop();
          } catch (error) {
            console.error('Genus shortcuts: autoplay tick failed.', error);
          }
        }, AUTOPLAY_MS);
      }

      function pauseAutoplay() {
        autoplayPaused = true;
        stopAutoplay();

        if (state.resumeTimer) {
          clearTimeout(state.resumeTimer);
          state.resumeTimer = null;
        }
      }

      function scheduleAutoplayResume() {
        if (state.resumeTimer) {
          clearTimeout(state.resumeTimer);
        }

        state.resumeTimer = setTimeout(function () {
          try {
            autoplayPaused = false;
            startAutoplay();
          } catch (error) {
            console.error('Genus shortcuts: autoplay resume failed.', error);
          }
        }, RESUME_DELAY_MS);
      }

      function syncNavVisibility() {
        var isDesktop = desktopQuery.matches;
        var overflow = track.scrollWidth > track.clientWidth + 2;
        nav.hidden = !isDesktop;
        nav.classList.toggle('is-visible', isDesktop && overflow);
        updateNavState(track, prevButton, nextButton);
      }

      trackListener(prevButton, 'click', function () {
        pauseAutoplay();
        scrollPrevWithLoop();
        scheduleAutoplayResume();
      });

      trackListener(nextButton, 'click', function () {
        pauseAutoplay();
        scrollNextWithLoop();
        scheduleAutoplayResume();
      });

      trackListener(track, 'scroll', function () {
        updateNavState(track, prevButton, nextButton);
      }, { passive: true });

      trackListener(track, 'pointerdown', pauseAutoplay);
      trackListener(track, 'pointerenter', pauseAutoplay);
      trackListener(track, 'focusin', pauseAutoplay);
      trackListener(track, 'pointerup', scheduleAutoplayResume);
      trackListener(track, 'pointerleave', scheduleAutoplayResume);
      trackListener(track, 'focusout', scheduleAutoplayResume);

      trackListener(window, 'resize', function () {
        syncNavVisibility();
        startAutoplay();
      });

      if (typeof desktopQuery.addEventListener === 'function') {
        trackListener(desktopQuery, 'change', function () {
          syncNavVisibility();
        });
      } else if (typeof desktopQuery.addListener === 'function') {
        desktopQuery.addListener(syncNavVisibility);
      }

      syncNavVisibility();
      root._genusCarouselState = state;
      root.dataset.genusCarouselInitialized = 'true';
      startAutoplay();
    }

    function initAllCarousels(scope) {
      var context = scope || document;
      var sections = context.querySelectorAll(SECTION_SELECTOR);

      sections.forEach(function (section) {
        if (section.dataset.genusCarouselInitialized === 'true') {
          return;
        }
        initCarousel(section);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        initAllCarousels();
      });
    } else {
      initAllCarousels();
    }

    document.addEventListener('shopify:section:load', function (event) {
      initAllCarousels(event.target);
    });

    document.addEventListener('shopify:section:unload', function (event) {
      var section = event.target.querySelector(SECTION_SELECTOR);
      if (section) {
        destroyCarousel(section);
      }
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.genus_shortcuts.name",
  "tag": "section",
  "class": "genus-shortcuts-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.genus_shortcuts.settings.heading",
      "default": "Shop by genus"
    },
    {
      "type": "text",
      "id": "default_placeholder_image",
      "label": "t:sections.genus_shortcuts.settings.default_placeholder_image",
      "info": "t:sections.genus_shortcuts.settings.default_placeholder_image_info",
      "default": "https://commons.wikimedia.org/wiki/Special:FilePath/Drosera_Capensis.jpg?width=1200"
    },
    {
      "type": "checkbox",
      "id": "use_dynamic_genera",
      "label": "t:sections.genus_shortcuts.settings.use_dynamic_genera",
      "info": "t:sections.genus_shortcuts.settings.use_dynamic_genera_info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "hide_empty_collections",
      "label": "t:sections.genus_shortcuts.settings.hide_empty_collections",
      "info": "t:sections.genus_shortcuts.settings.hide_empty_collections_info",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "genus",
      "name": "t:sections.genus_shortcuts.blocks.genus.name",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:general.collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.text",
          "info": "t:sections.genus_shortcuts.blocks.genus.settings.title_info"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.genus_shortcuts.blocks.genus.settings.link",
          "info": "t:sections.genus_shortcuts.blocks.genus.settings.link_info"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.background"
        },
        {
          "type": "text",
          "id": "placeholder_image",
          "label": "t:sections.genus_shortcuts.blocks.genus.settings.placeholder_image",
          "info": "t:sections.genus_shortcuts.blocks.genus.settings.placeholder_image_info"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.genus_shortcuts.name",
      "blocks": [
        {
          "type": "genus",
          "settings": {
            "collection": "dionaea",
            "title": "Dionaea"
          }
        },
        {
          "type": "genus",
          "settings": {
            "collection": "sarracenia",
            "title": "Sarracenia"
          }
        },
        {
          "type": "genus",
          "settings": {
            "collection": "nepenthes",
            "title": "Nepenthes"
          }
        },
        {
          "type": "genus",
          "settings": {
            "collection": "drosera",
            "title": "Drosera"
          }
        },
        {
          "type": "genus",
          "settings": {
            "collection": "pinguicula",
            "title": "Pinguicula"
          }
        },
        {
          "type": "genus",
          "settings": {
            "collection": "cephalotus",
            "title": "Cephalotus"
          }
        },
        {
          "type": "genus",
          "settings": {
            "collection": "heliamphora",
            "title": "Heliamphora"
          }
        },
        {
          "type": "genus",
          "settings": {
            "collection": "utricularia",
            "title": "Utricularia"
          }
        }
      ]
    }
  ]
}
{% endschema %}
