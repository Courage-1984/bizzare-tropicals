<div
  class="search-overlay"
  data-search-overlay
  data-predictive-search-url="{{ routes.predictive_search_url }}"
  data-empty-label="{{ 'sections.search_overlay.no_results' | t | escape }}"
  data-live-match-label="{{ 'sections.search_overlay.live_match' | t | escape }}"
  hidden
  aria-hidden="true"
  {{ section.shopify_attributes }}
>
  <button
    type="button"
    class="search-overlay__backdrop"
    data-search-overlay-close
    tabindex="-1"
    aria-hidden="true"
  ></button>

  <div
    class="search-overlay__dialog"
    id="search-overlay-dialog"
    role="dialog"
    aria-modal="true"
    aria-labelledby="search-overlay-title-{{ section.id }}"
  >
    <button
      type="button"
      class="search-overlay__close"
      data-search-overlay-close
      aria-label="{{ 'sections.search_overlay.close' | t }}"
    >
      <span aria-hidden="true">&times;</span>
    </button>

    <h2 id="search-overlay-title-{{ section.id }}" class="visually-hidden">
      {{ 'sections.search_overlay.title' | t }}
    </h2>

    <form
      class="search-overlay__form"
      action="{{ routes.search_url }}"
      method="get"
      role="search"
      data-search-form
    >
      <label class="visually-hidden" for="search-overlay-input-{{ section.id }}">
        {{ 'sections.search_overlay.input_label' | t }}
      </label>
      <input
        id="search-overlay-input-{{ section.id }}"
        class="search-overlay__input"
        type="search"
        name="q"
        value=""
        autocomplete="off"
        autocorrect="off"
        autocapitalize="off"
        spellcheck="false"
        placeholder="{{ 'sections.search_overlay.placeholder' | t }}"
        data-search-input
      >
    </form>

    <div
      class="search-overlay__results search-overlay__reveal"
      data-search-results
      hidden
      aria-live="polite"
      aria-atomic="true"
    ></div>

    {% render 'search-overlay-browse-marquees' %}

    <div
      class="search-overlay__suggested search-overlay__reveal"
      data-search-suggested
      aria-label="{{ 'sections.search_overlay.suggested_matches' | t }}"
    >
      <p class="search-overlay__suggested-heading">{{ 'sections.search_overlay.suggested_matches' | t }}</p>
      {% render 'search-overlay-suggested-matches', section: section %}
    </div>
  </div>
</div>

{% stylesheet %}
  .search-overlay-section.shopify-section {
    display: block;
    height: 0;
    min-height: 0;
    margin: 0;
    padding: 0;
    overflow: visible;
  }

  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: var(--z-search-overlay, 1110);
    display: flex;
    align-items: stretch;
    justify-content: center;
    padding: var(--space-xl) var(--page-margin);
    padding-block-start: calc(var(--header-height) + var(--announcement-bar-height, 0px) + var(--space-2xl));
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1),
      visibility 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .search-overlay:not([hidden]) {
    visibility: visible;
  }

  .search-overlay.is-open {
    opacity: 1;
    align-items: flex-start;
    overflow-y: auto;
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
    padding-block-end: var(--space-lg);
  }

  .search-overlay__backdrop {
    position: absolute;
    inset: 0;
    padding: 0;
    cursor: pointer;
    background-color: rgb(247 244 237 / 0.9);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 0;
    opacity: 1;
  }

  .search-overlay__dialog {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: min(42rem, 100%);
    max-height: calc(
      100svh - var(--header-height, 4rem) - var(--announcement-bar-height, 0px) - var(--space-xl)
    );
    min-height: 0;
    margin-inline: auto;
    margin-block-end: var(--space-lg);
    overflow-y: auto;
    overscroll-behavior: contain;
    pointer-events: auto;
    scrollbar-width: thin;
    scrollbar-color: rgb(10 24 18 / 0.22) transparent;
  }

  .search-overlay__close {
    position: absolute;
    top: 0;
    inset-inline-end: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    font-size: 1.75rem;
    line-height: 1;
    cursor: pointer;
    color: var(--color-forest-green-dark);
    background: transparent;
    border: 0;
    opacity: 0.65;
    transition: opacity var(--transition-link-grow);
  }

  .search-overlay__close:hover {
    opacity: 1;
  }

  .search-overlay__form {
    width: 100%;
    flex-shrink: 0;
    margin-block-start: clamp(1rem, 6vh, 3rem);
  }

  .search-overlay__input {
    width: 100%;
    padding: var(--space-md) 0;
    font-family: var(--font-family-serif);
    font-size: clamp(1.75rem, 4vw + 0.5rem, 3rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: 0.01em;
    text-align: center;
    color: var(--color-forest-green-dark);
    background: transparent;
    border: 0;
    border-block-end: 1px solid var(--color-border-strong);
    border-radius: 0;
    outline: none;
    transition: border-color var(--transition-link-grow);
  }

  .search-overlay__input::placeholder {
    color: rgb(10 24 18 / 0.42);
    opacity: 1;
  }

  .search-overlay__input:focus {
    border-block-end-color: var(--color-forest-green-dark);
    box-shadow: inset 0 -1px 0 var(--color-forest-green-dark);
  }

  .search-overlay__reveal {
    opacity: 0;
    transform: translate3d(0, 12px, 0);
    transition:
      opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1),
      transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .search-overlay.is-open .search-overlay__reveal.is-visible,
  .search-overlay.is-open .search-overlay__reveal:not([hidden]) {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .search-overlay__results {
    width: 100%;
    max-height: none;
    margin-block-start: var(--space-lg);
    overflow: visible;
  }

  .search-overlay__results[hidden] {
    display: none;
  }

  .search-overlay__results-list {
    max-height: min(50vh, 28rem);
    margin: 0;
    padding: 0;
    padding-inline-end: 0.25rem;
    overflow-y: auto;
    overscroll-behavior: contain;
    list-style: none;
    scrollbar-width: thin;
    scrollbar-color: rgb(10 24 18 / 0.28) transparent;
  }

  .search-overlay__results-item + .search-overlay__results-item {
    margin-block-start: var(--space-xs);
  }

  .search-overlay__result-link {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-sm) 0;
    font-family: var(--font-family-serif);
    font-size: var(--font-size-lg);
    font-style: italic;
    text-decoration: none;
    color: var(--color-forest-green-dark);
    transition: color var(--transition-link-grow);
  }

  .search-overlay__result-link:hover {
    color: var(--color-accent);
  }

  .search-overlay__result-media {
    flex-shrink: 0;
    display: block;
    width: 3.25rem;
    height: 3.25rem;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border: 1px solid rgb(10 24 18 / 0.12);
    background-color: rgb(10 24 18 / 0.04);
  }

  .search-overlay__result-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  .search-overlay__result-label {
    flex: 1;
    min-width: 0;
    line-height: 1.3;
    text-align: start;
  }

  .search-overlay__result-link:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  .search-overlay__results-empty {
    margin: 0;
    font-size: var(--font-size-sm);
    text-align: center;
    color: var(--color-text-muted);
  }

  .search-overlay__browse {
    width: 100%;
    flex-shrink: 0;
    margin-block-start: var(--space-lg);
    text-align: center;
  }

  .search-overlay__browse[hidden] {
    display: none !important;
  }

  .search-overlay__browse-heading {
    margin: 0 0 var(--space-sm);
    font-family: var(--font-family-base);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(10 24 18 / 0.55);
  }

  .search-marquee {
    overflow: hidden;
    margin-block-end: var(--space-sm);
    mask-image: linear-gradient(
      90deg,
      transparent 0%,
      rgb(0 0 0) 8%,
      rgb(0 0 0) 92%,
      transparent 100%
    );
  }

  .search-marquee__viewport {
    overflow: hidden;
  }

  .search-marquee__track {
    display: flex;
    width: max-content;
    will-change: transform;
  }

  .search-marquee__track--ltr {
    animation: search-marquee-ltr 150s linear infinite;
  }

  .search-marquee__track--rtl {
    animation: search-marquee-rtl 165s linear infinite;
  }

  .search-marquee:hover .search-marquee__track {
    animation-play-state: paused;
  }

  .search-marquee__group {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    gap: clamp(0.75rem, 2vw, 1.5rem);
    padding-inline: clamp(0.5rem, 1.5vw, 0.85rem);
  }

  .search-marquee__chip {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    padding: 0.35rem 0.15rem;
    font-family: var(--font-family-serif);
    font-size: clamp(1rem, 1.6vw + 0.35rem, 1.35rem);
    font-style: italic;
    text-decoration: none;
    color: var(--color-forest-green-dark);
    white-space: nowrap;
    transition: color var(--transition-link-grow);
  }

  .search-marquee__chip--common {
    font-size: clamp(0.9rem, 1.2vw + 0.3rem, 1.125rem);
    opacity: 0.88;
  }

  .search-marquee__chip:hover {
    color: var(--color-accent);
  }

  @keyframes search-marquee-ltr {
    from {
      transform: translate3d(0, 0, 0);
    }

    to {
      transform: translate3d(-50%, 0, 0);
    }
  }

  @keyframes search-marquee-rtl {
    from {
      transform: translate3d(-50%, 0, 0);
    }

    to {
      transform: translate3d(0, 0, 0);
    }
  }

  .search-overlay__suggested {
    width: 100%;
    flex-shrink: 0;
    margin-block-start: var(--space-lg);
    padding-block-end: var(--space-sm);
    text-align: center;
  }

  .search-overlay__suggested[hidden] {
    display: none;
  }

  .search-overlay__suggested-heading {
    margin: 0 0 var(--space-md);
    font-family: var(--font-family-base);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(10 24 18 / 0.55);
  }

  .search-overlay__suggested-rotator {
    width: 100%;
    margin-inline: auto;
  }

  .search-overlay__suggested-viewport {
    overflow: hidden;
    margin-inline: auto;
    max-width: 100%;
    min-height: 6.75rem;
  }

  .search-overlay__suggested-track {
    display: flex;
    flex-direction: column;
    will-change: transform;
  }

  .search-overlay__suggested-track.is-advancing {
    transition: transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .search-overlay__suggested-row.search-overlay__trending {
    flex-shrink: 0;
    margin-block-end: 0;
  }

  .search-overlay__trending {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 5.5rem));
    justify-content: center;
    gap: var(--space-sm);
    margin: 0 auto;
    padding: 0;
    max-width: 100%;
    list-style: none;
  }

  .search-overlay__trending-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    text-decoration: none;
    color: var(--color-forest-green-dark);
  }

  .search-overlay__trending-media {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border: 1px solid rgb(10 24 18 / 0.12);
    background-color: rgb(10 24 18 / 0.04);
  }

  .search-overlay__trending-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .search-overlay__trending-link:hover .search-overlay__trending-image {
    transform: scale3d(1.04, 1.04, 1);
  }

  .search-overlay__trending-label {
    font-family: var(--font-family-serif);
    font-size: 0.6875rem;
    line-height: 1.3;
    color: var(--color-forest-green-dark);
  }

  .search-overlay__trending-label em {
    font-style: italic;
  }

  @media (max-width: 749px) {
    .search-overlay {
      padding-block-start: calc(var(--header-height) + var(--announcement-bar-height, 0px) + var(--space-lg));
    }

    .search-overlay__trending {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      max-width: 18rem;
      gap: 0.5rem;
    }

    .search-marquee__track--ltr,
    .search-marquee__track--rtl {
      animation-duration: 190s;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .search-overlay,
    .search-overlay__reveal,
    .search-overlay__trending-image {
      transition: none;
    }

    .search-marquee__track--ltr,
    .search-marquee__track--rtl {
      animation: none;
      transform: none;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
    }

    .search-marquee__group[aria-hidden='true'] {
      display: none;
    }

    .search-marquee__viewport {
      overflow: visible;
    }

    .search-marquee {
      mask-image: none;
    }

    .search-overlay__trending-link:hover .search-overlay__trending-image {
      transform: none;
    }

    .search-overlay__suggested-track.is-advancing {
      transition: none;
      transform: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    'use strict';

    var overlay = document.querySelector('[data-search-overlay]');
    if (!overlay) {
      return;
    }

    var form = overlay.querySelector('[data-search-form]');
    var input = overlay.querySelector('[data-search-input]');
    var results = overlay.querySelector('[data-search-results]');
    var predictiveUrl = overlay.getAttribute('data-predictive-search-url');
    var openTriggers = document.querySelectorAll('[data-search-overlay-open]');
    var closeTriggers = overlay.querySelectorAll('[data-search-overlay-close]');
    var debounceTimer = null;
    var lastController = null;
    var debounceMs = 280;
    var suggested = overlay.querySelector('[data-search-suggested]');
    var liveMatchLabel = overlay.getAttribute('data-live-match-label') || 'Live match';
    var suggestedRotatorState = null;

    function prefersReducedMotion() {
      try {
        return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      } catch (error) {
        return false;
      }
    }

    function destroySuggestedRotator() {
      if (!suggestedRotatorState) {
        return;
      }

      if (suggestedRotatorState.waitTimer) {
        window.clearTimeout(suggestedRotatorState.waitTimer);
      }

      if (suggestedRotatorState.transitionHandler && suggestedRotatorState.track) {
        suggestedRotatorState.track.removeEventListener(
          'transitionend',
          suggestedRotatorState.transitionHandler
        );
      }

      if (suggestedRotatorState.resizeHandler) {
        window.removeEventListener('resize', suggestedRotatorState.resizeHandler);
      }

      suggestedRotatorState = null;
    }

    function buildSuggestedItem(product) {
      var listItem = document.createElement('li');
      listItem.className = 'search-overlay__trending-item';
      listItem.setAttribute('role', 'listitem');

      var link = document.createElement('a');
      link.className = 'search-overlay__trending-link';
      link.href = product.url || '#';

      var media = document.createElement('span');
      media.className = 'search-overlay__trending-media';

      if (product.imageUrl) {
        var image = document.createElement('img');
        image.className = 'search-overlay__trending-image';
        image.src = product.imageUrl;
        image.alt = '';
        image.width = 400;
        image.height = 400;
        image.loading = 'lazy';
        image.decoding = 'async';
        image.addEventListener(
          'load',
          function () {
            if (suggestedRotatorState && suggestedRotatorState.resizeHandler) {
              suggestedRotatorState.resizeHandler();
            }
          },
          { once: true }
        );
        media.appendChild(image);
      }

      link.appendChild(media);

      var label = document.createElement('span');
      label.className = 'search-overlay__trending-label';
      var emphasis = document.createElement('em');
      emphasis.textContent = product.latinName || product.title || '';
      label.appendChild(emphasis);
      link.appendChild(label);

      var ariaTitle = product.latinName || product.title || 'Product';
      link.setAttribute('aria-label', ariaTitle);

      listItem.appendChild(link);
      return listItem;
    }

    function renderSuggestedRow(rowEl, items) {
      if (!rowEl) {
        return;
      }

      rowEl.replaceChildren();
      items.forEach(function (product) {
        rowEl.appendChild(buildSuggestedItem(product));
      });
    }

    function getSuggestedPageItems(products, pageIndex, pageSize) {
      var items = [];
      var i;

      if (!products.length) {
        return items;
      }

      for (i = 0; i < pageSize; i += 1) {
        items.push(products[(pageIndex * pageSize + i) % products.length]);
      }

      return items;
    }

    function initSuggestedRotator() {
      destroySuggestedRotator();

      var rotator = overlay.querySelector('[data-search-suggested-rotator]');
      if (!rotator) {
        return;
      }

      var jsonEl = overlay.querySelector('[data-suggested-products-json]');
      if (!jsonEl) {
        return;
      }

      var products = [];
      try {
        products = JSON.parse(jsonEl.textContent || '[]');
      } catch (error) {
        console.error('Search overlay: suggested products JSON invalid.', error);
        return;
      }

      if (products.length < 3) {
        return;
      }

      var track = rotator.querySelector('[data-suggested-track]');
      var rowA = rotator.querySelector('[data-suggested-row="a"]');
      var rowB = rotator.querySelector('[data-suggested-row="b"]');
      var viewport = rotator.querySelector('[data-suggested-viewport]');
      var reducedMotion = prefersReducedMotion();

      if (!track || !rowA || !rowB) {
        return;
      }

      var pageSize = 3;
      var pageIndex = 0;
      var totalPages = Math.max(1, Math.ceil(products.length / pageSize));
      var holdMs = parseInt(rotator.getAttribute('data-rotate-pause'), 10) || 3200;
      var animating = false;

      function syncViewportHeight() {
        if (!viewport || !rowA) {
          return;
        }

        viewport.style.height = rowA.offsetHeight + 'px';
      }

      function finishAdvance() {
        track.classList.remove('is-advancing');
        track.style.transform = '';
        pageIndex = (pageIndex + 1) % totalPages;
        renderSuggestedRow(rowA, getSuggestedPageItems(products, pageIndex, pageSize));
        renderSuggestedRow(
          rowB,
          getSuggestedPageItems(products, (pageIndex + 1) % totalPages, pageSize)
        );
        rowB.setAttribute('aria-hidden', 'true');
        rowA.removeAttribute('aria-hidden');
        syncViewportHeight();
        animating = false;
        scheduleHold();
      }

      function advanceSuggested() {
        if (animating || document.hidden || !overlay.classList.contains('is-open')) {
          scheduleHold();
          return;
        }

        if (totalPages < 2) {
          scheduleHold();
          return;
        }

        animating = true;
        syncViewportHeight();
        track.classList.add('is-advancing');
        track.style.transform = 'translate3d(0, -50%, 0)';

        suggestedRotatorState.transitionHandler = function (event) {
          if (event.propertyName !== 'transform') {
            return;
          }

          track.removeEventListener('transitionend', suggestedRotatorState.transitionHandler);
          suggestedRotatorState.transitionHandler = null;
          finishAdvance();
        };

        track.addEventListener('transitionend', suggestedRotatorState.transitionHandler);
      }

      function scheduleHold() {
        if (!suggestedRotatorState) {
          return;
        }

        if (suggestedRotatorState.waitTimer) {
          window.clearTimeout(suggestedRotatorState.waitTimer);
        }

        suggestedRotatorState.waitTimer = window.setTimeout(advanceSuggested, holdMs);
      }

      renderSuggestedRow(rowA, getSuggestedPageItems(products, 0, pageSize));
      renderSuggestedRow(rowB, getSuggestedPageItems(products, 1 % totalPages, pageSize));
      rowB.setAttribute('aria-hidden', 'true');

      suggestedRotatorState = {
        track: track,
        waitTimer: null,
        transitionHandler: null,
        resizeHandler: syncViewportHeight
      };

      window.addEventListener('resize', suggestedRotatorState.resizeHandler);
      syncViewportHeight();
      window.requestAnimationFrame(syncViewportHeight);
      window.setTimeout(syncViewportHeight, 120);

      if (reducedMotion) {
        rowB.hidden = true;
        if (viewport) {
          viewport.style.height = 'auto';
        }
        return;
      }

      scheduleHold();
    }

    function setRevealVisible(element, isVisible) {
      if (!element) {
        return;
      }

      element.classList.toggle('is-visible', isVisible);
    }

    var browse = overlay.querySelector('[data-search-browse]');

    function updateSuggestedVisibility(query, hasResultItems) {
      var hidePanels = query.length >= 2 && hasResultItems;

      if (suggested) {
        suggested.hidden = hidePanels;
        setRevealVisible(suggested, !hidePanels);
      }

      if (browse) {
        browse.hidden = hidePanels;
        setRevealVisible(browse, !hidePanels);
      }

      if (hidePanels) {
        destroySuggestedRotator();
      } else if (overlay.classList.contains('is-open')) {
        initSuggestedRotator();
      }
    }

    function setOpen(isOpen) {
      try {
        overlay.classList.toggle('is-open', isOpen);
        overlay.hidden = !isOpen;
        overlay.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
        document.documentElement.classList.toggle('is-scroll-locked', isOpen);

        openTriggers.forEach(function (trigger) {
          trigger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        });

        if (isOpen && input) {
          window.setTimeout(function () {
            input.focus();
          }, 60);
          window.setTimeout(function () {
            setRevealVisible(suggested, true);
            if (browse) {
              setRevealVisible(browse, true);
            }
            initSuggestedRotator();
          }, 120);
        }

        if (!isOpen) {
          destroySuggestedRotator();
          clearResults();
          if (input) {
            input.value = '';
          }
          setRevealVisible(suggested, false);
          if (browse) {
            setRevealVisible(browse, false);
          }
          updateSuggestedVisibility('', false);
        }
      } catch (error) {
        console.error('Search overlay: failed to toggle open state.', error);
      }
    }

    function clearResults() {
      if (!results) {
        return;
      }

      results.hidden = true;
      results.innerHTML = '';
      setRevealVisible(results, false);
      updateSuggestedVisibility(input ? input.value.trim() : '', false);
    }

    function resolveEntryImage(entry) {
      if (!entry) {
        return '';
      }

      if (entry.featured_image && entry.featured_image.url) {
        return entry.featured_image.url;
      }

      if (entry.image && entry.image.url) {
        return entry.image.url;
      }

      return '';
    }

    function buildResultItem(item) {
      var listItem = document.createElement('li');
      listItem.className = 'search-overlay__results-item';
      listItem.setAttribute('role', 'listitem');

      var link = document.createElement('a');
      link.className = 'search-overlay__result-link link-underline-grow';
      link.href = item.url;

      if (item.imageUrl) {
        var media = document.createElement('span');
        media.className = 'search-overlay__result-media';

        var thumb = document.createElement('img');
        thumb.className = 'search-overlay__result-image';
        thumb.src = item.imageUrl;
        thumb.alt = '';
        thumb.width = 80;
        thumb.height = 80;
        thumb.loading = 'lazy';
        thumb.decoding = 'async';
        media.appendChild(thumb);
        link.appendChild(media);
      }

      var label = document.createElement('span');
      label.className = 'search-overlay__result-label';
      label.textContent = item.title;
      link.appendChild(label);

      link.setAttribute('aria-label', liveMatchLabel.replace(/\{\{\s*title\s*\}\}/g, item.title));

      listItem.appendChild(link);
      return listItem;
    }

    function renderResults(items, query) {
      if (!results) {
        return;
      }

      var searchQuery = query || (input ? input.value.trim() : '');

      if (!items.length) {
        results.hidden = false;
        setRevealVisible(results, true);
        updateSuggestedVisibility(searchQuery, false);
        results.innerHTML =
          '<p class="search-overlay__results-empty">' +
          (overlay.getAttribute('data-empty-label') || 'No results') +
          '</p>';
        return;
      }

      var list = document.createElement('ul');
      list.className = 'search-overlay__results-list';
      list.setAttribute('role', 'list');

      items.forEach(function (item) {
        list.appendChild(buildResultItem(item));
      });

      results.hidden = false;
      setRevealVisible(results, true);
      updateSuggestedVisibility(searchQuery, true);
      results.replaceChildren(list);
    }

    function fetchPredictive(query) {
      if (!predictiveUrl || query.length < 2) {
        clearResults();
        updateSuggestedVisibility(query, false);
        setRevealVisible(suggested, true);
        return;
      }

      if (lastController) {
        lastController.abort();
      }

      lastController = new AbortController();

      var url =
        predictiveUrl +
        '?q=' +
        encodeURIComponent(query) +
        '&resources[type]=product,collection,page&resources[limit]=6&resources[options][unavailable_products]=hide';

      fetch(url, {
        signal: lastController.signal,
        headers: {
          Accept: 'application/json',
        },
      })
        .then(function (response) {
          if (!response.ok) {
            throw new Error('Predictive search request failed.');
          }
          return response.json();
        })
        .then(function (payload) {
          var items = [];
          var resources = payload.resources && payload.resources.results;

          if (!resources) {
            renderResults([], query);
            return;
          }

          ['products', 'collections', 'pages'].forEach(function (type) {
            var group = resources[type];
            if (!group || !group.length) {
              return;
            }

            group.forEach(function (entry) {
              items.push({
                title: entry.title,
                url: entry.url,
                imageUrl: type === 'products' ? resolveEntryImage(entry) : '',
              });
            });
          });

          renderResults(items.slice(0, 6), query);
        })
        .catch(function (error) {
          if (error.name === 'AbortError') {
            return;
          }
          clearResults();
        });
    }

    function handleInput() {
      if (!input) {
        return;
      }

      var query = input.value.trim();

      if (debounceTimer) {
        window.clearTimeout(debounceTimer);
      }

      debounceTimer = window.setTimeout(function () {
        fetchPredictive(query);
      }, debounceMs);
    }

    try {
      openTriggers.forEach(function (trigger) {
        trigger.addEventListener('click', function (event) {
          event.preventDefault();
          setOpen(true);
        });
      });

      closeTriggers.forEach(function (trigger) {
        trigger.addEventListener('click', function () {
          setOpen(false);
        });
      });

      document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape' && overlay.classList.contains('is-open')) {
          setOpen(false);
          var firstTrigger = openTriggers[0];
          if (firstTrigger) {
            firstTrigger.focus();
          }
        }
      });

      if (form) {
        form.addEventListener('submit', function (event) {
          if (!input || !input.value.trim()) {
            event.preventDefault();
          }
        });
      }

      if (input) {
        input.addEventListener('input', handleInput);
      }
    } catch (error) {
      console.error('Search overlay: failed to initialize.', error);
    }
  })();
{% endjavascript %}

