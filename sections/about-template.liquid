{%- liquid
  assign hero_heading = section.settings.hero_heading
  assign hero_subheading = section.settings.hero_subheading
  assign split_image = section.settings.split_image
  assign split_heading = section.settings.split_heading
  assign split_text = section.settings.split_text
  assign image_position = section.settings.image_position
  assign conservatory_heading = section.settings.conservatory_heading
  assign placeholder_split = 'https://commons.wikimedia.org/wiki/Special:FilePath/Drosera_capensis_bend.JPG?width=1600'
  assign use_split_image = false

  if split_image != blank and split_image.width > 0
    assign use_split_image = true
  endif

  if hero_heading == blank and page.title != blank
    assign hero_heading = page.title
  endif
-%}

<article class="about-page" {{ section.shopify_attributes }}>
  <header class="about-page__hero">
    {%- if hero_heading != blank -%}
      <h1 class="about-page__hero-title">{{ hero_heading | escape }}</h1>
    {%- endif -%}
    {%- if hero_subheading != blank -%}
      <p class="about-page__hero-subtitle">{{ hero_subheading | escape }}</p>
    {%- endif -%}
  </header>

  <section class="about-page__split about-page__split--{{ image_position }}" aria-labelledby="about-split-heading-{{ section.id }}">
    <div class="about-page__split-media">
      {%- comment -%} TODO: replace placeholder image before launch — see placeholder-images.md {%- endcomment -%}
      {%- if use_split_image -%}
        {{
          split_image
          | image_url: width: 1400, height: 1050, crop: 'center'
          | image_tag:
            class: 'about-page__split-image',
            widths: '600, 900, 1200, 1400',
            sizes: '(min-width: 990px) 46vw, 100vw',
            loading: 'lazy',
            alt: split_heading
        }}
      {%- else -%}
        <img
          class="about-page__split-image about-page__split-image--fallback"
          src="{{ placeholder_split }}"
          alt="{{ split_heading | default: hero_heading | escape }}"
          width="1400"
          height="1050"
          loading="lazy"
          decoding="async"
        >
      {%- endif -%}
    </div>

    <div class="about-page__split-content">
      {%- if split_heading != blank -%}
        <h2 id="about-split-heading-{{ section.id }}" class="about-page__split-heading">{{ split_heading | escape }}</h2>
      {%- endif -%}
      {%- if split_text != blank -%}
        <div class="about-page__split-text rte">{{ split_text }}</div>
      {%- endif -%}
    </div>
  </section>

  {%- if section.blocks.size > 0 -%}
    <section class="about-page__conservatory" aria-labelledby="about-conservatory-heading-{{ section.id }}">
      {%- if conservatory_heading != blank -%}
        <h2 id="about-conservatory-heading-{{ section.id }}" class="about-page__conservatory-title">
          {{ conservatory_heading | escape }}
        </h2>
      {%- endif -%}

      <ul class="about-page__pillars" role="list">
        {%- for block in section.blocks -%}
          {%- liquid
            assign pillar_image = block.settings.image
            assign use_pillar_image = false
            if pillar_image != blank and pillar_image.width > 0
              assign use_pillar_image = true
            endif
          -%}

          <li class="about-page__pillar" {{ block.shopify_attributes }} role="listitem">
            {%- if use_pillar_image -%}
              <div class="about-page__pillar-media">
                {{
                  pillar_image
                  | image_url: width: 600, height: 450, crop: 'center'
                  | image_tag:
                    class: 'about-page__pillar-image',
                    widths: '300, 450, 600',
                    sizes: '(min-width: 750px) 28vw, 88vw',
                    loading: 'lazy',
                    alt: block.settings.title
                }}
              </div>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <h3 class="about-page__pillar-title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <p class="about-page__pillar-text">{{ block.settings.text | escape }}</p>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </section>
  {%- endif -%}
</article>

{% stylesheet %}
  .about-page {
    padding-block: var(--space-3xl) var(--space-4xl);
  }

  .about-page__hero {
    max-width: 42rem;
    margin: 0 auto var(--space-3xl);
    text-align: center;
  }

  .about-page__hero-title {
    margin: 0 0 var(--space-md);
    font-family: var(--font-family-serif);
    font-size: clamp(2rem, 4vw + 0.75rem, 3.25rem);
    font-style: normal;
    font-weight: 400;
    line-height: var(--line-height-tight);
    letter-spacing: 0.01em;
    text-wrap: balance;
  }

  .about-page__hero-subtitle {
    margin: 0;
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-muted);
    text-wrap: pretty;
  }

  .about-page__split {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
    margin-block-end: var(--space-4xl);
  }

  .about-page__split-media {
    overflow: hidden;
    border-radius: var(--radius-lg);
    background-color: var(--color-surface);
    box-shadow: var(--shadow-md);
  }

  .about-page__split-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    object-position: center center;
  }

  .about-page__split-heading {
    margin: 0 0 var(--space-md);
    font-size: clamp(1.375rem, 2vw + 0.5rem, 2rem);
    font-weight: 600;
    line-height: var(--line-height-tight);
  }

  .about-page__split-text {
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-muted);
  }

  .about-page__split-text p {
    margin: 0 0 var(--space-md);
  }

  .about-page__conservatory-title {
    margin: 0 0 var(--space-2xl);
    font-family: var(--font-family-serif);
    font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2.25rem);
    font-style: normal;
    font-weight: 400;
    line-height: var(--line-height-tight);
    text-align: center;
    text-wrap: balance;
  }

  .about-page__pillars {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .about-page__pillar {
    padding: var(--space-xl);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .about-page__pillar-media {
    margin-block-end: var(--space-md);
    overflow: hidden;
    border-radius: var(--radius-sm);
  }

  .about-page__pillar-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .about-page__pillar-title {
    margin: 0 0 var(--space-sm);
    font-size: var(--font-size-lg);
    font-weight: 600;
    line-height: var(--line-height-tight);
  }

  .about-page__pillar-text {
    margin: 0;
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-muted);
  }

  @media (min-width: 750px) {
    .about-page__pillars {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (min-width: 990px) {
    .about-page__split {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3xl);
    }

    .about-page__split--right .about-page__split-media {
      order: 2;
    }

    .about-page__split--right .about-page__split-content {
      order: 1;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.about_template.name",
  "tag": "section",
  "class": "about-template-section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.about_template.settings.hero_header"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "t:sections.about_template.settings.hero_heading",
      "default": "About us"
    },
    {
      "type": "text",
      "id": "hero_subheading",
      "label": "t:sections.about_template.settings.hero_subheading",
      "default": "Our mission: grow extraordinary carnivorous plants for South African collectors."
    },
    {
      "type": "header",
      "content": "t:sections.about_template.settings.split_header"
    },
    {
      "type": "image_picker",
      "id": "split_image",
      "label": "t:labels.background"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "t:sections.about_template.settings.image_position",
      "default": "left",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "right", "label": "t:options.alignment.right" }
      ]
    },
    {
      "type": "text",
      "id": "split_heading",
      "label": "t:sections.about_template.settings.split_heading",
      "default": "A scientific history of care"
    },
    {
      "type": "richtext",
      "id": "split_text",
      "label": "t:sections.about_template.settings.split_text",
      "default": "<p>Founded in the Western Cape, our nursery pairs macro photography with field-tested culture protocols. Every genus we sell is backed by integrated care guidance — light, water, soil, and dormancy notes written for Southern Hemisphere seasons.</p><p>We propagate in-house, acclimate stock before shipping, and prioritise living plants that arrive ready for your bench or terrarium.</p>"
    },
    {
      "type": "header",
      "content": "t:sections.about_template.settings.conservatory_header"
    },
    {
      "type": "text",
      "id": "conservatory_heading",
      "label": "t:sections.about_template.settings.conservatory_heading",
      "default": "The conservatory"
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "t:sections.about_template.blocks.pillar.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.background"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.text",
          "default": "Pillar"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:general.content",
          "default": "Describe your process."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.about_template.name",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "title": "Quality control",
            "text": "Every plant is inspected for pests, vigour, and true-to-name characteristics before it is listed."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "Specialized soil",
            "text": "We blend peat, perlite, and mineral components matched to each genus — never generic potting mix."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "Expert care",
            "text": "Integrated genus guides, difficulty ratings, and seasonal dormancy notes ship with every order."
          }
        }
      ]
    }
  ]
}
{% endschema %}


