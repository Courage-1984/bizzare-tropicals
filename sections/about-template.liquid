{%- liquid
  assign hero_heading = section.settings.hero_heading
  assign hero_subheading = section.settings.hero_subheading
  assign split_image = section.settings.split_image
  assign split_heading = section.settings.split_heading
  assign split_text = section.settings.split_text
  assign image_position = section.settings.image_position
  assign conservatory_heading = section.settings.conservatory_heading
  assign lab_heading = section.settings.lab_heading
  assign lab_text = section.settings.lab_text
  assign lab_image = section.settings.lab_image
  assign lab_image_position = section.settings.lab_image_position | default: 'right'
  assign curator_heading = section.settings.curator_heading
  assign curator_text = section.settings.curator_text
  assign curator_image = section.settings.curator_image
  assign hero_overline = section.settings.hero_overline
  assign split_overline = section.settings.split_overline
  assign lab_overline = section.settings.lab_overline
  assign curator_signature = section.settings.curator_signature
  assign placeholder_split = section.settings.split_placeholder_image | default: 'https://commons.wikimedia.org/wiki/Special:FilePath/Sarracenia_Judith_Hindle_(5964475729).jpg?width=1600'
  assign placeholder_lab = section.settings.lab_placeholder_image | default: 'https://commons.wikimedia.org/wiki/Special:FilePath/Perlite_as_a_medium_for_rooting_of_cuttings.jpg?width=1600'
  assign placeholder_curator = section.settings.curator_placeholder_image | default: 'https://commons.wikimedia.org/wiki/Special:FilePath/George_Washington_Carver_1942.jpg?width=1200'
  if placeholder_curator contains 'Luther_Burbank'
    assign placeholder_curator = 'https://commons.wikimedia.org/wiki/Special:FilePath/George_Washington_Carver_1942.jpg?width=1200'
  endif
  assign default_pillar_placeholder = section.settings.default_pillar_placeholder | default: 'https://commons.wikimedia.org/wiki/Special:FilePath/Nepenthes_ventricosa0.jpg?width=1200'
  assign use_split_image = false
  assign use_lab_image = false
  assign use_curator_image = false

  if lab_image != blank
    if lab_image.width > 0
      assign use_lab_image = true
    endif
  endif

  if curator_image != blank
    if curator_image.width > 0
      if curator_image.height > 0
        assign use_curator_image = true
      endif
    endif
  endif

  if split_image != blank and split_image.width > 0
    assign use_split_image = true
  endif

  if hero_heading == blank and page.title != blank
    assign hero_heading = page.title
  endif
-%}

<article class="about-page full-width" {{ section.shopify_attributes }}>
  <header class="about-page__hero reveal-up">
    <p class="about-page__hero-overline">{{ section.settings.hero_overline | default: 'Our story' | escape }}</p>
    <h1 class="about-page__hero-title">
      {{ hero_heading | default: 'Cultivating the extraordinary.' | escape }}
    </h1>
    <p class="about-page__hero-subtitle">
      {{ section.settings.hero_subheading | default: "South Africa's premier carnivorous plant and tissue culture nursery — field-tested protocols for collectors nationwide." | escape }}
    </p>
  </header>

  <section class="about-page__split about-page__split--{{ image_position }} reveal-up" aria-labelledby="about-split-heading-{{ section.id }}">
    <div class="about-page__split-media about-page__arch-frame">
      {%- comment -%} TODO: replace placeholder image before launch — see placeholder-images.md {%- endcomment -%}
      {%- if use_split_image -%}
        {{
          split_image
          | image_url: width: 1400, height: 1050, crop: 'center'
          | image_tag:
            class: 'about-page__split-image',
            widths: '600, 900, 1200, 1400',
            sizes: '(min-width: 990px) 46vw, 100vw',
            loading: 'lazy',
            alt: split_heading
        }}
      {%- elsif placeholder_split != blank -%}
        <img
          class="about-page__split-image about-page__split-image--fallback"
          src="{{ placeholder_split }}"
          alt="{{ split_heading | default: hero_heading | escape }}"
          width="1400"
          height="1050"
          loading="lazy"
          decoding="async"
        >
      {%- endif -%}
    </div>

    <div class="about-page__split-content">
      <p class="about-page__section-overline">{{ section.settings.split_overline | default: 'A scientific history' | escape }}</p>
      <h2 id="about-split-heading-{{ section.id }}" class="about-page__split-heading">
        {{ section.settings.split_heading | default: 'A scientific history of care' | escape }}
      </h2>
      <div class="about-page__split-text rte">{{ section.settings.split_text }}</div>
    </div>
  </section>

  <section
    class="about-page__laboratory full-width reveal-up"
    aria-labelledby="about-laboratory-heading-{{ section.id }}"
  >
    <div class="about-page__laboratory-inner">
      <div class="about-page__laboratory-grid about-page__laboratory-grid--image-{{ lab_image_position }}">
        <div class="about-page__laboratory-content">
          <p class="about-page__section-overline">{{ section.settings.lab_overline | default: 'The laboratory' | escape }}</p>
          <h2 id="about-laboratory-heading-{{ section.id }}" class="about-page__laboratory-title">
            {{ section.settings.lab_heading | default: 'Science in service of nature.' | escape }}
          </h2>
          <div class="about-page__laboratory-text rte">{{ section.settings.lab_text }}</div>
        </div>

        <div class="about-page__laboratory-media about-page__frame about-page__frame--organic">
          {%- comment -%} TODO: replace placeholder — tissue culture lab flask (placeholder-images.md) {%- endcomment -%}
          {%- if use_lab_image -%}
            {{
              lab_image
              | image_url: width: 1400, height: 1050, crop: 'center'
              | image_tag:
                class: 'about-page__laboratory-image',
                widths: '600, 900, 1200, 1400',
                sizes: '(min-width: 990px) 44vw, 100vw',
                loading: 'lazy',
                alt: lab_heading
            }}
          {%- elsif placeholder_lab != blank -%}
            <img
              class="about-page__laboratory-image about-page__laboratory-image--fallback"
              src="{{ placeholder_lab }}"
              alt="{{ lab_heading | escape }}"
              width="1400"
              height="1050"
              loading="lazy"
              decoding="async"
            >
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  <section class="about-page__curator reveal-up" aria-labelledby="about-curator-heading-{{ section.id }}">
    <div class="about-page__curator-layout">
      <div class="about-page__curator-portrait about-page__frame about-page__frame--circle">
        {%- comment -%} TODO: replace placeholder — curator portrait before launch {%- endcomment -%}
        {%- if use_curator_image -%}
          {{
            curator_image
            | image_url: width: 800, height: 1000, crop: 'center'
            | image_tag:
              class: 'about-page__curator-image',
              widths: '400, 600, 800',
              sizes: '(min-width: 990px) 16rem, (min-width: 750px) 14rem, 70vw',
              loading: 'lazy',
              alt: curator_heading
          }}
        {%- elsif placeholder_curator != blank -%}
          <img
            class="about-page__curator-image about-page__curator-image--fallback"
            src="{{ placeholder_curator }}"
            alt="{{ curator_heading | escape }}"
            width="800"
            height="1000"
            loading="lazy"
            decoding="async"
          >
        {%- endif -%}
      </div>

      <div class="about-page__curator-copy">
        <h2 id="about-curator-heading-{{ section.id }}" class="about-page__curator-title">
          {{ section.settings.curator_heading | default: 'A message from Jaco Van Den Berg.' | escape }}
        </h2>
        <div class="about-page__curator-text rte">{{ section.settings.curator_text }}</div>
        <p class="about-page__curator-signature" aria-hidden="true">
          {{ section.settings.curator_signature | default: 'Jaco Van Den Berg' | escape }}
        </p>
      </div>
    </div>
  </section>

  {%- if section.blocks.size > 0 -%}
    <section class="about-page__conservatory" aria-labelledby="about-conservatory-heading-{{ section.id }}">
      <h2 id="about-conservatory-heading-{{ section.id }}" class="about-page__conservatory-title">
        {{ section.settings.conservatory_heading | default: 'The conservatory' | escape }}
      </h2>

      <ul class="about-page__plates" role="list" data-reveal-stagger>
        {%- for block in section.blocks -%}
          {%- unless block.type == 'scientific_plate' -%}
            {%- continue -%}
          {%- endunless -%}

          {%- liquid
            assign plate_image = block.settings.image
            assign plate_heading = block.settings.heading | default: 'Scientific plate'
            assign plate_text = block.settings.text
            assign plate_ref = block.settings.ref_id
            assign plate_placeholder = block.settings.placeholder_image | default: default_pillar_placeholder
            assign use_plate_image = false

            if plate_image != blank and plate_image.width > 0
              assign use_plate_image = true
            endif

            if plate_ref == blank
              case forloop.index
                when 1
                  assign plate_ref = 'REF. QC-01'
                when 2
                  assign plate_ref = 'REF. SS-02'
                else
                  assign plate_ref = 'REF. EC-03'
              endcase
            endif
          -%}

          <li class="about-page__plates-item reveal-up" {{ block.shopify_attributes }} role="listitem">
            <article class="about-page__plate">
              <div class="about-page__plate__media">
                <span class="about-page__plate__ref" aria-hidden="true">{{ plate_ref | escape }}</span>
                {%- comment -%} TODO: replace placeholder image before launch — see placeholder-images.md {%- endcomment -%}
                {%- if use_plate_image -%}
                  {{
                    plate_image
                    | image_url: width: 600, height: 750, crop: 'center'
                    | image_tag:
                      class: 'about-page__plate__image',
                      widths: '300, 450, 600',
                      sizes: '(min-width: 750px) 30vw, 88vw',
                      loading: 'lazy',
                      alt: plate_heading
                  }}
                {%- elsif plate_placeholder != blank -%}
                  <img
                    class="about-page__plate__image about-page__plate__image--fallback"
                    src="{{ plate_placeholder }}"
                    alt="{{ plate_heading | escape }}"
                    width="600"
                    height="750"
                    loading="lazy"
                    decoding="async"
                  >
                {%- endif -%}
              </div>

              <div class="about-page__plate__body">
                <h3 class="about-page__plate__title">{{ plate_heading | escape }}</h3>

                {%- if plate_text != blank -%}
                  <p class="about-page__plate__text">{{ plate_text | escape }}</p>
                {%- endif -%}
              </div>
            </article>
          </li>
        {%- endfor -%}
      </ul>
    </section>
  {%- endif -%}
</article>

{% stylesheet %}
  .about-page {
    --about-block-gap: 3rem;
    width: min(var(--page-width), calc(100% - var(--page-margin) * 2));
    margin-inline: auto;
    padding-block: var(--space-3xl) var(--space-4xl);
  }

  .about-page__hero {
    max-width: 44rem;
    margin: 0 auto var(--space-3xl);
    text-align: center;
  }

  .about-page__hero-overline {
    margin: 0 0 var(--space-sm);
    font-family: var(--font-family-base);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .about-page__hero-title {
    margin: 0 0 var(--space-md);
    font-family: var(--font-family-serif);
    font-size: clamp(2.25rem, 5vw + 0.5rem, 3.5rem);
    font-style: italic;
    font-weight: 400;
    line-height: var(--line-height-tight);
    letter-spacing: 0.01em;
    color: var(--color-forest-green-dark);
    text-wrap: balance;
  }

  .about-page__hero-subtitle {
    margin: 0;
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-muted);
    text-wrap: pretty;
  }

  .about-page__split {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
    margin-block-end: var(--about-block-gap);
  }

  .about-page__arch-frame {
    overflow: hidden;
    padding: var(--space-sm);
    background-color: var(--color-parchment);
    border: 1px solid var(--color-forest-green-dark);
    border-radius: 999px 999px var(--radius-lg) var(--radius-lg);
    box-shadow: var(--shadow-md);
    transition:
      box-shadow 0.4s cubic-bezier(0.25, 1, 0.5, 1),
      transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .about-page__frame {
    overflow: hidden;
    background-color: var(--color-parchment);
    border: 1px solid var(--color-forest-green-dark);
    box-shadow: var(--shadow-md);
    transition:
      box-shadow 0.4s cubic-bezier(0.25, 1, 0.5, 1),
      transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .about-page__frame--organic {
    padding: var(--space-2xs);
    border-radius: 120px 24px 120px 24px;
    overflow: hidden;
  }

  .about-page__frame--circle {
    width: min(100%, 15rem);
    margin-inline: auto;
    padding: var(--space-2xs);
    border: 1px solid var(--color-forest-green-dark);
    border-radius: 50%;
    background-color: var(--color-parchment);
  }

  .about-page__split-media {
    margin-inline: auto;
    max-width: 28rem;
  }

  .about-page__split-image {
    width: 100%;
    object-fit: cover;
    object-position: center 35%;
    border-radius: 999px 999px var(--radius-md) var(--radius-md);
    aspect-ratio: 4 / 5;
  }

  /* Conservatory — botanical index plates */
  .about-page__plate {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
    margin: 0;
    overflow: hidden;
    background-color: rgb(255 255 255 / 0.35);
    border: 1px solid var(--color-forest-green-dark);
    box-shadow: 1px 2px 0 rgb(10 24 18 / 0.06);
    transition:
      box-shadow 0.4s cubic-bezier(0.25, 1, 0.5, 1),
      transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .about-page__plates-item:hover .about-page__plate {
    box-shadow: 2px 6px 16px rgb(10 24 18 / 0.1);
    transform: translate3d(0, -2px, 0);
  }

  .about-page__plate__media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background-color: rgb(10 24 18 / 0.04);
  }

  .about-page__plate__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .about-page__plates-item:hover .about-page__plate__image {
    transform: scale3d(1.02, 1.02, 1);
  }

  .about-page__plate__ref {
    position: absolute;
    top: var(--space-xs);
    right: var(--space-xs);
    z-index: 1;
    padding: 0.2rem 0.45rem;
    font-family: 'Courier New', Courier, 'Liberation Mono', monospace;
    font-size: 0.625rem;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: 0.08em;
    color: var(--color-forest-green-dark);
    opacity: 0.6;
    background-color: rgb(245 243 238 / 0.92);
    border: 0.5px solid rgb(10 24 18 / 0.12);
    pointer-events: none;
  }

  .about-page__plate__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-lg) var(--space-lg);
    text-align: left;
  }

  .about-page__plate__title {
    margin: 0;
    font-family: var(--font-family-serif);
    font-size: 1.25rem;
    font-style: normal;
    font-weight: 400;
    line-height: var(--line-height-tight);
    letter-spacing: 0.01em;
    color: var(--color-forest-green-dark);
  }

  .about-page__plate__text {
    margin: 0;
    font-family: var(--font-family-base);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: var(--color-forest-green-dark);
    opacity: 0.88;
  }

  .about-page__split-heading {
    margin: 0 0 var(--about-block-gap);
    font-family: var(--font-family-serif);
    font-size: clamp(1.375rem, 2vw + 0.5rem, 2rem);
    font-style: normal;
    font-weight: 400;
    line-height: var(--line-height-tight);
    letter-spacing: 0.01em;
  }

  .about-page__split-text {
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-muted);
  }

  .about-page__split-text p {
    margin: 0 0 var(--space-md);
  }

  .about-page__section-overline {
    margin: 0 0 var(--space-sm);
    font-family: var(--font-family-base);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .about-page__laboratory {
    margin-block: var(--space-4xl);
    padding-block: var(--space-4xl);
    background-color: var(--color-parchment);
    border-block: 1px solid var(--color-border);
  }

  .about-page__laboratory-inner {
    width: min(var(--page-width), calc(100% - var(--page-margin) * 2));
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }

  .about-page__laboratory-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  .about-page__laboratory-title {
    margin: 0 0 var(--about-block-gap);
    font-family: var(--font-family-serif);
    font-size: clamp(1.75rem, 3vw + 0.5rem, 2.5rem);
    font-style: italic;
    font-weight: 400;
    line-height: var(--line-height-tight);
    color: var(--color-forest-green-dark);
    text-wrap: balance;
  }

  .about-page__laboratory-text {
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-muted);
  }

  .about-page__laboratory-text p {
    margin: 0 0 var(--space-md);
  }

  .about-page__laboratory-media {
    margin-inline: auto;
    max-width: 28rem;
  }

  .about-page__laboratory-image {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center center;
    border-radius: 120px 24px 120px 24px;
    box-shadow: inset 0 0 20px rgb(0 0 0 / 0.05);
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .about-page__frame--organic:hover .about-page__laboratory-image {
    transform: scale3d(1.02, 1.02, 1);
  }

  .about-page__curator {
    margin-block-end: var(--about-block-gap);
  }

  .about-page__curator-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  .about-page__curator-portrait {
    flex-shrink: 0;
  }

  .about-page__curator-image {
    display: block;
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    object-position: center 28%;
    border-radius: 50%;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .about-page__frame--circle:hover .about-page__curator-image {
    transform: scale3d(1.03, 1.03, 1);
  }

  .about-page__curator-title {
    margin: 0 0 var(--about-block-gap);
    font-family: var(--font-family-serif);
    font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2.125rem);
    font-style: italic;
    font-weight: 400;
    line-height: var(--line-height-tight);
    color: var(--color-forest-green-dark);
    text-wrap: balance;
  }

  .about-page__curator-text {
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-muted);
  }

  .about-page__curator-text p {
    margin: 0 0 var(--space-md);
  }

  .about-page__curator-signature {
    margin: var(--space-xl) 0 0;
    font-family: var(--font-family-serif);
    font-size: var(--font-size-xl);
    font-style: italic;
    font-weight: 400;
    color: var(--color-forest-green-dark);
    opacity: 0.85;
  }

  .about-page__conservatory {
    padding: var(--space-2xl);
    background-color: var(--color-parchment);
    border: 1px solid var(--color-forest-green-dark);
    border-radius: var(--radius-lg);
    box-shadow: 2px 2px 10px rgb(0 0 0 / 0.05);
  }

  .about-page__conservatory-title {
    margin: 0 0 var(--about-block-gap);
    font-family: var(--font-family-serif);
    font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2.25rem);
    font-style: italic;
    font-weight: 400;
    line-height: var(--line-height-tight);
    text-align: center;
    color: var(--color-forest-green-dark);
    text-wrap: balance;
  }

  .about-page__plates {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .about-page__plates-item {
    min-width: 0;
  }

  @media (min-width: 750px) {
    .about-page__plates {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-lg);
      align-items: stretch;
    }
  }

  @media (min-width: 990px) {
    .about-page__split {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-4xl);
    }

    .about-page__split--right .about-page__split-media {
      order: 2;
    }

    .about-page__split--right .about-page__split-content {
      order: 1;
    }

    .about-page__laboratory-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-4xl);
    }

    .about-page__laboratory-grid--image-left .about-page__laboratory-media {
      order: -1;
    }

    .about-page__laboratory-grid--image-right .about-page__laboratory-content {
      order: -1;
    }

    .about-page__curator-layout {
      grid-template-columns: minmax(14rem, 16rem) minmax(0, 1fr);
      gap: var(--space-3xl);
      align-items: center;
    }

    .about-page__frame--circle {
      width: 100%;
      max-width: 16rem;
      margin-inline: 0;
    }

    .about-page__curator-title {
      margin-bottom: var(--space-lg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .about-page__arch-frame,
    .about-page__frame,
    .about-page__laboratory-image,
    .about-page__curator-image,
    .about-page__plate,
    .about-page__plate__image {
      transition: none;
    }

    .about-page__frame--organic:hover .about-page__laboratory-image,
    .about-page__frame--circle:hover .about-page__curator-image,
    .about-page__plates-item:hover .about-page__plate,
    .about-page__plates-item:hover .about-page__plate__image {
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.about_template.name",
  "tag": "section",
