{%- liquid
  assign form_heading = section.settings.form_heading | strip
  if form_heading == blank and page.title != blank
    assign form_heading = page.title
  endif
  if form_heading == blank
    assign form_heading = 'sections.contact_template.form_heading_default' | t
  endif

  assign hero_overline = section.settings.hero_overline | strip
  if hero_overline == blank
    assign hero_overline = 'sections.contact_template.hero_overline_default' | t
  endif

  assign form_intro = section.settings.form_intro | strip
  if form_intro == blank
    assign form_intro = 'sections.contact_template.form_intro_default' | t
  endif

  assign form_subheading = section.settings.form_subheading | strip
  if form_subheading == blank
    assign form_subheading = 'sections.contact_template.form_subheading_default' | t
  endif

  assign form_card_note = section.settings.form_card_note | strip
  if form_card_note == blank
    assign form_card_note = 'sections.contact_template.form_card_note_default' | t
  endif

  assign panel_heading = section.settings.panel_heading | strip
  if panel_heading == blank
    assign panel_heading = 'sections.contact_template.panel_heading_default' | t
  endif

  assign panel_intro = section.settings.panel_intro | strip
  if panel_intro == blank
    assign panel_intro = 'sections.contact_template.panel_intro_default' | t
  endif

  assign contact_address = section.settings.contact_address | strip
  if contact_address == blank
    assign contact_address = 'sections.contact_template.contact_address_default' | t
  endif

  assign contact_email = section.settings.contact_email | strip
  if contact_email == blank
    assign contact_email = 'sections.contact_template.contact_email_default' | t
  endif

  assign contact_hours = section.settings.contact_hours | strip
  if contact_hours == blank
    assign contact_hours = 'sections.contact_template.contact_hours_default' | t
  endif

  assign contact_phone = section.settings.contact_phone | strip
  if contact_phone == blank
    assign contact_phone = 'sections.contact_template.contact_phone_default' | t
  endif
  assign whatsapp_url = section.settings.whatsapp_url | strip
  if whatsapp_url == blank
    assign whatsapp_url = 'https://wa.me/27721527446'
  endif
  assign panel_image = section.settings.panel_image
  assign hero_background = section.settings.hero_background_image
  assign hero_placeholder = section.settings.hero_placeholder_image | strip
  assign placeholder_panel_image = section.settings.placeholder_panel_image | strip
  assign show_faq = section.settings.show_faq
  assign show_social_links = section.settings.show_social_links
  assign show_quick_links = section.settings.show_quick_links
  assign enable_sticky_sidebar = section.settings.enable_sticky_sidebar
  assign faq_heading = section.settings.faq_heading | strip
  if faq_heading == blank
    assign faq_heading = 'sections.contact_template.faq_heading_default' | t
  endif
  assign social_heading = section.settings.social_heading | strip
  if social_heading == blank
    assign social_heading = 'sections.contact_template.social_heading_default' | t
  endif
  assign facebook_url = section.settings.facebook_url | strip
  assign instagram_url = section.settings.instagram_url | strip
  assign facebook_handle = section.settings.facebook_handle | strip
  assign instagram_handle = section.settings.instagram_handle | strip

  assign use_panel_image = false
  if panel_image != blank
    if panel_image.width > 0
      assign use_panel_image = true
    endif
  endif

  assign use_hero_image = false
  if hero_background != blank
    if hero_background.width > 0
      assign use_hero_image = true
    endif
  endif

  if hero_placeholder == blank
    assign hero_placeholder = 'https://commons.wikimedia.org/wiki/Special:FilePath/Nepenthes_ventricosa0.jpg?width=1800'
  endif

  if placeholder_panel_image == blank
    assign placeholder_panel_image = 'https://commons.wikimedia.org/wiki/Special:FilePath/Heliamphora_nutans_(a_pitcher_plant_from_Venezuela)_at_Kew_Gardens_(5253200783).jpg?width=1400'
  endif

  assign faq_block_count = 0
  for block in section.blocks
    if block.type == 'faq'
      assign faq_question = block.settings.question | strip
      if faq_question != blank
        assign faq_block_count = faq_block_count | plus: 1
      endif
    endif
  endfor

  assign has_social_links = false
  if facebook_url != blank or instagram_url != blank
    assign has_social_links = true
  endif
-%}

<article class="contact-page full-width" {{ section.shopify_attributes }}>
  <header class="contact-page__hero reveal-up">
    <div class="contact-page__hero-media" aria-hidden="true">
      {%- if use_hero_image -%}
        {{
          hero_background
          | image_url: width: 2000, height: 900, crop: 'center'
          | image_tag:
            class: 'contact-page__hero-image',
            widths: '800, 1200, 1600, 2000',
            sizes: '100vw',
            loading: 'eager',
            fetchpriority: 'high',
            alt: ''
        }}
      {%- else -%}
        <img
          class="contact-page__hero-image contact-page__hero-image--fallback"
          src="{{ hero_placeholder | escape }}"
          alt=""
          width="2000"
          height="900"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        >
      {%- endif -%}
      <span class="contact-page__hero-scrim"></span>
      <span class="contact-page__hero-grain"></span>
    </div>

    <div class="contact-page__hero-content">
      <p class="contact-page__hero-overline">{{ hero_overline | escape }}</p>
      <h1 class="contact-page__hero-title">{{ form_heading | escape }}</h1>
      <p class="contact-page__hero-intro">{{ form_intro | escape }}</p>
    </div>
  </header>

  <div class="contact-page__body">
    {%- if show_quick_links -%}
      <nav class="contact-page__quick-links reveal-up" aria-label="{{ 'sections.contact_template.quick_links_label' | t }}">
        <ul class="contact-page__quick-list" role="list">
          {%- if contact_email != blank -%}
            <li class="contact-page__quick-item" role="listitem">
              <a class="contact-page__quick-card" href="mailto:{{ contact_email }}">
                <span class="contact-page__quick-icon" aria-hidden="true">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" focusable="false">
                    <path d="M4 6h16v12H4V6Z" stroke="currentColor" stroke-width="1.2"/>
                    <path d="m4 7 8 6 8-6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                <span class="contact-page__quick-label">{{ 'sections.contact_template.quick_email' | t }}</span>
                <span class="contact-page__quick-value">{{ contact_email | escape }}</span>
              </a>
            </li>
          {%- endif -%}
          {%- if contact_phone != blank -%}
            <li class="contact-page__quick-item" role="listitem">
              {%- if whatsapp_url != blank -%}
                <a class="contact-page__quick-card" href="{{ whatsapp_url }}" target="_blank" rel="noopener noreferrer">
              {%- else -%}
                <div class="contact-page__quick-card contact-page__quick-card--static">
              {%- endif -%}
                <span class="contact-page__quick-icon" aria-hidden="true">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" focusable="false">
                    <path d="M8.5 4.5h7A3.5 3.5 0 0 1 19 8v8a3.5 3.5 0 0 1-3.5 3.5h-7A3.5 3.5 0 0 1 5 16V8a3.5 3.5 0 0 1 3.5-3.5Z" stroke="currentColor" stroke-width="1.2"/>
                    <path d="M9 10h6M9 14h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                  </svg>
                </span>
                <span class="contact-page__quick-label">{{ 'sections.contact_template.quick_phone' | t }}</span>
                <span class="contact-page__quick-value">{{ contact_phone | escape }}</span>
                {%- if whatsapp_url != blank -%}
                  <span class="visually-hidden">{{ 'footer.opens_new_window' | t }}</span>
                {%- endif -%}
              {%- if whatsapp_url != blank -%}
                </a>
              {%- else -%}
                </div>
              {%- endif -%}
            </li>
          {%- endif -%}
          {%- if contact_hours != blank -%}
            <li class="contact-page__quick-item" role="listitem">
              <div class="contact-page__quick-card contact-page__quick-card--static">
                <span class="contact-page__quick-icon" aria-hidden="true">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" focusable="false">
                    <circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.2"/>
                    <path d="M12 8v4l2.5 2.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                  </svg>
                </span>
                <span class="contact-page__quick-label">{{ 'sections.contact_template.detail_hours' | t }}</span>
                <span class="contact-page__quick-value">{{ contact_hours | escape }}</span>
              </div>
            </li>
          {%- endif -%}
          {%- if contact_address != blank -%}
            <li class="contact-page__quick-item" role="listitem">
              <div class="contact-page__quick-card contact-page__quick-card--static">
                <span class="contact-page__quick-icon" aria-hidden="true">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" focusable="false">
                    <path d="M12 21s6-5.2 6-10a6 6 0 1 0-12 0c0 4.8 6 10 6 10Z" stroke="currentColor" stroke-width="1.2"/>
                    <circle cx="12" cy="11" r="2.25" stroke="currentColor" stroke-width="1.2"/>
                  </svg>
                </span>
                <span class="contact-page__quick-label">{{ 'sections.contact_template.quick_visit' | t }}</span>
                <span class="contact-page__quick-value">{{ contact_address | escape }}</span>
              </div>
            </li>
          {%- endif -%}
        </ul>
      </nav>
    {%- endif -%}

    <div class="contact-page__split reveal-up">
      <div class="contact-page__form-column">
        <div class="contact-page__form-card">
          <h2 class="contact-page__form-heading">{{ form_subheading | escape }}</h2>
          <p class="contact-page__form-note">{{ form_card_note | escape }}</p>

          {%- form 'contact', class: 'contact-form contact-form--card' -%}
            {%- if form.posted_successfully? -%}
              <div class="contact-form__success" role="status" tabindex="-1" autofocus>
                <p>{{ 'sections.contact_template.form_success' | t }}</p>
              </div>
            {%- endif -%}

            {%- if form.errors -%}
              <div class="contact-form__errors" role="alert">
                {{ form.errors | default_errors }}
              </div>
            {%- endif -%}

            <div class="contact-form__field">
              <label class="contact-form__label" for="ContactForm-name-{{ section.id }}">
                {{ 'sections.contact_template.field_name' | t }}
              </label>
              <input
                class="contact-form__input"
                type="text"
                id="ContactForm-name-{{ section.id }}"
                name="contact[name]"
                value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                autocomplete="name"
                required
                {% if form.errors contains 'name' %}
                  aria-invalid="true"
                  aria-describedby="ContactForm-name-error-{{ section.id }}"
                {% endif %}
              >
              {%- if form.errors contains 'name' -%}
                <span id="ContactForm-name-error-{{ section.id }}" class="contact-form__field-error">
                  {{ form.errors.messages.name }}
                </span>
              {%- endif -%}
            </div>

            <div class="contact-form__field">
              <label class="contact-form__label" for="ContactForm-email-{{ section.id }}">
                {{ 'sections.contact_template.field_email' | t }}
              </label>
              <input
                class="contact-form__input"
                type="email"
                id="ContactForm-email-{{ section.id }}"
                name="contact[email]"
                value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                autocomplete="email"
                spellcheck="false"
                autocapitalize="off"
                required
                {% if form.errors contains 'email' %}
                  aria-invalid="true"
                  aria-describedby="ContactForm-email-error-{{ section.id }}"
                {% endif %}
              >
              {%- if form.errors contains 'email' -%}
                <span id="ContactForm-email-error-{{ section.id }}" class="contact-form__field-error">
                  {{ form.errors.messages.email }}
                </span>
              {%- endif -%}
            </div>

            <div class="contact-form__field">
              <label class="contact-form__label" for="ContactForm-phone-{{ section.id }}">
                {{ 'sections.contact_template.field_phone' | t }}
              </label>
              <input
                class="contact-form__input"
                type="tel"
                id="ContactForm-phone-{{ section.id }}"
                name="contact[phone]"
                value="{% if form.phone %}{{ form.phone }}{% endif %}"
                autocomplete="tel"
                {% if form.errors contains 'phone' %}
                  aria-invalid="true"
                  aria-describedby="ContactForm-phone-error-{{ section.id }}"
                {% endif %}
              >
              {%- if form.errors contains 'phone' -%}
                <span id="ContactForm-phone-error-{{ section.id }}" class="contact-form__field-error">
                  {{ form.errors.messages.phone }}
                </span>
              {%- endif -%}
            </div>

            <div class="contact-form__field">
              <label class="contact-form__label" for="ContactForm-body-{{ section.id }}">
                {{ 'sections.contact_template.field_message' | t }}
              </label>
              <textarea
                class="contact-form__textarea"
                id="ContactForm-body-{{ section.id }}"
                name="contact[body]"
                rows="6"
                required
                {% if form.errors contains 'body' %}
                  aria-invalid="true"
                  aria-describedby="ContactForm-body-error-{{ section.id }}"
                {% endif %}
              >{% if form.body %}{{ form.body }}{% endif %}</textarea>
              {%- if form.errors contains 'body' -%}
                <span id="ContactForm-body-error-{{ section.id }}" class="contact-form__field-error">
                  {{ form.errors.messages.body }}
                </span>
              {%- endif -%}
            </div>

            <button type="submit" class="contact-form__submit">
              {{ 'sections.contact_template.submit' | t }}
            </button>
          {%- endform -%}
        </div>
      </div>

      <aside
        class="contact-page__details-column{% if enable_sticky_sidebar %} contact-page__details-column--sticky{% endif %}"
        aria-labelledby="contact-panel-heading-{{ section.id }}"
      >
        <div class="contact-page__conservatory">
          <div class="contact-page__arch-frame">
            {%- if use_panel_image -%}
              {{
                panel_image
                | image_url: width: 1400, height: 1750, crop: 'center'
                | image_tag:
                  class: 'contact-page__arch-image',
                  widths: '600, 900, 1200, 1400',
                  sizes: '(min-width: 990px) 38vw, 88vw',
                  loading: 'lazy',
                  alt: panel_heading
              }}
            {%- elsif placeholder_panel_image != blank -%}
              <img
                class="contact-page__arch-image contact-page__arch-image--fallback"
                src="{{ placeholder_panel_image | escape }}"
                alt="{{ panel_heading | default: shop.name | escape }}"
                width="1400"
                height="1750"
                loading="lazy"
                decoding="async"
              >
            {%- endif -%}
            <span class="contact-page__specimen-tag" aria-hidden="true">{{ 'sections.contact_template.specimen_tag' | t }}</span>
          </div>

          <div class="contact-page__conservatory-copy">
            <h2 id="contact-panel-heading-{{ section.id }}" class="contact-page__panel-title">
              {{ panel_heading | escape }}
            </h2>
            <p class="contact-page__panel-intro">{{ panel_intro | escape }}</p>

            <ul class="contact-page__details-list" role="list">
              {%- if contact_address != blank -%}
                <li class="contact-page__details-item">
                  <span class="contact-page__details-icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 21s6-5.2 6-10a6 6 0 1 0-12 0c0 4.8 6 10 6 10Z" stroke="currentColor" stroke-width="1.2"/><circle cx="12" cy="11" r="2" stroke="currentColor" stroke-width="1.2"/></svg>
                  </span>
                  <span class="contact-page__details-text">
                    <span class="contact-page__details-label">{{ 'sections.contact_template.detail_address' | t }}</span>
                    <span class="contact-page__details-value">{{ contact_address | escape }}</span>
                  </span>
                </li>
              {%- endif -%}
              {%- if contact_email != blank -%}
                <li class="contact-page__details-item">
                  <span class="contact-page__details-icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M4 6h16v12H4V6Z" stroke="currentColor" stroke-width="1.2"/><path d="m4 7 8 6 8-6" stroke="currentColor" stroke-width="1.2"/></svg>
                  </span>
                  <span class="contact-page__details-text">
                    <span class="contact-page__details-label">{{ 'sections.contact_template.detail_email' | t }}</span>
                    <a class="contact-page__details-link link-underline-grow" href="mailto:{{ contact_email }}">{{ contact_email | escape }}</a>
                  </span>
                </li>
              {%- endif -%}
              {%- if contact_hours != blank -%}
                <li class="contact-page__details-item">
                  <span class="contact-page__details-icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.2"/><path d="M12 8v4l2.5 2.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                  </span>
                  <span class="contact-page__details-text">
                    <span class="contact-page__details-label">{{ 'sections.contact_template.detail_hours' | t }}</span>
                    <span class="contact-page__details-value">{{ contact_hours | escape }}</span>
                  </span>
                </li>
              {%- endif -%}
              {%- if contact_phone != blank -%}
                <li class="contact-page__details-item">
                  <span class="contact-page__details-icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M8.5 4.5h7A3.5 3.5 0 0 1 19 8v8a3.5 3.5 0 0 1-3.5 3.5h-7A3.5 3.5 0 0 1 5 16V8a3.5 3.5 0 0 1 3.5-3.5Z" stroke="currentColor" stroke-width="1.2"/></svg>
                  </span>
                  <span class="contact-page__details-text">
                    <span class="contact-page__details-label">{{ 'sections.contact_template.detail_phone' | t }}</span>
                    {%- if whatsapp_url != blank -%}
                      <a class="contact-page__details-link link-underline-grow" href="{{ whatsapp_url }}" target="_blank" rel="noopener noreferrer">{{ contact_phone | escape }}</a>
                    {%- else -%}
                      <span class="contact-page__details-value">{{ contact_phone | escape }}</span>
                    {%- endif -%}
                  </span>
                </li>
              {%- endif -%}
            </ul>
          </div>
        </div>
      </aside>
    </div>

    {%- if show_faq and faq_block_count > 0 -%}
      <section class="contact-page__faq reveal-up" aria-labelledby="contact-faq-heading-{{ section.id }}">
        <div class="contact-page__faq-inner">
          {%- if faq_heading != blank -%}
            <header class="contact-page__faq-header">
              <p class="contact-page__section-overline">{{ 'sections.contact_template.faq_overline' | t }}</p>
              <h2 id="contact-faq-heading-{{ section.id }}" class="contact-page__faq-title">
                {{ faq_heading | escape }}
              </h2>
            </header>
          {%- endif -%}

          <div class="botanical-accordion contact-page__accordion" role="region" aria-label="{{ faq_heading | default: 'FAQ' | escape }}">
            {%- for block in section.blocks -%}
              {%- if block.type == 'faq' -%}
                {%- assign faq_question = block.settings.question | strip -%}
                {%- if faq_question != blank -%}
                  <details class="botanical-accordion__item" {{ block.shopify_attributes }}>
                    <summary class="botanical-accordion__summary">
                      {% render 'icon-accordion-mark' %}
                      <span class="botanical-accordion__question">{{ faq_question | escape }}</span>
                    </summary>
                    <div class="botanical-accordion__answer rte">
                      {{ block.settings.answer }}
                    </div>
                  </details>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </section>
    {%- endif -%}

    {%- if show_faq and faq_block_count == 0 -%}
      <section class="contact-page__faq reveal-up" aria-labelledby="contact-faq-heading-{{ section.id }}">
        <div class="contact-page__faq-inner">
          <header class="contact-page__faq-header">
            <p class="contact-page__section-overline">{{ 'sections.contact_template.faq_overline' | t }}</p>
            <h2 id="contact-faq-heading-{{ section.id }}" class="contact-page__faq-title">
              {{ faq_heading | escape }}
            </h2>
          </header>
          <p class="contact-page__empty">{{ 'sections.contact_template.empty_faq' | t }}</p>
        </div>
      </section>
    {%- endif -%}

    {%- if show_social_links and social_heading != blank -%}
      {%- if facebook_url != blank or instagram_url != blank -%}
        <section class="contact-page__social reveal-up" aria-labelledby="contact-social-heading-{{ section.id }}">
          <div class="contact-page__social-inner">
            <h2 id="contact-social-heading-{{ section.id }}" class="contact-page__social-title">
              {{ social_heading | escape }}
            </h2>
            <ul class="contact-page__social-list" role="list">
              {%- if instagram_url != blank -%}
                <li>
                  <a
                    class="contact-page__social-link contact-page__social-link--instagram"
                    href="{{ instagram_url }}"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <span class="contact-page__social-icon" aria-hidden="true">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="4" y="4" width="16" height="16" rx="4" stroke="currentColor" stroke-width="1.2"/><circle cx="12" cy="12" r="3.25" stroke="currentColor" stroke-width="1.2"/><circle cx="17.2" cy="6.8" r="0.75" fill="currentColor"/></svg>
                    </span>
                    <span class="contact-page__social-copy">
                      <span class="contact-page__social-label">{{ 'sections.contact_template.social_instagram' | t }}</span>
                      {%- if instagram_handle != blank -%}
                        <span class="contact-page__social-handle">{{ instagram_handle | escape }}</span>
                      {%- endif -%}
                    </span>
                    <span class="visually-hidden">{{ 'footer.opens_new_window' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if facebook_url != blank -%}
                <li>
                  <a
                    class="contact-page__social-link contact-page__social-link--facebook"
                    href="{{ facebook_url }}"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <span class="contact-page__social-icon" aria-hidden="true">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M14 8.5h2.5l-.5 3H14v8.5h-3.5V11.5H9V8.5h1.5V7c0-1.2.4-2.2 1.2-3 .9-.8 2-1.2 3.3-1.2H17v3h-2c-.7 0-1.1.15-1.35.45-.25.3-.4.75-.4 1.35v.65Z" fill="currentColor"/></svg>
                    </span>
                    <span class="contact-page__social-copy">
                      <span class="contact-page__social-label">{{ 'sections.contact_template.social_facebook' | t }}</span>
                      {%- if facebook_handle != blank -%}
                        <span class="contact-page__social-handle">{{ facebook_handle | escape }}</span>
                      {%- endif -%}
                    </span>
                    <span class="visually-hidden">{{ 'footer.opens_new_window' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
            </ul>
          </div>
        </section>
      {%- endif -%}
    {%- endif -%}

    {%- if show_social_links and has_social_links == false -%}
      <section class="contact-page__social reveal-up" aria-labelledby="contact-social-heading-{{ section.id }}">
        <div class="contact-page__social-inner">
          <h2 id="contact-social-heading-{{ section.id }}" class="contact-page__social-title">
            {{ social_heading | escape }}
          </h2>
          <p class="contact-page__empty contact-page__empty--social">{{ 'sections.contact_template.empty_social' | t }}</p>
        </div>
      </section>
    {%- endif -%}
  </div>
</article>

{% stylesheet %}
  .contact-page {
    --contact-hero-min: clamp(16rem, 38vw, 22rem);
    background-color: var(--color-parchment);
    padding-block-end: var(--space-4xl);
  }

  .contact-page__hero {
    position: relative;
    display: grid;
    align-items: end;
    min-height: var(--contact-hero-min);
    margin-block-end: var(--space-3xl);
    overflow: hidden;
    color: var(--color-parchment);
  }

  .contact-page__hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .contact-page__hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    transform: scale(1.03);
  }

  .contact-page__hero-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgb(10 24 18 / 0.55) 0%, rgb(10 24 18 / 0.82) 72%, rgb(10 24 18 / 0.94) 100%),
      linear-gradient(120deg, rgb(45 90 69 / 0.35) 0%, transparent 55%);
  }

  .contact-page__hero-grain {
    position: absolute;
    inset: 0;
    opacity: 0.12;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    mix-blend-mode: soft-light;
    pointer-events: none;
  }

  .contact-page__hero-content {
    position: relative;
    z-index: 1;
    width: min(var(--page-width), calc(100% - var(--page-margin) * 2));
    max-width: 44rem;
    margin-inline: auto;
    padding: var(--space-3xl) var(--page-margin) var(--space-2xl);
    text-align: center;
  }

  .contact-page__hero-overline {
    margin: 0 0 var(--space-sm);
    font-family: var(--font-family-base);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgb(247 244 237 / 0.72);
  }

  .contact-page__hero-title {
    margin: 0 0 var(--space-md);
    font-family: var(--font-family-serif);
    font-size: clamp(2.25rem, 5vw + 0.5rem, 3.25rem);
    font-style: italic;
    font-weight: 400;
    line-height: var(--line-height-tight);
    text-wrap: balance;
  }

  .contact-page__hero-intro {
    margin: 0 auto;
    max-width: 36rem;
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: rgb(247 244 237 / 0.88);
    text-wrap: pretty;
  }

  .contact-page__body {
    width: min(var(--page-width), calc(100% - var(--page-margin) * 2));
    max-width: 76rem;
    margin-inline: auto;
  }

  .contact-page__quick-links {
    margin-block-end: var(--space-3xl);
  }

  .contact-page__quick-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-sm);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .contact-page__quick-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    min-height: 100%;
    padding: var(--space-md) var(--space-lg);
    text-decoration: none;
    color: var(--color-forest-green-dark);
    background: var(--color-surface-elevated);
    border: 1px solid rgb(10 24 18 / 0.12);
    border-radius: var(--radius-md);
    box-shadow: 0 1px 0 rgb(255 255 255 / 0.65) inset, 0 8px 24px rgb(10 24 18 / 0.05);
    transition:
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.35s ease,
      box-shadow 0.35s ease;
  }

  .contact-page__quick-card--static {
    cursor: default;
  }

  a.contact-page__quick-card:hover,
  a.contact-page__quick-card:focus-visible {
    border-color: var(--color-accent);
    transform: translate3d(0, -3px, 0);
    box-shadow: 0 12px 28px rgb(10 24 18 / 0.1);
  }

  .contact-page__quick-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    color: var(--color-accent);
    background: rgb(45 90 69 / 0.08);
    border-radius: 50%;
  }

  .contact-page__quick-label {
    font-family: var(--font-family-base);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(10 24 18 / 0.55);
  }

  .contact-page__quick-value {
    font-family: var(--font-family-serif);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    overflow-wrap: anywhere;
  }

  .contact-page__split {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .contact-page__form-card {
    position: relative;
    padding: var(--space-2xl);
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-lg);
    box-shadow:
      0 1px 0 rgb(255 255 255 / 0.8) inset,
      0 20px 50px rgb(10 24 18 / 0.07);
  }

  .contact-page__form-card::before {
    content: '';
    position: absolute;
    inset-block-start: 0;
    inset-inline: var(--space-xl);
    height: 3px;
    border-radius: 0 0 4px 4px;
    background: linear-gradient(90deg, transparent, var(--color-accent), transparent);
  }

  .contact-page__form-heading {
    margin: 0 0 var(--space-sm);
    font-family: var(--font-family-serif);
    font-size: clamp(1.5rem, 2vw + 0.5rem, 1.875rem);
    font-style: italic;
    font-weight: 400;
    color: var(--color-forest-green-dark);
  }

  .contact-page__form-note {
    margin: 0 0 var(--space-xl);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-muted);
  }

  .contact-form--card {
    max-width: none;
  }

  .contact-page__conservatory {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    padding: var(--space-xl);
    color: var(--color-parchment);
    background:
      radial-gradient(120% 80% at 100% 0%, rgb(45 90 69 / 0.35) 0%, transparent 55%),
      linear-gradient(165deg, #0f2419 0%, #0a1812 100%);
    border: 1px solid rgb(247 244 237 / 0.12);
    border-radius: var(--radius-lg);
    box-shadow: 0 24px 48px rgb(10 24 18 / 0.22);
  }

  .contact-page__arch-frame {
    position: relative;
    overflow: hidden;
    padding: var(--space-sm);
    background: rgb(247 244 237 / 0.06);
    border: 1px solid rgb(247 244 237 / 0.14);
    border-radius: 999px 999px var(--radius-lg) var(--radius-lg);
  }

  .contact-page__arch-image {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center 35%;
    border-radius: 999px 999px var(--radius-md) var(--radius-md);
  }

  .contact-page__specimen-tag {
    position: absolute;
    inset-block-end: var(--space-md);
    inset-inline-start: var(--space-md);
    padding: 0.35rem 0.65rem;
    font-family: var(--font-family-base);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-forest-green-dark);
    background: rgb(247 244 237 / 0.92);
    border-radius: var(--radius-sm);
  }

  .contact-page__panel-title {
    margin: 0 0 var(--space-sm);
    font-family: var(--font-family-serif);
    font-size: clamp(1.375rem, 2vw + 0.35rem, 1.75rem);
    font-style: italic;
    font-weight: 400;
    line-height: var(--line-height-tight);
  }

  .contact-page__panel-intro {
    margin: 0 0 var(--space-lg);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: rgb(247 244 237 / 0.78);
  }

  .contact-page__details-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .contact-page__details-item {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
    padding-block-start: var(--space-md);
    border-block-start: 1px solid rgb(247 244 237 / 0.12);
  }

  .contact-page__details-item:first-child {
    padding-block-start: 0;
    border-block-start: none;
  }

  .contact-page__details-icon {
    flex-shrink: 0;
    display: inline-flex;
    margin-block-start: 0.1rem;
    color: rgb(247 244 237 / 0.65);
  }

  .contact-page__details-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .contact-page__details-label {
    font-family: var(--font-family-base);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(247 244 237 / 0.55);
  }

  .contact-page__details-value,
  .contact-page__details-link {
    font-family: var(--font-family-serif);
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--color-parchment);
  }

  .contact-page__details-link.link-underline-grow:hover,
  .contact-page__details-link.link-underline-grow:focus-visible {
    color: rgb(247 244 237 / 0.95);
  }

  .contact-page__section-overline {
    margin: 0 0 var(--space-sm);
    font-family: var(--font-family-base);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .contact-page__faq {
    margin-block-start: var(--space-4xl);
    padding: var(--space-3xl) var(--page-margin);
    margin-inline: calc(var(--page-margin) * -1);
    background:
      linear-gradient(180deg, rgb(243 241 235) 0%, var(--color-parchment) 100%);
    border-block: 1px solid var(--color-border);
  }

  .contact-page__faq-inner {
    width: min(48rem, 100%);
    margin-inline: auto;
  }

  .contact-page__faq-header {
    margin-block-end: var(--space-xl);
    text-align: center;
  }

  .contact-page__faq-title {
    margin: 0;
    font-family: var(--font-family-serif);
    font-size: clamp(1.5rem, 2vw + 0.35rem, 2rem);
    font-style: italic;
    font-weight: 400;
    color: var(--color-forest-green-dark);
  }

  .contact-page__accordion {
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .contact-page__social {
    margin-block-start: var(--space-3xl);
    padding: var(--space-2xl);
    background: var(--color-forest-green-dark);
    border-radius: var(--radius-lg);
  }

  .contact-page__social-inner {
    max-width: 40rem;
    margin-inline: auto;
    text-align: center;
  }

  .contact-page__social-title {
    margin: 0 0 var(--space-xl);
    font-family: var(--font-family-serif);
    font-size: clamp(1.35rem, 2vw + 0.25rem, 1.65rem);
    font-style: italic;
    font-weight: 400;
    color: var(--color-parchment);
  }

  .contact-page__social-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .contact-page__social-link {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-lg) var(--space-xl);
    text-align: start;
    text-decoration: none;
    color: var(--color-forest-green-dark);
    background: var(--color-parchment);
    border: 1px solid rgb(247 244 237 / 0.2);
    border-radius: var(--radius-md);
    transition:
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.4s ease;
  }

  .contact-page__social-link:hover {
    transform: translate3d(0, -2px, 0);
    box-shadow: 0 12px 28px rgb(0 0 0 / 0.2);
  }

  .contact-page__social-icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: rgb(10 24 18 / 0.06);
  }

  .contact-page__social-copy {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .contact-page__social-label {
    font-family: var(--font-family-base);
    font-size: var(--font-size-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .contact-page__social-handle {
    font-family: var(--font-family-serif);
    font-size: var(--font-size-lg);
    font-style: italic;
  }

  .contact-page__empty {
    margin: 0;
    padding: var(--space-lg);
    text-align: center;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background-color: rgb(255 255 255 / 0.45);
  }

  .contact-page__empty--social {
    color: rgb(247 244 237 / 0.78);
    border-color: rgb(247 244 237 / 0.22);
    background-color: rgb(5 13 10 / 0.28);
  }

  @media (min-width: 750px) {
    .contact-page__quick-list {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (min-width: 990px) {
    .contact-page__hero-content {
      text-align: start;
      padding-inline: max(var(--page-margin), calc((100vw - var(--page-width)) / 2 + var(--page-margin)));
    }

    .contact-page__split {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
      gap: var(--space-4xl);
    }

    .contact-page__details-column--sticky .contact-page__conservatory {
      position: sticky;
      top: calc(var(--header-height) + var(--space-md));
    }

    .contact-page__social-list {
      flex-direction: row;
      justify-content: center;
    }

    .contact-page__social-link {
      flex: 1 1 14rem;
      max-width: 18rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-page__hero-image {
      transform: none;
    }

    a.contact-page__quick-card:hover,
    .contact-page__social-link:hover {
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.contact_template.name",
