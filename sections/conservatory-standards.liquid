<section
  class="conservatory-standards full-width reveal-up"
  aria-labelledby="conservatory-standards-heading-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="conservatory-standards__container">
    <header class="conservatory-standards__header">
      <p class="conservatory-standards__subheading">
        {{ section.settings.subheading | default: 'Our philosophy' | escape }}
      </p>
      <h2 id="conservatory-standards-heading-{{ section.id }}" class="conservatory-standards__title">
        {{ section.settings.heading | default: 'The Conservatory Standards' | escape }}
      </h2>
    </header>

    {%- if section.blocks.size > 0 -%}
      <div class="conservatory-standards__grid" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'pillar' -%}
            {%- liquid
              assign pillar_image = block.settings.image
              assign pillar_heading = block.settings.heading | default: 'Pillar heading'
              assign pillar_body = block.settings.body
              assign pillar_placeholder = block.settings.placeholder_image
              assign use_shopify_image = false

              if pillar_image != blank and pillar_image.width > 0
                assign use_shopify_image = true
              endif

              if pillar_placeholder == blank
                case forloop.index
                  when 1
                    assign pillar_placeholder = 'https://commons.wikimedia.org/wiki/Special:FilePath/Drosera_capensis_bend.JPG?width=100'
                  when 2
                    assign pillar_placeholder = 'https://commons.wikimedia.org/wiki/Special:FilePath/Nepenthes_villosa.jpg?width=100'
                  when 3
                    assign pillar_placeholder = 'https://commons.wikimedia.org/wiki/Special:FilePath/Schultz_Sphagnum_Peat_Moss.jpg?width=100'
                  else
                    assign pillar_placeholder = 'https://commons.wikimedia.org/wiki/Special:FilePath/Drosera_capensis_bend.JPG?width=100'
                endcase
              endif
            -%}

            <article
              class="conservatory-standards__pillar"
              role="listitem"
              {{ block.shopify_attributes }}
            >
              <div class="conservatory-standards__thumb" aria-hidden="true">
                {%- comment -%} TODO: replace placeholder image before launch — see placeholder-images.md {%- endcomment -%}
                {%- if use_shopify_image -%}
                  {{
                    pillar_image
                    | image_url: width: 100, height: 100, crop: 'center'
                    | image_tag:
                      class: 'conservatory-standards__thumb-image',
                      widths: '50, 100',
                      sizes: '50px',
                      loading: 'lazy',
                      alt: ''
                  }}
                {%- elsif pillar_placeholder != blank -%}
                  <img
                    class="conservatory-standards__thumb-image conservatory-standards__thumb-image--fallback"
                    src="{{ pillar_placeholder }}"
                    alt=""
                    width="50"
                    height="50"
                    loading="lazy"
                    decoding="async"
                  >
                {%- endif -%}
              </div>

              <h3 class="conservatory-standards__pillar-title">{{ pillar_heading | escape }}</h3>

              <p class="conservatory-standards__pillar-body">
                {{ pillar_body | default: 'Describe this standard.' | escape }}
              </p>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .conservatory-standards {
    color: var(--color-forest-green-dark);
    background-color: var(--color-parchment);
  }

  .conservatory-standards__container {
    width: 100%;
    max-width: var(--page-width);
    margin-inline: auto;
    padding: 6rem 5%;
  }

  .conservatory-standards__header {
    margin-block-end: var(--space-3xl);
    text-align: center;
  }

  .conservatory-standards__subheading {
    margin: 0 0 var(--space-md);
    font-family: var(--font-family-base);
    font-size: var(--font-size-xs);
    font-weight: 600;
    font-variant: small-caps;
    line-height: var(--line-height-base);
    letter-spacing: 0.14em;
    color: var(--color-forest-green-dark);
    opacity: 0.72;
  }

  .conservatory-standards__title {
    margin: 0;
    font-family: var(--font-family-serif);
    font-size: clamp(2rem, 3.5vw + 0.5rem, 2.75rem);
    font-weight: 400;
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tight);
    color: var(--color-forest-green-dark);
  }

  .conservatory-standards__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .conservatory-standards__pillar {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
    padding: var(--space-xl) var(--space-lg);
    transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .conservatory-standards__thumb {
    flex-shrink: 0;
    width: 50px;
    height: 50px;
    overflow: hidden;
    border-radius: var(--radius-full);
    border: 1px solid rgb(10 24 18 / 0.12);
  }

  .conservatory-standards__thumb-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .conservatory-standards__pillar:hover {
    transform: translate3d(0, -2px, 0);
  }

  .conservatory-standards__pillar:hover .conservatory-standards__thumb-image {
    transform: scale(1.08);
  }

  .conservatory-standards__pillar-title {
    margin: 0;
    font-family: var(--font-family-serif);
    font-size: 1.25rem;
    font-weight: 400;
    line-height: var(--line-height-tight);
    color: var(--color-forest-green-dark);
  }

  .conservatory-standards__pillar-body {
    margin: 0;
    max-width: 36ch;
    font-family: var(--font-family-base);
    font-size: 0.9rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--color-forest-green-dark);
    opacity: 0.88;
  }

  @media (min-width: 750px) {
    .conservatory-standards__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
    }

    .conservatory-standards__pillar {
      padding: var(--space-2xl) var(--space-xl);
    }

    .conservatory-standards__pillar:not(:last-child):not(:nth-child(3n)) {
      border-right: 1px solid rgb(10 20 11 / 0.1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .conservatory-standards__pillar,
    .conservatory-standards__thumb-image {
      transition: none;
    }

    .conservatory-standards__pillar:hover {
      transform: none;
    }

    .conservatory-standards__pillar:hover .conservatory-standards__thumb-image {
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.conservatory_standards.name",
  "tag": "section",
  "class": "conservatory-standards-section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.conservatory_standards.settings.subheading",
      "default": "Our philosophy"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.conservatory_standards.settings.heading",
      "default": "The Conservatory Standards"
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "t:sections.conservatory_standards.blocks.pillar.name",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.conservatory_standards.blocks.pillar.settings.image"
        },
        {
          "type": "text",
          "id": "placeholder_image",
          "label": "t:sections.conservatory_standards.blocks.pillar.settings.placeholder_image",
          "info": "t:sections.conservatory_standards.blocks.pillar.settings.placeholder_image_info"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.conservatory_standards.blocks.pillar.settings.heading",
          "default": "Pillar heading"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "t:sections.conservatory_standards.blocks.pillar.settings.body",
          "default": "Describe this standard in one or two sentences."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.conservatory_standards.name",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "heading": "Ethical Propagation",
            "body": "All specimens are cultivated in-house via advanced tissue culture, ensuring zero impact on vulnerable wild populations.",
            "placeholder_image": "https://commons.wikimedia.org/wiki/Special:FilePath/Drosera_capensis_bend.JPG?width=100"
          }
        },
        {
          "type": "pillar",
          "settings": {
            "heading": "Climate Acclimation",
            "body": "Our plants are hardened off in specific greenhouse zones, ensuring they thrive in the diverse South African climate.",
            "placeholder_image": "https://commons.wikimedia.org/wiki/Special:FilePath/Nepenthes_villosa.jpg?width=100"
          }
        },
        {
          "type": "pillar",
          "settings": {
            "heading": "Specialized Transit",
            "body": "Shipped bare-root in protective sphagnum using specialized botanical couriers to guarantee safe arrival.",
            "placeholder_image": "https://commons.wikimedia.org/wiki/Special:FilePath/Schultz_Sphagnum_Peat_Moss.jpg?width=100"
          }
        }
      ]
    }
  ]
}
{% endschema %}
