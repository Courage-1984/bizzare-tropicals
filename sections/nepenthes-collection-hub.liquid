{%- liquid
  assign show_hub = false
  if collection != blank
    if collection.handle == 'nepenthes'
      assign show_hub = true
    endif
  endif

  assign hub_heading = section.settings.heading | strip
  if hub_heading == blank
    assign hub_heading = 'sections.nepenthes_collection_hub.heading_default' | t
  endif
-%}

{%- unless show_hub -%}
{%- else -%}
  <section
    class="nepenthes-hub"
    aria-labelledby="nepenthes-hub-heading-{{ section.id }}"
    {{ section.shopify_attributes }}
  >
    <header class="nepenthes-hub__header">
      <p class="nepenthes-hub__overline">{{ 'sections.nepenthes_collection_hub.overline' | t }}</p>
      <h2 id="nepenthes-hub-heading-{{ section.id }}" class="nepenthes-hub__title">
        {{ hub_heading | escape }}
      </h2>
      {%- assign hub_intro = section.settings.intro | strip -%}
      {%- if hub_intro == blank -%}
        {%- assign hub_intro = 'sections.nepenthes_collection_hub.intro_default' | t -%}
      {%- endif -%}
      <p class="nepenthes-hub__intro">{{ hub_intro | escape }}</p>
    </header>

    <ul class="nepenthes-hub__grid" role="list">
      {%- liquid
        assign hub_handles = 'nepenthes-highland,nepenthes-intermediate,nepenthes-lowland' | split: ','
        assign hub_labels = 'sections.nepenthes_collection_hub.card_highland,sections.nepenthes_collection_hub.card_intermediate,sections.nepenthes_collection_hub.card_lowland' | split: ','
      -%}
      {%- for hub_handle in hub_handles -%}
        {%- assign hub_collection = collections[hub_handle] -%}
        {%- if hub_collection == blank -%}
          {%- continue -%}
        {%- endif -%}
        {%- assign label_key = hub_labels[forloop.index0] -%}
        {%- assign card_title = label_key | t -%}
        {%- capture collection_display_title -%}
          {%- render 'collection-display-title', collection: hub_collection -%}
        {%- endcapture -%}
        {%- assign collection_title = collection_display_title | strip -%}
        {%- if collection_title != blank -%}
          {%- assign card_title = collection_title -%}
        {%- endif -%}
        {%- assign card_image = hub_collection.image -%}
        {%- assign use_shopify_image = false -%}
        {%- if card_image != blank and card_image.width > 0 -%}
          {%- assign use_shopify_image = true -%}
        {%- endif -%}
        {%- capture placeholder_url -%}
          {%- render 'genus-placeholder-url', genus_handle: 'nepenthes' -%}
        {%- endcapture -%}
        <li class="nepenthes-hub__item" role="listitem">
          {% render 'genus-arch-card',
            card_title: card_title,
            card_link: hub_collection.url,
            placeholder_url: placeholder_url,
            card_image: card_image,
            use_shopify_image: use_shopify_image
          %}
        </li>
      {%- endfor -%}
    </ul>
  </section>
{%- endunless -%}

{% stylesheet %}
  .nepenthes-hub {
    padding-block: var(--space-xl);
    border-bottom: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
  }

  .nepenthes-hub__overline {
    margin: 0 0 var(--space-xs);
    font-size: var(--font-size-sm);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.65);
  }

  .nepenthes-hub__title {
    margin: 0 0 var(--space-sm);
    font-family: var(--font-heading-family);
    font-size: clamp(1.5rem, 3vw, 2rem);
  }

  .nepenthes-hub__intro {
    margin: 0 0 var(--space-lg);
    max-width: 52ch;
    color: rgb(var(--color-foreground-rgb) / 0.8);
  }

  .nepenthes-hub__grid {
    display: grid;
    gap: var(--space-md);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media (min-width: 750px) {
    .nepenthes-hub__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.nepenthes_collection_hub.name",
  "tag": "section",
  "class": "nepenthes-hub-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.nepenthes_collection_hub.settings.heading",
      "default": "Shop by elevation"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "t:sections.nepenthes_collection_hub.settings.intro"
    }
  ]
}
{% endschema %}
