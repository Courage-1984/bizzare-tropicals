{%- liquid
  assign featured_collection = section.settings.collection

  if featured_collection == blank
    assign featured_collection = collections.all
  endif

  if featured_collection == blank
    if product != blank
      for coll in product.collections
        if coll.products_count > 0
          assign featured_collection = coll
          break
        endif
      endfor
    endif
  endif

  assign show_real_products = false
  if featured_collection != blank
    if featured_collection.products.size > 0
      assign show_real_products = true
    endif
  endif

  assign products_limit = section.settings.products_to_show | default: 8
  assign section_heading = section.settings.heading
  assign section_subheading = section.settings.subheading
  assign view_all_label = section.settings.view_all_label
  assign background_color_start = section.settings.background_color_start | default: '#1e3320'
  assign background_color_end = section.settings.background_color_end | default: '#0a140b'
-%}

<section
  class="featured-collection full-width reveal-up"
  data-featured-carousel
  aria-labelledby="featured-collection-heading-{{ section.id }}"
  style="--featured-collection-bg-start: {{ background_color_start }}; --featured-collection-bg-end: {{ background_color_end }};"
  {{ section.shopify_attributes }}
>
  <div class="featured-collection__environment">
          <div class="featured-collection__environment-inner">
      <header class="featured-collection__header">
    <div class="featured-collection__intro">
      {%- if section_heading != blank -%}
        <h2 id="featured-collection-heading-{{ section.id }}" class="featured-collection__title">
          {{ section_heading | escape }}
        </h2>
      {%- endif -%}
      {%- if section_subheading != blank -%}
        <p class="featured-collection__subtitle">{{ section_subheading | escape }}</p>
      {%- endif -%}
    </div>

    <div class="featured-collection__actions">
      {%- if show_real_products and view_all_label != blank -%}
        <a class="featured-collection__view-all link-underline-grow" href="{{ featured_collection.url }}">
          {{ view_all_label | escape }}
        </a>
      {%- endif -%}

      <div class="featured-collection__nav" data-carousel-nav hidden>
        <button
          type="button"
          class="featured-collection__arrow"
          data-carousel-prev
          aria-controls="featured-carousel-track-{{ section.id }}"
          aria-label="{{ 'sections.featured_collection.prev' | t }}"
        >
          <span aria-hidden="true">&larr;</span>
        </button>
        <button
          type="button"
          class="featured-collection__arrow"
          data-carousel-next
          aria-controls="featured-carousel-track-{{ section.id }}"
          aria-label="{{ 'sections.featured_collection.next' | t }}"
        >
          <span aria-hidden="true">&rarr;</span>
        </button>
      </div>
    </div>
  </header>

  {%- if show_real_products -%}
    <div
      class="featured-collection__viewport"
      data-carousel-viewport
    >
      <ul
        id="featured-carousel-track-{{ section.id }}"
        class="featured-collection__track"
        data-carousel-track
        data-reveal-stagger
        role="list"
        tabindex="0"
        aria-label="{{ 'sections.featured_collection.carousel_label' | t }}"
      >
        {%- for product in featured_collection.products limit: products_limit -%}
          <li class="featured-collection__item reveal-up" data-carousel-item role="listitem">
            {% render 'product-card',
              product_item: product,
              sizes: '(min-width: 990px) 24vw, (min-width: 750px) 32vw, 78vw'
            %}
          </li>
        {%- endfor -%}
      </ul>
    </div>
  {%- else -%}
    <div
      class="featured-collection__viewport featured-collection__viewport--preview"
      data-carousel-viewport
    >
      <ul
        id="featured-carousel-track-{{ section.id }}"
        class="featured-collection__track"
        data-carousel-track
        data-reveal-stagger
        role="list"
        tabindex="0"
        aria-label="{{ 'sections.featured_collection.preview_label' | t }}"
      >
        {%- for i in (1..8) -%}
          <li class="featured-collection__item reveal-up" data-carousel-item role="listitem">
            {% render 'product-card',
              card_index: forloop.index0,
              sizes: '(min-width: 990px) 24vw, (min-width: 750px) 32vw, 78vw'
            %}
          </li>
        {%- endfor -%}
      </ul>
    </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .featured-collection {
    --featured-collection-ink: var(--color-parchment);
    --featured-collection-ink-muted: rgb(247 244 237 / 0.78);
    display: grid;
    grid-template-columns: var(--content-grid);
    padding-block: 0;
    color: var(--featured-collection-ink);
  }

  .featured-collection__environment {
    grid-column: 1 / -1;
    padding-block: 5rem;
    background: linear-gradient(145deg, var(--featured-collection-bg-start) 0%, var(--featured-collection-bg-end) 100%);
  }

  .featured-collection__environment-inner {
    display: grid;
    grid-template-columns: var(--content-grid);
    min-width: 0;
  }

  .featured-collection__environment-inner > * {
    grid-column: 2;
  }

  .featured-collection__header {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-lg);
    margin-block-end: var(--space-xl);
  }

  .featured-collection__title {
    margin: 0 0 var(--space-xs);
    font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2.25rem);
    font-weight: 600;
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tight);
    color: var(--featured-collection-ink);
  }

  .featured-collection__subtitle {
    margin: 0;
    max-width: 42ch;
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--featured-collection-ink-muted);
  }

  .featured-collection__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-md);
  }

  .featured-collection__view-all {
    font-size: var(--font-size-sm);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--featured-collection-ink);
  }

  .featured-collection__view-all.link-underline-grow:hover,
  .featured-collection__view-all.link-underline-grow:focus-visible {
    color: #fdfbf7;
  }

  .featured-collection__nav {
    display: none;
    gap: var(--space-xs);
  }

  .featured-collection__nav.is-visible {
    display: inline-flex;
  }

  .featured-collection .product-card__link {
    border-color: rgb(247 244 237 / 0.12);
    box-shadow: 0 8px 24px rgb(0 0 0 / 0.22);
  }

  .featured-collection .product-card__title,
  .featured-collection .product-card__price,
  .featured-collection .product-card__price-regular {
    color: var(--color-text);
  }

  .featured-collection .product-card__latin {
    color: var(--color-text-muted);
  }

  .featured-collection .product-card__link:hover .product-card__title {
    color: var(--color-primary);
  }

  .featured-collection__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    cursor: pointer;
    color: #0a140b;
    background-color: var(--featured-collection-ink);
    border: 1px solid rgb(247 244 237 / 0.35);
    border-radius: var(--radius-full);
    transition:
      background-color var(--transition-fast),
      transform var(--transition-fast),
      opacity var(--transition-fast);
  }

  .featured-collection__arrow:hover:not(:disabled) {
    background-color: #fdfbf7;
    transform: translate3d(0, -1px, 0);
  }

  .featured-collection__arrow:disabled {
    cursor: not-allowed;
    opacity: 0.4;
  }

  .featured-collection__viewport {
    position: relative;
    margin-inline: calc(var(--page-margin) * -1);
    padding-inline: var(--page-margin);
  }

  .featured-collection__track {
    display: flex;
    gap: var(--space-lg);
    margin: 0;
    padding: var(--space-sm) var(--page-margin) var(--space-md);
    padding-inline: var(--page-margin);
    list-style: none;
    overflow-x: auto;
    overscroll-behavior-x: contain;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .featured-collection__track::-webkit-scrollbar {
    display: none;
  }

  .featured-collection__track:focus-visible {
    outline: 2px solid var(--featured-collection-ink);
    outline-offset: 4px;
  }

  .featured-collection__item {
    flex: 0 0 min(78vw, 18rem);
    overflow: visible;
    scroll-snap-align: start;
    min-width: 0;
  }

  .featured-collection__empty {
    margin: 0;
    padding: var(--space-xl);
    text-align: center;
    color: var(--color-text-muted);
    background-color: var(--color-surface);
    border-radius: var(--radius-md);
  }

  @media (max-width: 749px) {
    .featured-collection__environment {
      padding-block: var(--space-3xl);
    }
  }

  @media (min-width: 750px) {
    .featured-collection__viewport {
      margin-inline: 0;
      padding-inline: 0;
    }

    .featured-collection__track {
      padding-inline: 0;
    }

    .featured-collection__item {
      flex: 0 0 calc((100% - var(--space-lg) * 2) / 3);
    }
  }

  @media (min-width: 990px) {
    .featured-collection__item {
      flex: 0 0 calc((100% - var(--space-lg) * 3) / 4);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .featured-collection__track {
      scroll-behavior: auto;
    }

    .featured-collection__arrow:hover:not(:disabled) {
      transition: none;
      transform: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    'use strict';

    var SECTION_SELECTOR = '[data-featured-carousel]';
    var AUTOPLAY_MS = 6000;
    var RESUME_DELAY_MS = 8000;

    function prefersReducedMotion() {
      try {
        return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      } catch (error) {
        return false;
      }
    }

    function destroyCarousel(root) {
      if (!root || !root._featuredCarouselState) {
        return;
      }

      try {
        var state = root._featuredCarouselState;

        if (state.autoplayTimer) {
          clearInterval(state.autoplayTimer);
        }

        if (state.resumeTimer) {
          clearTimeout(state.resumeTimer);
        }

        state.listeners.forEach(function (entry) {
          entry.target.removeEventListener(entry.type, entry.handler);
        });
      } catch (error) {
        console.error('Featured collection: teardown failed.', error);
      }

      delete root._featuredCarouselState;
      root.dataset.featuredCarouselInitialized = 'false';
    }

    function updateNavState(track, prevButton, nextButton) {
      if (!track || !prevButton || !nextButton) {
        return;
      }

      var overflow = track.scrollWidth > track.clientWidth + 2;
      prevButton.disabled = !overflow;
      nextButton.disabled = !overflow;
    }

    function getScrollStep(track) {
      var firstItem = track.querySelector('[data-carousel-item]');
      if (!firstItem) {
        return track.clientWidth * 0.85;
      }

      var trackStyles = window.getComputedStyle(track);
      var gap = parseFloat(trackStyles.columnGap || trackStyles.gap || '0') || 0;
      return firstItem.offsetWidth + gap;
    }

    function initCarousel(root) {
      if (!root) {
        return;
      }

      destroyCarousel(root);

      var track = root.querySelector('[data-carousel-track]');
      var nav = root.querySelector('[data-carousel-nav]');
      var prevButton = root.querySelector('[data-carousel-prev]');
      var nextButton = root.querySelector('[data-carousel-next]');

      if (!track || !prevButton || !nextButton || !nav) {
        return;
      }

      var desktopQuery = window.matchMedia('(min-width: 750px)');
      var autoplayPaused = false;
      var state = {
        listeners: [],
        autoplayTimer: null,
        resumeTimer: null
      };

      function trackListener(target, type, handler, options) {
        target.addEventListener(type, handler, options);
        state.listeners.push({ target: target, type: type, handler: handler });
      }

      function scrollByStep(direction) {
        var step = getScrollStep(track) * direction;
        var behavior = prefersReducedMotion() ? 'auto' : 'smooth';
        track.scrollBy({ left: step, behavior: behavior });
      }

      function scrollNextWithLoop() {
        var maxScroll = track.scrollWidth - track.clientWidth;
        var atEnd = track.scrollLeft >= maxScroll - 2;
        var behavior = prefersReducedMotion() ? 'auto' : 'smooth';

        if (atEnd) {
          track.scrollTo({ left: 0, behavior: behavior });
          return;
        }

        scrollByStep(1);
      }

      function scrollPrevWithLoop() {
        var atStart = track.scrollLeft <= 2;
        var maxScroll = track.scrollWidth - track.clientWidth;
        var behavior = prefersReducedMotion() ? 'auto' : 'smooth';

        if (atStart) {
          track.scrollTo({ left: maxScroll, behavior: behavior });
          return;
        }

        scrollByStep(-1);
      }

      function stopAutoplay() {
        if (state.autoplayTimer) {
          clearInterval(state.autoplayTimer);
          state.autoplayTimer = null;
        }
      }

      function startAutoplay() {
        stopAutoplay();

        var overflow = track.scrollWidth > track.clientWidth + 2;
        if (!overflow || autoplayPaused || prefersReducedMotion() || document.hidden) {
          return;
        }

        state.autoplayTimer = setInterval(function () {
          if (document.hidden) {
            return;
          }
          try {
            scrollNextWithLoop();
          } catch (error) {
            console.error('Featured collection: autoplay tick failed.', error);
          }
        }, AUTOPLAY_MS);
      }

      function pauseAutoplay() {
        autoplayPaused = true;
        stopAutoplay();

        if (state.resumeTimer) {
          clearTimeout(state.resumeTimer);
          state.resumeTimer = null;
        }
      }

      function scheduleAutoplayResume() {
        if (state.resumeTimer) {
          clearTimeout(state.resumeTimer);
        }

        state.resumeTimer = setTimeout(function () {
          try {
            autoplayPaused = false;
            startAutoplay();
          } catch (error) {
            console.error('Featured collection: autoplay resume failed.', error);
          }
        }, RESUME_DELAY_MS);
      }

      function syncNavVisibility() {
        var isDesktop = desktopQuery.matches;
        var overflow = track.scrollWidth > track.clientWidth + 2;
        nav.hidden = !isDesktop;
        nav.classList.toggle('is-visible', isDesktop && overflow);
        updateNavState(track, prevButton, nextButton);
      }

      trackListener(prevButton, 'click', function () {
        pauseAutoplay();
        scrollPrevWithLoop();
        scheduleAutoplayResume();
      });

      trackListener(nextButton, 'click', function () {
        pauseAutoplay();
        scrollNextWithLoop();
        scheduleAutoplayResume();
      });

      trackListener(track, 'scroll', function () {
        updateNavState(track, prevButton, nextButton);
      }, { passive: true });

      trackListener(track, 'pointerdown', pauseAutoplay);
      trackListener(track, 'pointerenter', pauseAutoplay);
      trackListener(track, 'focusin', pauseAutoplay);
      trackListener(track, 'pointerup', scheduleAutoplayResume);
      trackListener(track, 'pointerleave', scheduleAutoplayResume);
      trackListener(track, 'focusout', scheduleAutoplayResume);

      trackListener(window, 'resize', function () {
        syncNavVisibility();
        startAutoplay();
      });

      if (typeof desktopQuery.addEventListener === 'function') {
        trackListener(desktopQuery, 'change', function () {
          syncNavVisibility();
        });
      } else if (typeof desktopQuery.addListener === 'function') {
        desktopQuery.addListener(syncNavVisibility);
      }

      syncNavVisibility();
      root._featuredCarouselState = state;
      root.dataset.featuredCarouselInitialized = 'true';
      startAutoplay();
    }

    function initAllCarousels(scope) {
      var context = scope || document;
      var sections = context.querySelectorAll(SECTION_SELECTOR);

      sections.forEach(function (section) {
        if (section.dataset.featuredCarouselInitialized === 'true') {
          return;
        }
        initCarousel(section);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        initAllCarousels();
      });
    } else {
      initAllCarousels();
    }

    document.addEventListener('shopify:section:load', function (event) {
      initAllCarousels(event.target);
    });

    document.addEventListener('shopify:section:unload', function (event) {
      var section = event.target.querySelector(SECTION_SELECTOR);
      if (section) {
        destroyCarousel(section);
      }
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.featured_collection.name",
  "tag": "section",
  "class": "featured-collection-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.featured_collection.settings.heading",
      "default": "Featured plants"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.featured_collection.settings.subheading",
      "default": "Hand-picked specimens from our living collection."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:general.collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:sections.featured_collection.settings.products_to_show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "t:sections.featured_collection.settings.view_all_label",
      "default": "View all"
    },
    {
      "type": "color",
      "id": "background_color_start",
      "label": "t:sections.featured_collection.settings.background_color_start",
      "default": "#1e3320"
    },
    {
      "type": "color",
      "id": "background_color_end",
      "label": "t:sections.featured_collection.settings.background_color_end",
      "default": "#0a140b"
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_collection.name",
      "settings": {
        "heading": "Featured plants",
        "subheading": "Hand-picked specimens from our living collection.",
        "view_all_label": "View all"
      }
    }
  ]
}
{% endschema %}
