{%- liquid
  assign featured_collection = section.settings.collection
  if featured_collection == blank
    if collections.frontpage != blank and collections.frontpage.products_count > 0
      assign featured_collection = collections.frontpage
    else
      assign featured_collection = collections.all
    endif
  endif

  assign products_limit = section.settings.products_to_show | default: 8
  assign section_heading = section.settings.heading
  assign section_subheading = section.settings.subheading
  assign view_all_label = section.settings.view_all_label
-%}

<section
  class="featured-collection"
  data-featured-carousel
  aria-labelledby="featured-collection-heading-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <header class="featured-collection__header">
    <div class="featured-collection__intro">
      {%- if section_heading != blank -%}
        <h2 id="featured-collection-heading-{{ section.id }}" class="featured-collection__title">
          {{ section_heading | escape }}
        </h2>
      {%- endif -%}
      {%- if section_subheading != blank -%}
        <p class="featured-collection__subtitle">{{ section_subheading | escape }}</p>
      {%- endif -%}
    </div>

    <div class="featured-collection__actions">
      {%- if featured_collection != blank and view_all_label != blank -%}
        <a class="featured-collection__view-all" href="{{ featured_collection.url }}">
          {{ view_all_label | escape }}
        </a>
      {%- endif -%}

      <div class="featured-collection__nav" data-carousel-nav hidden>
        <button
          type="button"
          class="featured-collection__arrow"
          data-carousel-prev
          aria-controls="featured-carousel-track-{{ section.id }}"
          aria-label="{{ 'sections.featured_collection.prev' | t }}"
        >
          <span aria-hidden="true">&larr;</span>
        </button>
        <button
          type="button"
          class="featured-collection__arrow"
          data-carousel-next
          aria-controls="featured-carousel-track-{{ section.id }}"
          aria-label="{{ 'sections.featured_collection.next' | t }}"
        >
          <span aria-hidden="true">&rarr;</span>
        </button>
      </div>
    </div>
  </header>

  {%- if featured_collection != blank and featured_collection.products_count > 0 -%}
    <div
      class="featured-collection__viewport"
      data-carousel-viewport
    >
      <ul
        id="featured-carousel-track-{{ section.id }}"
        class="featured-collection__track"
        data-carousel-track
        role="list"
        tabindex="0"
        aria-label="{{ 'sections.featured_collection.carousel_label' | t }}"
      >
        {%- for product in featured_collection.products limit: products_limit -%}
          {%- liquid
            assign product_image = product.featured_media.preview_image | default: product.featured_image
            assign use_shopify_image = false
            if product_image != blank and product_image.width > 0
              assign use_shopify_image = true
            endif

            assign genus_handle = product.metafields.custom.genus.value | default: product.metafields.custom.genus
            assign latin_name = product.metafields.custom.latin_name.value | default: product.metafields.custom.latin_name
            assign difficulty_raw = product.metafields.custom.difficulty.value | default: product.metafields.custom.difficulty
            assign difficulty = difficulty_raw | plus: 0

            case genus_handle
              when 'dionaea'
                assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Venus_flytrap_-_Dionaea_muscipula_-_panoramio_(3).jpg?width=1200'
              when 'sarracenia'
                assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Sarracenia_((leucophylla_x_flava)_x_(purpurea_montana_x_flava))_x_%27Judith_Hindle%27_(5065614694).jpg?width=1200'
              when 'nepenthes'
                assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Nepenthes_ventricosa0.jpg?width=1200'
              when 'drosera'
                assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Drosera_aliciae2_ies.jpg?width=1200'
              when 'pinguicula'
                assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Pinguicula_moranensis_0zz.jpg?width=1200'
              when 'cephalotus'
                assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Albany_Pitcher_Plant_Oxford_Botanic_Garden.jpg?width=1200'
              else
                assign placeholder_url = 'https://commons.wikimedia.org/wiki/Special:FilePath/Drosera_aliciae2_ies.jpg?width=1200'
            endcase

            assign image_alt = product.title
            if latin_name != blank
              assign image_alt = latin_name
            endif
          -%}

          <li class="featured-collection__item" data-carousel-item role="listitem">
            <article class="product-card">
              <a class="product-card__media-link" href="{{ product.url }}" tabindex="-1" aria-hidden="true">
                <span class="product-card__media">
                  {%- comment -%} TODO: replace placeholder image before launch — see placeholder-images.md {%- endcomment -%}
                  {%- if use_shopify_image -%}
                    {{
                      product_image
                      | image_url: width: 800, height: 1000, crop: 'center'
                      | image_tag:
                        class: 'product-card__image',
                        widths: '400, 600, 800',
                        sizes: '(min-width: 990px) 24vw, (min-width: 750px) 32vw, 78vw',
                        loading: 'lazy',
                        alt: image_alt
                    }}
                  {%- else -%}
                    <img
                      class="product-card__image product-card__image--fallback"
                      src="{{ placeholder_url }}"
                      alt="{{ image_alt | escape }}"
                      width="800"
                      height="1000"
                      loading="lazy"
                      decoding="async"
                    >
                  {%- endif -%}
                </span>
              </a>

              <div class="product-card__body">
                {%- if difficulty > 0 -%}
                  <div
                    class="product-card__difficulty difficulty-pips"
                    role="img"
                    aria-label="{{ 'sections.featured_collection.difficulty_label' | t: level: difficulty, max: 5 }}"
                  >
                    {%- for pip in (1..5) -%}
                      <span
                        class="difficulty-pip{% if pip <= difficulty %} difficulty-pip--filled{% endif %}"
                        aria-hidden="true"
                      ></span>
                    {%- endfor -%}
                  </div>
                {%- endif -%}

                <h3 class="product-card__title">
                  <a href="{{ product.url }}">{{ product.title | escape }}</a>
                </h3>

                {%- if latin_name != blank -%}
                  <p class="product-card__latin">
                    <em>{{ latin_name | escape }}</em>
                  </p>
                {%- endif -%}

                <p class="product-card__price">
                  {%- if product.compare_at_price > product.price -%}
                    <span class="visually-hidden">{{ 'sections.featured_collection.price_sale' | t }}</span>
                    <span class="product-card__price-sale">{{ product.price | money }}</span>
                    <span class="visually-hidden">{{ 'sections.featured_collection.price_regular' | t }}</span>
                    <s class="product-card__price-compare">{{ product.compare_at_price | money }}</s>
                  {%- else -%}
                    <span class="product-card__price-regular">{{ product.price | money }}</span>
                  {%- endif -%}
                </p>
              </div>
            </article>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  {%- else -%}
    <p class="featured-collection__empty">{{ 'sections.featured_collection.empty' | t }}</p>
  {%- endif -%}
</section>

{% stylesheet %}
  .featured-collection {
    padding-block: var(--space-3xl);
  }

  .featured-collection__header {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-lg);
    margin-block-end: var(--space-xl);
  }

  .featured-collection__title {
    margin: 0 0 var(--space-xs);
    font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2.25rem);
    font-weight: 600;
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tight);
  }

  .featured-collection__subtitle {
    margin: 0;
    max-width: 42ch;
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-muted);
  }

  .featured-collection__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-md);
  }

  .featured-collection__view-all {
    font-size: var(--font-size-sm);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .featured-collection__view-all:hover {
    color: var(--color-accent);
  }

  .featured-collection__nav {
    display: none;
    gap: var(--space-xs);
  }

  .featured-collection__nav.is-visible {
    display: inline-flex;
  }

  .featured-collection__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    cursor: pointer;
    color: var(--color-text-inverse);
    background-color: var(--color-primary);
    border: 1px solid transparent;
    border-radius: var(--radius-full);
    transition:
      background-color var(--transition-fast),
      transform var(--transition-fast),
      opacity var(--transition-fast);
  }

  .featured-collection__arrow:hover:not(:disabled) {
    background-color: var(--color-primary-hover);
    transform: translate3d(0, -1px, 0);
  }

  .featured-collection__arrow:disabled {
    cursor: not-allowed;
    opacity: 0.4;
  }

  .featured-collection__viewport {
    position: relative;
    margin-inline: calc(var(--page-margin) * -1);
    padding-inline: var(--page-margin);
  }

  .featured-collection__track {
    display: flex;
    gap: var(--space-lg);
    margin: 0;
    padding: var(--space-xs) var(--page-margin) var(--space-md);
    padding-inline: var(--page-margin);
    list-style: none;
    overflow-x: auto;
    overscroll-behavior-x: contain;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .featured-collection__track::-webkit-scrollbar {
    display: none;
  }

  .featured-collection__track:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 4px;
  }

  .featured-collection__item {
    flex: 0 0 min(78vw, 18rem);
    scroll-snap-align: start;
    min-width: 0;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background-color: var(--color-surface-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: box-shadow var(--transition-base);
  }

  .product-card:hover {
    box-shadow: var(--shadow-md);
  }

  .product-card__media-link {
    display: block;
    text-decoration: none;
  }

  .product-card__media {
    display: block;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background-color: var(--color-surface);
  }

  .product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    transition: transform var(--transition-transform);
  }

  .product-card:hover .product-card__image {
    transform: scale3d(1.03, 1.03, 1);
  }

  .product-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: var(--space-2xs);
    padding: var(--space-md);
  }

  .product-card__difficulty {
    margin-block-end: var(--space-2xs);
  }

  .product-card__title {
    margin: 0;
    font-size: var(--font-size-md);
    font-weight: 600;
    line-height: var(--line-height-tight);
  }

  .product-card__title a {
    text-decoration: none;
  }

  .product-card__title a:hover {
    color: var(--color-accent);
  }

  .product-card__latin {
    margin: 0;
    font-size: var(--font-size-sm);
    line-height: var(--line-height-base);
    color: var(--color-text-muted);
  }

  .product-card__latin em {
    font-family: var(--font-family-serif);
    font-style: italic;
  }

  .product-card__price {
    margin: auto 0 0;
    padding-block-start: var(--space-xs);
    font-size: var(--font-size-base);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .product-card__price-sale {
    color: var(--color-accent);
    margin-inline-end: var(--space-xs);
  }

  .product-card__price-compare {
    font-size: var(--font-size-sm);
    font-weight: 400;
    color: var(--color-text-muted);
  }

  .featured-collection__empty {
    margin: 0;
    padding: var(--space-xl);
    text-align: center;
    color: var(--color-text-muted);
    background-color: var(--color-surface);
    border-radius: var(--radius-md);
  }

  @media (min-width: 750px) {
    .featured-collection__viewport {
      margin-inline: 0;
      padding-inline: 0;
    }

    .featured-collection__track {
      padding-inline: 0;
    }

    .featured-collection__item {
      flex: 0 0 calc((100% - var(--space-lg) * 2) / 3);
    }
  }

  @media (min-width: 990px) {
    .featured-collection__item {
      flex: 0 0 calc((100% - var(--space-lg) * 3) / 4);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .featured-collection__track {
      scroll-behavior: auto;
    }

    .product-card__image,
    .featured-collection__arrow:hover:not(:disabled) {
      transition: none;
      transform: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    'use strict';

    var SECTION_SELECTOR = '[data-featured-carousel]';

    function prefersReducedMotion() {
      try {
        return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      } catch (error) {
        return false;
      }
    }

    function destroyCarousel(root) {
      if (!root || !root._featuredCarouselState) {
        return;
      }

      try {
        var state = root._featuredCarouselState;
        state.listeners.forEach(function (entry) {
          entry.target.removeEventListener(entry.type, entry.handler);
        });
      } catch (error) {
        console.error('Featured collection: teardown failed.', error);
      }

      delete root._featuredCarouselState;
      root.dataset.featuredCarouselInitialized = 'false';
    }

    function updateNavState(track, prevButton, nextButton) {
      if (!track || !prevButton || !nextButton) {
        return;
      }

      var maxScroll = track.scrollWidth - track.clientWidth;
      var scrollLeft = track.scrollLeft;
      var atStart = scrollLeft <= 2;
      var atEnd = scrollLeft >= maxScroll - 2;

      prevButton.disabled = atStart;
      nextButton.disabled = atEnd;
    }

    function getScrollStep(track) {
      var firstItem = track.querySelector('[data-carousel-item]');
      if (!firstItem) {
        return track.clientWidth * 0.85;
      }

      var trackStyles = window.getComputedStyle(track);
      var gap = parseFloat(trackStyles.columnGap || trackStyles.gap || '0') || 0;
      return firstItem.offsetWidth + gap;
    }

    function initCarousel(root) {
      if (!root) {
        return;
      }

      destroyCarousel(root);

      var track = root.querySelector('[data-carousel-track]');
      var nav = root.querySelector('[data-carousel-nav]');
      var prevButton = root.querySelector('[data-carousel-prev]');
      var nextButton = root.querySelector('[data-carousel-next]');

      if (!track || !prevButton || !nextButton || !nav) {
        return;
      }

      var desktopQuery = window.matchMedia('(min-width: 750px)');
      var state = { listeners: [] };

      function trackListener(target, type, handler, options) {
        target.addEventListener(type, handler, options);
        state.listeners.push({ target: target, type: type, handler: handler });
      }

      function scrollByStep(direction) {
        var step = getScrollStep(track) * direction;
        var behavior = prefersReducedMotion() ? 'auto' : 'smooth';
        track.scrollBy({ left: step, behavior: behavior });
      }

      function syncNavVisibility() {
        var isDesktop = desktopQuery.matches;
        var overflow = track.scrollWidth > track.clientWidth + 2;
        nav.hidden = !isDesktop;
        nav.classList.toggle('is-visible', isDesktop && overflow);
        updateNavState(track, prevButton, nextButton);
      }

      trackListener(prevButton, 'click', function () {
        scrollByStep(-1);
      });

      trackListener(nextButton, 'click', function () {
        scrollByStep(1);
      });

      trackListener(track, 'scroll', function () {
        updateNavState(track, prevButton, nextButton);
      }, { passive: true });

      trackListener(window, 'resize', function () {
        syncNavVisibility();
      });

      if (typeof desktopQuery.addEventListener === 'function') {
        trackListener(desktopQuery, 'change', function () {
          syncNavVisibility();
        });
      } else if (typeof desktopQuery.addListener === 'function') {
        desktopQuery.addListener(syncNavVisibility);
      }

      syncNavVisibility();
      root._featuredCarouselState = state;
      root.dataset.featuredCarouselInitialized = 'true';
    }

    function initAllCarousels(scope) {
      var context = scope || document;
      var sections = context.querySelectorAll(SECTION_SELECTOR);

      sections.forEach(function (section) {
        if (section.dataset.featuredCarouselInitialized === 'true') {
          return;
        }
        initCarousel(section);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        initAllCarousels();
      });
    } else {
      initAllCarousels();
    }

    document.addEventListener('shopify:section:load', function (event) {
      initAllCarousels(event.target);
    });

    document.addEventListener('shopify:section:unload', function (event) {
      var section = event.target.querySelector(SECTION_SELECTOR);
      if (section) {
        destroyCarousel(section);
      }
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.featured_collection.name",
  "tag": "section",
  "class": "featured-collection-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.featured_collection.settings.heading",
      "default": "Featured plants"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.featured_collection.settings.subheading",
      "default": "Hand-picked specimens from our living collection."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:general.collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:sections.featured_collection.settings.products_to_show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "t:sections.featured_collection.settings.view_all_label",
      "default": "View all"
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_collection.name",
      "settings": {
        "heading": "Featured plants",
        "subheading": "Hand-picked specimens from our living collection.",
        "view_all_label": "View all"
      }
    }
  ]
}
{% endschema %}
