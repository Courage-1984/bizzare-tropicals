{%- liquid
  assign featured_collection = section.settings.collection
  assign related_collection_url = blank

  if featured_collection != blank
    assign related_collection_url = featured_collection.url
  endif

  if featured_collection == blank
    if product != blank
      assign product_related_collection = blank
      for coll in product.collections
        if coll.handle != 'all' and coll.products_count > 1
          assign product_related_collection = coll
          break
        endif
      endfor

      if product_related_collection == blank
        for coll in product.collections
          if coll.products_count > 1
            assign product_related_collection = coll
            break
          endif
        endfor
      endif

      if product_related_collection != blank
        assign featured_collection = product_related_collection
        assign related_collection_url = product_related_collection.url
      endif
    endif
  endif

  if featured_collection == blank
    assign featured_collection = collections.all
    if collections.all != blank
      assign related_collection_url = collections.all.url
    endif
  endif

  assign products_limit = section.settings.products_to_show | default: 8
  if products_limit < 1
    assign products_limit = 8
  endif

  assign current_product_id = blank
  assign current_product_genus = blank
  if product != blank
    assign current_product_id = product.id
    assign current_product_genus = product.metafields.custom.genus.value | default: product.metafields.custom.genus | strip | handleize
  endif

  assign rendered_related_ids = '|'
  assign rendered_related_count = 0

  if featured_collection != blank
    for related_product in featured_collection.products
      if current_product_id != blank and related_product.id == current_product_id
        continue
      endif

      assign related_marker = '|' | append: related_product.id | append: '|'
      unless rendered_related_ids contains related_marker
        assign rendered_related_ids = rendered_related_ids | append: related_product.id | append: '|'
        assign rendered_related_count = rendered_related_count | plus: 1
      endunless

      if rendered_related_count >= products_limit
          break
      endif
    endfor
  endif

  if rendered_related_count < products_limit
    for related_product in collections.all.products limit: 60
      if current_product_id != blank and related_product.id == current_product_id
        continue
      endif

      assign related_marker = '|' | append: related_product.id | append: '|'
      unless rendered_related_ids contains related_marker
        assign rendered_related_ids = rendered_related_ids | append: related_product.id | append: '|'
        assign rendered_related_count = rendered_related_count | plus: 1
      endunless

      if rendered_related_count >= products_limit
        break
      endif
    endfor
  endif

  assign show_real_products = false
  if rendered_related_count > 0
    assign show_real_products = true
  endif

  assign section_heading = section.settings.heading | strip
  if section_heading == blank
    assign section_heading = 'sections.featured_collection.heading_default' | t
  endif

  assign section_subheading = section.settings.subheading | strip
  if section_subheading == blank
    assign section_subheading = 'sections.featured_collection.subheading_default' | t
  endif

  assign view_all_label = section.settings.view_all_label | strip
  if view_all_label == blank
    assign view_all_label = 'sections.featured_collection.view_all_label_default' | t
  endif

  if related_collection_url == blank
    assign related_collection_url = routes.all_products_collection_url
  endif

  assign background_color_start = section.settings.background_color_start | default: '#1e3320'
  assign background_color_end = section.settings.background_color_end | default: '#0a140b'
-%}

<section
  class="featured-collection full-width reveal-up"
  data-featured-carousel
  aria-labelledby="featured-collection-heading-{{ section.id }}"
  style="--featured-collection-bg-start: {{ background_color_start }}; --featured-collection-bg-end: {{ background_color_end }};"
  {{ section.shopify_attributes }}
>
  <div class="featured-collection__environment">
          <div class="featured-collection__environment-inner">
      <header class="featured-collection__header">
    <div class="featured-collection__intro">
      {%- if section_heading != blank -%}
        <h2 id="featured-collection-heading-{{ section.id }}" class="featured-collection__title">
          {{ section_heading | escape }}
        </h2>
      {%- endif -%}
      {%- if section_subheading != blank -%}
        <p class="featured-collection__subtitle">{{ section_subheading | escape }}</p>
      {%- endif -%}
    </div>

    <div class="featured-collection__actions">
      {%- if show_real_products and view_all_label != blank -%}
        <a class="featured-collection__view-all link-underline-grow" href="{{ related_collection_url }}">
          {{ view_all_label | escape }}
        </a>
      {%- endif -%}

      <div class="featured-collection__nav" data-carousel-nav hidden>
        <button
          type="button"
          class="featured-collection__arrow"
          data-carousel-prev
          aria-controls="featured-carousel-track-{{ section.id }}"
          aria-label="{{ 'sections.featured_collection.prev' | t }}"
        >
          <span aria-hidden="true">&larr;</span>
        </button>
        <button
          type="button"
          class="featured-collection__arrow"
          data-carousel-next
          aria-controls="featured-carousel-track-{{ section.id }}"
          aria-label="{{ 'sections.featured_collection.next' | t }}"
        >
          <span aria-hidden="true">&rarr;</span>
        </button>
      </div>
    </div>
  </header>

  {%- if show_real_products -%}
    <div
      class="featured-collection__viewport"
      id="featured-carousel-track-{{ section.id }}"
      data-carousel-viewport
      data-carousel-track
      aria-label="{{ 'sections.featured_collection.carousel_label' | t }}"
    >
      <ul
        class="featured-collection__track"
        data-reveal-stagger
        role="list"
      >
        {%- liquid
          assign rendered_markup_count = 0
          assign rendered_markup_ids = '|'
          assign related_seed = 0
          if current_product_id != blank
            assign related_seed = current_product_id | modulo: 11
          endif
        -%}
        {%- for pass in (1..2) -%}
          {%- for offset in (0..10) -%}
            {%- assign seed_bucket = related_seed | plus: offset | modulo: 11 -%}
            {%- for related_product in featured_collection.products -%}
              {%- if current_product_id != blank and related_product.id == current_product_id -%}
                {%- continue -%}
              {%- endif -%}

              {%- assign related_marker = '|' | append: related_product.id | append: '|' -%}
              {%- if rendered_markup_ids contains related_marker -%}
                {%- continue -%}
              {%- endif -%}

              {%- assign related_genus = related_product.metafields.custom.genus.value | default: related_product.metafields.custom.genus | strip | handleize -%}
              {%- assign related_bucket = related_product.id | plus: related_seed | modulo: 11 -%}
              {%- assign genus_match = false -%}
              {%- if current_product_genus != blank and related_genus == current_product_genus -%}
                {%- assign genus_match = true -%}
              {%- endif -%}

              {%- if pass == 1 and genus_match == false -%}
                {%- continue -%}
              {%- endif -%}
              {%- if pass == 2 and genus_match -%}
                {%- continue -%}
              {%- endif -%}
              {%- if related_bucket != seed_bucket -%}
                {%- continue -%}
              {%- endif -%}

              {%- assign rendered_markup_ids = rendered_markup_ids | append: related_product.id | append: '|' -%}
              {%- assign rendered_markup_count = rendered_markup_count | plus: 1 -%}
              <li class="featured-collection__item reveal-up" data-carousel-item role="listitem">
                {% render 'product-card',
                  product_item: related_product,
                  show_specimen_id: false,
                  sizes: '(min-width: 990px) 24vw, (min-width: 750px) 32vw, 78vw'
                %}
              </li>
              {%- if rendered_markup_count >= products_limit -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if rendered_markup_count >= products_limit -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if rendered_markup_count >= products_limit -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if rendered_markup_count < products_limit -%}
          {%- for related_product in collections.all.products limit: 80 -%}
            {%- if current_product_id != blank and related_product.id == current_product_id -%}
              {%- continue -%}
            {%- endif -%}
            {%- assign related_marker = '|' | append: related_product.id | append: '|' -%}
            {%- unless rendered_markup_ids contains related_marker -%}
              {%- assign rendered_markup_ids = rendered_markup_ids | append: related_product.id | append: '|' -%}
              {%- assign rendered_markup_count = rendered_markup_count | plus: 1 -%}
              <li class="featured-collection__item reveal-up" data-carousel-item role="listitem">
                {% render 'product-card',
                  product_item: related_product,
                  show_specimen_id: false,
                  sizes: '(min-width: 990px) 24vw, (min-width: 750px) 32vw, 78vw'
                %}
              </li>
              {%- if rendered_markup_count >= products_limit -%}
                {%- break -%}
              {%- endif -%}
            {%- endunless -%}
          {%- endfor -%}
        {%- endif -%}
      </ul>
    </div>
  {%- else -%}
    <div
      class="featured-collection__viewport featured-collection__viewport--preview"
      id="featured-carousel-track-{{ section.id }}"
      data-carousel-viewport
      data-carousel-track
      aria-label="{{ 'sections.featured_collection.preview_label' | t }}"
    >
      <ul
        class="featured-collection__track"
        data-reveal-stagger
        role="list"
      >
        {%- for i in (1..8) -%}
          <li class="featured-collection__item reveal-up" data-carousel-item role="listitem">
            {% render 'product-card',
              card_index: forloop.index0,
              show_specimen_id: false,
              sizes: '(min-width: 990px) 24vw, (min-width: 750px) 32vw, 78vw'
            %}
          </li>
        {%- endfor -%}
      </ul>
    </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .featured-collection {
    --featured-collection-ink: var(--color-parchment);
    --featured-collection-ink-muted: rgb(247 244 237 / 0.78);
    display: grid;
    grid-template-columns: var(--content-grid);
    padding-block: 0;
    color: var(--featured-collection-ink);
  }

  .featured-collection__environment {
    grid-column: 1 / -1;
    padding-block: 5rem;
    background: linear-gradient(145deg, var(--featured-collection-bg-start) 0%, var(--featured-collection-bg-end) 100%);
  }

  .featured-collection__environment-inner {
    display: grid;
    grid-template-columns: var(--content-grid);
    min-width: 0;
  }

  .featured-collection__environment-inner > * {
    grid-column: 2;
  }

  .featured-collection__header {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-lg);
    margin-block-end: var(--space-xl);
  }

  .featured-collection__title {
    margin: 0 0 var(--space-xs);
    font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2.25rem);
    font-weight: 600;
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tight);
    color: var(--featured-collection-ink);
  }

  .featured-collection__subtitle {
    margin: 0;
    max-width: 42ch;
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--featured-collection-ink-muted);
  }

  .featured-collection__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-md);
  }

  .featured-collection__view-all {
    font-size: var(--font-size-sm);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--featured-collection-ink);
  }

  .featured-collection__view-all.link-underline-grow:hover,
  .featured-collection__view-all.link-underline-grow:focus-visible {
    color: #fdfbf7;
  }

  .featured-collection__nav {
    display: none;
    gap: var(--space-xs);
  }

  .featured-collection__nav.is-visible {
    display: inline-flex;
  }

  .featured-collection .product-card__link {
    border-color: rgb(247 244 237 / 0.12);
    box-shadow: 0 8px 24px rgb(0 0 0 / 0.22);
  }

  .featured-collection .product-card__title,
  .featured-collection .product-card__price,
  .featured-collection .product-card__price-regular {
    color: var(--color-text);
  }

  .featured-collection .product-card__latin {
    color: var(--color-text-muted);
  }

  .featured-collection .product-card__specimen-id {
    display: none;
  }

  .featured-collection .product-card__price {
    padding-block-start: 0;
  }

  .featured-collection .product-card__link:hover .product-card__title {
    color: var(--color-primary);
  }

  .featured-collection__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    cursor: pointer;
    color: #0a140b;
    background-color: var(--featured-collection-ink);
    border: 1px solid rgb(247 244 237 / 0.35);
    border-radius: var(--radius-full);
    transition:
      background-color var(--transition-fast),
      transform var(--transition-fast),
      opacity var(--transition-fast);
  }

  .featured-collection__arrow:hover:not(:disabled) {
    background-color: #fdfbf7;
    transform: translate3d(0, -1px, 0);
  }

  .featured-collection__arrow:disabled {
    cursor: not-allowed;
    opacity: 0.4;
  }

  .featured-collection__viewport {
    position: relative;
    margin-inline: calc(50% - 50vw);
    width: 100vw;
    max-width: 100vw;
    padding-inline: max(var(--page-margin), env(safe-area-inset-left, 0px));
    padding-inline-end: max(var(--page-margin), env(safe-area-inset-right, 0px));
    overflow-x: auto;
    overflow-y: visible;
    overscroll-behavior-x: contain;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scroll-padding-inline: max(var(--page-margin), env(safe-area-inset-left, 0px));
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .featured-collection__viewport:focus-visible {
    outline: 2px solid var(--featured-collection-ink);
    outline-offset: 4px;
  }

  .featured-collection__viewport::-webkit-scrollbar {
    display: none;
  }

  .featured-collection__track {
    display: flex;
    gap: var(--space-lg);
    margin: 0;
    padding: var(--space-sm) 0 var(--space-md);
    list-style: none;
  }

  .featured-collection__item {
    flex: 0 0 min(calc(100vw - var(--page-margin) * 2 - var(--space-lg)), 18rem);
    overflow: visible;
    scroll-snap-align: start;
    min-width: 0;
  }

  .featured-collection__empty {
    margin: 0;
    padding: var(--space-xl);
    text-align: center;
    color: var(--color-text-muted);
    background-color: var(--color-surface);
    border-radius: var(--radius-md);
  }

  @media (max-width: 749px) {
    .featured-collection__environment {
      padding-block: var(--space-3xl);
    }
  }

  @media (min-width: 750px) {
    .featured-collection__viewport {
      overflow-x: hidden;
      scroll-snap-type: none;
    }

    .featured-collection__item {
      flex: 0 0 calc((100% - var(--space-lg) * 2) / 3);
    }
  }

  @media (min-width: 990px) {
    .featured-collection__item {
      flex: 0 0 calc((100% - var(--space-lg) * 3) / 4);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .featured-collection__viewport {
      scroll-behavior: auto;
    }

    .featured-collection__arrow:hover:not(:disabled) {
      transition: none;
      transform: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    'use strict';

    var SECTION_SELECTOR = '[data-featured-carousel]';

    function initCarousel(root) {
      if (!root || !window.BT || !window.BT.initScrollCarousel) {
        return;
      }

      window.BT.initScrollCarousel(root, {
        track: '[data-carousel-track]',
        navMinWidth: 750,
        autoplayDisableMinWidth: 750
      });
    }

    function initAll(scope) {
      (scope || document).querySelectorAll(SECTION_SELECTOR).forEach(initCarousel);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        initAll();
      });
    } else {
      initAll();
    }

    document.addEventListener('shopify:section:load', function (event) {
      initAll(event.target);
    });

    document.addEventListener('shopify:section:unload', function (event) {
      var section = event.target.querySelector(SECTION_SELECTOR);
      if (section && window.BT && window.BT.destroyScrollCarousel) {
        window.BT.destroyScrollCarousel(section);
      }
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.featured_collection.name",
  "tag": "section",
  "class": "featured-collection-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.featured_collection.settings.heading",
      "default": "Featured plants"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.featured_collection.settings.subheading",
      "default": "Hand-picked specimens from our living collection."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:general.collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:sections.featured_collection.settings.products_to_show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "t:sections.featured_collection.settings.view_all_label",
      "default": "View all"
    },
    {
      "type": "color",
      "id": "background_color_start",
      "label": "t:sections.featured_collection.settings.background_color_start",
      "default": "#1e3320"
    },
    {
      "type": "color",
      "id": "background_color_end",
      "label": "t:sections.featured_collection.settings.background_color_end",
      "default": "#0a140b"
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_collection.name",
      "settings": {
        "heading": "Featured plants",
        "subheading": "Hand-picked specimens from our living collection.",
        "view_all_label": "View all"
      }
    }
  ]
}
{% endschema %}
